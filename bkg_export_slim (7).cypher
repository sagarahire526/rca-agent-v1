_right, punch_checklist_completion_percent, "\n        "punchlist_received_from_t_mobile, punchlist_cleared_by_gc_percent, "\n        "punch_checklist_reviewed_and_resubmitted_to_t_mobile, "\n        "ms_1556_punch_checklist_audit_completed_by_nokia_actual, "\n        "ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl, "\n        "ms_1558_admin_checklist_submitted_to_t_mobile_actual, "\n        "pj_a_5400_punch_list_to_gc_finish, "\n        "pj_a_5425_punch_list_complete_finish, "\n        "pj_a_5375_conduct_final_qa_walk_finish, "\n        "scop_title, scop_approved_percent, scop_rejected_percent, "\n        "scop_pending_percent, scop_completed_percent, scop_total, "\n        "scop_cw_cl_completed_by_gc, scop_cw_checklist_audit_completed, "\n        "scop_cw_checklist_audit_pl_category, scop_cw_punchlist_by_customer, "\n        "scop_tw_cl_completed_by_gc, scop_tw_checklist_audit_completed, "\n        "scop_tw_checklist_audit_pl_category, scop_tw_punchlist_by_customer, "\n        "scop_checklist_accepted_by_customer, "\n        "scop_cop_pending_approval_code_ndpd_custom_field, "\n        "scop_cop_pending_gc_action, scop_pending_days_for_gc_action, "\n        "scop_aging_for_pending_gc_action, scop_aging_for_tmo_acceptance "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined"\n    )\n\n    if where_parts:\n        sql += " WHERE " + " AND ".join(where_parts)\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'punch_checklist', definition: 'A post-integration deliverable document package assembled for a project/site and submitted to T-Mobile for review. Requires integration to be complete and may go through rejection/acceptance loops. Serves as the bridge between integration completion and downstream closeout/acceptance steps.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'punch_checklist'});
CREATE (:BKGNode {map_table_name: 'stg_ndpd_mbt_tmobile_macro_combined', map_key_column: 'pj_project_id', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'General Contractor Assignment', map_sql_template: 'SELECT\n    pj_project_id,\n    s_site_id,\n    m_market,\n    m_area,\n    rgn_region,\n    construction_gc,\n    ci_gc,\n    confirm_split_spo,\n    por_category,\n    pj_project_status,\n    construction_gc_assigned_date,\n    pj_a_3775_gc_selected_finish,\n    pj_a_4075_construction_ntp_submitted_to_gc_finish,\n    pj_a_4100_construction_ntp_accepted_by_gc_finish,\n    pj_a_4025_civil_ntp_submitted_to_gc_finish,\n    pj_a_4050_civil_ntp_accepted_by_gc_finish\nFROM public.stg_ndpd_mbt_tmobile_macro_combined\nWHERE construction_gc IS NOT NULL', map_label_column: 'pj_project_id', nl_description: 'A scoped assignment of a General Contractor to a Site/Project for a specific construction scope segment. Used to represent normal single-vendor cases and split-scope cases where different GCs handle civil vs tower. Tracks assignment status (pending/accepted/rejected/reassigned) and effective dates. Scope is constrained to {civil, tower}.', map_contract: '{"function_name": "get_general_contractor_assignment", "node_type": "core", "node_id": "general_contractor_assignment", "node_label": "general_contractor_assignment", "description": "Query general_contractor_assignment data from stg_ndpd_mbt_tmobile_macro_combined", "parameters": [{"name": "pj_project_id", "type": "string", "description": "Filter by pj_project_id (primary key)", "required": false, "sample_values": ["CH10000A-0002000000", "DE10001A-0002000001", "IN10002A-0002000002"]}, {"name": "m_area", "type": "string", "description": "Filter by m_area", "required": false, "sample_values": ["GREAT LAKES"]}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn_region", "required": false, "sample_values": ["CENTRAL"]}, {"name": "pj_project_status", "type": "string", "description": "Filter by pj_project_status", "required": false, "sample_values": ["Dead", "Completed"]}, {"name": "m_market", "type": "string", "description": "Filter by m_market", "required": false, "sample_values": ["CHICAGO", "DETROIT", "INDIANAPOLIS"]}, {"name": "por_category", "type": "string", "description": "Filter by por_category", "required": false, "sample_values": ["NTM", "LTW", "Site Mod"]}, {"name": "ci_gc", "type": "string", "description": "Filter by ci_gc", "required": false, "sample_values": ["nokia"]}, {"name": "confirm_split_spo", "type": "string", "description": "Filter by confirm_split_spo", "required": false, "sample_values": []}, {"name": "construction_gc_assigned_date", "type": "string", "description": "Filter by construction_gc_assigned_date", "required": false, "sample_values": []}, {"name": "pj_a_4075_construction_ntp_submitted_to_gc_finish", "type": "string", "description": "Filter by pj_a_4075_construction_ntp_submitted_to_gc_finish", "required": false, "sample_values": ["2024-11-20 10:31:00"]}, {"name": "pj_a_4100_construction_ntp_accepted_by_gc_finish", "type": "string", "description": "Filter by pj_a_4100_construction_ntp_accepted_by_gc_finish", "required": false, "sample_values": ["2025-08-08 16:42:00"]}], "output_columns": [{"name": "pj_project_id", "type": "string", "nullable": false}, {"name": "s_site_id", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "rgn_region", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "ci_gc", "type": "string", "nullable": true}, {"name": "confirm_split_spo", "type": "string", "nullable": true}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "pj_project_status", "type": "string", "nullable": false}, {"name": "construction_gc_assigned_date", "type": "string", "nullable": true}, {"name": "pj_a_3775_gc_selected_finish", "type": "string", "nullable": true}, {"name": "pj_a_4075_construction_ntp_submitted_to_gc_finish", "type": "string", "nullable": true}, {"name": "pj_a_4100_construction_ntp_accepted_by_gc_finish", "type": "string", "nullable": true}, {"name": "pj_a_4025_civil_ntp_submitted_to_gc_finish", "type": "string", "nullable": true}, {"name": "pj_a_4050_civil_ntp_accepted_by_gc_finish", "type": "string", "nullable": true}], "sample_output": [], "row_count": 3}', entity_type: 'transaction', node_type: 'CORE', map_python_function: 'def get_general_contractor_assignment(execute_query, filters=None):\n    """Fetch GC Assignment records showing which GC is assigned to which project/site.\n\n    Notes:\n      - This dataset is denormalized: one row per project; split-scope signals are represented via\n        columns like `confirm_split_spo` and separate civil vs construction NTP timestamps.\n\n    Node: General Contractor Assignment | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: pj_project_id | DB: public\n    """\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = ["construction_gc IS NOT NULL"]\n\n    for k in [\n        "pj_project_id",\n        "s_site_id",\n        "construction_gc",\n        "ci_gc",\n        "m_market",\n        "m_area",\n        "rgn_region",\n        "por_category",\n        "pj_project_status",\n        "confirm_split_spo",\n    ]:\n        if filters.get(k) is not None:\n            where_parts.append(f"{k} = \'{esc(filters[k])}\'")\n\n    sql = (\n        "SELECT "\n        "pj_project_id, s_site_id, m_market, m_area, rgn_region, "\n        "construction_gc, ci_gc, confirm_split_spo, "\n        "por_category, pj_project_status, construction_gc_assigned_date, "\n        "pj_a_3775_gc_selected_finish, "\n        "pj_a_4075_construction_ntp_submitted_to_gc_finish, "\n        "pj_a_4100_construction_ntp_accepted_by_gc_finish, "\n        "pj_a_4025_civil_ntp_submitted_to_gc_finish, "\n        "pj_a_4050_civil_ntp_accepted_by_gc_finish "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        "WHERE " + " AND ".join(where_parts)\n    )\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'general_contractor_assignment', definition: 'A scoped assignment of a General Contractor to a Site/Project for a specific construction scope segment. Used to represent normal single-vendor cases and split-scope cases where different GCs handle civil vs tower. Tracks assignment status (pending/accepted/rejected/reassigned) and effective dates. Scope is constrained to {civil, tower}.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'general_contractor_assignment'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_session_level_combined_data'], nl_business_rule: '', kpi_formula_description: 'Per (nas_market, nas_activity_type, nas_company_name, date_bucket) over completed sessions (nas_checkout_approve_time IS NOT NULL): completed_sessions = COUNT(DISTINCT nas_session_id); checkout_sla_rate_pct = 100 * COUNT(DISTINCT completed sessions with extension proxy = no extension) / NULLIF(COUNT(DISTINCT completed sessions),0); extension_rate_pct = 100 * COUNT(DISTINCT completed sessions with extension proxy = extension) / NULLIF(COUNT(DISTINCT completed sessions),0); avg_extensions_per_session = AVG(nas_total_ext_count_approved) over completed sessions where COALESCE(nas_total_ext_count_approved,0)>0; avg_activity_duration = AVG(nas_total_activity_duration).', kpi_output_schema: '[{"column": "nas_market", "type": "string", "description": "NAS market grouping dimension."}, {"column": "nas_activity_type", "type": "string", "description": "NAS activity type grouping dimension."}, {"column": "nas_company_name", "type": "string", "description": "NAS company name grouping dimension."}, {"column": "date_bucket", "type": "string", "description": "Time bucket derived from nas_checkout_approve_time at the selected grain (day or week)."}, {"column": "completed_sessions", "type": "int", "description": "Distinct count of completed sessions."}, {"column": "checkout_sla_rate_pct", "type": "float", "description": "Percent of completed sessions completed without needing an extension (SLA proxy)."}, {"column": "extension_rate_pct", "type": "float", "description": "Percent of completed sessions that required an extension (proxy)."}, {"column": "avg_extensions_per_session", "type": "float", "description": "Average approved extensions among completed sessions with at least one approved extension."}, {"column": "avg_activity_duration", "type": "float", "description": "Average total activity duration over completed sessions (may be NULL if duration is stored as non-numeric text)."}]', kpi_business_logic: '1) Start from stg_nas_session_level_combined_data (session-level).\n2) Keep only completed sessions where nas_checkout_approve_time IS NOT NULL.\n3) Derive date_bucket from nas_checkout_approve_time (day: cast to date; week: date_trunc(\'week\')::date).\n4) Group by nas_market, nas_activity_type, nas_company_name, date_bucket.\n5) Compute completed_sessions as COUNT(DISTINCT nas_session_id).\n6) Compute checkout_sla_rate_pct as percent of completed sessions with no approved extensions (either COALESCE(nas_total_ext_count_approved,0)=0 or, in the provided SQL option, nas_status_nest_ext IS NULL).\n7) Compute extension_rate_pct as percent of completed sessions with extensions (either COALESCE(nas_total_ext_count_approved,0)>0 or, in the provided SQL option, nas_status_nest_ext IS NOT NULL).\n8) Compute avg_extensions_per_session as AVG(nas_total_ext_count_approved) over completed sessions with COALESCE(nas_total_ext_count_approved,0)>0.\n9) Compute avg_activity_duration as AVG(nas_total_activity_duration) over completed sessions (SQL casts to numeric; may be NULL if non-numeric text).', kpi_filters: '[{"name": "completed_sessions_only", "type": "string", "description": "Includes only sessions where nas_checkout_approve_time IS NOT NULL."}, {"name": "start_date", "type": "date", "description": "Filters nas_checkout_approve_time to be >= start_date."}, {"name": "end_date", "type": "date", "description": "Filters nas_checkout_approve_time to be < end_date."}, {"name": "nas_market", "type": "string", "description": "Limits results to a specific nas_market."}, {"name": "nas_activity_type", "type": "string", "description": "Limits results to a specific nas_activity_type."}, {"name": "nas_company_name", "type": "string", "description": "Limits results to a specific nas_company_name."}, {"name": "nas_vendor_name", "type": "string", "description": "Optional filter for nas_vendor_name."}, {"name": "nas_primary_gc", "type": "string", "description": "Optional filter for nas_primary_gc."}, {"name": "nas_session_id", "type": "string", "description": "Optional filter for a specific nas_session_id."}, {"name": "nas_site_id", "type": "string", "description": "Optional filter for a specific nas_site_id."}, {"name": "nas_project_category", "type": "string", "description": "Optional filter for a specific nas_project_category."}, {"name": "nas_date_period", "type": "string", "description": "Optional filter for a specific nas_date_period."}, {"name": "time_grain", "type": "string", "description": "Controls date_bucket derivation: daily (nas_checkout_approve_time::date) or weekly (date_trunc(\'week\', nas_checkout_approve_time)::date)."}]', kpi_contract: '{"function_name": "get_nas_integration_sla", "node_type": "kpi", "node_id": "dc2892a1-5c59-4892-b008-e30afd4df123", "node_label": "NAS Integration SLA", "description": "Combined NAS integration capacity KPI returning multiple measures per (nas_market, nas_activity_type, nas_company_name, date_bucket) from `stg_nas_session_level_combined_data`. A session is considered completed when `nas_checkout_approve_time IS NOT NULL` and is counted as `COUNT(DISTINCT nas_session_id)`.\\n\\nOutput columns per row:\\n1) completed_sessions: COUNT(DISTINCT nas_session_id) over completed sessions.\\n2) checkout_sla_rate_pct: 100 * (COUNT(DISTINCT nas_session_id) where completed AND COALESCE(nas_total_ext_count_approved,0)=0) / NULLIF(COUNT(DISTINCT nas_session_id) where completed, 0). (SLA proxy = completed without any approved extensions.)\\n3) extension_rate_pct: 100 * (COUNT(DISTINCT nas_session_id) where completed AND COALESCE(nas_total_ext_count_approved,0)>0) / NULLIF(COUNT(DISTINCT nas_session_id) where completed, 0).\\n4) avg_extensions_per_session: AVG(nas_total_ext_count_approved) over completed sessions with COALESCE(nas_total_ext_count_approved,0)>0.\\n5) avg_activity_duration: AVG(nas_total_activity_duration) over completed sessions.\\n\\nTime grouping: date_bucket derived from `nas_checkout_approve_time` (daily: `nas_checkout_approve_time::date`; weekly: `date_trunc(\'week\', nas_checkout_approve_time)::date`). Grouping dimensions: nas_market, nas_activity_type, nas_company_name, date_bucket. Optional additional dimensions if needed: nas_vendor_name, nas_primary_gc.\\n\\nPrimary entities involved: Integration Activity (session-level records) joined conceptually to Market and vendor/company; computed directly from NAS session fact table without requiring additional joins.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "time_grain", "type": "date", "description": "Filter by time grain", "required": false, "sample_values": []}, {"name": "date_bucket_grain", "type": "date", "description": "Filter by date bucket grain", "required": false, "sample_values": []}], "output_columns": [{"name": "nas_market", "type": "string", "nullable": false}, {"name": "nas_activity_type", "type": "string", "nullable": false}, {"name": "nas_company_name", "type": "string", "nullable": false}, {"name": "date_bucket", "type": "date", "nullable": false}, {"name": "completed_sessions", "type": "number", "nullable": false}, {"name": "checkout_sla_rate_pct", "type": "string", "nullable": false}, {"name": "extension_rate_pct", "type": "string", "nullable": false}, {"name": "avg_activity_duration", "type": "null", "nullable": true}], "sample_output": [{"nas_market": "Cincinnati", "nas_activity_type": "Radio Upgrade NR", "nas_company_name": "PM Communications", "date_bucket": "2025-10-01", "completed_sessions": 1, "checkout_sla_rate_pct": "100.0000000000000000", "extension_rate_pct": "0E-20", "avg_activity_duration": null}, {"nas_market": "Los Angeles", "nas_activity_type": "Punch Items", "nas_company_name": "ClearPath Telecom", "date_bucket": "2025-10-01", "completed_sessions": 1, "checkout_sla_rate_pct": "100.0000000000000000", "extension_rate_pct": "0E-20", "avg_activity_duration": null}, {"nas_market": "Kansas City", "nas_activity_type": "Tower Inspection", "nas_company_name": "On Air Solutions", "date_bucket": "2025-10-02", "completed_sessions": 1, "checkout_sla_rate_pct": "100.0000000000000000", "extension_rate_pct": "0E-20", "avg_activity_duration": null}], "row_count": 10}', nl_description: 'KPI = aggregates over completed Integration Activity sessions grouped by (nas_market, nas_activity_type, nas_company_name, date_bucket) where completed sessions are those with nas_checkout_approve_time not null. Uses single-table extension proxy: sessions with nas_status_nest_ext IS NULL are treated as completed within original window (checkout_sla_rate_pct), while nas_status_nest_ext IS NOT NULL indicates an extension was needed (extension_rate_pct). Note: avg_activity_duration is included as a throughput/capacity signal, but may be NULL if nas_total_activity_duration is stored as non-numeric text (e.g., \'1h 19m\'); parsing to minutes would be a future enhancement.', node_type: 'CORE', definition: 'KPI = aggregates over completed Integration Activity sessions grouped by (nas_market, nas_activity_type, nas_company_name, date_bucket) where completed sessions are those with nas_checkout_approve_time not null. Uses single-table extension proxy: sessions with nas_status_nest_ext IS NULL are treated as completed within original window (checkout_sla_rate_pct), while nas_status_nest_ext IS NOT NULL indicates an extension was needed (extension_rate_pct). Note: avg_activity_duration is included as a throughput/capacity signal, but may be NULL if nas_total_activity_duration is stored as non-numeric text (e.g., \'1h 19m\'); parsing to minutes would be a future enhancement.', kpi_python_function: 'def get_nas_integration_sla(execute_query, filters=None) -> list[dict]:\n    filters = filters or {}\n\n    # Integration Activity accessor doesn\'t expose required measure fields,\n    # so we aggregate via raw SQL from the session-level combined table.\n\n    # Base predicate: only completed sessions (approve time present)\n    where = ["nas_checkout_approve_time IS NOT NULL"]\n\n    # Date range filtering applies to approve time (the KPI\'s time anchor)\n    if filters.get(\'start_date\') is not None:\n        sd = str(filters.get(\'start_date\')).replace("\'", "\'\'")\n        where.append(f"nas_checkout_approve_time >= \'{sd}\'")\n    if filters.get(\'end_date\') is not None:\n        ed = str(filters.get(\'end_date\')).replace("\'", "\'\'")\n        where.append(f"nas_checkout_approve_time < \'{ed}\'")\n\n    # Optional dimension filters\n    dim_filter_map = {\n        \'nas_market\': \'nas_market\',\n        \'nas_activity_type\': \'nas_activity_type\',\n        \'nas_company_name\': \'nas_company_name\',\n        \'nas_vendor_name\': \'nas_vendor_name\',\n        \'nas_primary_gc\': \'nas_primary_gc\',\n        \'nas_session_id\': \'nas_session_id\',\n        \'nas_site_id\': \'nas_site_id\',\n        \'nas_project_category\': \'nas_project_category\',\n        \'nas_date_period\': \'nas_date_period\'\n    }\n    for fk, col in dim_filter_map.items():\n        if filters.get(fk) is not None:\n            val = str(filters.get(fk)).replace("\'", "\'\'")\n            where.append(f"{col} = \'{val}\'")\n\n    # Time grouping\n    time_grain = (filters.get(\'time_grain\') or filters.get(\'date_bucket_grain\') or \'day\').lower()\n    if time_grain in (\'week\', \'weekly\'):\n        date_bucket_expr = "date_trunc(\'week\', nas_checkout_approve_time)::date"\n    else:\n        date_bucket_expr = "nas_checkout_approve_time::date"\n\n    where_sql = "\\n  AND ".join(where)\n\n    # Option A (single-table): use nas_status_nest_ext as extension proxy.\n    sql = f"""\nSELECT\n  nas_market,\n  nas_activity_type,\n  nas_company_name,\n  {date_bucket_expr} AS date_bucket,\n\n  COUNT(DISTINCT nas_session_id) AS completed_sessions,\n\n  100.0 * COUNT(DISTINCT CASE WHEN nas_status_nest_ext IS NULL THEN nas_session_id END)\n    / NULLIF(COUNT(DISTINCT nas_session_id), 0) AS checkout_sla_rate_pct,\n\n  100.0 * COUNT(DISTINCT CASE WHEN nas_status_nest_ext IS NOT NULL THEN nas_session_id END)\n    / NULLIF(COUNT(DISTINCT nas_session_id), 0) AS extension_rate_pct,\n\n  AVG(nas_total_activity_duration::numeric) AS avg_activity_duration\n\nFROM public.stg_nas_session_level_combined_data\nWHERE {where_sql}\nGROUP BY\n  nas_market,\n  nas_activity_type,\n  nas_company_name,\n  {date_bucket_expr}\nORDER BY\n  date_bucket,\n  nas_market,\n  nas_activity_type,\n  nas_company_name\n"""\n\n    return execute_query(sql)\n', kpi_source_columns: ['nas_market', 'nas_activity_type', 'nas_company_name', 'nas_checkout_approve_time', 'nas_session_id', 'nas_total_ext_count_approved', 'nas_total_activity_duration', 'nas_status_nest_ext', 'nas_vendor_name', 'nas_primary_gc', 'nas_site_id', 'nas_project_category', 'nas_date_period'], session_id: '69a3d22f26e208edc083a06e', label: 'NAS Integration SLA', kpi_related_core_node_ids: ['integration_activity'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: 'dc2892a1-5c59-4892-b008-e30afd4df123', entity_type: 'kpi', kpi_name: 'NAS Integration SLA', name: 'dc2892a1-5c59-4892-b008-e30afd4df123', kpi_dimensions: ['nas_market', 'nas_activity_type', 'nas_company_name', 'date_bucket', 'nas_vendor_name', 'nas_primary_gc'], kpi_description: 'Measures NAS integration capacity and a proxy for checkout SLA by summarizing completed integration activity sessions. It reports how many sessions were completed and the share completed without needing an extension, segmented by market, activity type, company, and time period.', status: 'mentioned', node_id: 'dc2892a1-5c59-4892-b008-e30afd4df123'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Compute cycle_time_days = (ms_1550_construction_start_actual::date - CPO_date::date). Preferred CPO_date source is "confirm_receipt_of_base_pos_and_spos_generated" when populated (requires parseable YYYY-MM-DD), but the active implementation uses pj_a_4200_pull_construction_po_number_finish (MS 4200) because the confirmation column is NULL in current synthetic data. Include only records where both dates are present and cycle_time_days >= 0. Report AVG, P50, and P90 by (rgn_region, m_area, m_market, construction_gc, por_regional_dev_initiatives).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping value."}, {"column": "m_area", "type": "string", "description": "Area grouping value."}, {"column": "m_market", "type": "string", "description": "Market grouping value."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping value."}, {"column": "por_regional_dev_initiatives", "type": "string", "description": "Regional development initiatives grouping value."}, {"column": "project_count", "type": "int", "description": "Number of distinct projects (COUNT DISTINCT pj_project_id) in the group."}, {"column": "avg_cycle_time_days", "type": "float", "description": "Average cycle time in days across projects in the group."}, {"column": "median_p50_cycle_time_days", "type": "float", "description": "Median (P50) cycle time in days across projects in the group."}, {"column": "p90_cycle_time_days", "type": "float", "description": "90th percentile (P90) cycle time in days across projects in the group."}]', kpi_business_logic: '1) From stg_ndpd_mbt_tmobile_macro_combined, read ms_1550_construction_start_actual and confirm_receipt_of_base_pos_and_spos_generated.\n2) Parse cpo_date from confirm_receipt_of_base_pos_and_spos_generated only if it matches the pattern YYYY-MM-DD; cast ms_1550_construction_start_actual to cx_start_date (date).\n3) Keep rows where cpo_date and cx_start_date are not null and (cx_start_date - cpo_date) >= 0.\n4) Compute cycle_time_days = cx_start_date - cpo_date per pj_project_id.\n5) Group by rgn_region, m_area, m_market, construction_gc, por_regional_dev_initiatives.\n6) For each group, compute COUNT(DISTINCT pj_project_id) as project_count, AVG(cycle_time_days) as avg_cycle_time_days, PERCENTILE_CONT(0.5) as median_p50_cycle_time_days, and PERCENTILE_CONT(0.9) as p90_cycle_time_days.\n7) Optional exact-match filters may be applied on rgn_region, m_area, m_market, construction_gc, por_regional_dev_initiatives, pj_project_id, s_site_id; optional date range filters apply to ms_1550_construction_start_actual (cx_start_date).', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact-match filter on region."}, {"name": "m_area", "type": "string", "description": "Exact-match filter on area."}, {"name": "m_market", "type": "string", "description": "Exact-match filter on market."}, {"name": "construction_gc", "type": "string", "description": "Exact-match filter on general contractor."}, {"name": "por_regional_dev_initiatives", "type": "string", "description": "Exact-match filter on regional development initiatives."}, {"name": "pj_project_id", "type": "string", "description": "Exact-match filter to a specific project."}, {"name": "s_site_id", "type": "string", "description": "Exact-match filter to a specific site."}, {"name": "start_date", "type": "date", "description": "Lower bound date filter applied to ms_1550_construction_start_actual (construction start actual)."}, {"name": "end_date", "type": "date", "description": "Upper bound date filter applied to ms_1550_construction_start_actual (construction start actual)."}, {"name": "valid_cpo_date_format", "type": "string", "description": "Include only records where confirm_receipt_of_base_pos_and_spos_generated matches ^\\\\d{4}-\\\\d{2}-\\\\d{2} for parsing to a date."}, {"name": "non_null_milestones_and_non_negative_cycle", "type": "string", "description": "Include only records where both milestone dates are non-null and (ms_1550_construction_start_actual - cpo_date) >= 0."}]', kpi_contract: '{"function_name": "get_cpo_to_cx_start", "node_type": "kpi", "node_id": "56171ab1-3ce1-44b6-b22e-400f5ffd9552", "node_label": "CPO to Cx Start", "description": "Measures the cycle time (in days) from CPO receipt confirmation to Construction Start Actual for each project/site. This helps track how long it takes to move from CPO receipt to the start of construction and enables performance comparisons across regions/markets/contractors and initiative groupings.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'Compute cycle_time_days = (ms_1550_construction_start_actual::date - CPO_date::date). Preferred CPO_date source is "confirm_receipt_of_base_pos_and_spos_generated" when populated (requires parseable YYYY-MM-DD), but the active implementation uses pj_a_4200_pull_construction_po_number_finish (MS 4200) because the confirmation column is NULL in current synthetic data. Include only records where both dates are present and cycle_time_days >= 0. Report AVG, P50, and P90 by (rgn_region, m_area, m_market, construction_gc, por_regional_dev_initiatives).', node_type: 'CORE', definition: 'Compute cycle_time_days = (ms_1550_construction_start_actual::date - CPO_date::date). Preferred CPO_date source is "confirm_receipt_of_base_pos_and_spos_generated" when populated (requires parseable YYYY-MM-DD), but the active implementation uses pj_a_4200_pull_construction_po_number_finish (MS 4200) because the confirmation column is NULL in current synthetic data. Include only records where both dates are present and cycle_time_days >= 0. Report AVG, P50, and P90 by (rgn_region, m_area, m_market, construction_gc, por_regional_dev_initiatives).', kpi_python_function: 'def get_cpo_to_cx_start(execute_query, filters=None) -> list[dict]:\n    """CPO to Cx Start cycle time (days).\n\n    Preferred CPO source (production intent): confirm_receipt_of_base_pos_and_spos_generated.\n    Active implementation (until preferred column is populated): pj_a_4200_pull_construction_po_number_finish (MS 4200).\n\n    Cycle time (days) = ms_1550_construction_start_actual::date - pj_a_4200_pull_construction_po_number_finish::date.\n\n    Returns grouped rollups with average, median (P50), and P90 across projects.\n    Group-by dimensions: rgn_region, m_area, m_market, construction_gc, por_regional_dev_initiatives.\n\n    Optional filters supported (exact-match):\n      - rgn_region, m_area, m_market, construction_gc, por_regional_dev_initiatives\n      - pj_project_id, s_site_id\n      - start_date, end_date (applies to ms_1550_construction_start_actual)\n    """\n\n    filters = filters or {}\n\n    def _to_date_str(v):\n        if v is None:\n            return None\n        s = str(v).strip()\n        if not s:\n            return None\n        return s[:10]\n\n    where_parts = []\n\n    # Dimension filters ONLY\n    for k in [\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "por_regional_dev_initiatives",\n        "pj_project_id",\n        "s_site_id",\n    ]:\n        if filters.get(k) is not None and str(filters.get(k)).strip() != "":\n            escaped = str(filters[k]).replace("\'", "\'\'")\n            where_parts.append(f"{k} = \'{escaped}\'")\n\n    # Date range filter: apply to end milestone (construction start actual)\n    start_date = _to_date_str(filters.get("start_date"))\n    end_date = _to_date_str(filters.get("end_date"))\n    if start_date:\n        where_parts.append(f"ms_1550_construction_start_actual::date >= \'{start_date}\'::date")\n    if end_date:\n        where_parts.append(f"ms_1550_construction_start_actual::date <= \'{end_date}\'::date")\n\n    additional_where = ""\n    if where_parts:\n        additional_where = " AND " + " AND ".join(where_parts)\n\n    sql = f"""\n        SELECT\n            rgn_region,\n            m_area,\n            m_market,\n            construction_gc,\n            por_regional_dev_initiatives,\n            COUNT(DISTINCT pj_project_id) AS project_count,\n            AVG(cycle_time_days::numeric) AS avg_cycle_time_days,\n            PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY cycle_time_days) AS median_p50_cycle_time_days,\n            PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY cycle_time_days) AS p90_cycle_time_days\n        FROM (\n            SELECT\n                pj_project_id,\n                rgn_region,\n                m_area,\n                m_market,\n                construction_gc,\n                por_regional_dev_initiatives,\n                (ms_1550_construction_start_actual::date - pj_a_4200_pull_construction_po_number_finish::date) AS cycle_time_days\n            FROM public.stg_ndpd_mbt_tmobile_macro_combined\n            WHERE ms_1550_construction_start_actual IS NOT NULL\n              AND pj_a_4200_pull_construction_po_number_finish IS NOT NULL\n              AND (ms_1550_construction_start_actual::date - pj_a_4200_pull_construction_po_number_finish::date) >= 0\n              {additional_where}\n        ) sub\n        GROUP BY 1,2,3,4,5\n        ORDER BY 1,2,3,4,5\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['ms_1550_construction_start_actual', 'confirm_receipt_of_base_pos_and_spos_generated', 'pj_project_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_regional_dev_initiatives', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'CPO to Cx Start', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'AGGREGATES_FROM', kpi_kpi_id: '56171ab1-3ce1-44b6-b22e-400f5ffd9552', entity_type: 'kpi', kpi_name: 'CPO to Cx Start', name: '56171ab1-3ce1-44b6-b22e-400f5ffd9552', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_regional_dev_initiatives'], kpi_description: 'Measures the cycle time (in days) from CPO receipt confirmation to Construction Start Actual for each project/site. This helps track how long it takes to move from CPO receipt to the start of construction and enables performance comparisons across regions/markets/contractors and initiative groupings.', status: 'mentioned', node_id: '56171ab1-3ce1-44b6-b22e-400f5ffd9552'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'COUNT(DISTINCT pj_project_id) where pj_a_4425_mw_installation_complete_finish IS NOT NULL AND pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping field."}, {"column": "m_area", "type": "string", "description": "Area grouping field."}, {"column": "m_market", "type": "string", "description": "Market grouping field."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping field (optional)."}, {"column": "por_regional_dev_initiatives", "type": "string", "description": "Regional development initiative / build plan year or program segmentation grouping field (optional)."}, {"column": "pj_program_name", "type": "string", "description": "Program name grouping field (optional)."}, {"column": "pending_mw_acceptance_count", "type": "int", "description": "Count of distinct projects pending MW link final acceptance."}]', kpi_business_logic: '1) Start with records from public.stg_ndpd_mbt_tmobile_macro_combined.\n2) Keep only rows where MW installation complete finish date is present (pj_a_4425_mw_installation_complete_finish IS NOT NULL).\n3) Also require MW link final accepted/operational finish date is missing (pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL).\n4) Count distinct pj_project_id.\n5) Optionally group results by rgn_region, m_area, m_market, and/or construction_gc, por_regional_dev_initiatives, pj_program_name.', kpi_filters: '[{"name": "pj_a_4425_mw_installation_complete_finish", "type": "date", "description": "Include only records where MW installation complete finish date is not null."}, {"name": "pj_a_5300_mw_link_final_accepted_and_operational_finish", "type": "date", "description": "Include only records where MW link final accepted/operational finish date is null."}, {"name": "rgn_region", "type": "string", "description": "Optional slice/filter by region."}, {"name": "m_area", "type": "string", "description": "Optional slice/filter by area."}, {"name": "m_market", "type": "string", "description": "Optional slice/filter by market."}, {"name": "construction_gc", "type": "string", "description": "Optional slice/filter by general contractor."}, {"name": "por_regional_dev_initiatives", "type": "string", "description": "Optional slice/filter by regional development initiative / build plan year or program segmentation."}, {"name": "pj_program_name", "type": "string", "description": "Optional slice/filter by program name."}, {"name": "pj_project_id", "type": "string", "description": "Optional filter to a specific project id."}, {"name": "s_site_id", "type": "string", "description": "Optional filter to a specific site id."}]', kpi_contract: '{"function_name": "get_pending_mw_acceptance", "node_type": "kpi", "node_id": "86351076-dcbb-42b7-83bf-58eae5481ae8", "node_label": "Pending MW Acceptance", "description": "Counts the number of distinct projects/sites pending microwave link final acceptance. Calculation: COUNT(DISTINCT pj_project_id) from stg_ndpd_mbt_tmobile_macro_combined where pj_a_4425_mw_installation_complete_finish IS NOT NULL (MW installation completed) AND pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL (MW link not formally accepted/operational). Reportable/groupable by rgn_region, m_area, m_market, and optionally construction_gc and por_regional_dev_initiatives (build plan year/program segmentation). No joins required; all fields are in the same table.", "parameters": [{"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "pending_mw_acceptance_count", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "pending_mw_acceptance_count": 1}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "pending_mw_acceptance_count": 5}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "pending_mw_acceptance_count": 7}], "row_count": 10}', nl_description: 'Pending MW Acceptance = count of distinct pj_project_id where MW installation complete finish date is present and MW link final accepted/operational finish date is missing, optionally grouped by region/area/market and program segmentation fields.', node_type: 'CORE', definition: 'Pending MW Acceptance = count of distinct pj_project_id where MW installation complete finish date is present and MW link final accepted/operational finish date is missing, optionally grouped by region/area/market and program segmentation fields.', kpi_python_function: 'def get_pending_mw_acceptance(execute_query, filters=None) -> list[dict]:\n    """Counts distinct projects pending MW link final acceptance.\n\n    Definition:\n      MW installation complete date is NOT NULL\n      AND MW link final accepted/operational date is NULL\n      KPI = COUNT(DISTINCT pj_project_id)\n\n    Groupable by: rgn_region, m_area, m_market; optionally construction_gc, por_regional_dev_initiatives.\n\n    Notes:\n      The Tier-1 get_project accessor does not expose the two MW milestone columns, so we use raw SQL.\n    """\n\n    filters = filters or {}\n\n    # Dimensions to group by\n    group_by = filters.get("group_by")\n    if not group_by:\n        group_by_cols = ["rgn_region", "m_area", "m_market"]\n    else:\n        if isinstance(group_by, str):\n            group_by_cols = [c.strip() for c in group_by.split(",") if c.strip()]\n        else:\n            group_by_cols = [str(c).strip() for c in group_by if str(c).strip()]\n\n    # Allowlist group-by columns for safety\n    allowed_group_bys = {\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "por_regional_dev_initiatives",\n        "pj_program_name"\n    }\n    group_by_cols = [c for c in group_by_cols if c in allowed_group_bys]\n    if not group_by_cols:\n        group_by_cols = ["rgn_region", "m_area", "m_market"]\n\n    select_dims = ", ".join(group_by_cols)\n    group_by_sql = ", ".join(group_by_cols)\n\n    where_parts = [\n        "pj_a_4425_mw_installation_complete_finish IS NOT NULL",\n        "pj_a_5300_mw_link_final_accepted_and_operational_finish IS NULL"\n    ]\n\n    # Optional filters\n    # (No explicit date filtering since KPI definition is based on milestone null-ness;\n    #  but allow slicing by region/area/market/gc/program/project/site if provided.)\n    allowed_filters = {\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "por_regional_dev_initiatives",\n        "pj_program_name",\n        "pj_project_id",\n        "s_site_id"\n    }\n    for k, v in (filters or {}).items():\n        if k in ("group_by", "start_date", "end_date"):\n            continue\n        if k not in allowed_filters:\n            continue\n        if v is None or v == "":\n            continue\n        escaped = str(v).replace("\'", "\'\'")\n        where_parts.append(f"{k} = \'{escaped}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        f"{select_dims}, "\n        "COUNT(DISTINCT pj_project_id) AS pending_mw_acceptance_count "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        f"WHERE {where_sql} "\n        f"GROUP BY {group_by_sql} "\n        f"ORDER BY {group_by_sql}"\n    )\n\n    rows = execute_query(sql)\n    return rows\n', kpi_source_columns: ['pj_project_id', 'pj_a_4425_mw_installation_complete_finish', 'pj_a_5300_mw_link_final_accepted_and_operational_finish', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_regional_dev_initiatives', 'pj_program_name', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'Pending MW Acceptance', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '86351076-dcbb-42b7-83bf-58eae5481ae8', entity_type: 'kpi', kpi_name: 'Pending MW Acceptance', name: '86351076-dcbb-42b7-83bf-58eae5481ae8', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_regional_dev_initiatives', 'pj_program_name'], kpi_description: 'Counts the number of distinct projects/sites that are pending microwave link final acceptance. This indicates work where MW installation is complete but the link has not yet been formally accepted/operational.', status: 'mentioned', node_id: '86351076-dcbb-42b7-83bf-58eae5481ae8'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'For each project, compute lead_days for each milestone-pair segment as (end_milestone::date - start_milestone::date). Segments include 9 core pipeline pairs plus 6 additional bottleneck segments (MW Installation, MW→Integration Start, COP Received→Approved (MB), Pre-NTP→BoM Submission, E2E Cycle Time, Quote Approved→CX Start). Exclude rows where start or end is NULL and exclude negative lead_days; optionally restrict by end milestone date using start_date/end_date filters. Aggregate by (rgn_region, m_area, m_market, construction_gc, segment_name) and compute AVG(lead_days), PERCENTILE_CONT(0.5), PERCENTILE_CONT(0.9), and COUNT(DISTINCT pj_project_id).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region."}, {"column": "m_area", "type": "string", "description": "Area."}, {"column": "m_market", "type": "string", "description": "Market."}, {"column": "construction_gc", "type": "string", "description": "General contractor."}, {"column": "segment_name", "type": "string", "description": "Intermediate milestone segment name."}, {"column": "avg_days", "type": "float", "description": "Average lead time in calendar days for the segment."}, {"column": "p50_days", "type": "float", "description": "Median (50th percentile) lead time in calendar days for the segment."}, {"column": "p90_days", "type": "float", "description": "90th percentile lead time in calendar days for the segment."}, {"column": "project_count", "type": "int", "description": "Distinct count of projects contributing to the segment metrics."}]', kpi_business_logic: 'Accept optional filters: pj_project_id, rgn_region, m_area, m_market, construction_gc, por_category, start_date, end_date.\nBuild a base WHERE clause from pass-through filters (pj_project_id, rgn_region, m_area, m_market, construction_gc, por_category) applied to public.stg_ndpd_mbt_tmobile_macro_combined.\nFor each configured segment (segment_name, start_column, end_column), select pj_project_id, segment_name, lead_days = (end::date - start::date), and the grouping columns; filter out NULL start/end; filter out negative lead_days; optionally filter where end::date is within [start_date, end_date].\nUNION ALL all segment selects into a single derived subquery aliased as segment_leads.\nAggregate segment_leads by rgn_region, m_area, m_market, construction_gc, segment_name to compute avg_days, p50_days, p90_days, and project_count; order by the same dimensions.', kpi_filters: '[{"name": "pj_project_id", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "por_category", "type": "string", "description": ""}, {"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_intermediate_milestone_lead_time", "node_type": "kpi", "node_id": "2f2e0906-e4e7-42b5-93ed-1431fd7f85f9", "node_label": "Intermediate Milestone Lead Time", "description": "Measures the calendar-day lead time between defined intermediate milestone pairs for each project, then aggregates results to highlight bottleneck segments in the project lifecycle.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "segment_name", "type": "string", "nullable": false}, {"name": "avg_days", "type": "string", "nullable": false}, {"name": "p50_days", "type": "number", "nullable": false}, {"name": "p90_days", "type": "number", "nullable": false}, {"name": "project_count", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'For each project, compute lead_days for each milestone-pair segment as (end_milestone::date - start_milestone::date). Segments include 9 core pipeline pairs plus 6 additional bottleneck segments (MW Installation, MW→Integration Start, COP Received→Approved (MB), Pre-NTP→BoM Submission, E2E Cycle Time, Quote Approved→CX Start). Exclude rows where start or end is NULL and exclude negative lead_days; optionally restrict by end milestone date using start_date/end_date filters. Aggregate by (rgn_region, m_area, m_market, construction_gc, segment_name) and compute AVG(lead_days), PERCENTILE_CONT(0.5), PERCENTILE_CONT(0.9), and COUNT(DISTINCT pj_project_id).', node_type: 'CORE', definition: 'For each project, compute lead_days for each milestone-pair segment as (end_milestone::date - start_milestone::date). Segments include 9 core pipeline pairs plus 6 additional bottleneck segments (MW Installation, MW→Integration Start, COP Received→Approved (MB), Pre-NTP→BoM Submission, E2E Cycle Time, Quote Approved→CX Start). Exclude rows where start or end is NULL and exclude negative lead_days; optionally restrict by end milestone date using start_date/end_date filters. Aggregate by (rgn_region, m_area, m_market, construction_gc, segment_name) and compute AVG(lead_days), PERCENTILE_CONT(0.5), PERCENTILE_CONT(0.9), and COUNT(DISTINCT pj_project_id).', kpi_python_function: 'def get_intermediate_milestone_lead_time(execute_query, filters=None) -> list[dict]:\n    """Compute intermediate milestone lead times per segment and aggregate by (region, area, market, GC, segment).\n\n    Optional filters supported (if provided in `filters`):\n      - por_category: restrict projects to a given POR category (not in default group-by)\n      - rgn_region, m_area, m_market, construction_gc, pj_project_id: pass-through filters to base table\n      - start_date, end_date: applied to segment end milestone date (end_column::date within range)\n\n    Returns rows:\n      rgn_region, m_area, m_market, construction_gc, segment_name,\n      avg_days, p50_days, p90_days, project_count\n    """\n\n    filters = filters or {}\n\n    def _escape(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Base WHERE clause: only filters that exist as columns on the wide table.\n    # (We intentionally do not include start_date/end_date here because we apply them to each segment\'s end date.)\n    passthrough_keys = [\n        "pj_project_id",\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "por_category",\n    ]\n    where_parts = []\n    for k in passthrough_keys:\n        if k in filters and filters.get(k) not in (None, ""):\n            where_parts.append(f"{k} = \'{_escape(filters.get(k))}\'")\n    where_sql = ("WHERE " + " AND ".join(where_parts)) if where_parts else ""\n\n    # Date range filters (applied to end milestone date for each segment)\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n\n    # Segment definitions: (segment_name, start_column_sql, end_column_sql)\n    segments = [\n        (\n            "Pre-NTP to Scoping Ready",\n            "ms_1310_pre_construction_package_received_actual",\n            "ms_1323_ready_for_scoping_actual",\n        ),\n        (\n            "Scoping to NTP Approved",\n            "ms_1323_ready_for_scoping_actual",\n            "ms_1507_tower_ntp_approved_actual",\n        ),\n        (\n            "NTP to Material Pickup",\n            "ms_1507_tower_ntp_approved_actual",\n            \'"pj_a_3925_msl_pickup_date_finish"\',\n        ),\n        (\n            "Material to CX Start",\n            \'"pj_a_3925_msl_pickup_date_finish"\',\n            "ms_1550_construction_start_actual",\n        ),\n        (\n            "CX Start to CX Complete",\n            "ms_1550_construction_start_actual",\n            "ms_1555_construction_complete_actual",\n        ),\n        (\n            "CX Complete to IX Start",\n            "ms_1555_construction_complete_actual",\n            "pj_a_5270_integration_start_finish",\n        ),\n        (\n            "IX Start to IX Complete",\n            "pj_a_5270_integration_start_finish",\n            "ms_1970_integration_complete_actual",\n        ),\n        (\n            "IX Complete to COP",\n            "ms_1970_integration_complete_actual",\n            "ms_1559_cop_approved_by_t_mobile_actual",\n        ),\n        (\n            "COP to On-Air",\n            "ms_1559_cop_approved_by_t_mobile_actual",\n            "pj_completion_objective_actual_date",\n        ),\n        (\n            "MW Installation (SLA 14d)",\n            "pj_a_4400_mw_installation_start_finish",\n            "pj_a_4425_mw_installation_complete_finish",\n        ),\n        (\n            "MW to Integration Start (SLA 7d)",\n            "pj_a_4425_mw_installation_complete_finish",\n            "pj_a_5270_integration_start_finish",\n        ),\n        (\n            "COP Received to Approved (MB) (SLA 14d)",\n            "pj_a_5500_receive_close_out_binder_finish",\n            "pj_a_5525_approve_close_out_binder_finish",\n        ),\n        (\n            "Pre-NTP to BoM Submission (SLA 10d)",\n            "pj_a_3800_pre_ntp_issued_finish",\n            "pj_a_3850_bom_submitted_bom_in_bat_finish",\n        ),\n        (\n            "E2E Cycle Time (SLA 120d)",\n            "ms_1313_pre_construction_package_validated_actual",\n            "ms_1559_cop_approved_by_t_mobile_actual",\n        ),\n        (\n            "Quote Approved to CX Start (SLA 21d)",\n            "ms_1333_scoping_package_approved_by_customer_actual",\n            "ms_1550_construction_start_actual",\n        ),\n    ]\n\n    # Build UNION ALL unpivot with lead_days and filtering rules:\n    union_selects = []\n    for segment_name, start_col, end_col in segments:\n        seg_filters = [\n            f"{start_col} IS NOT NULL",\n            f"{end_col} IS NOT NULL",\n            f"(({end_col})::date - ({start_col})::date) >= 0",\n        ]\n        if start_date not in (None, ""):\n            seg_filters.append(f"({end_col})::date >= \'{_escape(start_date)}\'::date")\n        if end_date not in (None, ""):\n            seg_filters.append(f"({end_col})::date <= \'{_escape(end_date)}\'::date")\n\n        seg_where = " AND ".join(seg_filters)\n\n        union_selects.append(\n            "\\n".join(\n                [\n                    "SELECT",\n                    "  pj_project_id,",\n                    f"  \'{_escape(segment_name)}\'::text AS segment_name,",\n                    f"  (({end_col})::date - ({start_col})::date)::int AS lead_days,",\n                    "  rgn_region,",\n                    "  m_area,",\n                    "  m_market,",\n                    "  construction_gc,",\n                    "  por_category",\n                    "FROM public.stg_ndpd_mbt_tmobile_macro_combined",\n                    where_sql,\n                    ("AND " if where_sql else "WHERE ") + seg_where,\n                ]\n            )\n        )\n\n    unpivot_sql = "\\nUNION ALL\\n".join(union_selects)\n\n    # Aggregate with AVG and percentiles (no CTEs; wrap UNION ALL as a subquery)\n    agg_sql = "\\n".join(\n        [\n            "SELECT",\n            "  rgn_region,",\n            "  m_area,",\n            "  m_market,",\n            "  construction_gc,",\n            "  segment_name,",\n            "  AVG(lead_days)::numeric(18,2) AS avg_days,",\n            "  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY lead_days) AS p50_days,",\n            "  PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY lead_days) AS p90_days,",\n            "  COUNT(DISTINCT pj_project_id) AS project_count",\n            "FROM (",\n            unpivot_sql,\n            ") segment_leads",\n            "GROUP BY rgn_region, m_area, m_market, construction_gc, segment_name",\n            "ORDER BY rgn_region, m_area, m_market, construction_gc, segment_name",\n        ]\n    )\n\n    return execute_query(agg_sql)\n', kpi_source_columns: ['pj_project_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'ms_1310_pre_construction_package_received_actual', 'ms_1323_ready_for_scoping_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_3925_msl_pickup_date_finish', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual', 'pj_a_5270_integration_start_finish', 'ms_1970_integration_complete_actual', 'ms_1559_cop_approved_by_t_mobile_actual', 'pj_completion_objective_actual_date', 'pj_a_4400_mw_installation_start_finish', 'pj_a_4425_mw_installation_complete_finish', 'pj_a_5500_receive_close_out_binder_finish', 'pj_a_5525_approve_close_out_binder_finish', 'pj_a_3800_pre_ntp_issued_finish', 'pj_a_3850_bom_submitted_bom_in_bat_finish', 'ms_1313_pre_construction_package_validated_actual', 'ms_1333_scoping_package_approved_by_customer_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Intermediate Milestone Lead Time', kpi_related_core_node_ids: ['project', 'milestone', 'market', 'general_contractor'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '2f2e0906-e4e7-42b5-93ed-1431fd7f85f9', entity_type: 'kpi', kpi_name: 'Intermediate Milestone Lead Time', name: '2f2e0906-e4e7-42b5-93ed-1431fd7f85f9', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'segment_name'], kpi_description: 'Measures the calendar-day lead time between defined intermediate milestone pairs for each project, then aggregates results to highlight bottleneck segments in the project lifecycle.', status: 'mentioned', node_id: '2f2e0906-e4e7-42b5-93ed-1431fd7f85f9'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'For each active project in public.stg_ndpd_mbt_tmobile_macro_combined, evaluate configured (predecessor_milestone_column → milestone_column) pairs. For each pair where predecessor date is present and current milestone date is null, compute aging_days = (as_of_date - predecessor_date in days) and sla_pct = (aging_days / expected_sla_days) * 100. Classify status as On Track if sla_pct < risk_threshold_pct, At Risk if risk_threshold_pct <= sla_pct < breach_threshold_pct, else Breached. Aggregate waiting projects by (region, area, market, milestone) and optionally general_contractor, returning total_waiting (distinct projects), at_risk_count, breached_count, avg_aging_days, and p90_aging_days (and echoing as_of_date).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping for the aggregated alert metrics."}, {"column": "m_area", "type": "string", "description": "Area grouping for the aggregated alert metrics."}, {"column": "m_market", "type": "string", "description": "Market grouping for the aggregated alert metrics."}, {"column": "milestone_name", "type": "string", "description": "Current (waiting) milestone being monitored for aging/SLA risk."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping (only when include_gc is enabled)."}, {"column": "total_waiting", "type": "int", "description": "Count of distinct projects waiting on the milestone (predecessor complete, current incomplete)."}, {"column": "at_risk_count", "type": "int", "description": "Number of waiting rows classified as \'At Risk\' within the group."}, {"column": "breached_count", "type": "int", "description": "Number of waiting rows classified as \'Breached\' within the group."}, {"column": "avg_aging_days", "type": "float", "description": "Average aging_days for waiting items in the group."}, {"column": "p90_aging_days", "type": "float", "description": "90th percentile of aging_days for waiting items in the group (percentile_cont)."}]', kpi_business_logic: 'Parse as_of_date from filters (date/datetime or parseable string); if not provided or unparseable, default to the runtime\'s current date.\nInitialize default milestone pairs with physical milestone date column names and default expected_sla_days.\nRead KPI controls from filters: sla_config overrides (by milestone column), risk_threshold_pct, breach_threshold_pct, include_gc, and optional milestone_pairs override list.\nBuild a single SELECT against public.stg_ndpd_mbt_tmobile_macro_combined for active projects, selecting grouping columns plus the milestone columns referenced by configured pairs.\nApply optional equality filters from an explicit allowlist: pj_project_id, rgn_region, m_area, m_market, construction_gc, pj_project_type, pj_program_name.\nFor each returned project row, iterate milestone pairs and include a \'waiting\' record only when predecessor_date is non-null and current milestone date is null.\nFor each waiting record, determine expected_sla_days using sla_config override keyed by milestone_name (else default), compute aging_days using as_of_date and compute sla_pct, and assign status based on thresholds.\nAggregate waiting records by (rgn_region, m_area, m_market, milestone_name) and optional construction_gc, counting distinct projects, counting At Risk and Breached, and collecting aging_days.\nCompute avg_aging_days (mean) and p90_aging_days (continuous percentile) per group, echo as_of_date, and return sorted results.', kpi_filters: '[{"name": "pj_project_id", "type": "string", "description": "Optional. Equality filter."}, {"name": "rgn_region", "type": "string", "description": "Optional. Equality filter."}, {"name": "m_area", "type": "string", "description": "Optional. Equality filter."}, {"name": "m_market", "type": "string", "description": "Optional. Equality filter."}, {"name": "construction_gc", "type": "string", "description": "Optional. Equality filter (only affects query; included in dimensions when include_gc=True)."}, {"name": "pj_project_type", "type": "string", "description": "Optional. Equality filter."}, {"name": "pj_program_name", "type": "string", "description": "Optional. Equality filter."}, {"name": "include_gc", "type": "string", "description": "Optional boolean. If true, include construction_gc in grouping/output."}, {"name": "risk_threshold_pct", "type": "string", "description": "Optional numeric. Default 50."}, {"name": "breach_threshold_pct", "type": "string", "description": "Optional numeric. Default 100."}, {"name": "sla_config", "type": "string", "description": "Optional dict mapping milestone_name (current milestone column) -> expected_sla_days override."}, {"name": "milestone_pairs", "type": "string", "description": "Optional list of dicts to override evaluated pairs: {milestone_name, predecessor_name, expected_sla_days}."}, {"name": "as_of_date", "type": "string", "description": "Optional. Reference date used for aging calculations; if omitted/unparseable, defaults to the runtime current date."}]', kpi_contract: '{"function_name": "get_milestone_aging_alert", "node_type": "kpi", "node_id": "b1325712-f39f-4551-ba34-98a0bc767ebe", "node_label": "Milestone Aging Alert", "description": "Detects milestone aging and SLA breach risk for active projects by measuring how long projects have been waiting on specific upcoming milestones after their predecessor milestone was completed. This helps identify projects that are on track, at risk, or breached against expected SLA timelines.", "parameters": [{"name": "as_of_date", "type": "date", "description": "Filter by as of date", "required": false, "sample_values": []}, {"name": "sla_config", "type": "string", "description": "Filter by sla config", "required": false, "sample_values": []}, {"name": "risk_threshold_pct", "type": "string", "description": "Filter by risk threshold pct", "required": false, "sample_values": []}, {"name": "breach_threshold_pct", "type": "string", "description": "Filter by breach threshold pct", "required": false, "sample_values": []}, {"name": "include_gc", "type": "string", "description": "Filter by include gc", "required": false, "sample_values": []}, {"name": "milestone_pairs", "type": "string", "description": "Filter by milestone pairs", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "milestone_name", "type": "string", "nullable": false}, {"name": "total_waiting", "type": "number", "nullable": false}, {"name": "at_risk_count", "type": "number", "nullable": false}, {"name": "breached_count", "type": "number", "nullable": false}, {"name": "avg_aging_days", "type": "number", "nullable": false}, {"name": "p90_aging_days", "type": "number", "nullable": false}, {"name": "as_of_date", "type": "date", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'For each active project in public.stg_ndpd_mbt_tmobile_macro_combined, evaluate configured (predecessor_milestone_column → milestone_column) pairs. For each pair where predecessor date is present and current milestone date is null, compute aging_days = (as_of_date - predecessor_date in days) and sla_pct = (aging_days / expected_sla_days) * 100. Classify status as On Track if sla_pct < risk_threshold_pct, At Risk if risk_threshold_pct <= sla_pct < breach_threshold_pct, else Breached. Aggregate waiting projects by (region, area, market, milestone) and optionally general_contractor, returning total_waiting (distinct projects), at_risk_count, breached_count, avg_aging_days, and p90_aging_days (and echoing as_of_date).', node_type: 'CORE', definition: 'For each active project in public.stg_ndpd_mbt_tmobile_macro_combined, evaluate configured (predecessor_milestone_column → milestone_column) pairs. For each pair where predecessor date is present and current milestone date is null, compute aging_days = (as_of_date - predecessor_date in days) and sla_pct = (aging_days / expected_sla_days) * 100. Classify status as On Track if sla_pct < risk_threshold_pct, At Risk if risk_threshold_pct <= sla_pct < breach_threshold_pct, else Breached. Aggregate waiting projects by (region, area, market, milestone) and optionally general_contractor, returning total_waiting (distinct projects), at_risk_count, breached_count, avg_aging_days, and p90_aging_days (and echoing as_of_date).', kpi_python_function: 'def get_milestone_aging_alert(execute_query, filters=None) -> list[dict]:\n    import datetime\n    from statistics import mean\n\n    filters = filters or {}\n\n    # --- \'As of\' date ---\n    # Allow caller to set the reference date for aging calculations.\n    # Accepted formats: datetime.date/datetime.datetime or strings: YYYY-MM-DD, YYYY-MM-DD HH:MM:SS, ISO-8601\n    as_of_date = filters.get("as_of_date")\n\n    def _to_date(v):\n        if v is None or v == "":\n            return None\n        if isinstance(v, datetime.date) and not isinstance(v, datetime.datetime):\n            return v\n        if isinstance(v, datetime.datetime):\n            return v.date()\n        s = str(v).strip()\n        try:\n            return datetime.datetime.fromisoformat(s.replace("Z", "+00:00")).date()\n        except Exception:\n            pass\n        for fmt in ("%Y-%m-%d", "%Y-%m-%d %H:%M:%S", "%m/%d/%Y", "%m/%d/%Y %H:%M:%S"):\n            try:\n                return datetime.datetime.strptime(s, fmt).date()\n            except Exception:\n                continue\n        return None\n\n    today = _to_date(as_of_date) or datetime.date.today()\n\n    # --- SLA + thresholds configuration ---\n    # Physical milestone column names from public.stg_ndpd_mbt_tmobile_macro_combined\n    default_pairs = [\n        ("ms_1323_ready_for_scoping_actual", "ms_1310_pre_construction_package_received_actual", 14),\n        ("ms_1327_scoping_and_quoting_package_validated_actual", "ms_1323_ready_for_scoping_actual", 10),\n        ("ms_1507_tower_ntp_approved_actual", "ms_1327_scoping_and_quoting_package_validated_actual", 21),\n        ("ms_1550_construction_start_actual", "ms_1507_tower_ntp_approved_actual", 14),\n        ("ms_1555_construction_complete_actual", "ms_1550_construction_start_actual", 21),\n        ("ms_1970_integration_complete_actual", "ms_1555_construction_complete_actual", 30),\n        ("ms_1559_cop_approved_by_t_mobile_actual", "ms_1970_integration_complete_actual", 14),\n    ]\n\n    sla_override = filters.get("sla_config") or {}\n    risk_threshold_pct = float(filters.get("risk_threshold_pct", 50))\n    breach_threshold_pct = float(filters.get("breach_threshold_pct", 100))\n    include_gc = bool(filters.get("include_gc", False))\n\n    # Allow overriding which milestone pairs are evaluated\n    # Expected format: [{"milestone_name":"<physical_col>","predecessor_name":"<physical_col>","expected_sla_days":14}, ...]\n    if filters.get("milestone_pairs"):\n        milestone_pairs = []\n        for mp in (filters.get("milestone_pairs") or []):\n            milestone_pairs.append(\n                (\n                    mp.get("milestone_name"),\n                    mp.get("predecessor_name"),\n                    int(mp.get("expected_sla_days")) if mp.get("expected_sla_days") is not None else None,\n                )\n            )\n    else:\n        milestone_pairs = list(default_pairs)\n\n    def _percentile_cont(sorted_vals, p):\n        n = len(sorted_vals)\n        if n == 0:\n            return None\n        if n == 1:\n            return float(sorted_vals[0])\n        if p <= 0:\n            return float(sorted_vals[0])\n        if p >= 1:\n            return float(sorted_vals[-1])\n        k = (n - 1) * p\n        f = int(k)\n        c = min(f + 1, n - 1)\n        if f == c:\n            return float(sorted_vals[f])\n        d0 = sorted_vals[f] * (c - k)\n        d1 = sorted_vals[c] * (k - f)\n        return float(d0 + d1)\n\n    # Determine required milestone columns\n    needed_ms_cols = set()\n    for milestone_name, predecessor_name, _sla in milestone_pairs:\n        if milestone_name:\n            needed_ms_cols.add(milestone_name)\n        if predecessor_name:\n            needed_ms_cols.add(predecessor_name)\n\n    # Base columns needed for grouping\n    base_cols = ["pj_project_id", "rgn_region", "m_area", "m_market"]\n    if include_gc:\n        base_cols.append("construction_gc")\n\n    select_cols = base_cols + sorted(needed_ms_cols)\n\n    where_parts = ["pj_project_status = \'Active\'"]\n\n    # Explicit allowlist of column filters (single-table)\n    for fcol in [\n        "pj_project_id",\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "pj_project_type",\n        "pj_program_name",\n    ]:\n        if fcol in filters and filters.get(fcol) not in (None, ""):\n            escaped = str(filters.get(fcol)).replace("\'", "\'\'")\n            where_parts.append(f"{fcol} = \'{escaped}\'")\n\n    sql = (\n        "SELECT "\n        + ", ".join(select_cols)\n        + " FROM public.stg_ndpd_mbt_tmobile_macro_combined"\n        + " WHERE "\n        + " AND ".join(where_parts)\n    )\n\n    rows = execute_query(sql, db="public", max_rows=None) or []\n\n    # --- Unpivot milestone pairs into waiting rows ---\n    waiting_rows = []\n    for r in rows:\n        pj_project_id = r.get("pj_project_id")\n        rgn_region = r.get("rgn_region")\n        m_area = r.get("m_area")\n        m_market = r.get("m_market")\n        construction_gc = r.get("construction_gc") if include_gc else None\n\n        for milestone_name, predecessor_name, default_sla in milestone_pairs:\n            if not milestone_name or not predecessor_name:\n                continue\n\n            predecessor_date = _to_date(r.get(predecessor_name))\n            current_milestone_date = _to_date(r.get(milestone_name))\n\n            # include only if predecessor completed and current milestone not complete\n            if predecessor_date is None:\n                continue\n            if current_milestone_date is not None:\n                continue\n\n            expected_sla_days = sla_override.get(milestone_name, default_sla)\n            if expected_sla_days in (None, 0, "0"):\n                continue\n            expected_sla_days = float(expected_sla_days)\n\n            aging_days = (today - predecessor_date).days\n            sla_pct = (aging_days / expected_sla_days) * 100.0\n\n            if sla_pct < risk_threshold_pct:\n                status = "On Track"\n            elif sla_pct < breach_threshold_pct:\n                status = "At Risk"\n            else:\n                status = "Breached"\n\n            out = {\n                "pj_project_id": pj_project_id,\n                "rgn_region": rgn_region,\n                "m_area": m_area,\n                "m_market": m_market,\n                "milestone_name": milestone_name,\n                "predecessor_name": predecessor_name,\n                "predecessor_date": predecessor_date.isoformat(),\n                "expected_sla_days": expected_sla_days,\n                "aging_days": aging_days,\n                "sla_pct": sla_pct,\n                "status": status,\n            }\n            if include_gc:\n                out["construction_gc"] = construction_gc\n\n            waiting_rows.append(out)\n\n    # --- Aggregate output ---\n    agg = {}\n    for wr in waiting_rows:\n        key = (\n            wr.get("rgn_region"),\n            wr.get("m_area"),\n            wr.get("m_market"),\n            wr.get("milestone_name"),\n            wr.get("construction_gc") if include_gc else None,\n        )\n        if key not in agg:\n            agg[key] = {\n                "rgn_region": wr.get("rgn_region"),\n                "m_area": wr.get("m_area"),\n                "m_market": wr.get("m_market"),\n                "milestone_name": wr.get("milestone_name"),\n                "_project_ids": set(),\n                "_aging_days": [],\n                "at_risk_count": 0,\n                "breached_count": 0,\n            }\n            if include_gc:\n                agg[key]["construction_gc"] = wr.get("construction_gc")\n\n        agg[key]["_project_ids"].add(wr.get("pj_project_id"))\n        agg[key]["_aging_days"].append(int(wr.get("aging_days", 0)))\n        if wr.get("status") == "At Risk":\n            agg[key]["at_risk_count"] += 1\n        elif wr.get("status") == "Breached":\n            agg[key]["breached_count"] += 1\n\n    results = []\n    for v in agg.values():\n        aging = sorted(v["_aging_days"])\n        total_waiting = len(v["_project_ids"])\n        avg_aging_days = float(mean(aging)) if aging else None\n        p90_aging_days = _percentile_cont(aging, 0.9) if aging else None\n\n        rec = {\n            "rgn_region": v.get("rgn_region"),\n            "m_area": v.get("m_area"),\n            "m_market": v.get("m_market"),\n            "milestone_name": v.get("milestone_name"),\n            "total_waiting": total_waiting,\n            "at_risk_count": int(v.get("at_risk_count", 0)),\n            "breached_count": int(v.get("breached_count", 0)),\n            "avg_aging_days": avg_aging_days,\n            "p90_aging_days": p90_aging_days,\n            "as_of_date": today.isoformat(),\n        }\n        if include_gc:\n            rec["construction_gc"] = v.get("construction_gc")\n\n        results.append(rec)\n\n    results.sort(\n        key=lambda x: (\n            (x.get("rgn_region") or ""),\n            (x.get("m_area") or ""),\n            (x.get("m_market") or ""),\n            (x.get("milestone_name") or ""),\n            (x.get("construction_gc") or "") if include_gc else "",\n        )\n    )\n\n    return results\n', kpi_source_columns: ['pj_project_status', 'pj_project_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_type', 'pj_program_name', 'ms_1323_ready_for_scoping_actual', 'ms_1310_pre_construction_package_received_actual', 'ms_1327_scoping_and_quoting_package_validated_actual', 'ms_1507_tower_ntp_approved_actual', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual', 'ms_1970_integration_complete_actual', 'ms_1559_cop_approved_by_t_mobile_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Milestone Aging Alert', kpi_related_core_node_ids: ['project', 'milestone', 'market', 'general_contractor'], kpi_relationship_type: 'DERIVED_FROM', kpi_kpi_id: 'b1325712-f39f-4551-ba34-98a0bc767ebe', entity_type: 'kpi', kpi_name: 'Milestone Aging Alert', name: 'b1325712-f39f-4551-ba34-98a0bc767ebe', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'milestone_name', 'construction_gc (optional when include_gc=True)'], kpi_description: 'Detects milestone aging and SLA breach risk for active projects by measuring how long projects have been waiting on specific upcoming milestones after their predecessor milestone was completed. This helps identify projects that are on track, at risk, or breached against expected SLA timelines.', status: 'mentioned', node_id: 'b1325712-f39f-4551-ba34-98a0bc767ebe'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Counts distinct projects with RAN entitlement completion timestamp present, split into (1) entitled_not_built_projects where construction complete actual is NULL and (2) entitled_and_completed_projects where construction complete actual is NOT NULL. Supports optional filtering by entitlement completion date range and by region/area/market/general contractor and POR category; results can be grouped by region/area/market/general contractor (defaults to all four).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension (present when grouped by region; included by default when no group_by flags are provided)."}, {"column": "m_area", "type": "string", "description": "Area dimension (present when grouped by area; included by default when no group_by flags are provided)."}, {"column": "m_market", "type": "string", "description": "Market dimension (present when grouped by market; included by default when no group_by flags are provided)."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension (present when grouped by GC; included by default when no group_by flags are provided)."}, {"column": "entitled_not_built_projects", "type": "integer", "description": "Count of distinct projects entitled (RAN entitlement complete present) but not yet construction complete (construction complete actual is null)."}]', kpi_business_logic: 'Start from rows in public.stg_ndpd_mbt_tmobile_macro_combined.\nFilter to projects where pj_a_3710_ran_entitlement_complete_finish IS NOT NULL.\nApply optional filters: start_date/end_date on pj_a_3710_ran_entitlement_complete_finish (cast to timestamp), and equality filters on rgn_region, m_area, m_market, construction_gc, por_category.\nGroup results by requested dimensions (group_by_region/area/market/gc); if none are requested, default to grouping by rgn_region, m_area, m_market, construction_gc.\nCompute entitled_not_built_projects as COUNT(DISTINCT pj_project_id) where ms_1555_construction_complete_actual IS NULL.\nCompute entitled_and_completed_projects as COUNT(DISTINCT pj_project_id) where ms_1555_construction_complete_actual IS NOT NULL.\nReturn grouped rows ordered by the grouping dimensions.', kpi_filters: '[{"name": "start_date", "type": "string", "description": "Lower bound (inclusive) for pj_a_3710_ran_entitlement_complete_finish (timestamp)."}, {"name": "end_date", "type": "string", "description": "Upper bound (exclusive) for pj_a_3710_ran_entitlement_complete_finish (timestamp)."}, {"name": "rgn_region", "type": "string", "description": "Exact match filter on rgn_region."}, {"name": "m_area", "type": "string", "description": "Exact match filter on m_area."}, {"name": "m_market", "type": "string", "description": "Exact match filter on m_market."}, {"name": "construction_gc", "type": "string", "description": "Exact match filter on construction_gc."}, {"name": "por_category", "type": "string", "description": "Exact match filter on por_category."}, {"name": "group_by_region", "type": "string", "description": "If truthy, include rgn_region in GROUP BY/SELECT."}, {"name": "group_by_area", "type": "string", "description": "If truthy, include m_area in GROUP BY/SELECT."}, {"name": "group_by_market", "type": "string", "description": "If truthy, include m_market in GROUP BY/SELECT."}, {"name": "group_by_gc", "type": "string", "description": "If truthy, include construction_gc in GROUP BY/SELECT."}]', kpi_contract: '{"function_name": "get_entitled_not_built", "node_type": "kpi", "node_id": "4d3a8f74-eece-46d9-a865-17ce022b210d", "node_label": "Entitled Not Built", "description": "Counts sites/projects that have received RAN entitlement but have not yet reached construction completion, highlighting the construction pipeline backlog after entitlement clearance. This helps identify execution bottlenecks and prioritize construction follow-up by region, market, and general contractor.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "group_by_region", "type": "string", "description": "Filter by group by region", "required": false, "sample_values": []}, {"name": "group_by_area", "type": "string", "description": "Filter by group by area", "required": false, "sample_values": []}, {"name": "group_by_market", "type": "string", "description": "Filter by group by market", "required": false, "sample_values": []}, {"name": "group_by_gc", "type": "string", "description": "Filter by group by gc", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "entitled_not_built_projects", "type": "number", "nullable": false}, {"name": "entitled_and_completed_projects", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Counts distinct projects with RAN entitlement completion timestamp present, split into (1) entitled_not_built_projects where construction complete actual is NULL and (2) entitled_and_completed_projects where construction complete actual is NOT NULL. Supports optional filtering by entitlement completion date range and by region/area/market/general contractor and POR category; results can be grouped by region/area/market/general contractor (defaults to all four).', node_type: 'CORE', definition: 'Counts distinct projects with RAN entitlement completion timestamp present, split into (1) entitled_not_built_projects where construction complete actual is NULL and (2) entitled_and_completed_projects where construction complete actual is NOT NULL. Supports optional filtering by entitlement completion date range and by region/area/market/general contractor and POR category; results can be grouped by region/area/market/general contractor (defaults to all four).', kpi_python_function: 'def get_entitled_not_built(execute_query, filters=None) -> list[dict]:\n    """Counts projects with RAN entitlement complete, split by whether construction is complete, grouped by region/area/market/GC."""\n\n    where_parts = [\n        \'"pj_a_3710_ran_entitlement_complete_finish" IS NOT NULL\'\n    ]\n\n    group_by = []\n    select_dims = []\n\n    # Allowlist filters\n    if filters:\n        if filters.get("start_date"):\n            start = str(filters["start_date"]).replace("\'", "\'\'")\n            where_parts.append(f\'"pj_a_3710_ran_entitlement_complete_finish"::timestamp >= \\\'{start}\\\'::timestamp\')\n        if filters.get("end_date"):\n            end = str(filters["end_date"]).replace("\'", "\'\'")\n            where_parts.append(f\'"pj_a_3710_ran_entitlement_complete_finish"::timestamp < \\\'{end}\\\'::timestamp\')\n\n        if filters.get("rgn_region"):\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f\'"rgn_region" = \\\'{v}\\\'\')\n        if filters.get("m_area"):\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f\'"m_area" = \\\'{v}\\\'\')\n        if filters.get("m_market"):\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f\'"m_market" = \\\'{v}\\\'\')\n        if filters.get("construction_gc"):\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f\'"construction_gc" = \\\'{v}\\\'\')\n        if filters.get("por_category"):\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f\'"por_category" = \\\'{v}\\\'\')\n\n        # Optional grouping controls\n        if filters.get("group_by_region"):\n            select_dims.append(\'"rgn_region" AS "rgn_region"\')\n            group_by.append(\'"rgn_region"\')\n        if filters.get("group_by_area"):\n            select_dims.append(\'"m_area" AS "m_area"\')\n            group_by.append(\'"m_area"\')\n        if filters.get("group_by_market"):\n            select_dims.append(\'"m_market" AS "m_market"\')\n            group_by.append(\'"m_market"\')\n        if filters.get("group_by_gc"):\n            select_dims.append(\'"construction_gc" AS "construction_gc"\')\n            group_by.append(\'"construction_gc"\')\n\n    # Default dimensions if none requested\n    if not group_by:\n        select_dims = [\n            \'"rgn_region" AS "rgn_region"\',\n            \'"m_area" AS "m_area"\',\n            \'"m_market" AS "m_market"\',\n            \'"construction_gc" AS "construction_gc"\'\n        ]\n        group_by = [\'"rgn_region"\', \'"m_area"\', \'"m_market"\', \'"construction_gc"\']\n\n    # Two metrics:\n    # 1) entitled_not_built_projects: entitled complete AND construction complete is NULL\n    # 2) entitled_and_completed_projects: entitled complete AND construction complete is NOT NULL\n    metrics = [\n        \'COUNT(DISTINCT CASE WHEN "ms_1555_construction_complete_actual" IS NULL THEN "pj_project_id" END)::bigint AS "entitled_not_built_projects"\',\n        \'COUNT(DISTINCT CASE WHEN "ms_1555_construction_complete_actual" IS NOT NULL THEN "pj_project_id" END)::bigint AS "entitled_and_completed_projects"\'\n    ]\n\n    select_clause = ",\\n            ".join(select_dims + metrics)\n\n    group_by_clause = ", ".join(group_by)\n    where_clause = " AND ".join(where_parts)\n\n    sql = f"""\n        SELECT\n            {select_clause}\n        FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n        WHERE {where_clause}\n        GROUP BY {group_by_clause}\n        ORDER BY {group_by_clause}\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'pj_a_3710_ran_entitlement_complete_finish', 'ms_1555_construction_complete_actual', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], session_id: '69a3d22f26e208edc083a06e', label: 'Workfront', kpi_related_core_node_ids: ['Workfront', 'project', 'permit'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '4d3a8f74-eece-46d9-a865-17ce022b210d', entity_type: 'kpi', kpi_name: 'Workfront', name: '4d3a8f74-eece-46d9-a865-17ce022b210d', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Counts sites/projects that have received RAN entitlement but have not yet reached construction completion, highlighting the construction pipeline backlog after entitlement clearance. This helps identify execution bottlenecks and prioritize construction follow-up by region, market, and general contractor.', status: 'mentioned', node_id: '4d3a8f74-eece-46d9-a865-17ce022b210d'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Counts distinct projects that have not started construction (ms_1550_construction_start_actual IS NULL) and have all prerequisite readiness gates satisfied (NTP, material pickup, power ready, backhaul ready). Results are grouped by rgn_region, m_area, m_market, construction_gc. start_date/end_date inputs are accepted but ignored (snapshot as-of now). Unknown filter keys are ignored and the caller’s filters dict is not mutated.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension."}, {"column": "ready_site_backlog", "type": "int", "description": "Count of distinct ready-but-not-started projects in the group."}]', kpi_business_logic: 'Start from public.stg_ndpd_mbt_tmobile_macro_combined.\nApply optional dimension/entity filters (rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id, pj_program_name, pj_project_status, pj_project_type) as equality predicates when provided; ignore unknown filter keys; do not apply start_date/end_date.\nFilter to rows where ms_1550_construction_start_actual IS NULL.\nRequire NTP gate satisfied: ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL.\nRequire material gate satisfied: "pj_a_3925_msl_pickup_date_finish" IS NOT NULL.\nRequire power gate satisfied: pj_a_4525_power_ready_finish IS NOT NULL.\nRequire backhaul gate satisfied: pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL.\nGroup by rgn_region, m_area, m_market, construction_gc and compute COUNT(DISTINCT pj_project_id).', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}, {"name": "pj_program_name", "type": "string", "description": ""}, {"name": "pj_project_status", "type": "string", "description": ""}, {"name": "pj_project_type", "type": "string", "description": ""}, {"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_ready_site_backlog", "node_type": "kpi", "node_id": "5976040b-71f0-4f2b-a57e-8db52d8c853d", "node_label": "Ready Site Backlog", "description": "Counts projects that are ready to start construction but have not yet started, shown by market and general contractor as of the current date. This helps quantify construction-ready demand/backlog by geography and GC.", "parameters": [], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "ready_site_backlog", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Counts distinct projects that have not started construction (ms_1550_construction_start_actual IS NULL) and have all prerequisite readiness gates satisfied (NTP, material pickup, power ready, backhaul ready). Results are grouped by rgn_region, m_area, m_market, construction_gc. start_date/end_date inputs are accepted but ignored (snapshot as-of now). Unknown filter keys are ignored and the caller’s filters dict is not mutated.', node_type: 'CORE', definition: 'Counts distinct projects that have not started construction (ms_1550_construction_start_actual IS NULL) and have all prerequisite readiness gates satisfied (NTP, material pickup, power ready, backhaul ready). Results are grouped by rgn_region, m_area, m_market, construction_gc. start_date/end_date inputs are accepted but ignored (snapshot as-of now). Unknown filter keys are ignored and the caller’s filters dict is not mutated.', kpi_python_function: 'def get_ready_site_backlog(execute_query, filters=None) -> list[dict]:\n    """Counts ready-but-not-started projects per (rgn_region, m_area, m_market, construction_gc) as-of CURRENT_DATE.\n\n    Definition:\n      COUNT(DISTINCT pj_project_id)\n      WHERE ms_1550_construction_start_actual IS NULL\n        AND NTP cleared\n        AND material picked up\n        AND power ready\n        AND backhaul ready\n\n    Allowed filters (date filters are accepted but ignored):\n      rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id,\n      pj_program_name, pj_project_status, pj_project_type, start_date, end_date\n\n    Notes:\n      - Does not mutate the caller-provided filters dict; unknown keys are ignored.\n    """\n\n    filters = filters or {}\n\n    def _esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    allowed_filter_cols = {\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "pj_project_id",\n        "s_site_id",\n        "pj_program_name",\n        "pj_project_status",\n        "pj_project_type",\n        "start_date",\n        "end_date",\n    }\n\n    where_parts = []\n\n    # Optional entity filters (non-date). Unknown keys are ignored.\n    for k in (\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "pj_project_id",\n        "s_site_id",\n        "pj_program_name",\n        "pj_project_status",\n        "pj_project_type",\n    ):\n        if k not in allowed_filter_cols:\n            continue\n        v = filters.get(k)\n        if v is None:\n            continue\n        where_parts.append(f"{k} = \'{_esc(v)}\'")\n\n    # Base readiness logic\n    where_parts.append("ms_1550_construction_start_actual IS NULL")\n\n    # 1) NTP cleared\n    where_parts.append("(ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)")\n\n    # 2) Material picked up (capital \'I\' in msI; requires quoted identifier)\n    where_parts.append(\'"pj_a_3925_msl_pickup_date_finish" IS NOT NULL\')\n\n    # 3) Power ready\n    where_parts.append("pj_a_4525_power_ready_finish IS NOT NULL")\n\n    # 4) Backhaul ready\n    where_parts.append("(pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)")\n\n    where_sql = " AND ".join(where_parts) if where_parts else "TRUE"\n\n    sql = f"""\n        SELECT\n            rgn_region,\n            m_area,\n            m_market,\n            construction_gc,\n            COUNT(DISTINCT pj_project_id) AS ready_site_backlog\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        WHERE {where_sql}\n        GROUP BY rgn_region, m_area, m_market, construction_gc\n        ORDER BY rgn_region, m_area, m_market, construction_gc\n    """.strip()\n\n    return execute_query(sql)\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_id', 's_site_id', 'pj_program_name', 'pj_project_status', 'pj_project_type', 'ms_1550_construction_start_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_a_3925_msl_pickup_date_finish', 'pj_a_4525_power_ready_finish', 'pj_a_4925_aav_fiber_ready_finish', 'pj_a_4425_mw_installation_complete_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Ready Site Backlog', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '5976040b-71f0-4f2b-a57e-8db52d8c853d', entity_type: 'kpi', kpi_name: 'Ready Site Backlog', name: '5976040b-71f0-4f2b-a57e-8db52d8c853d', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Counts projects that are ready to start construction but have not yet started, shown by market and general contractor as of the current date. This helps quantify construction-ready demand/backlog by geography and GC.', status: 'mentioned', node_id: '5976040b-71f0-4f2b-a57e-8db52d8c853d'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_hse_site_checklist'], nl_business_rule: '', kpi_formula_description: 'HSE Open Noncompliance is computed from public.stg_ndpd_hse_site_checklist as the count of distinct site_id where ANY of the four HSE gates fails, treating NULL as a failure: (check_in_status IS NULL OR check_in_status <> \'Checked-In\') OR (ppe_validation IS NULL OR ppe_validation <> \'Valid\') OR (jsa_completion_status IS NULL OR jsa_completion_status <> \'Completed\') OR (each_crew_ptid_l2w_status IS NULL OR each_crew_ptid_l2w_status <> \'Compliant\'). The KPI also returns: (a) distinct-site failure counts per gate; (b) per-gate standalone compliance percentages over all distinct sites; and (c) distinct-site escalation resolved/open counts for levels L1-L4 based on escalation_* presence and level_*_status resolution. Results may be optionally grouped by gc_name, market, region, and/or non_compliance_category.', kpi_output_schema: '[{"column": "open_noncompliant_site_count", "type": "int", "description": "Distinct count of sites with an open (unapproved) checkout rejection (proxy for open HSE noncompliance given available mapped fields)."}, {"column": "open_noncompliance_session_count", "type": "int", "description": "Total count of sessions meeting the open noncompliance proxy condition (may be > distinct sites if multiple sessions per site)."}]', kpi_business_logic: 'Query public.stg_ndpd_hse_site_checklist (single-table) with site_id IS NOT NULL.\nApply optional equality filters: gc_name, market, region, site_id, non_compliance_category.\nCompute a denominator per group: site_count = COUNT(DISTINCT site_id).\nDefine gate failures (NULL counts as failure): (col IS NULL OR col <> pass_value) for check-in, PPE, JSA, PTID/L2W; define any_fail as OR across the four failures.\nCompute open_noncompliant_site_count = COUNT(DISTINCT CASE WHEN any_fail THEN site_id END).\nCompute per-gate failure site counts = COUNT(DISTINCT CASE WHEN gate_fail THEN site_id END) for each gate.\nCompute per-gate compliance percentages = 100.0 * COUNT(DISTINCT CASE WHEN gate_pass THEN site_id END) / NULLIF(COUNT(DISTINCT site_id), 0) for each gate, where gate_pass is exact equality to the pass value.\nCompute escalation counts (distinct sites): for each level N in 1..4, resolved = COUNT(DISTINCT CASE WHEN level_N_status = \'Resolved\' THEN site_id END); open = COUNT(DISTINCT CASE WHEN escalation_field IS NOT NULL AND (level_N_status IS NULL OR level_N_status <> \'Resolved\') THEN site_id END).\nIf group_by is provided (allowlist: gc_name, market, region, non_compliance_category), compute all metrics per group.', kpi_filters: '[{"name": "gc_name", "type": "string", "description": ""}, {"name": "market", "type": "string", "description": ""}, {"name": "region", "type": "string", "description": ""}, {"name": "site_id", "type": "string", "description": ""}, {"name": "non_compliance_category", "type": "string", "description": ""}, {"name": "group_by", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_hse_open_noncompliance", "node_type": "kpi", "node_id": "d277e553-9597-413e-b21e-01ff617357c7", "node_label": "HSE Open Noncompliance", "description": "Counts the number of distinct sites with unresolved HSE non-compliance, where at least one mandatory safety gate fails (check-in, PPE, JSA, or PTID/L2W). This KPI highlights current safety risk exposure and operational discipline gaps, and is used to trigger escalation and corrective-action follow-up\\u2014especially when open items persist at higher escalation levels (L3/L4). It supports drilldowns by failing gate, non-compliance category, escalation level reached, and organizational ownership such as general contractor and market/region.", "parameters": [{"name": "gc_name", "type": "string", "description": "Filter by gc name", "required": false, "sample_values": []}, {"name": "market", "type": "string", "description": "Filter by market", "required": false, "sample_values": []}, {"name": "region", "type": "string", "description": "Filter by region", "required": false, "sample_values": []}, {"name": "site_id", "type": "string", "description": "Filter by site id", "required": false, "sample_values": []}, {"name": "non_compliance_category", "type": "string", "description": "Filter by non compliance category", "required": false, "sample_values": []}, {"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}], "output_columns": [{"name": "site_count", "type": "number", "nullable": false}, {"name": "open_noncompliant_site_count", "type": "number", "nullable": false}, {"name": "check_in_failed_site_count", "type": "number", "nullable": false}, {"name": "ppe_failed_site_count", "type": "number", "nullable": false}, {"name": "jsa_failed_site_count", "type": "number", "nullable": false}, {"name": "ptid_l2w_failed_site_count", "type": "number", "nullable": false}, {"name": "check_in_compliance_pct", "type": "number", "nullable": false}, {"name": "ppe_compliance_pct", "type": "number", "nullable": false}, {"name": "jsa_compliance_pct", "type": "number", "nullable": false}, {"name": "ptid_compliance_pct", "type": "number", "nullable": false}, {"name": "l1_resolved", "type": "number", "nullable": false}, {"name": "l1_open", "type": "number", "nullable": false}, {"name": "l2_resolved", "type": "number", "nullable": false}, {"name": "l2_open", "type": "number", "nullable": false}, {"name": "l3_resolved", "type": "number", "nullable": false}, {"name": "l3_open", "type": "number", "nullable": false}, {"name": "l4_resolved", "type": "number", "nullable": false}, {"name": "l4_open", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'HSE Open Noncompliance is computed from public.stg_ndpd_hse_site_checklist as the count of distinct site_id where ANY of the four HSE gates fails, treating NULL as a failure: (check_in_status IS NULL OR check_in_status <> \'Checked-In\') OR (ppe_validation IS NULL OR ppe_validation <> \'Valid\') OR (jsa_completion_status IS NULL OR jsa_completion_status <> \'Completed\') OR (each_crew_ptid_l2w_status IS NULL OR each_crew_ptid_l2w_status <> \'Compliant\'). The KPI also returns: (a) distinct-site failure counts per gate; (b) per-gate standalone compliance percentages over all distinct sites; and (c) distinct-site escalation resolved/open counts for levels L1-L4 based on escalation_* presence and level_*_status resolution. Results may be optionally grouped by gc_name, market, region, and/or non_compliance_category.', node_type: 'CORE', definition: 'HSE Open Noncompliance is computed from public.stg_ndpd_hse_site_checklist as the count of distinct site_id where ANY of the four HSE gates fails, treating NULL as a failure: (check_in_status IS NULL OR check_in_status <> \'Checked-In\') OR (ppe_validation IS NULL OR ppe_validation <> \'Valid\') OR (jsa_completion_status IS NULL OR jsa_completion_status <> \'Completed\') OR (each_crew_ptid_l2w_status IS NULL OR each_crew_ptid_l2w_status <> \'Compliant\'). The KPI also returns: (a) distinct-site failure counts per gate; (b) per-gate standalone compliance percentages over all distinct sites; and (c) distinct-site escalation resolved/open counts for levels L1-L4 based on escalation_* presence and level_*_status resolution. Results may be optionally grouped by gc_name, market, region, and/or non_compliance_category.', kpi_python_function: 'def get_hse_open_noncompliance(execute_query, filters=None) -> list[dict]:\n    """HSE Open Noncompliance\n\n    Computes open noncompliance based on explicit HSE gate fields on\n    public.stg_ndpd_hse_site_checklist (no NAS proxy).\n\n    Outputs:\n      - open_noncompliant_site_count\n      - per-gate failure site counts (distinct sites failing each gate)\n      - per-gate compliance percentages (distinct compliant sites / distinct sites)\n      - escalation resolved/open distinct-site counts for levels L1-L4\n\n    Optionally groups by one or more dimensions via filters[\'group_by\'].\n    """\n\n    filters = filters or {}\n\n    # --- allowlisted filters ---\n    gc_name = filters.get(\'gc_name\')\n    market = filters.get(\'market\')\n    region = filters.get(\'region\')\n    site_id = filters.get(\'site_id\')\n    non_compliance_category = filters.get(\'non_compliance_category\')\n\n    group_by = filters.get(\'group_by\')\n    if group_by is None:\n        group_by = []\n    if isinstance(group_by, str):\n        group_by = [group_by]\n\n    allowed_group_bys = {\'gc_name\', \'market\', \'region\', \'non_compliance_category\'}\n    group_by = [g for g in group_by if g in allowed_group_bys]\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = [\'"site_id" IS NOT NULL\']\n    if gc_name is not None:\n        where_parts.append(f"\\"gc_name\\" = \'{esc(gc_name)}\'")\n    if market is not None:\n        where_parts.append(f"\\"market\\" = \'{esc(market)}\'")\n    if region is not None:\n        where_parts.append(f"\\"region\\" = \'{esc(region)}\'")\n    if site_id is not None:\n        where_parts.append(f"\\"site_id\\" = \'{esc(site_id)}\'")\n    if non_compliance_category is not None:\n        where_parts.append(f"\\"non_compliance_category\\" = \'{esc(non_compliance_category)}\'")\n\n    where_sql = \' AND \'.join(where_parts)\n\n    # Gate fail conditions (NULL counts as failure)\n    checkin_fail = "(\\"check_in_status\\" IS NULL OR \\"check_in_status\\" <> \'Checked-In\')"\n    ppe_fail = "(\\"ppe_validation\\" IS NULL OR \\"ppe_validation\\" <> \'Valid\')"\n    jsa_fail = "(\\"jsa_completion_status\\" IS NULL OR \\"jsa_completion_status\\" <> \'Completed\')"\n    ptid_fail = "(\\"each_crew_ptid_l2w_status\\" IS NULL OR \\"each_crew_ptid_l2w_status\\" <> \'Compliant\')"\n    any_fail = f"({checkin_fail} OR {ppe_fail} OR {jsa_fail} OR {ptid_fail})"\n\n    # Gate pass conditions (for compliance %)\n    checkin_pass = "\\"check_in_status\\" = \'Checked-In\'"\n    ppe_pass = "\\"ppe_validation\\" = \'Valid\'"\n    jsa_pass = "\\"jsa_completion_status\\" = \'Completed\'"\n    ptid_pass = "\\"each_crew_ptid_l2w_status\\" = \'Compliant\'"\n\n    select_dims = \'\'\n    group_by_sql = \'\'\n    order_by_sql = \'\'\n    if group_by:\n        dim_sql = \', \'.join([f\'"{d}"\' for d in group_by])\n        select_dims = f"{dim_sql}, "\n        group_by_sql = f" GROUP BY {dim_sql}"\n        order_by_sql = f" ORDER BY {dim_sql}"\n\n    sql = (\n        "SELECT "\n        f"{select_dims}"\n        # denominators\n        "COUNT(DISTINCT \\"site_id\\")::bigint AS \\"site_count\\", "\n        # existing outputs\n        f"COUNT(DISTINCT CASE WHEN {any_fail} THEN \\"site_id\\" END)::bigint AS \\"open_noncompliant_site_count\\", "\n        f"COUNT(DISTINCT CASE WHEN {checkin_fail} THEN \\"site_id\\" END)::bigint AS \\"check_in_failed_site_count\\", "\n        f"COUNT(DISTINCT CASE WHEN {ppe_fail} THEN \\"site_id\\" END)::bigint AS \\"ppe_failed_site_count\\", "\n        f"COUNT(DISTINCT CASE WHEN {jsa_fail} THEN \\"site_id\\" END)::bigint AS \\"jsa_failed_site_count\\", "\n        f"COUNT(DISTINCT CASE WHEN {ptid_fail} THEN \\"site_id\\" END)::bigint AS \\"ptid_l2w_failed_site_count\\", "\n        # new: per-gate compliance %\n        f"(100.0 * COUNT(DISTINCT CASE WHEN {checkin_pass} THEN \\"site_id\\" END) / NULLIF(COUNT(DISTINCT \\"site_id\\"), 0))::double precision AS \\"check_in_compliance_pct\\", "\n        f"(100.0 * COUNT(DISTINCT CASE WHEN {ppe_pass} THEN \\"site_id\\" END) / NULLIF(COUNT(DISTINCT \\"site_id\\"), 0))::double precision AS \\"ppe_compliance_pct\\", "\n        f"(100.0 * COUNT(DISTINCT CASE WHEN {jsa_pass} THEN \\"site_id\\" END) / NULLIF(COUNT(DISTINCT \\"site_id\\"), 0))::double precision AS \\"jsa_compliance_pct\\", "\n        f"(100.0 * COUNT(DISTINCT CASE WHEN {ptid_pass} THEN \\"site_id\\" END) / NULLIF(COUNT(DISTINCT \\"site_id\\"), 0))::double precision AS \\"ptid_compliance_pct\\", "\n        # new: escalation counts by level\n        "COUNT(DISTINCT CASE WHEN \\"level_1_status\\" = \'Resolved\' THEN \\"site_id\\" END)::bigint AS \\"l1_resolved\\", "\n        "COUNT(DISTINCT CASE WHEN \\"escalation_l1_to_gc\\" IS NOT NULL AND (\\"level_1_status\\" IS NULL OR \\"level_1_status\\" <> \'Resolved\') THEN \\"site_id\\" END)::bigint AS \\"l1_open\\", "\n        "COUNT(DISTINCT CASE WHEN \\"level_2_status\\" = \'Resolved\' THEN \\"site_id\\" END)::bigint AS \\"l2_resolved\\", "\n        "COUNT(DISTINCT CASE WHEN \\"escalation_l2_to_cm\\" IS NOT NULL AND (\\"level_2_status\\" IS NULL OR \\"level_2_status\\" <> \'Resolved\') THEN \\"site_id\\" END)::bigint AS \\"l2_open\\", "\n        "COUNT(DISTINCT CASE WHEN \\"level_3_status\\" = \'Resolved\' THEN \\"site_id\\" END)::bigint AS \\"l3_resolved\\", "\n        "COUNT(DISTINCT CASE WHEN \\"escalation_l3_to_pm\\" IS NOT NULL AND (\\"level_3_status\\" IS NULL OR \\"level_3_status\\" <> \'Resolved\') THEN \\"site_id\\" END)::bigint AS \\"l3_open\\", "\n        "COUNT(DISTINCT CASE WHEN \\"level_4_status\\" = \'Resolved\' THEN \\"site_id\\" END)::bigint AS \\"l4_resolved\\", "\n        "COUNT(DISTINCT CASE WHEN \\"escalation_l4_pd_all\\" IS NOT NULL AND (\\"level_4_status\\" IS NULL OR \\"level_4_status\\" <> \'Resolved\') THEN \\"site_id\\" END)::bigint AS \\"l4_open\\" "\n        "FROM \\"public\\".\\"stg_ndpd_hse_site_checklist\\" "\n        f"WHERE {where_sql}"\n        f"{group_by_sql}"\n        f"{order_by_sql}"\n    )\n\n    rows = execute_query(sql)\n    if not rows:\n        base = {\n            \'site_count\': 0,\n            \'open_noncompliant_site_count\': 0,\n            \'check_in_failed_site_count\': 0,\n            \'ppe_failed_site_count\': 0,\n            \'jsa_failed_site_count\': 0,\n            \'ptid_l2w_failed_site_count\': 0,\n            \'check_in_compliance_pct\': None,\n            \'ppe_compliance_pct\': None,\n            \'jsa_compliance_pct\': None,\n            \'ptid_compliance_pct\': None,\n            \'l1_resolved\': 0,\n            \'l1_open\': 0,\n            \'l2_resolved\': 0,\n            \'l2_open\': 0,\n            \'l3_resolved\': 0,\n            \'l3_open\': 0,\n            \'l4_resolved\': 0,\n            \'l4_open\': 0\n        }\n        return [base]\n\n    return rows\n', kpi_source_columns: ['site_id', 'gc_name', 'market', 'region', 'non_compliance_category', 'check_in_status', 'ppe_validation', 'jsa_completion_status', 'each_crew_ptid_l2w_status', 'escalation_l1_to_gc', 'escalation_l2_to_cm', 'escalation_l3_to_pm', 'escalation_l4_pd_all', 'level_1_status', 'level_2_status', 'level_3_status', 'level_4_status'], session_id: '69a3d22f26e208edc083a06e', label: 'HSE Open Noncompliance', kpi_related_core_node_ids: ['site', 'general_contractor', 'project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'd277e553-9597-413e-b21e-01ff617357c7', entity_type: 'kpi', kpi_name: 'HSE Open Noncompliance', name: 'd277e553-9597-413e-b21e-01ff617357c7', kpi_dimensions: ['gc_name', 'market', 'region', 'non_compliance_category'], kpi_description: 'Counts the number of distinct sites with unresolved HSE non-compliance, where at least one mandatory safety gate fails (check-in, PPE, JSA, or PTID/L2W). This KPI highlights current safety risk exposure and operational discipline gaps, and is used to trigger escalation and corrective-action follow-up—especially when open items persist at higher escalation levels (L3/L4). It supports drilldowns by failing gate, non-compliance category, escalation level reached, and organizational ownership such as general contractor and market/region.', status: 'mentioned', node_id: 'd277e553-9597-413e-b21e-01ff617357c7'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Prereq Readiness Strict (%) = 100.0 * Numerator / NULLIF(Denominator, 0), grouped by rgn_region, m_area, m_market, construction_gc, and suppressing groups where Denominator=0 via HAVING. Denominator = COUNT(DISTINCT pj_project_id) of rows where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL, and if enable_scoping_validated_denominator then also require ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL. Numerator = COUNT(DISTINCT pj_project_id) meeting Denominator conditions plus all gates: NTP cleared (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL), material pickup (pj_a_3925_msl_pickup_date_finish IS NOT NULL), power gate (pj_a_4525_power_ready_finish IS NOT NULL, or if enable_soft_power_gate then pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL), backhaul ready (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL), site access strict (pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL). Optional exact-match WHERE filters: rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id, por_category. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping field."}, {"column": "m_area", "type": "string", "description": "Area grouping field."}, {"column": "m_market", "type": "string", "description": "Market grouping field."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping field."}, {"column": "denominator", "type": "int", "description": "Count of distinct active projects/sites where construction has not started."}, {"column": "numerator", "type": "int", "description": "Count of distinct denominator-eligible projects/sites that meet all readiness gates plus strict site access proxy."}, {"column": "kpi_value", "type": "float", "description": "Prereq Readiness Strict percentage (100 * numerator / denominator)."}]', kpi_business_logic: 'Read optional filters: rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id, por_category (exact-match equality) and flags enable_scoping_validated_denominator and enable_soft_power_gate.\nBuild denominator predicate requiring pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL; if enable_scoping_validated_denominator is true, also require ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL.\nBuild gate predicates: NTP cleared, material pickup, backhaul ready, site access strict; build power predicate either strict (pj_a_4525_power_ready_finish IS NOT NULL) or soft (pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL) depending on enable_soft_power_gate.\nDefine numerator predicate as denominator predicate AND all gate predicates.\nRun a single SQL aggregation over public.stg_ndpd_mbt_tmobile_macro_combined applying the optional WHERE filters, grouping by rgn_region, m_area, m_market, construction_gc.\nCompute denominator as COUNT(DISTINCT CASE WHEN denom_pred THEN pj_project_id END), numerator as COUNT(DISTINCT CASE WHEN num_pred THEN pj_project_id END), and kpi_value = 100.0 * numerator / NULLIF(denominator, 0).\nSuppress noisy output groups with denominator=0 using HAVING COUNT(DISTINCT CASE WHEN denom_pred THEN pj_project_id END) > 0.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}, {"name": "por_category", "type": "string", "description": ""}, {"name": "enable_scoping_validated_denominator", "type": "string", "description": ""}, {"name": "enable_soft_power_gate", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_prereq_readiness_strict", "node_type": "kpi", "node_id": "dcf98a0e-2891-47a3-a258-ebea62201ba4", "node_label": "Prereq Readiness Strict", "description": "Strict version of prerequisite readiness rate that measures the share of active projects/sites that are ready to start construction and also have demonstrated site access. It is used to track readiness progress with an added requirement for a site-access proxy.", "parameters": [{"name": "enable_scoping_validated_denominator", "type": "date", "description": "Filter by enable scoping validated denominator", "required": false, "sample_values": []}, {"name": "enable_soft_power_gate", "type": "string", "description": "Filter by enable soft power gate", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "denominator", "type": "number", "nullable": false}, {"name": "numerator", "type": "number", "nullable": false}, {"name": "kpi_value", "type": "string", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Prereq Readiness Rate (%) = 100.0 * Numerator / NULLIF(Denominator, 0), grouped by rgn_region, m_area, m_market, construction_gc, and suppressing groups where Denominator=0 via HAVING. Denominator = COUNT(DISTINCT pj_project_id) of rows where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL, and if enable_scoping_validated_denominator then also require ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL. Numerator = COUNT(DISTINCT pj_project_id) meeting Denominator conditions plus all gates: NTP cleared (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL), material pickup (pj_a_3925_msl_pickup_date_finish IS NOT NULL), power gate (pj_a_4525_power_ready_finish IS NOT NULL, or if enable_soft_power_gate then pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL), backhaul ready (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL), site access strict (pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL). Optional exact-match WHERE filters: rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id, por_category. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).', node_type: 'CORE', definition: 'Prereq Readiness Rate (%) = 100.0 * Numerator / NULLIF(Denominator, 0), grouped by rgn_region, m_area, m_market, construction_gc, and suppressing groups where Denominator=0 via HAVING. Denominator = COUNT(DISTINCT pj_project_id) of rows where pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL, and if enable_scoping_validated_denominator then also require ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL. Numerator = COUNT(DISTINCT pj_project_id) meeting Denominator conditions plus all gates: NTP cleared (ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL), material pickup (pj_a_3925_msl_pickup_date_finish IS NOT NULL), power gate (pj_a_4525_power_ready_finish IS NOT NULL, or if enable_soft_power_gate then pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL), backhaul ready (pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL), site access strict (pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL). Optional exact-match WHERE filters: rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id, por_category. Source table: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).', kpi_python_function: 'def get_prereq_readiness_strict(execute_query, filters=None) -> list[dict]:\n    """Prereq Readiness Strict (%) grouped by region/area/market/GC.\n\n    Source: public.stg_ndpd_mbt_tmobile_macro_combined (no joins).\n\n    Denominator base (Active, construction not started):\n      - pj_project_status = \'Active\'\n      - ms_1550_construction_start_actual IS NULL\n\n    Optional denominator refinement:\n      - if enable_scoping_validated_denominator: require ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL\n\n    Numerator: Denominator + all prerequisite gates met:\n      - NTP cleared:\n          ms_1507_tower_ntp_approved_actual IS NOT NULL\n          OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL\n      - Material pickup: pj_a_3925_msl_pickup_date_finish IS NOT NULL\n      - Power gate (strict by default): pj_a_4525_power_ready_finish IS NOT NULL\n          - if enable_soft_power_gate: (pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL)\n      - Backhaul ready:\n          pj_a_4925_aav_fiber_ready_finish IS NOT NULL\n          OR pj_a_4425_mw_installation_complete_finish IS NOT NULL\n      - Site access (strict): pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL\n\n    KPI = 100 * numerator / denominator\n\n    Output suppression:\n      - groups with denominator = 0 are suppressed via HAVING\n\n    Allowlisted filters (exact-match):\n      rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id, por_category\n\n    Flags:\n      enable_scoping_validated_denominator (bool)\n      enable_soft_power_gate (bool)\n    """\n\n    filters = filters or {}\n\n    # Flags (truthy enables)\n    enable_scoping_validated_denominator = bool(filters.get("enable_scoping_validated_denominator", False))\n    enable_soft_power_gate = bool(filters.get("enable_soft_power_gate", False))\n\n    # Denominator predicate (optionally refined)\n    denom_parts = [\n        "pj_project_status = \'Active\'",\n        "ms_1550_construction_start_actual IS NULL",\n    ]\n    if enable_scoping_validated_denominator:\n        denom_parts.append("ms_1327_scoping_and_quoting_package_validated_actual IS NOT NULL")\n    denom_pred = "(" + " AND ".join(denom_parts) + ")"\n\n    # Verified physical column predicates (no placeholders)\n    ntp_pred = "(ms_1507_tower_ntp_approved_actual IS NOT NULL OR pj_a_4100_construction_ntp_accepted_by_gc_finish IS NOT NULL)"\n    material_pred = "(pj_a_3925_msl_pickup_date_finish IS NOT NULL)"\n\n    if enable_soft_power_gate:\n        power_pred = "(pj_a_4525_power_ready_finish IS NOT NULL OR pj_a_4450_permanent_power_ordered_finish IS NOT NULL)"\n    else:\n        power_pred = "(pj_a_4525_power_ready_finish IS NOT NULL)"\n\n    backhaul_pred = "(pj_a_4925_aav_fiber_ready_finish IS NOT NULL OR pj_a_4425_mw_installation_complete_finish IS NOT NULL)"\n    site_access_pred = "(pj_a_3825_pre_construction_walk_complete_finish IS NOT NULL)"\n\n    num_pred = " AND ".join([\n        denom_pred,\n        ntp_pred,\n        material_pred,\n        power_pred,\n        backhaul_pred,\n        site_access_pred,\n    ])\n\n    group_dims = ["rgn_region", "m_area", "m_market", "construction_gc"]\n\n    # Optional dimension/entity filters (exact-match)\n    where_parts = []\n    if filters.get("rgn_region") is not None:\n        v = str(filters.get("rgn_region")).replace("\'", "\'\'")\n        where_parts.append(f"rgn_region = \'{v}\'")\n    if filters.get("m_area") is not None:\n        v = str(filters.get("m_area")).replace("\'", "\'\'")\n        where_parts.append(f"m_area = \'{v}\'")\n    if filters.get("m_market") is not None:\n        v = str(filters.get("m_market")).replace("\'", "\'\'")\n        where_parts.append(f"m_market = \'{v}\'")\n    if filters.get("construction_gc") is not None:\n        v = str(filters.get("construction_gc")).replace("\'", "\'\'")\n        where_parts.append(f"construction_gc = \'{v}\'")\n\n    if filters.get("pj_project_id") is not None:\n        v = str(filters.get("pj_project_id")).replace("\'", "\'\'")\n        where_parts.append(f"pj_project_id = \'{v}\'")\n    if filters.get("s_site_id") is not None:\n        v = str(filters.get("s_site_id")).replace("\'", "\'\'")\n        where_parts.append(f"s_site_id = \'{v}\'")\n    if filters.get("por_category") is not None:\n        v = str(filters.get("por_category")).replace("\'", "\'\'")\n        where_parts.append(f"por_category = \'{v}\'")\n\n    where_clause = ""\n    if where_parts:\n        where_clause = "WHERE " + " AND ".join(where_parts)\n\n    group_by = ", ".join(group_dims)\n    select_dims = ", ".join(group_dims)\n\n    denom_count_expr = f"COUNT(DISTINCT CASE WHEN {denom_pred} THEN pj_project_id END)"\n\n    sql = f"""\n        SELECT\n            {select_dims},\n            {denom_count_expr} AS denominator,\n            COUNT(DISTINCT CASE WHEN {num_pred} THEN pj_project_id END) AS numerator,\n            100.0 * COUNT(DISTINCT CASE WHEN {num_pred} THEN pj_project_id END)\n                / NULLIF({denom_count_expr}, 0) AS kpi_value\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        {where_clause}\n        GROUP BY {group_by}\n        HAVING {denom_count_expr} > 0\n        ORDER BY {group_by}\n    """.strip()\n\n    rows = execute_query(sql)\n\n    out = []\n    for r in rows:\n        rec = {k: r.get(k) for k in group_dims}\n        rec["denominator"] = r.get("denominator")\n        rec["numerator"] = r.get("numerator")\n        rec["kpi_value"] = r.get("kpi_value")\n        out.append(rec)\n    return out\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_id', 's_site_id', 'por_category', 'pj_project_status', 'ms_1550_construction_start_actual', 'ms_1327_scoping_and_quoting_package_validated_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_a_3925_msl_pickup_date_finish', 'pj_a_4525_power_ready_finish', 'pj_a_4450_permanent_power_ordered_finish', 'pj_a_4925_aav_fiber_ready_finish', 'pj_a_4425_mw_installation_complete_finish', 'pj_a_3825_pre_construction_walk_complete_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Prereq Readiness Rate', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'DERIVED_FROM', kpi_kpi_id: 'dcf98a0e-2891-47a3-a258-ebea62201ba4', entity_type: 'kpi', kpi_name: 'Prereq Readiness Rate', name: 'dcf98a0e-2891-47a3-a258-ebea62201ba4', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Strict version of prerequisite readiness rate that measures the share of active projects/sites that are ready to start construction and also have demonstrated site access. It is used to track readiness progress with an added requirement for a site-access proxy.', status: 'mentioned', node_id: 'dcf98a0e-2891-47a3-a258-ebea62201ba4'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_hse_site_checklist'], nl_business_rule: '', kpi_formula_description: 'compliance_rate_pct = 100.0 * compliant_reviews / NULLIF(attempted_reviews, 0), where attempted_reviews = COUNT(DISTINCT site_id) with non-null review date and check-in status; compliant_reviews = COUNT(DISTINCT site_id) meeting all four gates (check-in, PPE, JSA, PTID I2W).', kpi_output_schema: '[{"column": "region", "type": "string", "description": "Region grouping field."}, {"column": "market", "type": "string", "description": "Market grouping field."}, {"column": "gc_name", "type": "string", "description": "General contractor name grouping field."}, {"column": "gsd_hse_review_check_date", "type": "date", "description": "Review/check date (cast to date) used for daily grain."}, {"column": "attempted_reviews", "type": "int", "description": "Distinct sites with a review attempt (non-null review date and non-null check-in status)."}, {"column": "compliant_reviews", "type": "int", "description": "Distinct sites that pass all mandatory HSE checks (all four gates)."}, {"column": "compliance_rate_pct", "type": "float", "description": "Percent of attempted reviews that are fully compliant."}, {"column": "fail_check_in_count", "type": "int", "description": "Distinct attempted sites failing the check-in gate."}, {"column": "fail_ppe_count", "type": "int", "description": "Distinct attempted sites failing the PPE validation gate."}, {"column": "fail_jsa_count", "type": "int", "description": "Distinct attempted sites failing the JSA completion gate."}, {"column": "fail_ptid_i2w_count", "type": "int", "description": "Distinct attempted sites failing the PTID I2W availability gate."}, {"column": "any_non_compliant_count", "type": "int", "description": "Distinct attempted sites failing at least one of the four mandatory gates."}]', kpi_business_logic: '1) Start from stg_ndpd_hse_site_checklist and keep rows where gsd_hse_review_check_date is not null.\n2) Group by region, market, gc_name, and gsd_hse_review_check_date::date.\n3) attempted_reviews = count distinct site_id where check_in_status is not null (and review date is not null).\n4) compliant_reviews = count distinct site_id among attempted reviews where check_in_status in (\'Done\',\'Checked In\') AND ppe_validation = \'Pass\' AND jsa_completion_status = \'Completed\' AND each_crew_ptid_I2w_status = \'Available\'.\n5) compliance_rate_pct = 100.0 * compliant_reviews / NULLIF(attempted_reviews, 0).\n6) fail_check_in_count = count distinct site_id among attempted reviews where check_in_status not in (\'Done\',\'Checked In\') OR check_in_status is null.\n7) fail_ppe_count = count distinct site_id among attempted reviews where ppe_validation IS DISTINCT FROM \'Pass\'.\n8) fail_jsa_count = count distinct site_id among attempted reviews where jsa_completion_status IS DISTINCT FROM \'Completed\'.\n9) fail_ptid_i2w_count = count distinct site_id among attempted reviews where each_crew_ptid_I2w_status IS DISTINCT FROM \'Available\'.\n10) any_non_compliant_count = count distinct site_id among attempted reviews where NOT(all 4 compliance conditions are true).\n11) Use DISTINCT site_id to avoid double counting multiple checklist rows per site-day.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Filters to rows with gsd_hse_review_check_date >= start_date."}, {"name": "end_date", "type": "date", "description": "Filters to rows with gsd_hse_review_check_date < (end_date + 1 day)."}, {"name": "region", "type": "string", "description": "Filters to a specific region."}, {"name": "market", "type": "string", "description": "Filters to a specific market."}, {"name": "gc_name", "type": "string", "description": "Filters to a specific general contractor name."}, {"name": "site_id", "type": "string", "description": "Filters to a specific site."}, {"name": "customer_name", "type": "string", "description": "Filters to a specific customer."}, {"name": "hse_status", "type": "string", "description": "Filters to a specific HSE status (reference field; not part of the rate unless explicitly included)."}, {"name": "non_compliance_status", "type": "string", "description": "Filters to a specific non-compliance status (reference field; not part of the rate unless explicitly included)."}, {"name": "hse_engineer_name", "type": "string", "description": "Filters to a specific HSE engineer."}, {"name": "smp_id", "type": "string", "description": "Filters to a specific SMP ID."}, {"name": "smp_name", "type": "string", "description": "Filters to a specific SMP name."}]', kpi_contract: '{"function_name": "get_hse_daily_compliance_rate", "node_type": "kpi", "node_id": "313756f8-da42-470a-998f-dc558b1940f3", "node_label": "HSE Daily Compliance Rate", "description": "Measures the percent of daily site visits/reviews that meet all mandatory HSE checks. Grain: one row per (region, market, gc_name, gsd_hse_review_check_date). Source table: stg_ndpd_hse_site_checklist. \\n\\nDenominator (attempted reviews): COUNT(DISTINCT site_id) where gsd_hse_review_check_date IS NOT NULL AND check_in_status IS NOT NULL (i.e., an HSE review attempt exists for that site-day).\\n\\nNumerator (fully compliant): COUNT(DISTINCT site_id) where check_in_status IN (\'Done\',\'Checked In\') AND ppe_validation = \'Pass\' AND jsa_completion_status = \'Completed\' AND each_crew_ptid_I2w_status = \'Available\'.\\n\\nRate: 100.0 * numerator / NULLIF(denominator, 0).\\n\\nInclude additional output columns (wide-format) for actionable diagnosis on the same row: \\n- attempted_reviews (denominator)\\n- compliant_reviews (numerator)\\n- compliance_rate_pct\\n- fail_check_in_count: COUNT(DISTINCT site_id) among attempted reviews where check_in_status NOT IN (\'Done\',\'Checked In\') OR check_in_status IS NULL\\n- fail_ppe_count: COUNT(DISTINCT site_id) among attempted reviews where ppe_validation IS DISTINCT FROM \'Pass\'\\n- fail_jsa_count: COUNT(DISTINCT site_id) among attempted reviews where jsa_completion_status IS DISTINCT FROM \'Completed\'\\n- fail_ptid_i2w_count: COUNT(DISTINCT site_id) among attempted reviews where each_crew_ptid_I2w_status IS DISTINCT FROM \'Available\'\\n- any_non_compliant_count: COUNT(DISTINCT site_id) among attempted reviews where NOT(all 4 gates pass)\\n\\nNotes/handling: Use DISTINCT site_id to avoid multiple checklist rows per site-day double counting. Use the table\\u2019s region/market/gc_name columns for grouping; optionally also surface hse_status and/or non_compliance_status as reference fields (not part of the rate unless you request it). If you later switch to stg_tmo_hse_daily_tracker_v0_1, preserve the same logic but map date to review_date and use compliance_status/escalation columns for additional breakdown KPIs.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "region", "type": "string", "nullable": false}, {"name": "market", "type": "string", "nullable": false}, {"name": "gc_name", "type": "string", "nullable": false}, {"name": "gsd_hse_review_check_date", "type": "date", "nullable": false}, {"name": "attempted_reviews", "type": "number", "nullable": false}, {"name": "compliant_reviews", "type": "number", "nullable": false}, {"name": "compliance_rate_pct", "type": "string", "nullable": false}, {"name": "fail_check_in_count", "type": "number", "nullable": false}, {"name": "fail_ppe_count", "type": "number", "nullable": false}, {"name": "fail_jsa_count", "type": "number", "nullable": false}, {"name": "fail_ptid_i2w_count", "type": "number", "nullable": false}, {"name": "any_non_compliant_count", "type": "number", "nullable": false}], "sample_output": [{"region": "Central", "market": "Chicago", "gc_name": "Adcom Communication Wireless", "gsd_hse_review_check_date": "2024-10-18", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 1, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "Adcom Communication Wireless", "gsd_hse_review_check_date": "2025-03-18", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}, {"region": "Central", "market": "Chicago", "gc_name": "EWS Group", "gsd_hse_review_check_date": "2024-10-27", "attempted_reviews": 1, "compliant_reviews": 0, "compliance_rate_pct": "0E-20", "fail_check_in_count": 0, "fail_ppe_count": 1, "fail_jsa_count": 0, "fail_ptid_i2w_count": 1, "any_non_compliant_count": 1}], "row_count": 10}', nl_description: 'HSE Daily Compliance Rate = 100 * (distinct sites on a given region/market/gc/day where check-in is Done/Checked In AND PPE=Pass AND JSA=Completed AND PTID I2W=Available) / (distinct sites on that region/market/gc/day with a non-null review date and non-null check-in status), plus distinct-site failure counts per gate and any-noncompliant.', node_type: 'CORE', definition: 'HSE Daily Compliance Rate = 100 * (distinct sites on a given region/market/gc/day where check-in is Done/Checked In AND PPE=Pass AND JSA=Completed AND PTID I2W=Available) / (distinct sites on that region/market/gc/day with a non-null review date and non-null check-in status), plus distinct-site failure counts per gate and any-noncompliant.', kpi_python_function: 'def get_hse_daily_compliance_rate(execute_query, filters=None) -> list[dict]:\n    """Grain: one row per (region, market, gc_name, gsd_hse_review_check_date::date).\n\n    Computes attempted vs compliant distinct sites and failure-gate distinct-site counts.\n    """\n\n    def _esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Build WHERE clause (PostgreSQL)\n    where_parts = []\n\n    # Date filtering: apply to gsd_hse_review_check_date\n    if filters:\n        start_date = filters.get("start_date")\n        end_date = filters.get("end_date")\n        if start_date:\n            where_parts.append(f"gsd_hse_review_check_date >= \'{_esc(start_date)}\'")\n        if end_date:\n            where_parts.append(\n                f"gsd_hse_review_check_date < (\'{_esc(end_date)}\'::date + interval \'1 day\')"\n            )\n\n        # Optional dimension filters (only if provided)\n        for k in [\n            "region",\n            "market",\n            "gc_name",\n            "site_id",\n            "customer_name",\n            "hse_status",\n            "non_compliance_status",\n            "hse_engineer_name",\n            "smp_id",\n            "smp_name",\n        ]:\n            if k in filters and filters.get(k) is not None and filters.get(k) != "":\n                where_parts.append(f"{k} = \'{_esc(filters.get(k))}\'")\n\n    where_parts.append("gsd_hse_review_check_date IS NOT NULL")\n\n    where_sql = ""\n    if where_parts:\n        where_sql = "WHERE " + " AND ".join(where_parts)\n\n    # NOTE: "each_crew_ptid_l2w_status" is a physically-cased column name; must be double-quoted in Postgres.\n    sql = f"""\n        SELECT\n            region,\n            market,\n            gc_name,\n            (gsd_hse_review_check_date::date) AS gsd_hse_review_check_date,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                THEN site_id\n            END) AS attempted_reviews,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND check_in_status IN (\'Done\',\'Checked-In\')\n                 AND ppe_validation = \'Pass\'\n                 AND jsa_completion_status = \'Completed\'\n                 AND "each_crew_ptid_l2w_status" = \'Available\'\n                THEN site_id\n            END) AS compliant_reviews,\n\n            (100.0 *\n                COUNT(DISTINCT CASE\n                    WHEN gsd_hse_review_check_date IS NOT NULL\n                     AND check_in_status IS NOT NULL\n                     AND check_in_status IN (\'Done\',\'Checked-In\')\n                     AND ppe_validation = \'Pass\'\n                     AND jsa_completion_status = \'Completed\'\n                     AND "each_crew_ptid_l2w_status" = \'Available\'\n                    THEN site_id\n                END)\n             / NULLIF(\n                COUNT(DISTINCT CASE\n                    WHEN gsd_hse_review_check_date IS NOT NULL\n                     AND check_in_status IS NOT NULL\n                    THEN site_id\n                END)\n             , 0)\n            ) AS compliance_rate_pct,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND (check_in_status NOT IN (\'Done\',\'Checked-In\') OR check_in_status IS NULL)\n                THEN site_id\n            END) AS fail_check_in_count,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND (ppe_validation IS DISTINCT FROM \'Pass\')\n                THEN site_id\n            END) AS fail_ppe_count,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND (jsa_completion_status IS DISTINCT FROM \'Completed\')\n                THEN site_id\n            END) AS fail_jsa_count,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND ("each_crew_ptid_l2w_status" IS DISTINCT FROM \'Available\')\n                THEN site_id\n            END) AS fail_ptid_i2w_count,\n\n            COUNT(DISTINCT CASE\n                WHEN gsd_hse_review_check_date IS NOT NULL\n                 AND check_in_status IS NOT NULL\n                 AND NOT (\n                    check_in_status IN (\'Done\',\'Checked-In\')\n                    AND ppe_validation = \'Pass\'\n                    AND jsa_completion_status = \'Completed\'\n                    AND "each_crew_ptid_l2w_status" = \'Available\'\n                 )\n                THEN site_id\n            END) AS any_non_compliant_count\n\n        FROM public.stg_ndpd_hse_site_checklist\n        {where_sql}\n        GROUP BY\n            region,\n            market,\n            gc_name,\n            (gsd_hse_review_check_date::date)\n        ORDER BY\n            region,\n            market,\n            gc_name,\n            (gsd_hse_review_check_date::date)\n    """\n\n    return execute_query(sql, db="public")\n', kpi_source_columns: ['region', 'market', 'gc_name', 'gsd_hse_review_check_date', 'site_id', 'check_in_status', 'ppe_validation', 'jsa_completion_status', 'each_crew_ptid_I2w_status', 'customer_name', 'hse_status', 'non_compliance_status', 'hse_engineer_name', 'smp_id', 'smp_name'], session_id: '69a3d22f26e208edc083a06e', label: 'HSE Daily Compliance Rate', kpi_related_core_node_ids: ['customer'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '313756f8-da42-470a-998f-dc558b1940f3', entity_type: 'kpi', kpi_name: 'HSE Daily Compliance Rate', name: '313756f8-da42-470a-998f-dc558b1940f3', kpi_dimensions: ['region', 'market', 'gc_name', 'gsd_hse_review_check_date'], kpi_description: 'Measures the percent of daily site visits/reviews that meet all mandatory HSE checks. It indicates daily compliance performance by region/market/GC and helps identify where HSE requirements are not being met.', status: 'mentioned', node_id: '313756f8-da42-470a-998f-dc558b1940f3'});
CREATE (:BKGNode {kpi_source_tables: ['stg_nas_e911_readiness_riot_validation', 'public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Computes two related E911 metrics: (1) E911 Readiness Rate from stg_nas_e911_readiness_riot_validation using latest validation per site with PASS/PASS criteria (passed/attempted), excluding NULL validation dates; and (2) E911 Requested Rate (%) from public.stg_ndpd_mbt_tmobile_macro_combined as 100 * (# distinct pj_project_id with pj_a_5200_e911_routing_received_finish not null) / (# distinct pj_project_id with pj_a_3710_ran_entitlement_complete_finish not null).', kpi_output_schema: '[{"column": "kpi", "type": "string", "description": "KPI name."}, {"column": "attempted_site_count", "type": "integer", "description": "Number of distinct sites where E911 validation was attempted."}, {"column": "passed_site_count", "type": "integer", "description": "Number of distinct attempted sites that passed all required E911 validation layers (per implemented proxy logic)."}, {"column": "e911_readiness_rate", "type": "float", "description": "passed_site_count / attempted_site_count."}]', kpi_business_logic: '1) RIOT readiness: filter stg_nas_e911_readiness_riot_validation to rows where nas_e911_validation_date is not null and optional filters (nas_site_id, nas_engineer, start_date/end_date). 2) For each nas_site_id, find MAX(nas_e911_validation_date) as latest_validation_date. 3) Join back to the table on (nas_site_id, latest_validation_date). 4) site_passed = 1 if any row on that latest date has nas_validate_e911_readiness=\'PASS\' AND nas_consolidation_check_all_layers=\'PASS\', else 0. 5) attempted_site_count = number of sites returned; passed_site_count = sum(site_passed); e911_readiness_rate = passed/attempted. 6) Optional: enrich with site dimensions via get_site and optionally aggregate by market or region. 7) Macro companion: from public.stg_ndpd_mbt_tmobile_macro_combined compute entitled_site_count as distinct pj_project_id with pj_a_3710_ran_entitlement_complete_finish not null, and e911_requested_count as distinct pj_project_id with pj_a_5200_e911_routing_received_finish not null; compute e911_requested_rate_pct = 100*requested/entitled (null if entitled=0). 8) Return both metrics in the output (macro metrics are global and repeated for grouped/site-level outputs).', kpi_filters: '[{"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}, {"name": "nas_site_id", "type": "string", "description": ""}, {"name": "nas_engineer", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "group_by", "type": "string", "description": ""}, {"name": "include_site_level", "type": "string", "description": ""}, {"name": "include_site_details", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_e911_readiness_rate", "node_type": "kpi", "node_id": "4d46b430-b2af-43e7-8a47-0391a2b77c53", "node_label": "E911 Readiness Rate", "description": "Measures the share of sites where E911 validation has been attempted that successfully pass all required E911 validation layers, indicating the site is legally and technically ready to route emergency calls correctly prior to on-air. This KPI is used to quantify integration go-live blocking risk, identify markets/regions/vendors with disproportionate E911 failures, and monitor readiness trends over time.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas site id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "site_code", "type": "string", "description": "Filter by site code", "required": false, "sample_values": []}, {"name": "nas_engineer", "type": "string", "description": "Filter by nas engineer", "required": false, "sample_values": []}, {"name": "include_site_details", "type": "string", "description": "Filter by include site details", "required": false, "sample_values": []}, {"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "include_site_level", "type": "string", "description": "Filter by include site level", "required": false, "sample_values": []}], "output_columns": [{"name": "kpi", "type": "string", "nullable": false}, {"name": "attempted_site_count", "type": "number", "nullable": false}, {"name": "passed_site_count", "type": "number", "nullable": false}, {"name": "e911_readiness_rate", "type": "number", "nullable": false}, {"name": "entitled_site_count", "type": "number", "nullable": false}, {"name": "e911_requested_count", "type": "number", "nullable": false}, {"name": "e911_requested_rate_pct", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'Computes two related E911 metrics: (1) E911 Readiness Rate from stg_nas_e911_readiness_riot_validation using latest validation per site with PASS/PASS criteria (passed/attempted), excluding NULL validation dates; and (2) E911 Requested Rate (%) from public.stg_ndpd_mbt_tmobile_macro_combined as 100 * (# distinct pj_project_id with pj_a_5200_e911_routing_received_finish not null) / (# distinct pj_project_id with pj_a_3710_ran_entitlement_complete_finish not null).', node_type: 'CORE', definition: 'Computes two related E911 metrics: (1) E911 Readiness Rate from stg_nas_e911_readiness_riot_validation using latest validation per site with PASS/PASS criteria (passed/attempted), excluding NULL validation dates; and (2) E911 Requested Rate (%) from public.stg_ndpd_mbt_tmobile_macro_combined as 100 * (# distinct pj_project_id with pj_a_5200_e911_routing_received_finish not null) / (# distinct pj_project_id with pj_a_3710_ran_entitlement_complete_finish not null).', kpi_python_function: 'def get_e911_readiness_rate(execute_query, filters=None) -> list[dict]:\n    """KPI: E911 Readiness Rate (RIOT) + E911 Requested Rate (macro).\n\n    Outputs\n    -------\n    1) RIOT-based readiness (primary):\n       - attempted_site_count: count of sites with >=1 non-null nas_e911_validation_date record\n       - passed_site_count: count of sites whose latest validation record is PASS/PASS\n       - e911_readiness_rate: passed_site_count / attempted_site_count\n\n    2) Macro-based completion companion (secondary):\n       - entitled_site_count: distinct projects with pj_a_3710_ran_entitlement_complete_finish IS NOT NULL\n       - e911_requested_count: distinct projects with pj_a_5200_e911_routing_received_finish IS NOT NULL\n       - e911_requested_rate_pct: 100 * e911_requested_count / entitled_site_count\n\n    Notes\n    -----\n    * RIOT readiness is sourced from stg_nas_e911_readiness_riot_validation.\n    * E911 Requested Rate is sourced from public.stg_ndpd_mbt_tmobile_macro_combined.\n    * This function avoids CTEs (no WITH clauses).\n\n    Filters (optional)\n    ------------------\n    RIOT portion:\n      start_date, end_date: applied to nas_e911_validation_date\n      nas_site_id: filter to a single site\n      nas_engineer: filter to a single engineer\n      m_market, m_area, rgn_region: optional dimensional filters via site enrichment\n      group_by: None|\'region\'|\'market\'\n      include_site_level: bool\n      include_site_details: bool\n\n    Macro portion:\n      (No filters applied in this version; metric is global over macro_combined.)\n    """\n\n    filters = filters or {}\n\n    # ----------------------------\n    # Part A: RIOT Readiness (latest-status, PASS/PASS)\n    # ----------------------------\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n    nas_site_id = filters.get("nas_site_id") or filters.get("s_site_id") or filters.get("site_code")\n    nas_engineer = filters.get("nas_engineer")\n\n    where = ["nas_e911_validation_date IS NOT NULL"]\n    if nas_site_id:\n        where.append(f"nas_site_id = \'{nas_site_id}\'")\n    if nas_engineer:\n        where.append(f"nas_engineer = \'{nas_engineer}\'")\n    if start_date:\n        where.append(f"nas_e911_validation_date::date >= \'{str(start_date)[:10]}\'")\n    if end_date:\n        where.append(f"nas_e911_validation_date::date <= \'{str(end_date)[:10]}\'")\n\n    riot_sql = f"""\n        SELECT\n            v.nas_site_id,\n            v.latest_validation_date,\n            MAX(CASE\n                WHEN r.nas_validate_e911_readiness = \'PASS\'\n                 AND r.nas_consolidation_check_all_layers = \'PASS\'\n                THEN 1 ELSE 0 END\n            ) AS site_passed,\n            MAX(CASE\n                WHEN r.nas_validate_e911_readiness <> \'PASS\'\n                THEN r.nas_e911_validation_reason ELSE NULL END\n            ) AS failure_reason\n        FROM (\n            SELECT\n                nas_site_id,\n                MAX(nas_e911_validation_date) AS latest_validation_date\n            FROM stg_nas_e911_readiness_riot_validation\n            WHERE {\' AND \'.join(where)}\n            GROUP BY nas_site_id\n        ) v\n        JOIN stg_nas_e911_readiness_riot_validation r\n          ON r.nas_site_id = v.nas_site_id\n         AND r.nas_e911_validation_date = v.latest_validation_date\n        GROUP BY v.nas_site_id, v.latest_validation_date\n    """\n\n    riot_by_site = execute_query(riot_sql) or []\n\n    include_site_details = bool(filters.get("include_site_details"))\n    need_dims = include_site_details or filters.get("group_by") in ("region", "market") or any(filters.get(k) for k in ("m_market", "m_area", "rgn_region"))\n\n    site_dim = {}\n    if need_dims:\n        site_filters = {}\n        for k in ("m_market", "m_area", "rgn_region"):\n            if filters.get(k) not in (None, ""):\n                site_filters[k] = filters.get(k)\n\n        sites = get_site(execute_query, site_filters)\n        for s in sites or []:\n            key = s.get("nas_site_id") or s.get("s_site_id") or s.get("site_code")\n            if key is not None:\n                site_dim[str(key)] = s\n\n    by_site = []\n    for r in riot_by_site:\n        sid = r.get("nas_site_id")\n        if sid is None:\n            continue\n        sid_key = str(sid)\n        passed = int(r.get("site_passed") or 0)\n        s = site_dim.get(sid_key, {})\n\n        if need_dims and site_dim:\n            if filters.get("m_market") and s.get("m_market") != filters.get("m_market"):\n                continue\n            if filters.get("m_area") and s.get("m_area") != filters.get("m_area"):\n                continue\n            if filters.get("rgn_region") and s.get("rgn_region") != filters.get("rgn_region"):\n                continue\n\n        rec = {\n            "nas_site_id": sid,\n            "attempted": 1,\n            "passed": passed,\n            "latest_validation_date": r.get("latest_validation_date"),\n            "failure_reason": r.get("failure_reason"),\n            "m_market": s.get("m_market"),\n            "m_area": s.get("m_area"),\n            "rgn_region": s.get("rgn_region"),\n        }\n\n        if include_site_details:\n            rec.update({\n                "site_name": s.get("site_name"),\n                "s_city": s.get("s_city"),\n                "s_state": s.get("s_state"),\n            })\n        by_site.append(rec)\n\n    # Aggregate RIOT readiness\n    attempted_sites = len(by_site)\n    passed_sites = sum(x["passed"] for x in by_site)\n    riot_rate = (float(passed_sites) / float(attempted_sites)) if attempted_sites else None\n\n    # ----------------------------\n    # Part B: Macro companion - E911 Requested Rate (%)\n    # ----------------------------\n    macro_sql = """\n        SELECT\n            COUNT(DISTINCT CASE\n                WHEN pj_a_3710_ran_entitlement_complete_finish IS NOT NULL\n                THEN pj_project_id END\n            ) AS entitled_site_count,\n            COUNT(DISTINCT CASE\n                WHEN pj_a_5200_e911_routing_received_finish IS NOT NULL\n                THEN pj_project_id END\n            ) AS e911_requested_count\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n    """\n\n    macro_rows = execute_query(macro_sql) or []\n    mr = macro_rows[0] if macro_rows else {}\n    entitled = int(mr.get("entitled_site_count") or 0)\n    requested = int(mr.get("e911_requested_count") or 0)\n    requested_rate_pct = (100.0 * float(requested) / float(entitled)) if entitled else None\n\n    # ----------------------------\n    # Output formatting\n    # ----------------------------\n    if filters.get("group_by") == "region":\n        agg = {}\n        for rec in by_site:\n            key = rec.get("rgn_region") or "(unknown)"\n            a = agg.get(key)\n            if a is None:\n                agg[key] = {"rgn_region": key, "attempted_site_count": 1, "passed_site_count": rec["passed"]}\n            else:\n                a["attempted_site_count"] += 1\n                a["passed_site_count"] += rec["passed"]\n\n        out = []\n        for _, a in sorted(agg.items(), key=lambda x: x[0]):\n            attempted = a["attempted_site_count"]\n            passed = a["passed_site_count"]\n            a["e911_readiness_rate"] = (float(passed) / float(attempted)) if attempted else None\n            # attach macro companion (global values)\n            a["entitled_site_count"] = entitled\n            a["e911_requested_count"] = requested\n            a["e911_requested_rate_pct"] = requested_rate_pct\n            out.append(a)\n        return out\n\n    if filters.get("group_by") == "market":\n        agg = {}\n        for rec in by_site:\n            key = rec.get("m_market") or "(unknown)"\n            a = agg.get(key)\n            if a is None:\n                agg[key] = {"m_market": key, "attempted_site_count": 1, "passed_site_count": rec["passed"]}\n            else:\n                a["attempted_site_count"] += 1\n                a["passed_site_count"] += rec["passed"]\n\n        out = []\n        for _, a in sorted(agg.items(), key=lambda x: x[0]):\n            attempted = a["attempted_site_count"]\n            passed = a["passed_site_count"]\n            a["e911_readiness_rate"] = (float(passed) / float(attempted)) if attempted else None\n            # attach macro companion (global values)\n            a["entitled_site_count"] = entitled\n            a["e911_requested_count"] = requested\n            a["e911_requested_rate_pct"] = requested_rate_pct\n            out.append(a)\n        return out\n\n    if filters.get("include_site_level"):\n        # site-level view for RIOT portion; macro companion is repeated per row for convenience\n        for rec in by_site:\n            rec["entitled_site_count"] = entitled\n            rec["e911_requested_count"] = requested\n            rec["e911_requested_rate_pct"] = requested_rate_pct\n        return by_site\n\n    return [{\n        "kpi": "E911 Readiness Rate",\n        "attempted_site_count": attempted_sites,\n        "passed_site_count": passed_sites,\n        "e911_readiness_rate": riot_rate,\n        "entitled_site_count": entitled,\n        "e911_requested_count": requested,\n        "e911_requested_rate_pct": requested_rate_pct\n    }]\n', kpi_source_columns: ['stg_nas_e911_readiness_riot_validation.nas_site_id', 'stg_nas_e911_readiness_riot_validation.nas_e911_validation_date', 'stg_nas_e911_readiness_riot_validation.nas_validate_e911_readiness', 'stg_nas_e911_readiness_riot_validation.nas_consolidation_check_all_layers', 'stg_nas_e911_readiness_riot_validation.nas_e911_validation_reason', 'stg_nas_e911_readiness_riot_validation.nas_engineer', 'public.stg_ndpd_mbt_tmobile_macro_combined.pj_project_id', 'public.stg_ndpd_mbt_tmobile_macro_combined.pj_a_3710_ran_entitlement_complete_finish', 'public.stg_ndpd_mbt_tmobile_macro_combined.pj_a_5200_e911_routing_received_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'E911 Readiness Rate', kpi_related_core_node_ids: ['stg_nas_e911_readiness_riot_validation', 'site', 'market', 'project', 'milestone', 'integration_activity', 'person', 'integration_artifact'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '4d46b430-b2af-43e7-8a47-0391a2b77c53', entity_type: 'kpi', kpi_name: 'E911 Readiness Rate', name: '4d46b430-b2af-43e7-8a47-0391a2b77c53', kpi_dimensions: ['nas_site_id', 'rgn_region', 'm_market', 'm_area'], kpi_description: 'Measures the share of sites where E911 validation has been attempted that successfully pass all required E911 validation layers, indicating the site is legally and technically ready to route emergency calls correctly prior to on-air. This KPI is used to quantify integration go-live blocking risk, identify markets/regions/vendors with disproportionate E911 failures, and monitor readiness trends over time.', status: 'mentioned', node_id: '4d46b430-b2af-43e7-8a47-0391a2b77c53'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Computes Capacity vs Demand Gap by (rgn_region, m_area, m_market, construction_gc). Let N = trailing_weeks (default 12). run_rate = COUNT(DISTINCT projects with ms_1555_construction_complete_actual in the last N weeks) / N. backlog = COUNT(DISTINCT projects where ms_1550_construction_start_actual is NULL and the 4 readiness gates are satisfied). gap = run_rate − backlog.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region."}, {"column": "m_area", "type": "string", "description": "Area."}, {"column": "m_market", "type": "string", "description": "Market."}, {"column": "construction_gc", "type": "string", "description": "General contractor."}, {"column": "run_rate", "type": "float", "description": "Average weekly distinct completed projects over the trailing 12 weeks (completed_12w / 12)."}, {"column": "backlog", "type": "int", "description": "Count of distinct projects that meet readiness gates and have not started as of CURRENT_DATE."}, {"column": "gap", "type": "float", "description": "Capacity vs demand gap (run_rate minus backlog)."}]', kpi_business_logic: 'Read trailing_weeks from filters (default 12); coerce to a positive integer; if invalid/non-positive, use 12.\nConstruct a WHERE clause seeded with \'1=1\' and append allowlisted optional filters: rgn_region, m_area, m_market, construction_gc, pj_program_name, pj_project_type. This ensures subqueries can safely append additional predicates with AND.\nBuild a group spine as distinct (rgn_region, m_area, m_market, construction_gc) from public.stg_ndpd_mbt_tmobile_macro_combined, excluding NULL construction_gc and NULL m_market.\nCompute completed_nw per group by counting distinct pj_project_id where ms_1555_construction_complete_actual is not NULL and is within the trailing window: completed_ts >= CURRENT_DATE - (N*7 days) and < CURRENT_DATE + 1 day.\nCompute ready_not_started per group by counting distinct pj_project_id where ms_1550_construction_start_actual is NULL and readiness gates are satisfied: (ms_1507_tower_ntp_approved_actual OR pj_a_4100_construction_ntp_accepted_by_gc_finish) AND pj_a_3925_msl_pickup_date_finish AND pj_a_4525_power_ready_finish AND (pj_a_4925_aav_fiber_ready_finish OR pj_a_4425_mw_installation_complete_finish).\nLEFT JOIN the completed_nw and ready_not_started aggregates onto the spine using (rgn_region, m_area, m_market, construction_gc).\nReturn run_rate = completed_nw / N, backlog = ready_not_started, and gap = run_rate - backlog, plus trailing_weeks.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_program_name", "type": "string", "description": ""}, {"name": "pj_project_type", "type": "string", "description": ""}, {"name": "trailing_weeks", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_capacity_vs_demand_gap", "node_type": "kpi", "node_id": "ea9583cb-1701-45ef-a2db-5cc07b01948c", "node_label": "Capacity vs Demand Gap", "description": "Measures the execution capacity versus near-term demand by comparing observed weekly delivery capacity to the count of ready-but-not-started sites for each Market and General Contractor, anchored to the current date. Positive values indicate implied spare capacity, while negative values indicate backlog pressure.", "parameters": [{"name": "trailing_weeks", "type": "string", "description": "Filter by trailing weeks", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "pj_program_name", "type": "string", "description": "Filter by pj program name", "required": false, "sample_values": []}, {"name": "pj_project_type", "type": "string", "description": "Filter by pj project type", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "run_rate", "type": "string", "nullable": false}, {"name": "backlog", "type": "number", "nullable": false}, {"name": "gap", "type": "string", "nullable": false}, {"name": "trailing_weeks", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Computes Capacity vs Demand Gap by (rgn_region, m_area, m_market, construction_gc). Let N = trailing_weeks (default 12). run_rate = COUNT(DISTINCT projects with ms_1555_construction_complete_actual in the last N weeks) / N. backlog = COUNT(DISTINCT projects where ms_1550_construction_start_actual is NULL and the 4 readiness gates are satisfied). gap = run_rate − backlog.', node_type: 'CORE', definition: 'Computes Capacity vs Demand Gap by (rgn_region, m_area, m_market, construction_gc). Let N = trailing_weeks (default 12). run_rate = COUNT(DISTINCT projects with ms_1555_construction_complete_actual in the last N weeks) / N. backlog = COUNT(DISTINCT projects where ms_1550_construction_start_actual is NULL and the 4 readiness gates are satisfied). gap = run_rate − backlog.', kpi_python_function: 'def get_capacity_vs_demand_gap(execute_query, filters=None) -> list[dict]:\n    """Capacity vs Demand Gap per (rgn_region, m_area, m_market, construction_gc).\n\n    Definitions (per group):\n      - completed_nw = COUNT(DISTINCT projects with construction complete in the trailing N weeks)\n      - run_rate     = completed_nw / N\n      - backlog      = COUNT(DISTINCT projects not started as-of CURRENT_DATE that pass the 4 readiness gates)\n      - gap          = run_rate - backlog\n\n    Parameter:\n      - trailing_weeks (int, default 12)\n\n    Optional filters:\n      - rgn_region, m_area, m_market, construction_gc, pj_program_name, pj_project_type\n    """\n\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    trailing_weeks = filters.get("trailing_weeks", 12)\n    try:\n        trailing_weeks = int(trailing_weeks)\n    except Exception:\n        trailing_weeks = 12\n    if trailing_weeks <= 0:\n        trailing_weeks = 12\n\n    # Always-true seed so WHERE is always present\n    where_parts = ["1=1"]\n    if filters.get("rgn_region") is not None:\n        where_parts.append(f"rgn_region = \'{esc(filters[\'rgn_region\'])}\'")\n    if filters.get("m_area") is not None:\n        where_parts.append(f"m_area = \'{esc(filters[\'m_area\'])}\'")\n    if filters.get("m_market") is not None:\n        where_parts.append(f"m_market = \'{esc(filters[\'m_market\'])}\'")\n    if filters.get("construction_gc") is not None:\n        where_parts.append(f"construction_gc = \'{esc(filters[\'construction_gc\'])}\'")\n    if filters.get("pj_program_name") is not None:\n        where_parts.append(f"pj_program_name = \'{esc(filters[\'pj_program_name\'])}\'")\n    if filters.get("pj_project_type") is not None:\n        where_parts.append(f"pj_project_type = \'{esc(filters[\'pj_project_type\'])}\'")\n\n    where_sql = "WHERE " + " AND ".join(where_parts)\n\n    completed_col = \'"ms_1555_construction_complete_actual"\'\n    started_col = \'"ms_1550_construction_start_actual"\'\n\n    readiness_expr = """\n    (\n      ("ms_1507_tower_ntp_approved_actual" IS NOT NULL\n         OR "pj_a_4100_construction_ntp_accepted_by_gc_finish" IS NOT NULL)\n      AND "pj_a_3925_msl_pickup_date_finish" IS NOT NULL\n      AND "pj_a_4525_power_ready_finish" IS NOT NULL\n      AND ("pj_a_4925_aav_fiber_ready_finish" IS NOT NULL\n         OR "pj_a_4425_mw_installation_complete_finish" IS NOT NULL)\n    )\n    """\n\n    days = trailing_weeks * 7\n\n    sql = f"""\n    SELECT\n      g.rgn_region,\n      g.m_area,\n      g.m_market,\n      g.construction_gc,\n      COALESCE(r.completed_nw, 0)::numeric / {trailing_weeks}::numeric AS run_rate,\n      COALESCE(b.ready_not_started, 0) AS backlog,\n      (COALESCE(r.completed_nw, 0)::numeric / {trailing_weeks}::numeric) - COALESCE(b.ready_not_started, 0) AS gap,\n      {trailing_weeks}::int AS trailing_weeks\n    FROM (\n      SELECT DISTINCT rgn_region, m_area, m_market, construction_gc\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\n      {where_sql}\n        AND construction_gc IS NOT NULL\n        AND m_market IS NOT NULL\n    ) g\n    LEFT JOIN (\n      SELECT\n        rgn_region,\n        m_area,\n        m_market,\n        construction_gc,\n        COUNT(DISTINCT pj_project_id) AS completed_nw\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\n      {where_sql}\n        AND {completed_col} IS NOT NULL\n        AND {completed_col}::timestamp >= (CURRENT_DATE - ({days} * INTERVAL \'1 day\'))\n        AND {completed_col}::timestamp < (CURRENT_DATE + INTERVAL \'1 day\')\n      GROUP BY 1,2,3,4\n    ) r\n      ON r.rgn_region = g.rgn_region\n     AND r.m_area = g.m_area\n     AND r.m_market = g.m_market\n     AND r.construction_gc = g.construction_gc\n    LEFT JOIN (\n      SELECT\n        rgn_region,\n        m_area,\n        m_market,\n        construction_gc,\n        COUNT(DISTINCT pj_project_id) AS ready_not_started\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\n      {where_sql}\n        AND {started_col} IS NULL\n        AND {readiness_expr}\n      GROUP BY 1,2,3,4\n    ) b\n      ON b.rgn_region = g.rgn_region\n     AND b.m_area = g.m_area\n     AND b.m_market = g.m_market\n     AND b.construction_gc = g.construction_gc\n    ORDER BY g.rgn_region, g.m_area, g.m_market, g.construction_gc\n    ;\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_id', 'pj_program_name', 'pj_project_type', 'ms_1555_construction_complete_actual', 'ms_1550_construction_start_actual', 'ms_1507_tower_ntp_approved_actual', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_a_3925_msl_pickup_date_finish', 'pj_a_4525_power_ready_finish', 'pj_a_4925_aav_fiber_ready_finish', 'pj_a_4425_mw_installation_complete_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Capacity vs Demand Gap', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'ea9583cb-1701-45ef-a2db-5cc07b01948c', entity_type: 'kpi', kpi_name: 'Capacity vs Demand Gap', name: 'ea9583cb-1701-45ef-a2db-5cc07b01948c', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Measures the execution capacity versus near-term demand by comparing observed weekly delivery capacity to the count of ready-but-not-started sites for each Market and General Contractor, anchored to the current date. Positive values indicate implied spare capacity, while negative values indicate backlog pressure.', status: 'mentioned', node_id: 'ea9583cb-1701-45ef-a2db-5cc07b01948c'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'For projects with pj_project_status=\'Active\' AND ms_1550_construction_start_actual IS NULL, compute five boolean blockers from milestone NULL checks, then aggregate COUNT(DISTINCT pj_project_id) by (rgn_region, m_area, m_market) [optional + construction_gc] into total_pipeline, fully_ready (0 blockers), each blocked_by_* (blocker true), and blocked_multi (>=2 blockers).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region for aggregation."}, {"column": "m_area", "type": "string", "description": "Area for aggregation."}, {"column": "m_market", "type": "string", "description": "Market for aggregation."}, {"column": "construction_gc", "type": "string", "description": "General contractor (present only when optional grouping by GC is enabled)."}, {"column": "total_pipeline", "type": "int", "description": "Count of distinct active projects that have not started construction."}, {"column": "fully_ready", "type": "int", "description": "Count of distinct projects with none of the five blockers present."}, {"column": "blocked_by_ntp", "type": "int", "description": "Count of distinct projects blocked due to missing NTP approvals/acceptance per definition."}, {"column": "blocked_by_material", "type": "int", "description": "Count of distinct projects blocked due to missing material pickup milestone."}, {"column": "blocked_by_power", "type": "int", "description": "Count of distinct projects blocked due to missing power-ready milestone."}, {"column": "blocked_by_backhaul", "type": "int", "description": "Count of distinct projects blocked due to missing both fiber-ready and MW-install-complete milestones."}, {"column": "blocked_by_access", "type": "int", "description": "Count of distinct projects blocked due to missing pre-construction walk completion milestone."}, {"column": "blocked_multi", "type": "int", "description": "Count of distinct projects with two or more blockers simultaneously."}]', kpi_business_logic: '1) Select population where pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL.\n2) For each distinct pj_project_id, derive blockers:\n   - blocked_ntp = (ms_1507_tower_ntp_approved_actual IS NULL) AND (pj_a_4100_construction_ntp_accepted_by_gc_finish IS NULL)\n   - blocked_material = (pj_a_3925_msl_pickup_date_finish IS NULL)\n   - blocked_power = (pj_a_4525_power_ready_finish IS NULL)\n   - blocked_backhaul = (pj_a_4925_aav_fiber_ready_finish IS NULL) AND (pj_a_4425_mw_installation_complete_finish IS NULL)  # cleared if either is present\n   - blocked_access = (pj_a_3825_pre_construction_walk_complete_finish IS NULL)\n3) Compute blocker_count = number of true blockers among the five.\n4) Group by rgn_region, m_area, m_market (optionally also construction_gc):\n   - total_pipeline = COUNT(DISTINCT pj_project_id)\n   - fully_ready = COUNT(DISTINCT pj_project_id) where blocker_count = 0\n   - blocked_by_ntp/material/power/backhaul/access = COUNT(DISTINCT pj_project_id) where corresponding blocker is true\n   - blocked_multi = COUNT(DISTINCT pj_project_id) where blocker_count >= 2.', kpi_filters: '[{"name": "pj_project_status", "type": "string", "description": "Limits population to active projects (pj_project_status = \'Active\')."}, {"name": "ms_1550_construction_start_actual", "type": "date", "description": "Limits population to projects that have not started construction yet (ms_1550_construction_start_actual IS NULL)."}, {"name": "rgn_region", "type": "string", "description": "Optional filter to restrict results to a specific region."}, {"name": "m_area", "type": "string", "description": "Optional filter to restrict results to a specific area."}, {"name": "m_market", "type": "string", "description": "Optional filter to restrict results to a specific market."}, {"name": "construction_gc", "type": "string", "description": "Optional filter for drill-down to a specific general contractor."}, {"name": "pj_project_id", "type": "string", "description": "Optional filter to restrict results to a specific project."}, {"name": "pj_program_name", "type": "string", "description": "Optional filter to restrict results to a specific program name."}, {"name": "pj_project_type", "type": "string", "description": "Optional filter to restrict results to a specific project type."}, {"name": "group_by_gc", "type": "string", "description": "Optional flag to add construction_gc as a secondary grouping dimension."}]', kpi_contract: '{"function_name": "get_site_blocker_analysis", "node_type": "kpi", "node_id": "df549b33-4d47-4927-9a25-1c9b61911c90", "node_label": "Site Blocker Analysis", "description": "Market-level breakdown of prerequisite blockers for active projects that have not started construction yet. Population: projects where pj_project_status = \'Active\' AND ms_1550_construction_start_actual IS NULL in stg_ndpd_mbt_tmobile_macro_combined. For each project, compute boolean gate blockers: blocked_ntp = (ms_1507_tower_ntp_approved_actual IS NULL AND pj_a_4100_construction_ntp_accepted_by_gc_finish IS NULL); blocked_material = (\\"pj_a_3925_msl_pickup_date_finish\\" IS NULL); blocked_power = (pj_a_4525_power_ready_finish IS NULL); blocked_backhaul = (pj_a_4925_aav_fiber_ready_finish IS NULL AND pj_a_4425_mw_installation_complete_finish IS NULL) meaning either fiber-ready OR MW-complete clears backhaul; blocked_access = (pj_a_3825_pre_construction_walk_complete_finish IS NULL). Aggregate by (rgn_region, m_area, m_market): total_pipeline = COUNT(DISTINCT pj_project_id) over population; fully_ready = count where none of the 5 blockers are true; blocked_by_ntp/material/power/backhaul/access = counts where respective blocker is true; blocked_multi = count where two or more blockers are simultaneously true (sum of boolean flags >= 2). Output is a scorecard table per region/area/market. Optional enhancement: allow filtering or secondary grouping by construction_gc for drill-down, without changing the base market-level KPI.", "parameters": [{"name": "group_by_gc", "type": "string", "description": "Filter by group by gc", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "total_pipeline", "type": "number", "nullable": false}, {"name": "fully_ready", "type": "number", "nullable": false}, {"name": "blocked_by_ntp", "type": "number", "nullable": false}, {"name": "blocked_by_material", "type": "number", "nullable": false}, {"name": "blocked_by_power", "type": "number", "nullable": false}, {"name": "blocked_by_backhaul", "type": "number", "nullable": false}, {"name": "blocked_by_access", "type": "number", "nullable": false}, {"name": "blocked_multi", "type": "number", "nullable": false}], "sample_output": [{"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CHICAGO", "total_pipeline": 2, "fully_ready": 0, "blocked_by_ntp": 1, "blocked_by_material": 1, "blocked_by_power": 1, "blocked_by_backhaul": 2, "blocked_by_access": 0, "blocked_multi": 1}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CINCINNATI", "total_pipeline": 3, "fully_ready": 0, "blocked_by_ntp": 2, "blocked_by_material": 2, "blocked_by_power": 3, "blocked_by_backhaul": 3, "blocked_by_access": 2, "blocked_multi": 3}, {"rgn_region": "CENTRAL", "m_area": "GREAT LAKES", "m_market": "CLEVELAND", "total_pipeline": 3, "fully_ready": 0, "blocked_by_ntp": 1, "blocked_by_material": 1, "blocked_by_power": 3, "blocked_by_backhaul": 1, "blocked_by_access": 2, "blocked_multi": 2}], "row_count": 10}', nl_description: 'KPI = for projects with pj_project_status=\'Active\' and ms_1550_construction_start_actual IS NULL, compute five boolean blockers (NTP, material, power, backhaul, access) from milestone-null conditions per project, then aggregate distinct pj_project_id counts by (rgn_region, m_area, m_market) [optionally + construction_gc] into total_pipeline, fully_ready (no blockers), each blocked_by_* count, and blocked_multi (>=2 blockers).', node_type: 'CORE', definition: 'KPI = for projects with pj_project_status=\'Active\' and ms_1550_construction_start_actual IS NULL, compute five boolean blockers (NTP, material, power, backhaul, access) from milestone-null conditions per project, then aggregate distinct pj_project_id counts by (rgn_region, m_area, m_market) [optionally + construction_gc] into total_pipeline, fully_ready (no blockers), each blocked_by_* count, and blocked_multi (>=2 blockers).', kpi_python_function: 'def get_site_blocker_analysis(execute_query, filters=None) -> list[dict]:\n    """Market-level breakdown of prerequisite blockers for active projects not started.\n\n    Population:\n      pj_project_status = \'Active\'\n      AND ms_1550_construction_start_actual IS NULL\n\n    Optional enhancement:\n      If filters contains \'group_by_gc\': truthy, include construction_gc in grouping.\n      You can also filter by construction_gc / rgn_region / m_area / m_market via filters.\n    """\n\n    filters = filters or {}\n\n    # Build SQL WHERE clause (PostgreSQL)\n    where_parts = [\n        "pj_project_status = \'Active\'",\n        "ms_1550_construction_start_actual IS NULL"\n    ]\n\n    # Allow common dimension filters (and passthrough of any additional column filters)\n    passthrough_keys = [\n        \'rgn_region\', \'m_area\', \'m_market\',\n        \'construction_gc\', \'pj_project_id\',\n        \'pj_program_name\', \'pj_project_type\'\n    ]\n\n    for k in passthrough_keys:\n        if k in filters and filters.get(k) is not None and filters.get(k) != \'\':\n            v = str(filters.get(k)).replace("\'", "\'\'")\n            where_parts.append(f"{k} = \'{v}\'")\n\n    # NOTE: No date filter is applied because the KPI definition is point-in-time and\n    # milestone fields are nullable timestamps rather than event records.\n\n    where_sql = " AND ".join(where_parts)\n\n    group_by_gc = bool(filters.get(\'group_by_gc\'))\n\n    group_cols = ["rgn_region", "m_area", "m_market"]\n    if group_by_gc:\n        group_cols.append("construction_gc")\n\n    select_group_cols = ",\\n            ".join(group_cols)\n    group_by_sql = ", ".join(group_cols)\n\n    # Raw SQL is required because Tier-1 accessors do not expose the milestone columns needed.\n    sql = f"""\n        SELECT\n            {select_group_cols},\n            pj_project_id,\n            ms_1550_construction_start_actual,\n            ms_1507_tower_ntp_approved_actual,\n            pj_a_4100_construction_ntp_accepted_by_gc_finish,\n            "pj_a_3925_msl_pickup_date_finish",\n            pj_a_4525_power_ready_finish,\n            pj_a_4925_aav_fiber_ready_finish,\n            pj_a_4425_mw_installation_complete_finish,\n            pj_a_3825_pre_construction_walk_complete_finish\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        WHERE {where_sql}\n    """\n\n    rows = execute_query(sql)\n\n    def is_null(x):\n        # Treat None and empty-string as null-like; do NOT treat \'0\' as null.\n        return x is None or (isinstance(x, str) and x.strip() == \'\')\n\n    # Aggregate per group key with DISTINCT project ids\n    agg = {}\n\n    for r in rows:\n        key_vals = []\n        for c in group_cols:\n            key_vals.append(r.get(c))\n        key = tuple(key_vals)\n\n        if key not in agg:\n            agg[key] = {\n                "rgn_region": r.get("rgn_region"),\n                "m_area": r.get("m_area"),\n                "m_market": r.get("m_market"),\n                **({"construction_gc": r.get("construction_gc")} if group_by_gc else {}),\n                "_projects": set(),\n                "total_pipeline": 0,\n                "fully_ready": 0,\n                "blocked_by_ntp": 0,\n                "blocked_by_material": 0,\n                "blocked_by_power": 0,\n                "blocked_by_backhaul": 0,\n                "blocked_by_access": 0,\n                "blocked_multi": 0\n            }\n\n        project_id = r.get("pj_project_id")\n        if project_id in agg[key]["_projects"]:\n            continue\n        agg[key]["_projects"].add(project_id)\n\n        blocked_ntp = is_null(r.get("ms_1507_tower_ntp_approved_actual")) and is_null(r.get("pj_a_4100_construction_ntp_accepted_by_gc_finish"))\n        blocked_material = is_null(r.get("pj_a_3925_msl_pickup_date_finish"))\n        blocked_power = is_null(r.get("pj_a_4525_power_ready_finish"))\n        # Backhaul is cleared if either fiber-ready OR MW-complete is present\n        blocked_backhaul = is_null(r.get("pj_a_4925_aav_fiber_ready_finish")) and is_null(r.get("pj_a_4425_mw_installation_complete_finish"))\n        blocked_access = is_null(r.get("pj_a_3825_pre_construction_walk_complete_finish"))\n\n        blockers = [blocked_ntp, blocked_material, blocked_power, blocked_backhaul, blocked_access]\n        blocker_count = sum(1 for b in blockers if b)\n\n        agg[key]["total_pipeline"] += 1\n        if blocker_count == 0:\n            agg[key]["fully_ready"] += 1\n        if blocked_ntp:\n            agg[key]["blocked_by_ntp"] += 1\n        if blocked_material:\n            agg[key]["blocked_by_material"] += 1\n        if blocked_power:\n            agg[key]["blocked_by_power"] += 1\n        if blocked_backhaul:\n            agg[key]["blocked_by_backhaul"] += 1\n        if blocked_access:\n            agg[key]["blocked_by_access"] += 1\n        if blocker_count >= 2:\n            agg[key]["blocked_multi"] += 1\n\n    # finalize\n    out = []\n    for k, v in agg.items():\n        v.pop("_projects", None)\n        out.append(v)\n\n    # Stable ordering\n    def sort_key(d):\n        base = (\n            str(d.get(\'rgn_region\') or \'\'),\n            str(d.get(\'m_area\') or \'\'),\n            str(d.get(\'m_market\') or \'\')\n        )\n        if group_by_gc:\n            base = base + (str(d.get(\'construction_gc\') or \'\'),)\n        return base\n\n    out.sort(key=sort_key)\n    return out\n', kpi_source_columns: ['pj_project_status', 'ms_1550_construction_start_actual', 'pj_project_id', 'ms_1507_tower_ntp_approved_actual', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_a_3925_msl_pickup_date_finish', 'pj_a_4525_power_ready_finish', 'pj_a_4925_aav_fiber_ready_finish', 'pj_a_4425_mw_installation_complete_finish', 'pj_a_3825_pre_construction_walk_complete_finish', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_program_name', 'pj_project_type'], session_id: '69a3d22f26e208edc083a06e', label: 'Site Blocker Analysis', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: 'df549b33-4d47-4927-9a25-1c9b61911c90', entity_type: 'kpi', kpi_name: 'Site Blocker Analysis', name: 'df549b33-4d47-4927-9a25-1c9b61911c90', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Market-level breakdown of prerequisite blockers preventing active projects from starting construction. It quantifies how many not-yet-started active projects are ready versus blocked by key prerequisites, supporting prioritization and unblock efforts by market.', status: 'mentioned', node_id: 'df549b33-4d47-4927-9a25-1c9b61911c90'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_rejection_data_last_30_days', 'public.stg_nas_session_level_combined_data'], nl_business_rule: '', kpi_formula_description: 'checkout_rejection_rate_pct = (COUNT(DISTINCT rejected checkout sessions) / COUNT(DISTINCT sessions that reached checkout gate)) * 100; also produces distinct-session counts by check-in and check-out rejection reason.', kpi_output_schema: '[{"column": "result_set", "type": "string", "description": "Discriminator for which result set the row belongs to: \'A\' (rate scorecard) or \'B\' (reason breakdown)."}, {"column": "nas_rej_region", "type": "string", "description": "Rejection region."}, {"column": "nas_rej_market", "type": "string", "description": "Rejection market (also used to align/join to session market)."}, {"column": "checkout_rejection_count", "type": "int", "description": "Distinct rejected sessions with a non-null checkout rejection reason (Result set A only)."}, {"column": "checkin_rejection_count", "type": "int", "description": "Distinct rejected sessions with a non-null check-in rejection reason (Result set A only)."}, {"column": "total_rejection_sessions", "type": "int", "description": "Distinct rejected sessions in the filtered rejection dataset (Result set A only)."}, {"column": "total_completed_sessions", "type": "int", "description": "Distinct sessions that reached checkout gate in the filtered session dataset (Result set A only)."}, {"column": "checkout_rejection_rate_pct", "type": "float", "description": "Checkout rejection percentage = checkout_rejection_count / total_completed_sessions * 100; NULL when total_completed_sessions = 0 (Result set A only)."}, {"column": "reason_type", "type": "string", "description": "Reason category: \'checkin\' or \'checkout\' (Result set B only)."}, {"column": "reason_value", "type": "string", "description": "Rejection reason value from the corresponding reason column (Result set B only)."}, {"column": "reason_count", "type": "int", "description": "Distinct rejected sessions for the given reason (Result set B only)."}]', kpi_business_logic: '1) (Optional) Apply date range filters.\n2) From stg_nas_rejection_data_last_30_days, filter by nas_rej_rejection_time within the date range; group by nas_rej_region, nas_rej_market.\n3) Compute: checkout_rejection_count = COUNT(DISTINCT nas_rej_sessionid) where nas_rej_checkout_reject_reason IS NOT NULL; checkin_rejection_count = COUNT(DISTINCT nas_rej_sessionid) where nas_rej_checkin_reject_reason IS NOT NULL; total_rejection_sessions = COUNT(DISTINCT nas_rej_sessionid).\n4) Build denominator from stg_nas_session_level_combined_data: keep sessions that reached checkout gate (nas_checkout_approve_time IS NOT NULL OR nas_checkout_reject_time IS NOT NULL) and whose COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) is within the same date range; group by nas_market (treated as nas_rej_market) and compute total_completed_sessions = COUNT(DISTINCT nas_session_id).\n5) Left join numerator to denominator on nas_rej_market.\n6) Compute checkout_rejection_rate_pct = (checkout_rejection_count / total_completed_sessions) * 100; if total_completed_sessions = 0 return NULL.\n7) Reason breakdown: using the same rejection-table date filter, emit rows grouped by nas_rej_region, nas_rej_market, reason_type, reason_value where reason_type is \'checkin\' with reason_value = nas_rej_checkin_reject_reason (non-null) and \'checkout\' with reason_value = nas_rej_checkout_reject_reason (non-null); reason_count = COUNT(DISTINCT nas_rej_sessionid).', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Lower bound (inclusive) for filtering nas_rej_rejection_time in the rejection table and COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) in the session table."}, {"name": "end_date", "type": "date", "description": "Upper bound (exclusive) for filtering nas_rej_rejection_time in the rejection table and COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) in the session table."}, {"name": "nas_rej_*", "type": "string", "description": "Optional drill-down equality filters applied to the rejection table (any filter key starting with \'nas_rej_\')."}, {"name": "session_table_*", "type": "string", "description": "Optional drill-down equality filters applied to the session table for non-\'nas_rej_\' keys (e.g., nas_session_id, nas_market)."}]', kpi_contract: '{"function_name": "get_nas_checkout_rejection", "node_type": "kpi", "node_id": "41414556-b0ca-4b2c-8acd-4214a700b491", "node_label": "NAS Checkout Rejection", "description": "Measures NAS session rejection and rework signals by market/region, including checkout-gate rejection rate and rejection reason breakdown. Use `stg_nas_rejection_data_last_30_days` (rejections) joined to `stg_nas_session_level_combined_data` (session denominator) on `nas_rej_sessionid = nas_session_id`. Accept optional date range parameters `(start_date, end_date)`.\\n\\nResult set A \\u2014 Rate scorecard (one row per `nas_rej_region, nas_rej_market`):\\n- Population: rows from `stg_nas_rejection_data_last_30_days` where `nas_rej_rejection_time` is within the optional date range.\\n- `checkout_rejection_count`: COUNT(DISTINCT nas_rej_sessionid) FILTER (WHERE nas_rej_checkout_reject_reason IS NOT NULL).\\n- `checkin_rejection_count`: COUNT(DISTINCT nas_rej_sessionid) FILTER (WHERE nas_rej_checkin_reject_reason IS NOT NULL).\\n- `total_rejection_sessions`: COUNT(DISTINCT nas_rej_sessionid) over the filtered rejection dataset.\\n- Denominator population: `stg_nas_session_level_combined_data` rows where the session reached checkout gate, defined as `(nas_checkout_approve_time IS NOT NULL OR nas_checkout_reject_time IS NOT NULL)` AND `COALESCE(nas_checkout_approve_time, nas_checkout_reject_time)` falls within the same optional date range.\\n- `total_completed_sessions`: COUNT(DISTINCT nas_session_id) over the filtered denominator population, grouped by the session market mapped to rejection market (use `nas_market` for grouping, aligned to `nas_rej_market`).\\n- `checkout_rejection_rate_pct`: `checkout_rejection_count / total_completed_sessions * 100`, with divide-by-zero protection (return NULL when `total_completed_sessions = 0`).\\n\\nResult set B \\u2014 Reason breakdown (one row per `nas_rej_region, nas_rej_market, reason_type, reason_value`):\\n- Filter by the same optional date range on `nas_rej_rejection_time`.\\n- Emit one row for each distinct reason value with counts:\\n  - For check-in: `reason_type=\'checkin\'`, `reason_value=nas_rej_checkin_reject_reason`, `reason_count=COUNT(DISTINCT nas_rej_sessionid)` (or COUNT(*) if you prefer event-count; default is distinct sessions).\\n  - For check-out: `reason_type=\'checkout\'`, `reason_value=nas_rej_checkout_reject_reason`, `reason_count=COUNT(DISTINCT nas_rej_sessionid)`.\\n\\nDefault behavior when no date parameters are supplied: compute over all available data in both tables. Supports drill-down by adding optional dimensions (e.g., `nas_rej_userid`, `nas_rej_siteid`) without changing core definitions.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "result_set", "type": "string", "nullable": false}, {"name": "nas_rej_region", "type": "string", "nullable": false}, {"name": "nas_rej_market", "type": "string", "nullable": false}, {"name": "checkout_rejection_count", "type": "number", "nullable": false}, {"name": "checkin_rejection_count", "type": "number", "nullable": false}, {"name": "total_rejection_sessions", "type": "number", "nullable": false}, {"name": "total_completed_sessions", "type": "number", "nullable": false}, {"name": "checkout_rejection_rate_pct", "type": "string", "nullable": false}, {"name": "reason_type", "type": "null", "nullable": true}, {"name": "reason_value", "type": "null", "nullable": true}, {"name": "reason_count", "type": "null", "nullable": true}], "sample_output": [{"result_set": "A", "nas_rej_region": "Central", "nas_rej_market": "Chicago", "checkout_rejection_count": 15, "checkin_rejection_count": 8, "total_rejection_sessions": 19, "total_completed_sessions": 15, "checkout_rejection_rate_pct": "100.00000000000000000000", "reason_type": null, "reason_value": null, "reason_count": null}, {"result_set": "A", "nas_rej_region": "Central", "nas_rej_market": "Cincinnati", "checkout_rejection_count": 13, "checkin_rejection_count": 12, "total_rejection_sessions": 19, "total_completed_sessions": 15, "checkout_rejection_rate_pct": "86.66666666666666666700", "reason_type": null, "reason_value": null, "reason_count": null}, {"result_set": "A", "nas_rej_region": "Central", "nas_rej_market": "Cleveland", "checkout_rejection_count": 16, "checkin_rejection_count": 15, "total_rejection_sessions": 19, "total_completed_sessions": 17, "checkout_rejection_rate_pct": "94.11764705882352941200", "reason_type": null, "reason_value": null, "reason_count": null}], "row_count": 10}', nl_description: 'KPI = f(Integration Activity sessions, NAS rejection events) where checkout rejection rate by (nas_rej_region, nas_rej_market) equals distinct rejected checkout sessions in stg_nas_rejection_data_last_30_days divided by distinct sessions that reached checkout gate in stg_nas_session_level_combined_data (date-aligned), multiplied by 100, plus reason-level distinct-session counts for check-in and check-out rejection reasons.', node_type: 'CORE', definition: 'KPI = f(Integration Activity sessions, NAS rejection events) where checkout rejection rate by (nas_rej_region, nas_rej_market) equals distinct rejected checkout sessions in stg_nas_rejection_data_last_30_days divided by distinct sessions that reached checkout gate in stg_nas_session_level_combined_data (date-aligned), multiplied by 100, plus reason-level distinct-session counts for check-in and check-out rejection reasons.', kpi_python_function: 'def get_nas_checkout_rejection(execute_query, filters=None) -> list[dict]:\n    """NAS Checkout Rejection KPI.\n\n    Returns a single list containing BOTH result sets with a discriminator column:\n      - result_set = \'A\' (rate scorecard)\n      - result_set = \'B\' (reason breakdown)\n\n    Notes:\n      - Uses raw SQL because the rejection table is not exposed as a Tier-1 core node accessor.\n      - Uses plain SELECT statements with inline subqueries (no CTE/WITH) because the runtime\n        rejects non-SELECT syntax.\n      - Supports optional filters: start_date, end_date, plus optional drilldown fields such as\n        nas_rej_region, nas_rej_market, nas_rej_userid, nas_rej_siteid, nas_session_id, nas_market, etc.\n    """\n\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    start_date = filters.get(\'start_date\')\n    end_date = filters.get(\'end_date\')\n\n    # Split filters into: rejection-table filters vs session-table filters.\n    # Convention: anything starting with \'nas_rej_\' applies to rejection table.\n    # IMPORTANT: do NOT prefix with table aliases (r./s.) because queries use inline subqueries.\n    rej_filter_parts = []\n    sess_filter_parts = []\n\n    for k, v in filters.items():\n        if v is None:\n            continue\n        if k in (\'start_date\', \'end_date\'):\n            continue\n        # Basic allowlist-ish behavior: only simple equality predicates; callers can pass known columns.\n        if k.startswith(\'nas_rej_\'):\n            rej_filter_parts.append(f"{k} = \'{esc(v)}\'")\n        else:\n            sess_filter_parts.append(f"{k} = \'{esc(v)}\'")\n\n    # Date predicates\n    rej_date_pred = "TRUE"\n    if start_date and end_date:\n        rej_date_pred = (\n            f"nas_rej_rejection_time >= \'{esc(start_date)}\' "\n            f"AND nas_rej_rejection_time < \'{esc(end_date)}\'"\n        )\n    elif start_date:\n        rej_date_pred = f"nas_rej_rejection_time >= \'{esc(start_date)}\'"\n    elif end_date:\n        rej_date_pred = f"nas_rej_rejection_time < \'{esc(end_date)}\'"\n\n    denom_date_pred = "TRUE"\n    # denominator time uses COALESCE(approve, reject)\n    if start_date and end_date:\n        denom_date_pred = (\n            f"COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) >= \'{esc(start_date)}\' "\n            f"AND COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) < \'{esc(end_date)}\'"\n        )\n    elif start_date:\n        denom_date_pred = f"COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) >= \'{esc(start_date)}\'"\n    elif end_date:\n        denom_date_pred = f"COALESCE(nas_checkout_approve_time, nas_checkout_reject_time) < \'{esc(end_date)}\'"\n\n    rej_extra_pred = " AND ".join(rej_filter_parts) if rej_filter_parts else "TRUE"\n    sess_extra_pred = " AND ".join(sess_filter_parts) if sess_filter_parts else "TRUE"\n\n    sql_a = f"""\n    SELECT\n      \'A\'::text AS result_set,\n      ra.nas_rej_region,\n      ra.nas_rej_market,\n      ra.checkout_rejection_count,\n      ra.checkin_rejection_count,\n      ra.total_rejection_sessions,\n      COALESCE(da.total_completed_sessions, 0) AS total_completed_sessions,\n      CASE\n        WHEN COALESCE(da.total_completed_sessions, 0) = 0 THEN NULL\n        ELSE (ra.checkout_rejection_count::numeric / da.total_completed_sessions::numeric) * 100\n      END AS checkout_rejection_rate_pct,\n      NULL::text AS reason_type,\n      NULL::text AS reason_value,\n      NULL::bigint AS reason_count\n    FROM (\n      SELECT\n        nas_rej_region,\n        nas_rej_market,\n        COUNT(DISTINCT nas_rej_sessionid) FILTER (WHERE nas_rej_checkout_reject_reason IS NOT NULL) AS checkout_rejection_count,\n        COUNT(DISTINCT nas_rej_sessionid) FILTER (WHERE nas_rej_checkin_reject_reason IS NOT NULL) AS checkin_rejection_count,\n        COUNT(DISTINCT nas_rej_sessionid) AS total_rejection_sessions\n      FROM public.stg_nas_rejection_data_last_30_days\n      WHERE {rej_date_pred}\n        AND ({rej_extra_pred})\n      GROUP BY 1, 2\n    ) ra\n    LEFT JOIN (\n      SELECT\n        nas_market AS nas_rej_market,\n        COUNT(DISTINCT nas_session_id) AS total_completed_sessions\n      FROM public.stg_nas_session_level_combined_data\n      WHERE (nas_checkout_approve_time IS NOT NULL OR nas_checkout_reject_time IS NOT NULL)\n        AND {denom_date_pred}\n        AND ({sess_extra_pred})\n      GROUP BY 1\n    ) da\n      ON da.nas_rej_market = ra.nas_rej_market\n    """\n\n    sql_b = f"""\n    SELECT\n      \'B\'::text AS result_set,\n      x.nas_rej_region,\n      x.nas_rej_market,\n      NULL::bigint AS checkout_rejection_count,\n      NULL::bigint AS checkin_rejection_count,\n      NULL::bigint AS total_rejection_sessions,\n      NULL::bigint AS total_completed_sessions,\n      NULL::numeric AS checkout_rejection_rate_pct,\n      x.reason_type,\n      x.reason_value,\n      x.reason_count\n    FROM (\n      SELECT\n        nas_rej_region,\n        nas_rej_market,\n        \'checkin\'::text AS reason_type,\n        nas_rej_checkin_reject_reason::text AS reason_value,\n        COUNT(DISTINCT nas_rej_sessionid) AS reason_count\n      FROM public.stg_nas_rejection_data_last_30_days\n      WHERE {rej_date_pred}\n        AND ({rej_extra_pred})\n        AND nas_rej_checkin_reject_reason IS NOT NULL\n      GROUP BY 1, 2, 3, 4\n\n      UNION ALL\n\n      SELECT\n        nas_rej_region,\n        nas_rej_market,\n        \'checkout\'::text AS reason_type,\n        nas_rej_checkout_reject_reason::text AS reason_value,\n        COUNT(DISTINCT nas_rej_sessionid) AS reason_count\n      FROM public.stg_nas_rejection_data_last_30_days\n      WHERE {rej_date_pred}\n        AND ({rej_extra_pred})\n        AND nas_rej_checkout_reject_reason IS NOT NULL\n      GROUP BY 1, 2, 3, 4\n    ) x\n    """\n\n    rows_a = execute_query(sql_a)\n    rows_b = execute_query(sql_b)\n\n    # Return combined result for callers; they can split by result_set.\n    return (rows_a or []) + (rows_b or [])\n', kpi_source_columns: ['nas_rej_sessionid', 'nas_session_id', 'nas_rej_rejection_time', 'nas_rej_region', 'nas_rej_market', 'nas_rej_checkout_reject_reason', 'nas_rej_checkin_reject_reason', 'nas_checkout_approve_time', 'nas_checkout_reject_time', 'nas_market', 'nas_rej_userid', 'nas_rej_siteid'], session_id: '69a3d22f26e208edc083a06e', label: 'NAS Checkout Rejection', kpi_related_core_node_ids: ['integration_activity', 'nas_rejection'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '41414556-b0ca-4b2c-8acd-4214a700b491', entity_type: 'kpi', kpi_name: 'NAS Checkout Rejection', name: '41414556-b0ca-4b2c-8acd-4214a700b491', kpi_dimensions: ['nas_rej_region', 'nas_rej_market', 'reason_type', 'reason_value'], kpi_description: 'Measures NAS session rejection and rework signals by market/region, including the checkout-gate rejection rate and a breakdown of rejection reasons. This helps understand how often sessions are rejected at checkout and why, enabling monitoring and drill-down by geography and other attributes.', status: 'mentioned', node_id: '41414556-b0ca-4b2c-8acd-4214a700b491'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_session_level_combined_data', 'stg_nas_e2e_call_test_completion'], nl_business_rule: '', kpi_formula_description: 'revisit_rate_pct = 100.0 * revisit_sites / NULLIF(sites_with_sessions, 0), where revisit_sites are distinct sites with session_count > 2 (default threshold) and sites_with_sessions are distinct sites with >=1 completed session; avg_sessions_per_site = AVG(session_count).', kpi_output_schema: '[{"column": "nas_market", "type": "string", "description": "Market for the rollup."}, {"column": "nas_primary_gc", "type": "string", "description": "Primary GC for the rollup (when rollup_by_company_name is false)."}, {"column": "nas_company_name", "type": "string", "description": "Company name for the rollup (when rollup_by_company_name is true)."}, {"column": "sites_with_sessions", "type": "int", "description": "Distinct count of sites with at least one completed session in the rollup bucket."}, {"column": "revisit_sites", "type": "int", "description": "Distinct count of sites flagged as revisit sites (session_count > threshold) in the rollup bucket."}, {"column": "revisit_rate_pct", "type": "float", "description": "Percent of sites that are revisit sites within the rollup bucket."}, {"column": "avg_sessions_per_site", "type": "float", "description": "Average distinct completed session count per site within the rollup bucket."}, {"column": "revisit_threshold_sessions_gt", "type": "int", "description": "Threshold used to flag revisit sites (site is revisit if session_count > this value)."}]', kpi_business_logic: '1) From stg_nas_session_level_combined_data, keep only completed sessions where nas_checkout_approve_time IS NOT NULL (optionally also filter by date range on nas_checkout_approve_time and/or nas_market/nas_primary_gc/nas_company_name/nas_activity_type/nas_site_id).\n2) At site grain, for each (nas_market, vendor_dim, nas_site_id) compute session_count = COUNT(DISTINCT nas_session_id), where vendor_dim is nas_primary_gc by default or nas_company_name when rolling up by company name.\n3) Flag is_revisit_site = (session_count > revisit_threshold) where revisit_threshold defaults to 2 (i.e., 3+ sessions is a revisit site).\n4) Roll up to (nas_market, vendor_dim):\n   a) sites_with_sessions = COUNT(DISTINCT nas_site_id) across all sites with >=1 completed session.\n   b) revisit_sites = COUNT(DISTINCT nas_site_id) where is_revisit_site = true.\n   c) revisit_rate_pct = 100.0 * revisit_sites / NULLIF(sites_with_sessions, 0).\n   d) avg_sessions_per_site = AVG(session_count) across sites.\n5) (Future optional) Join stg_nas_e2e_call_test_completion on nas_site_id to segment revisit sites by nas_call_test_completion_status and/or compute share of revisit sites with poor call-test outcomes.', kpi_filters: '[{"name": "nas_checkout_approve_time_is_not_null", "type": "date", "description": "Includes only completed sessions (nas_checkout_approve_time IS NOT NULL)."}, {"name": "start_date", "type": "date", "description": "Lower bound filter applied to nas_checkout_approve_time."}, {"name": "end_date", "type": "date", "description": "Upper bound filter applied to nas_checkout_approve_time."}, {"name": "nas_market", "type": "string", "description": "Filters sessions/sites to a specific market."}, {"name": "nas_primary_gc", "type": "string", "description": "Filters sessions/sites to a specific primary GC (when using GC rollup)."}, {"name": "nas_company_name", "type": "string", "description": "Filters sessions/sites to a specific company name (when using company rollup)."}, {"name": "nas_activity_type", "type": "string", "description": "Filters sessions by activity type (e.g., integration-only vs troubleshooting/punch)."}, {"name": "nas_site_id", "type": "string", "description": "Filters to a specific site."}, {"name": "revisit_threshold", "type": "number", "description": "Threshold for revisit flag: is_revisit_site = (session_count > revisit_threshold); default 2."}, {"name": "rollup_by_company_name", "type": "string", "description": "Control parameter (boolean) that switches rollup dimension to (nas_market, nas_company_name) instead of (nas_market, nas_primary_gc)."}]', kpi_contract: '{"function_name": "get_site_revisit_rate", "node_type": "kpi", "node_id": "30e3c50e-a44c-4e27-8153-71741e2507d0", "node_label": "Site Revisit Rate", "description": "Measures post-integration rework by counting how many distinct completed NAS sessions each site required, then rolling up a revisit rate by GC/vendor and market. Data source: `stg_nas_session_level_combined_data`. Step 1 (site grain): filter to completed sessions where `nas_checkout_approve_time IS NOT NULL`; compute `session_count = COUNT(DISTINCT nas_session_id)` grouped by `nas_site_id` plus vendor/market dimensions (default: `nas_market`, `nas_primary_gc`; optionally `nas_company_name`). Define `is_revisit_site = (session_count > 2)` to flag sites requiring 3+ sessions. Step 2 (GC rollup): group by `(nas_market, nas_primary_gc)` (or `(nas_market, nas_company_name)`), compute: (a) `sites_with_sessions = COUNT(DISTINCT nas_site_id)` over all sites with >=1 completed session; (b) `revisit_sites = COUNT(DISTINCT nas_site_id)` where `is_revisit_site=true`; (c) `revisit_rate_pct = 100.0 * revisit_sites / NULLIF(sites_with_sessions,0)`; (d) `avg_sessions_per_site = AVG(session_count)` across sites. Optional parameter/filter: `nas_activity_type` to isolate integration-only vs troubleshooting/punch sessions. Future optional enrichment: join to `stg_nas_e2e_call_test_completion` on `nas_site_id` to segment revisit sites by `nas_call_test_completion_status` (e.g., RED/PARTIAL) and/or compute share of revisit sites with poor call-test outcomes.", "parameters": [{"name": "nas_market", "type": "string", "description": "Filter by nas market", "required": false, "sample_values": []}, {"name": "nas_primary_gc", "type": "string", "description": "Filter by nas primary gc", "required": false, "sample_values": []}, {"name": "nas_company_name", "type": "string", "description": "Filter by nas company name", "required": false, "sample_values": []}, {"name": "nas_activity_type", "type": "string", "description": "Filter by nas activity type", "required": false, "sample_values": []}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas site id", "required": false, "sample_values": []}], "output_columns": [{"name": "nas_market", "type": "string", "nullable": false}, {"name": "nas_primary_gc", "type": "string", "nullable": false}, {"name": "sites_with_sessions", "type": "number", "nullable": false}, {"name": "revisit_sites", "type": "number", "nullable": false}, {"name": "revisit_rate_pct", "type": "number", "nullable": false}, {"name": "avg_sessions_per_site", "type": "number", "nullable": false}, {"name": "revisit_threshold_sessions_gt", "type": "number", "nullable": false}], "sample_output": [{"nas_market": "Albany", "nas_primary_gc": "ADC", "sites_with_sessions": 1, "revisit_sites": 0, "revisit_rate_pct": 0.0, "avg_sessions_per_site": 1.0, "revisit_threshold_sessions_gt": 2}, {"nas_market": "Albany", "nas_primary_gc": "ARM", "sites_with_sessions": 1, "revisit_sites": 0, "revisit_rate_pct": 0.0, "avg_sessions_per_site": 1.0, "revisit_threshold_sessions_gt": 2}, {"nas_market": "Albany", "nas_primary_gc": "CPT", "sites_with_sessions": 3, "revisit_sites": 0, "revisit_rate_pct": 0.0, "avg_sessions_per_site": 1.0, "revisit_threshold_sessions_gt": 2}], "row_count": 10}', nl_description: 'Revisit Rate % = 100 * (count of distinct sites with >2 distinct completed NAS sessions) / (count of distinct sites with ≥1 completed NAS session), rolled up by (nas_market, nas_primary_gc) or (nas_market, nas_company_name), and avg_sessions_per_site is the average distinct completed session count per site.', node_type: 'CORE', definition: 'Revisit Rate % = 100 * (count of distinct sites with >2 distinct completed NAS sessions) / (count of distinct sites with ≥1 completed NAS session), rolled up by (nas_market, nas_primary_gc) or (nas_market, nas_company_name), and avg_sessions_per_site is the average distinct completed session count per site.', kpi_python_function: 'def get_site_revisit_rate(execute_query, filters=None) -> list[dict]:\n    """Site Revisit Rate\n\n    Step 1 (site grain): completed NAS sessions (nas_checkout_approve_time IS NOT NULL), count distinct nas_session_id per site and vendor/market dims.\n    Step 2 (rollup): per (nas_market, nas_primary_gc) or (nas_market, nas_company_name), compute revisit rate where sites with >2 sessions are revisit sites.\n\n    Supported filters (if present):\n      - start_date, end_date: applied to nas_checkout_approve_time (pushed into SQL)\n      - nas_market, nas_primary_gc, nas_company_name, nas_activity_type, nas_site_id\n      - rollup_by_company_name: bool; if truthy, roll up by (nas_market, nas_company_name) instead of (nas_market, nas_primary_gc)\n      - revisit_threshold: int; default 2 (revisit if session_count > threshold)\n\n    Returns list of dict rows at rollup grain.\n    """\n\n    filters = dict(filters or {})\n\n    # Pop control parameters that are not columns\n    rollup_by_company_name = bool(filters.pop(\'rollup_by_company_name\', False))\n    try:\n      revisit_threshold = int(filters.pop(\'revisit_threshold\', 2))\n    except Exception:\n      revisit_threshold = 2\n\n    start_date = filters.pop(\'start_date\', None)\n    end_date = filters.pop(\'end_date\', None)\n\n    def _norm(x):\n      if x is None:\n        return None\n      s = str(x).strip()\n      return s if s != \'\' else None\n\n    # Pull completed sessions from session-level combined table (includes nas_checkout_approve_time)\n    where = ["nas_checkout_approve_time IS NOT NULL"]\n\n    # Optional dimension filters (pushed down to SQL)\n    if filters.get(\'nas_market\') is not None:\n      where.append(f"nas_market = \'{str(filters.get(\'nas_market\')).replace("\'", "\'\'")}\'")\n    if filters.get(\'nas_primary_gc\') is not None:\n      where.append(f"nas_primary_gc = \'{str(filters.get(\'nas_primary_gc\')).replace("\'", "\'\'")}\'")\n    if filters.get(\'nas_company_name\') is not None:\n      where.append(f"nas_company_name = \'{str(filters.get(\'nas_company_name\')).replace("\'", "\'\'")}\'")\n    if filters.get(\'nas_activity_type\') is not None:\n      where.append(f"nas_activity_type = \'{str(filters.get(\'nas_activity_type\')).replace("\'", "\'\'")}\'")\n    if filters.get(\'nas_site_id\') is not None:\n      where.append(f"nas_site_id = \'{str(filters.get(\'nas_site_id\')).replace("\'", "\'\'")}\'")\n\n    # Optional date filters (pushed down to SQL on approve time)\n    # Assumes start_date/end_date are compatible with the warehouse (date or timestamp literal strings).\n    if start_date is not None:\n      where.append(f"nas_checkout_approve_time >= \'{str(start_date).replace("\'", "\'\'")}\'")\n    if end_date is not None:\n      where.append(f"nas_checkout_approve_time <= \'{str(end_date).replace("\'", "\'\'")}\'")\n\n    sql = f"""\nSELECT\n  nas_session_id,\n  nas_site_id,\n  nas_market,\n  nas_primary_gc,\n  nas_company_name,\n  nas_activity_type,\n  nas_checkout_approve_time\nFROM public.stg_nas_session_level_combined_data\nWHERE {\' AND \'.join(where)}\n""".strip()\n\n    rows = execute_query(sql)\n\n    # Step 1: (completion already enforced in SQL) keep Python-side normalization/guardrails\n    filtered = []\n    for r in rows:\n      approve_time = r.get(\'nas_checkout_approve_time\', None)\n      if approve_time is None:\n        continue\n      filtered.append(r)\n\n    # Site-grain aggregation: count distinct sessions per (market, vendor_dim, site)\n    site_sessions = {}  # key: (market, vendor_dim, site_id) -> set(session_id)\n    for r in filtered:\n      market = _norm(r.get(\'nas_market\'))\n      primary_gc = _norm(r.get(\'nas_primary_gc\'))\n      company_name = _norm(r.get(\'nas_company_name\'))\n      site_id = _norm(r.get(\'nas_site_id\'))\n      session_id = _norm(r.get(\'nas_session_id\'))\n\n      if site_id is None or session_id is None:\n        continue\n\n      vendor_dim = company_name if rollup_by_company_name else primary_gc\n\n      # Keep null vendor buckets explicit (so totals reconcile)\n      k = (market, vendor_dim, site_id)\n      if k not in site_sessions:\n        site_sessions[k] = set()\n      site_sessions[k].add(session_id)\n\n    # Step 2: roll up to (market, vendor_dim)\n    rollup = {}\n    # key: (market, vendor_dim) -> {sites:set, revisit_sites:set, session_counts:[...]}\n    for (market, vendor_dim, site_id), sess_set in site_sessions.items():\n      session_count = len(sess_set)\n      is_revisit_site = session_count > revisit_threshold\n\n      rk = (market, vendor_dim)\n      if rk not in rollup:\n        rollup[rk] = {\n          \'sites\': set(),\n          \'revisit_sites\': set(),\n          \'session_counts\': []\n        }\n      rollup[rk][\'sites\'].add(site_id)\n      if is_revisit_site:\n        rollup[rk][\'revisit_sites\'].add(site_id)\n      rollup[rk][\'session_counts\'].append(session_count)\n\n    out = []\n    for (market, vendor_dim), agg in rollup.items():\n      sites_with_sessions = len(agg[\'sites\'])\n      revisit_sites = len(agg[\'revisit_sites\'])\n      revisit_rate_pct = (100.0 * revisit_sites / sites_with_sessions) if sites_with_sessions else None\n      sc = agg[\'session_counts\']\n      avg_sessions_per_site = (sum(sc) / len(sc)) if sc else None\n\n      row = {\n        \'nas_market\': market,\n        (\'nas_company_name\' if rollup_by_company_name else \'nas_primary_gc\'): vendor_dim,\n        \'sites_with_sessions\': sites_with_sessions,\n        \'revisit_sites\': revisit_sites,\n        \'revisit_rate_pct\': revisit_rate_pct,\n        \'avg_sessions_per_site\': avg_sessions_per_site,\n        \'revisit_threshold_sessions_gt\': revisit_threshold\n      }\n      out.append(row)\n\n    # stable ordering\n    out.sort(key=lambda x: (str(x.get(\'nas_market\') or \'\'), str(x.get(\'nas_company_name\') or x.get(\'nas_primary_gc\') or \'\')))\n    return out\n', kpi_source_columns: ['nas_checkout_approve_time', 'nas_session_id', 'nas_site_id', 'nas_market', 'nas_primary_gc', 'nas_company_name', 'nas_activity_type', 'nas_call_test_completion_status'], session_id: '69a3d22f26e208edc083a06e', label: 'Site Revisit Rate', kpi_related_core_node_ids: ['integration_activity'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '30e3c50e-a44c-4e27-8153-71741e2507d0', entity_type: 'kpi', kpi_name: 'Site Revisit Rate', name: '30e3c50e-a44c-4e27-8153-71741e2507d0', kpi_dimensions: ['nas_market', 'nas_primary_gc', 'nas_company_name', 'nas_activity_type', 'nas_site_id', 'nas_call_test_completion_status'], kpi_description: 'Measures post-integration rework by identifying how often sites require multiple completed NAS sessions to reach completion. It summarizes the share of sites that needed revisits, helping compare rework levels across vendor/GC and markets.', status: 'mentioned', node_id: '30e3c50e-a44c-4e27-8153-71741e2507d0'});
CREATE (:BKGNode {kpi_source_tables: ['stg_nas_e911_readiness_riot_validation'], nl_business_rule: '', kpi_formula_description: 'From rows with nas_site_id IS NOT NULL, unpivot configured RIOT band status columns into (band_name, band_status); then compute distinct-site counts and rates per (nas_region, nas_market, vendor_dim/drilldown) including any-failure rate and per-band NOT READY rate.', kpi_output_schema: '[{"column": "view_type", "type": "string", "description": "Indicates which view the row belongs to: \'summary\' or \'band_breakdown\'."}, {"column": "nas_region", "type": "string", "description": "Region grouping."}, {"column": "nas_market", "type": "string", "description": "Market grouping."}, {"column": "drilldown_dim", "type": "string", "description": "Present when drilldown is enabled; indicates the drilldown dimension name (e.g., \'nas_engineer\')."}, {"column": "nas_engineer", "type": "string", "description": "Engineer drilldown value when drilldown_dim is \'nas_engineer\'."}, {"column": "total_validated_sites", "type": "int", "description": "Distinct count of nas_site_id in the group (validation attempted by virtue of being present with non-null nas_site_id)."}, {"column": "sites_passing_all_bands", "type": "int", "description": "Distinct sites where all configured band statuses are READY (subject to null_handling behavior)."}, {"column": "sites_with_any_failure", "type": "int", "description": "Distinct sites with at least one configured band status equal to NOT READY."}, {"column": "failure_rate_pct", "type": "float", "description": "Percentage of validated sites with any failure: sites_with_any_failure / total_validated_sites * 100."}, {"column": "e911_ready_sites", "type": "int", "description": "Distinct sites where nas_validate_e911_readiness is READY."}, {"column": "e911_not_ready_sites", "type": "int", "description": "Distinct sites where nas_validate_e911_readiness is NOT READY."}, {"column": "band_name", "type": "string", "description": "Unpivoted RIOT band/technology column name (present in band_breakdown view)."}, {"column": "failed_sites_band", "type": "int", "description": "Distinct sites with band_status = NOT READY for the given band_name (band_breakdown view)."}, {"column": "band_failure_rate_pct", "type": "float", "description": "Percentage of validated sites failing the specific band: failed_sites_band / total_validated_sites * 100 (band_breakdown view)."}]', kpi_business_logic: '1) Select rows from stg_nas_e911_readiness_riot_validation where nas_site_id is not null.\n2) Choose the set of RIOT band columns (defaults provided; can be overridden by filters.band_columns).\n3) Unpivot the chosen band columns into rows with fields: nas_site_id, nas_region, nas_market, (vendor/drilldown dim), band_name, band_status.\n4) Group by (nas_region, nas_market, vendor_dim) (vendor_dim defaults to nas_primary_gc; if filters[\'vendor_dim\']=\'nas_vendor_name\' then use nas_vendor_name instead).\n5) For each group compute:\n   - total_validated_sites = count distinct nas_site_id\n   - sites_passing_all_bands = count distinct nas_site_id where all configured band_status values are \'READY\' (NULL treated as not-ready unless filters.null_handling=\'ignore\', in which case NULLs are excluded from the all-bands-ready evaluation)\n   - sites_with_any_failure = count distinct nas_site_id where any configured band_status = \'NOT READY\'\n   - failure_rate_pct = sites_with_any_failure / total_validated_sites * 100\n   - e911_ready_sites = count distinct nas_site_id where nas_validate_e911_readiness = \'READY\'\n   - e911_not_ready_sites = count distinct nas_site_id where nas_validate_e911_readiness = \'NOT READY\'\n   - optionally filter to a specific nas_activity_type via filters[\'nas_activity_type\'].\n6) For each (nas_region, nas_market, vendor_dim, band_name) compute:\n   - failed_sites_band = count distinct nas_site_id where band_status=\'NOT READY\'\n   - total_validated_sites = same distinct-site denominator for the parent (nas_region, nas_market, vendor_dim)\n   - band_failure_rate_pct = failed_sites_band / total_validated_sites * 100.', kpi_filters: '[{"name": "band_columns", "type": "string", "description": "Overrides the default set of RIOT band status columns to unpivot/analyze."}, {"name": "vendor_dim", "type": "string", "description": "Selects the vendor grouping dimension; defaults to nas_primary_gc, or can be set to nas_vendor_name."}, {"name": "null_handling", "type": "string", "description": "Controls how NULL/missing band statuses affect all-bands-ready evaluation: \'not_ready\' (default) treats NULL as not-ready; \'ignore\' excludes NULLs from the all-bands-ready check."}, {"name": "nas_activity_type", "type": "string", "description": "Limits the population to a specific activity type."}, {"name": "drilldown_dim", "type": "string", "description": "Controls whether to include a drilldown grouping; allowed: \'nas_engineer\' or \'none\' (region/market only)."}]', kpi_contract: '{"function_name": "get_riot_failure_breakdown", "node_type": "kpi", "node_id": "8e19ae1f-5519-44ca-9a00-56a65e8f7184", "node_label": "RIOT Failure Breakdown", "description": "Analyzes RIOT/iNTP readiness validation outcomes and failure prevalence by band/technology, market/region, and (by default) primary GC. Source table: `stg_nas_e911_readiness_riot_validation`. Population: rows where `nas_site_id IS NOT NULL` (presence in the table implies validation attempted); no reliance on `nas_riot_overall_status`.\\n\\nLogic (single-table, internal unpivot):\\n1) Define band columns to analyze (defaults, overridable): `nas_validate_n41_riot`, `nas_validate_n71_riot`, `nas_validate_n25_riot`, `nas_validate_n66_riot`, `nas_validate_n2_riot`, `nas_validate_b2_riot`, `nas_validate_b66_riot`, `nas_validate_b71_riot`, `nas_validate_b41_riot`, `nas_validate_b12_riot`. Unpivot into rows: (`nas_site_id`, `nas_region`, `nas_market`, vendor_dim, `band_name`, `band_status`).\\n2) Summary per grouping key `(nas_region, nas_market, vendor_dim)` (vendor_dim defaults to `nas_primary_gc`; if `filters[\'vendor_dim\']=\'nas_vendor_name\'`, use that instead):\\n   - `total_validated_sites`: COUNT(DISTINCT nas_site_id)\\n   - `sites_passing_all_bands`: COUNT(DISTINCT nas_site_id) where for that site all configured band_status values are \'READY\' (treat missing/NULL band statuses as not-ready unless `filters[\'null_handling\']=\'ignore\'` is specified)\\n   - `sites_with_any_failure`: COUNT(DISTINCT nas_site_id) where any configured band_status = \'NOT READY\'\\n   - `failure_rate_pct`: sites_with_any_failure / NULLIF(total_validated_sites,0) * 100\\n   - `e911_ready_sites`: COUNT(DISTINCT nas_site_id) where `nas_validate_e911_readiness`=\'READY\'\\n   - `e911_not_ready_sites`: COUNT(DISTINCT nas_site_id) where `nas_validate_e911_readiness`=\'NOT READY\'\\n   - Optional filters: `filters[\'nas_activity_type\']` to limit to a specific activity type if needed.\\n3) Per-band failure breakdown per `(nas_region, nas_market, vendor_dim, band_name)`:\\n   - `failed_sites_band`: COUNT(DISTINCT nas_site_id) where band_status=\'NOT READY\'\\n   - `total_validated_sites`: COUNT(DISTINCT nas_site_id) within the same `(nas_region, nas_market, vendor_dim)` grouping (repeated denominator for context)\\n   - `band_failure_rate_pct`: failed_sites_band / NULLIF(total_validated_sites,0) * 100\\n\\nOutputs: KPI returns a dataset suitable for dashboarding with two views: (A) overall validation/failure summary by market/region/vendor, and (B) band_name-level failure breakdown to identify the most prevalent failing technologies. Key columns used: `nas_site_id`, `nas_market`, `nas_region`, `nas_activity_type`, `nas_primary_gc`, `nas_vendor_name`, `nas_validate_e911_readiness`, and the configured `nas_validate_*_riot` band columns.", "parameters": [{"name": "band_columns", "type": "string", "description": "Filter by band columns", "required": false, "sample_values": []}, {"name": "drilldown_dim", "type": "string", "description": "Filter by drilldown dim", "required": false, "sample_values": []}, {"name": "null_handling", "type": "string", "description": "Filter by null handling", "required": false, "sample_values": []}], "output_columns": [{"name": "view_type", "type": "string", "nullable": false}, {"name": "nas_region", "type": "null", "nullable": true}, {"name": "nas_market", "type": "string", "nullable": false}, {"name": "total_validated_sites", "type": "number", "nullable": false}, {"name": "sites_passing_all_bands", "type": "number", "nullable": false}, {"name": "sites_with_any_failure", "type": "number", "nullable": false}, {"name": "failure_rate_pct", "type": "number", "nullable": false}, {"name": "e911_ready_sites", "type": "number", "nullable": false}, {"name": "e911_not_ready_sites", "type": "number", "nullable": false}, {"name": "drilldown_dim", "type": "string", "nullable": false}, {"name": "nas_engineer", "type": "string", "nullable": true}], "sample_output": [{"view_type": "summary", "nas_region": null, "nas_market": "CH", "total_validated_sites": 1, "sites_passing_all_bands": 0, "sites_with_any_failure": 0, "failure_rate_pct": 0.0, "e911_ready_sites": 0, "e911_not_ready_sites": 0, "drilldown_dim": "nas_engineer", "nas_engineer": "N/A"}, {"view_type": "summary", "nas_region": "Central", "nas_market": "DE", "total_validated_sites": 3, "sites_passing_all_bands": 0, "sites_with_any_failure": 0, "failure_rate_pct": 0.0, "e911_ready_sites": 0, "e911_not_ready_sites": 0, "drilldown_dim": "nas_engineer", "nas_engineer": "PASS"}, {"view_type": "summary", "nas_region": null, "nas_market": "IN", "total_validated_sites": 3, "sites_passing_all_bands": 0, "sites_with_any_failure": 0, "failure_rate_pct": 0.0, "e911_ready_sites": 0, "e911_not_ready_sites": 0, "drilldown_dim": "nas_engineer", "nas_engineer": null}], "row_count": 10}', nl_description: 'KPI = unpivot the RIOT band columns on stg_nas_e911_readiness_riot_validation (nas_g1900_riot, nas_l600_riot, nas_l700_riot, nas_l850_riot, nas_laws3_riot, nas_l1900_c1_riot, nas_l1900_c2_riot, nas_l2100_c1_riot, nas_l2100_c2_riot, nas_l2500_c1_riot, nas_l2500_c2_riot, nas_n600_c1_riot, nas_n600_c2_riot, nas_n1900_c1_riot, nas_n1900_c2_riot, nas_n2500_c1_riot, nas_n2500_c2_riot, nas_n2500_c3_riot, nas_n2100_c1_riot, nas_u2100_c1_riot, nas_u1900_c1_riot, nas_n24g_c3_riot) over rows with nas_site_id not null; then for each (nas_region, nas_market) and optionally nas_engineer, compute distinct-site totals, all-bands-ready counts, any-failure counts/rates, and E911 readiness counts; additionally compute per-band distinct-site NOT READY counts and per-band failure rates using the same group denominator.', node_type: 'CORE', definition: 'KPI = unpivot the RIOT band columns on stg_nas_e911_readiness_riot_validation (nas_g1900_riot, nas_l600_riot, nas_l700_riot, nas_l850_riot, nas_laws3_riot, nas_l1900_c1_riot, nas_l1900_c2_riot, nas_l2100_c1_riot, nas_l2100_c2_riot, nas_l2500_c1_riot, nas_l2500_c2_riot, nas_n600_c1_riot, nas_n600_c2_riot, nas_n1900_c1_riot, nas_n1900_c2_riot, nas_n2500_c1_riot, nas_n2500_c2_riot, nas_n2500_c3_riot, nas_n2100_c1_riot, nas_u2100_c1_riot, nas_u1900_c1_riot, nas_n24g_c3_riot) over rows with nas_site_id not null; then for each (nas_region, nas_market) and optionally nas_engineer, compute distinct-site totals, all-bands-ready counts, any-failure counts/rates, and E911 readiness counts; additionally compute per-band distinct-site NOT READY counts and per-band failure rates using the same group denominator.', kpi_python_function: 'def get_riot_failure_breakdown(execute_query, filters=None) -> list[dict]:\n    filters = filters or {}\n\n    # Actual RIOT band columns on stg_nas_e911_readiness_riot_validation\n    default_band_columns = [\n        "nas_g1900_riot",\n        "nas_l600_riot",\n        "nas_l700_riot",\n        "nas_l850_riot",\n        "nas_laws3_riot",\n        "nas_l1900_c1_riot",\n        "nas_l1900_c2_riot",\n        "nas_l2100_c1_riot",\n        "nas_l2100_c2_riot",\n        "nas_l2500_c1_riot",\n        "nas_l2500_c2_riot",\n        "nas_n600_c1_riot",\n        "nas_n600_c2_riot",\n        "nas_n1900_c1_riot",\n        "nas_n1900_c2_riot",\n        "nas_n2500_c1_riot",\n        "nas_n2500_c2_riot",\n        "nas_n2500_c3_riot",\n        "nas_n2100_c1_riot",\n        "nas_u2100_c1_riot",\n        "nas_u1900_c1_riot",\n        "nas_n24g_c3_riot",\n    ]\n\n    band_columns = filters.get("band_columns") or default_band_columns\n    if isinstance(band_columns, str):\n        band_columns = [c.strip() for c in band_columns.split(",") if c.strip()]\n\n    # Only available drill-down dim on this table is nas_engineer.\n    # Allow turning it off to group by region/market only.\n    drilldown_dim = (filters.get("drilldown_dim") or "nas_engineer").strip()\n    allowed_drilldowns = {"nas_engineer", "none"}\n    if drilldown_dim not in allowed_drilldowns:\n        drilldown_dim = "nas_engineer"\n\n    null_handling = (filters.get("null_handling") or "not_ready").lower()\n    # null_handling: \'not_ready\' (default) treats NULL/missing as not-ready; \'ignore\' excludes NULLs from all-bands-ready evaluation\n    if null_handling not in {"not_ready", "ignore"}:\n        null_handling = "not_ready"\n\n    select_cols = [\n        "nas_site_id",\n        "nas_region",\n        "nas_market",\n        "nas_engineer",\n        "nas_validate_e911_readiness",\n    ] + band_columns\n\n    def _ident(col: str) -> str:\n        return \'"\' + col.replace(\'"\', \'""\') + \'"\'\n\n    sql = (\n        "SELECT "\n        + ", ".join(_ident(c) for c in select_cols)\n        + " FROM public.stg_nas_e911_readiness_riot_validation"\n        + " WHERE \\"nas_site_id\\" IS NOT NULL"\n    )\n\n    rows = execute_query(sql)\n\n    def _norm_status(v):\n        if v is None:\n            return None\n        s = str(v).strip().upper()\n        if s == "":\n            return None\n        return s\n\n    # Groupings\n    total_sites = {}          # key -> set(site_id)\n    passing_all_bands = {}    # key -> set(site_id)\n    any_failure = {}          # key -> set(site_id)\n    e911_ready = {}           # key -> set(site_id)\n    e911_not_ready = {}       # key -> set(site_id)\n    band_failed_sites = {}    # (key, band_name) -> set(site_id)\n\n    for r in rows:\n        site_id = r.get("nas_site_id")\n        if site_id is None:\n            continue\n\n        region = r.get("nas_region")\n        market = r.get("nas_market")\n        engineer = r.get("nas_engineer")\n\n        if drilldown_dim == "nas_engineer":\n            key = (region, market, engineer)\n        else:\n            key = (region, market)\n\n        total_sites.setdefault(key, set()).add(site_id)\n\n        # E911 readiness\n        e911_stat = _norm_status(r.get("nas_validate_e911_readiness"))\n        if e911_stat == "READY":\n            e911_ready.setdefault(key, set()).add(site_id)\n        elif e911_stat == "NOT READY":\n            e911_not_ready.setdefault(key, set()).add(site_id)\n\n        # Evaluate band statuses for this site\n        statuses = [(bc, _norm_status(r.get(bc))) for bc in band_columns]\n\n        # any failure = any configured band_status == \'NOT READY\'\n        if any(st == "NOT READY" for _, st in statuses):\n            any_failure.setdefault(key, set()).add(site_id)\n\n        # per-band failures\n        for band_name, st in statuses:\n            if st == "NOT READY":\n                band_failed_sites.setdefault((key, band_name), set()).add(site_id)\n\n        # sites_passing_all_bands\n        if null_handling == "ignore":\n            considered = [st for _, st in statuses if st is not None]\n            if considered and all(st == "READY" for st in considered):\n                passing_all_bands.setdefault(key, set()).add(site_id)\n        else:\n            if all(st == "READY" for _, st in statuses):\n                passing_all_bands.setdefault(key, set()).add(site_id)\n\n    results = []\n\n    # Summary rows\n    for key, sites_set in total_sites.items():\n        total = len(sites_set)\n        pass_all = len(passing_all_bands.get(key, set()))\n        any_fail = len(any_failure.get(key, set()))\n        e911_r = len(e911_ready.get(key, set()))\n        e911_nr = len(e911_not_ready.get(key, set()))\n        failure_rate_pct = (any_fail / total * 100.0) if total else None\n\n        if drilldown_dim == "nas_engineer":\n            region, market, engineer = key\n        else:\n            region, market = key\n            engineer = None\n\n        row = {\n            "view_type": "summary",\n            "nas_region": region,\n            "nas_market": market,\n            "total_validated_sites": total,\n            "sites_passing_all_bands": pass_all,\n            "sites_with_any_failure": any_fail,\n            "failure_rate_pct": failure_rate_pct,\n            "e911_ready_sites": e911_r,\n            "e911_not_ready_sites": e911_nr,\n        }\n        if drilldown_dim == "nas_engineer":\n            row.update({\n                "drilldown_dim": "nas_engineer",\n                "nas_engineer": engineer,\n            })\n        results.append(row)\n\n    # Band breakdown rows\n    for key, sites_set in total_sites.items():\n        total = len(sites_set)\n\n        if drilldown_dim == "nas_engineer":\n            region, market, engineer = key\n        else:\n            region, market = key\n            engineer = None\n\n        for band_name in band_columns:\n            failed = len(band_failed_sites.get((key, band_name), set()))\n            band_failure_rate_pct = (failed / total * 100.0) if total else None\n            row = {\n                "view_type": "band_breakdown",\n                "nas_region": region,\n                "nas_market": market,\n                "band_name": band_name,\n                "failed_sites_band": failed,\n                "total_validated_sites": total,\n                "band_failure_rate_pct": band_failure_rate_pct,\n            }\n            if drilldown_dim == "nas_engineer":\n                row.update({\n                    "drilldown_dim": "nas_engineer",\n                    "nas_engineer": engineer,\n                })\n            results.append(row)\n\n    return results\n', kpi_source_columns: ['nas_site_id', 'nas_region', 'nas_market', 'nas_activity_type', 'nas_primary_gc', 'nas_vendor_name', 'nas_engineer', 'nas_validate_e911_readiness', 'nas_validate_n41_riot', 'nas_validate_n71_riot', 'nas_validate_n25_riot', 'nas_validate_n66_riot', 'nas_validate_n2_riot', 'nas_validate_b2_riot', 'nas_validate_b66_riot', 'nas_validate_b71_riot', 'nas_validate_b41_riot', 'nas_validate_b12_riot', 'nas_g1900_riot', 'nas_l600_riot', 'nas_l700_riot', 'nas_l850_riot', 'nas_laws3_riot', 'nas_l1900_c1_riot', 'nas_l1900_c2_riot', 'nas_l2100_c1_riot', 'nas_l2100_c2_riot', 'nas_l2500_c1_riot', 'nas_l2500_c2_riot', 'nas_n600_c1_riot', 'nas_n600_c2_riot', 'nas_n1900_c1_riot', 'nas_n1900_c2_riot', 'nas_n2500_c1_riot', 'nas_n2500_c2_riot', 'nas_n2500_c3_riot', 'nas_n2100_c1_riot', 'nas_u2100_c1_riot', 'nas_u1900_c1_riot', 'nas_n24g_c3_riot'], session_id: '69a3d22f26e208edc083a06e', label: 'RIOT Failure Breakdown', kpi_related_core_node_ids: ['integration_activity'], kpi_relationship_type: 'DERIVED_FROM', kpi_kpi_id: '8e19ae1f-5519-44ca-9a00-56a65e8f7184', entity_type: 'kpi', kpi_name: 'RIOT Failure Breakdown', name: '8e19ae1f-5519-44ca-9a00-56a65e8f7184', kpi_dimensions: ['nas_region', 'nas_market', 'nas_primary_gc', 'nas_vendor_name', 'nas_engineer', 'band_name'], kpi_description: 'Analyzes RIOT/iNTP readiness validation outcomes to quantify how prevalent failures are across technologies (bands) by geography and a primary vendor grouping. It supports dashboarding to identify markets/regions and technologies with the highest NOT READY rates and to compare overall readiness versus E911 readiness.', status: 'mentioned', node_id: '8e19ae1f-5519-44ca-9a00-56a65e8f7184'});
CREATE (:BKGNode {map_table_name: 'stg_nas_planned_outage_activity', map_key_column: 'id', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Planned Outage', map_sql_template: 'SELECT "id", "nas_status", "nas_project_category", "nas_site_id", "nas_nest_type", "nas_workorder_id", "nas_market", "nas_activity_details", "nas_activity_start_date", "nas_activity_end_date", "nas_activity_duration", "nas_request_time", "nas_colocated_sites", "nas_company_name", "nas_wm_connected_sites" FROM "public"."stg_nas_planned_outage_activity"', map_label_column: 'nas_workorder_id', nl_description: 'A scheduled NAS maintenance/outage window for a primary Site, coordinated/owned by NAS (Nokia), during which network services are intentionally taken offline to enable integration/construction completion/troubleshooting. Includes requested start/end, duration, NEST type (e.g., NSI/SI), status lifecycle (pending/approved/active/completed/rejected/cancelled), work-order identifier, and overrun/extension handling. Tracks secondary impacted co-located/neighbor Sites via impacts_site; primary work Site is linked via is_for_site. The company performing the work requiring the outage (nas_company_name) is modeled via work_performed_by when not Nokia.', map_contract: '{"function_name": "get_planned_outage", "node_type": "core", "node_id": "planned_outage", "node_label": "Planned Outage", "description": "Query Planned Outage data from stg_nas_planned_outage_activity", "parameters": [{"name": "id", "type": "number", "description": "Filter by id (primary key)", "required": false, "sample_values": ["2340", "2341", "2342"]}, {"name": "nas_workorder_id", "type": "string", "description": "Filter by nas_workorder_id", "required": false, "sample_values": ["CHG084348788", "CHG0290391330", "CHG0291029710"]}, {"name": "nas_nest_type", "type": "string", "description": "Filter by nas_nest_type", "required": false, "sample_values": ["NSI", "SI"]}, {"name": "nas_status", "type": "string", "description": "Filter by nas_status", "required": false, "sample_values": ["cancelled", "rejected", "approved"]}, {"name": "nas_market", "type": "string", "description": "Filter by nas_market", "required": false, "sample_values": ["Chicago", "Detroit", "Indianapolis"]}, {"name": "nas_project_category", "type": "string", "description": "Filter by nas_project_category", "required": false, "sample_values": ["ACS DAS Venue", "AHLOA-B SWAP", "Microwave"]}, {"name": "nas_colocated_sites", "type": "string", "description": "Filter by nas_colocated_sites", "required": false, "sample_values": ["IN10002A, ML10003A"]}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas_site_id", "required": false, "sample_values": ["CH10000A", "DE10001A", "IN10002A"]}, {"name": "nas_request_time", "type": "string", "description": "Filter by nas_request_time", "required": false, "sample_values": ["2026-02-24 17:49:34", "2026-03-05 18:23:43", "2025-12-30 01:37:44"]}, {"name": "nas_company_name", "type": "string", "description": "Filter by nas_company_name", "required": false, "sample_values": ["Nokia", "Telcom Construction", "KCCTech"]}, {"name": "nas_activity_start_date", "type": "string", "description": "Filter by nas_activity_start_date", "required": false, "sample_values": ["2026-03-01 17:49:34", "2026-03-09 18:23:43", "2026-01-08 01:37:44"]}, {"name": "nas_activity_end_date", "type": "string", "description": "Filter by nas_activity_end_date", "required": false, "sample_values": ["2026-03-02 00:49:34", "2026-03-10 01:23:43", "2026-01-08 11:37:44"]}], "output_columns": [{"name": "id", "type": "number", "nullable": false}, {"name": "nas_status", "type": "string", "nullable": false}, {"name": "nas_project_category", "type": "string", "nullable": false}, {"name": "nas_site_id", "type": "string", "nullable": false}, {"name": "nas_nest_type", "type": "string", "nullable": false}, {"name": "nas_workorder_id", "type": "string", "nullable": false}, {"name": "nas_market", "type": "string", "nullable": false}, {"name": "nas_activity_details", "type": "string", "nullable": false}, {"name": "nas_activity_start_date", "type": "string", "nullable": false}, {"name": "nas_activity_end_date", "type": "string", "nullable": false}, {"name": "nas_activity_duration", "type": "string", "nullable": true}, {"name": "nas_request_time", "type": "string", "nullable": false}, {"name": "nas_colocated_sites", "type": "string", "nullable": true}, {"name": "nas_company_name", "type": "string", "nullable": false}, {"name": "nas_wm_connected_sites", "type": "string", "nullable": true}], "sample_output": [], "row_count": 3}', entity_type: 'transaction', node_type: 'CORE', map_python_function: 'def get_planned_outage(execute_query: callable, filters: dict = None) -> list[dict]:\n    """Fetch Planned Outage records with curated columns and common filters.\n\n    Supported equality filters (by column name):\n      - nas_status, nas_market, nas_site_id, nas_nest_type, nas_project_category, nas_company_name\n\n    Supported date range filters (applied to nas_activity_start_date):\n      - start_date_from: inclusive lower bound (ISO timestamp string)\n      - start_date_to: exclusive upper bound (ISO timestamp string)\n\n    Node: Planned Outage | Table: stg_nas_planned_outage_activity | Key: id | DB: public\n    """\n\n    select_sql = (\n        \'SELECT "id", "nas_status", "nas_project_category", "nas_site_id", "nas_nest_type", \'\n        \'"nas_workorder_id", "nas_market", "nas_activity_details", "nas_activity_start_date", \'\n        \'"nas_activity_end_date", "nas_activity_duration", "nas_request_time", \'\n        \'"nas_colocated_sites", "nas_company_name", "nas_wm_connected_sites" \'\n        \'FROM "public"."stg_nas_planned_outage_activity"\'\n    )\n\n    where_parts = []\n\n    if filters:\n        # Date range filters (special keys)\n        start_from = filters.get(\'start_date_from\')\n        start_to = filters.get(\'start_date_to\')\n        if start_from is not None:\n            escaped = str(start_from).replace("\'", "\'\'")\n            where_parts.append(f\'"nas_activity_start_date" >= \\\'{escaped}\\\'\')\n        if start_to is not None:\n            escaped = str(start_to).replace("\'", "\'\'")\n            where_parts.append(f\'"nas_activity_start_date" < \\\'{escaped}\\\'\')\n\n        # Column equality filters\n        allowed_eq = {\n            \'nas_status\',\n            \'nas_market\',\n            \'nas_site_id\',\n            \'nas_nest_type\',\n            \'nas_project_category\',\n            \'nas_company_name\',\n        }\n\n        for k, v in filters.items():\n            if k in (\'start_date_from\', \'start_date_to\'):\n                continue\n            if k not in allowed_eq:\n                continue\n\n            if v is None:\n                where_parts.append(f\'"{k}" IS NULL\')\n            elif isinstance(v, (list, tuple, set)):\n                values = [item for item in v if item is not None]\n                if not values:\n                    where_parts.append(\'1=0\')\n                else:\n                    in_list = []\n                    for item in values:\n                        escaped = str(item).replace("\'", "\'\'")\n                        in_list.append(f"\'{escaped}\'")\n                    where_parts.append(f\'"{k}" IN ({", ".join(in_list)})\')\n            else:\n                escaped = str(v).replace("\'", "\'\'")\n                where_parts.append(f\'"{k}" = \\\'{escaped}\\\'\')\n\n    sql = select_sql\n    if where_parts:\n        sql += \' WHERE \' + \' AND \'.join(where_parts)\n\n    rows = execute_query(sql)\n    return rows if rows else []\n', is_skipped: false, name: 'planned_outage', definition: 'A scheduled NAS maintenance/outage window for a primary Site, coordinated/owned by NAS (Nokia), during which network services are intentionally taken offline to enable integration/construction completion/troubleshooting. Includes requested start/end, duration, NEST type (e.g., NSI/SI), status lifecycle (pending/approved/active/completed/rejected/cancelled), work-order identifier, and overrun/extension handling. Tracks secondary impacted co-located/neighbor Sites via impacts_site; primary work Site is linked via is_for_site. The company performing the work requiring the outage (nas_company_name) is modeled via work_performed_by when not Nokia.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'planned_outage'});
CREATE (:BKGNode {map_table_name: 'stg_nas_nest_ext_raw_by_session', map_key_column: 'id', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'NEST Extension', map_sql_template: 'SELECT "id", "nas_session_id", "nas_date_requested", "nas_region", "nas_market", "nas_project_category", "nas_site_id", "nas_category", "nas_vendorname", "nas_company_name" FROM "public"."stg_nas_nest_ext_raw_by_session"', map_label_column: 'nas_session_id', nl_description: 'A formal NAS request to extend an approved maintenance/outage (NEST) window beyond its scheduled end time when work cannot be completed within the originally approved Planned Outage window. In data, the NEST Extension is keyed by nas_session_id and links reliably to Integration Activity; linkage to a specific Planned Outage is inferred (site+time overlap) and may be optional.', map_contract: '{"function_name": "get_nest_extension", "node_type": "core", "node_id": "nest_extension", "node_label": "NEST Extension", "description": "Query NEST Extension data from stg_nas_nest_ext_raw_by_session", "parameters": [{"name": "id", "type": "number", "description": "Filter by id (primary key)", "required": false, "sample_values": ["7675467", "7675468", "7675469"]}, {"name": "nas_session_id", "type": "string", "description": "Filter by nas_session_id", "required": false, "sample_values": ["300000", "300001", "300002"]}, {"name": "nas_region", "type": "string", "description": "Filter by nas_region", "required": false, "sample_values": ["Central"]}, {"name": "nas_category", "type": "string", "description": "Filter by nas_category", "required": false, "sample_values": ["Integration Work", "Backhaul Issues"]}, {"name": "nas_project_category", "type": "string", "description": "Filter by nas_project_category", "required": false, "sample_values": ["Equipment Upgrade", "ABIO Swap plus 5G Midband"]}, {"name": "nas_market", "type": "string", "description": "Filter by nas_market", "required": false, "sample_values": ["Chicago