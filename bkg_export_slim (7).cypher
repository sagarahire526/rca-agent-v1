ite_id", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction_gc", "required": false, "sample_values": []}, {"name": "pj_a_5750_l1900_onair_finish", "type": "string", "description": "Filter by pj_a_5750_l1900_onair_finish", "required": false, "sample_values": []}, {"name": "pj_a_5800_l2100_onair_finish", "type": "string", "description": "Filter by pj_a_5800_l2100_onair_finish", "required": false, "sample_values": []}, {"name": "pj_a_5863_l2500_onair_finish", "type": "string", "description": "Filter by pj_a_5863_l2500_onair_finish", "required": false, "sample_values": []}, {"name": "pj_a_5900_l600_onair_finish", "type": "string", "description": "Filter by pj_a_5900_l600_onair_finish", "required": false, "sample_values": []}], "output_columns": [{"name": "pj_project_id", "type": "string", "nullable": false}, {"name": "s_site_id", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "rgn_region", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "pj_project_status", "type": "string", "nullable": false}, {"name": "pj_a_5750_l1900_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_5800_l2100_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_5863_l2500_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_5900_l600_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_5950_n600_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_6000_l700_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_6050_l850_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_6257_n1900_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_6270_n2100_onair_finish", "type": "string", "nullable": false}, {"name": "pj_a_6318_n2500_onair_finish", "type": "string", "nullable": false}], "sample_output": [], "row_count": 3}', node_type: 'CORE', entity_type: 'core', map_python_function: 'def get_radio_unit(execute_query, filters=None):\n    """Fetch Radio Unit reference/proxy information.\n\n    Node: Radio Unit | Virtual/reference — no physical radio unit registry in staging schema.\n\n    Radio units (RRU/BBU) are tracked post-installation via the external FAST Tracker system,\n    which is not available in the staging tables. Band-level on-air status is available on\n    stg_ndpd_mbt_tmobile_macro_combined (pj_a_*_onair_finish columns) and RIOT validation\n    status exists on stg_nas_e911_readiness_riot_validation.\n\n    This accessor returns per-project band on-air status as a proxy for radio unit deployment.\n    """\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = []\n\n    # NOTE: columns are stored as-is in Postgres; we quote them to be safe.\n    for k in [\n        "pj_project_id",\n        "s_site_id",\n        "m_market",\n        "rgn_region",\n        "construction_gc",\n        "pj_project_status",\n    ]:\n        if filters.get(k) is not None:\n            where_parts.append(f\'"{k}" = \\\'{esc(filters[k])}\\\'\')\n\n    sql = (\n        \'SELECT "pj_project_id", "s_site_id", "m_market", "m_area", "rgn_region", \'\n        \'"construction_gc", "pj_project_status", \'\n        \'"pj_a_5750_l1900_onair_finish", \'\n        \'"pj_a_5800_l2100_onair_finish", \'\n        \'"pj_a_5863_l2500_onair_finish", \'\n        \'"pj_a_5900_l600_onair_finish", \'\n        \'"pj_a_5950_n600_onair_finish", \'\n        \'"pj_a_6000_l700_onair_finish", \'\n        \'"pj_a_6050_l850_onair_finish", \'\n        \'"pj_a_6257_n1900_onair_finish", \'\n        \'"pj_a_6270_n2100_onair_finish", \'\n        \'"pj_a_6318_n2500_onair_finish" \'\n        \'FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\'\n    )\n\n    if where_parts:\n        sql += " WHERE " + " AND ".join(where_parts)\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'radio_unit', definition: 'An individual radio hardware asset (e.g., RRU/BBU components) tracked at serial/asset level in FAST Tracker. Starts as an expected BOM line item and becomes an installed asset at a Site; validated against the BOM and integrated during the project lifecycle. Common issues include hardware failures, BOM mismatches, and missing components.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'radio_unit'});
