\n        for k, v in filters.items():\n            col = \'"\' + k + \'"\'\n            if v is None:\n                where_parts.append(col + " IS NULL")\n            else:\n                escaped = str(v).replace("\'", "\'\'")\n                where_parts.append(col + " = \'" + escaped + "\'")\n    if where_parts:\n        if " WHERE " in base_sql.upper():\n            base_sql += " AND " + " AND ".join(where_parts)\n        else:\n            base_sql += " WHERE " + " AND ".join(where_parts)\n    rows = execute_query(base_sql)\n    return rows if rows else []', is_skipped: false, name: 'integration_activity', definition: 'A set of integration work performed by NAS integration engineers to bring installed radio equipment on-air, validate readiness artifacts, integrate technologies, and complete post-integration monitoring. Can begin once a site reaches an integration-ready/matured phase and is not strictly sequential with construction.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'integration_activity'});
