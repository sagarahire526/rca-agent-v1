", "nullable": false}, {"name": "pj_building_permit_approved_status", "type": "string", "nullable": false}, {"name": "pj_building_permit_expiration_date", "type": "string", "nullable": false}, {"name": "pj_building_permit_not_required_document_status", "type": "string", "nullable": false}, {"name": "ms_1406_tower_ntp_received_actual", "type": "string", "nullable": false}, {"name": "ms_1407_tower_ntp_validated_actual", "type": "string", "nullable": false}, {"name": "ms_1408_tower_ntp_rejected_actual", "type": "string", "nullable": false}, {"name": "ms_1507_tower_ntp_approved_actual", "type": "string", "nullable": false}, {"name": "pj_a_3550_ran_zoning_applied_finish", "type": "string", "nullable": false}, {"name": "pj_a_3575_ran_zoning_approved_finish", "type": "string", "nullable": false}, {"name": "pj_a_3650_ran_building_permit_applied_finish", "type": "string", "nullable": false}, {"name": "pj_a_3675_ran_building_permit_approved_finish", "type": "string", "nullable": false}, {"name": "pj_a_3710_ran_entitlement_complete_finish", "type": "string", "nullable": false}, {"name": "pj_a_3715_aav_entitlement_complete_finish", "type": "string", "nullable": false}, {"name": "pj_a_3720_mw_entitlement_complete_finish", "type": "string", "nullable": false}, {"name": "pj_a_3725_all_entitlement_complete_finish", "type": "string", "nullable": false}, {"name": "pj_a_3500_all_regulatory_complete_finish", "type": "string", "nullable": false}, {"name": "pj_a_4350_electrical_permit_applied_finish", "type": "string", "nullable": false}, {"name": "pj_a_4375_electrical_permit_approved_finish", "type": "string", "nullable": false}], "sample_output": [], "row_count": 3}', node_type: 'CORE', entity_type: 'core', map_python_function: 'def get_permit(execute_query, filters=None):\n    """Fetch Permit/NTP/Regulatory records with approval lifecycle milestones.\n    Node: Permit | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: pj_project_id | DB: public\n    """\n    filters = filters or {}\n