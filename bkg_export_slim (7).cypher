 "project_category", "sow", "nest_type", "session_id", "site_id", \'\n        \'"on_site", "company_name", \'\n        \'"activity", "activity_status", "current_layers_sector_status", \'\n        \'"checkin_latest_start_time", "checkout_os", "totalActivity_duration", \'\n        \'"initial_nest_approved", "nest_extension_hrs", "nest_extension_approver", \'\n        \'"pre_rtwp", "post_rtwp", "pre_alarm", "pre_2g_3g_alarm", "post_2g_3g_alarm", "post_alarm", \'\n        \'"warroom_comments", "create_uid", "create_date", "write_uid", "write_date" \'\n        \'FROM "public"."stg_tmo_nas_daily_dashboard"\'\n    )\n\n    allowed_equals = {\n        "session_id",\n        "site_id",\n        "market",\n        "region",\n        "company_name",\n        "activity_status",\n        "nest_type",\n    }\n\n    where_parts = []\n\n    def _escape(val: str) -> str:\n        return str(val).replace("\'", "\'\'")\n\n    if filters:\n        # equality filters\n        for key in allowed_equals:\n            if key in filters and filters[key] is not None:\n                where_parts.append(f\'"{key}" = \\\'{_escape(filters[key])}\\\'\')\n            elif key in filters and filters[key] is None:\n                where_parts.append(f\'"{key}" IS NULL\')\n\n        # date range filters on checkin_latest_start_time\n        if filters.get("checkin_start_from") is not None:\n            where_parts.append(\n                f\'"checkin_latest_start_time" >= \\\'{_escape(filters["checkin_start_from"])}\\\'\'\n            )\n        if filters.get("checkin_start_to") is not None:\n            where_parts.append(\n                f\'"checkin_latest_start_time" <= \\\'{_escape(filters["checkin_start_to"])}\\\'\'\n            )\n\n    if where_parts:\n        base_sql += " WHERE " + " AND ".join(where_parts)\n\n    rows = execute_query(base_sql)\n    return rows if rows else []\n', is_skipped: false, name: 'nas_daily_dashboard_entry', definition: 'Shift-level war room snapshot row for an NAS integration session (daily-refreshed operational view). Grain: 1 row per NAS session (not per day). Enriches Integration Activity with real-time RF quality signals (pre/post RTWP, pre/post alarm states across layers, sector/layer status) and free-text war room comments. Contains timestamps for latest check-in start and checkout on-site. Includes nest_type as an attribute (NSI/SI) but has no direct outage/workorder FK; outage linkage is via site+time inference if needed.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'nas_daily_dashboard_entry'});
