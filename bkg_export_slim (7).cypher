otos, trmf_antenna_bearing_azimuth, "\n        "trmf_antenna_rru_color_code_count_issue, "\n        "trmf_rru_antenna_ret_weather_proofing_issue, "\n        "trmf_antenna_rru_sl_no, trmf_asset_tag, "\n        "trmf_site_hygiene, trmf_blur_image "\n        "FROM public.stg_tmo_rejections_master_file"\n    )\n\n    if where_parts:\n        sql += " WHERE " + " AND ".join(where_parts)\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'rejection_record', definition: 'A punch finding record produced from a Quality Session (NDPc) review/rejection. In the T-Mobile rejection master file grain, a rejection record is site/package-level and summarizes multiple punch points (trmf_no_of_tmo_punch_points typically > 1). Punch Item tracks status lifecycle (submitted/accepted/rejected/AI-rejected), audit trail, and resolution loop; typically completed by the assigned General Contractor.', map_database_name: 'public', skip_reason: '', status: 'revised', node_id: 'rejection_record'});
