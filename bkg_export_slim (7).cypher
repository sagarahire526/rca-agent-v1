    where_parts = []\n    if filters:\n        for k, v in filters.items():\n            escaped = str(v).replace("\'", "\'\'")\n            where_parts.append(f\'"{k}" = \\\'{escaped}\\\'\')\n\n    if where_parts:\n        base_sql += " WHERE " + " AND ".join(where_parts)\n\n    rows = execute_query(base_sql)\n    return rows if rows else []', is_skipped: false, name: 'nest_extension', definition: 'A formal NAS request to extend an approved maintenance/outage (NEST) window beyond its scheduled end time when work cannot be completed within the originally approved Planned Outage window. In data, the NEST Extension is keyed by nas_session_id and links reliably to Integration Activity; linkage to a specific Planned Outage is inferred (site+time overlap) and may be optional.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'nest_extension'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: '', kpi_output_schema: '[{"column": "metric_name", "type": "string", "description": "KPI label."}, {"column": "eligible_projects", "type": "int", "description": "Count of projects with a non-null material availability timestamp."}, {"column": "projects_with_pickup_or_validation", "type": "int", "description": "Eligible projects with a completed pickup/validation timestamp."}, {"column": "projects_waiting_for_pickup_or_validation", "type": "int", "description": "Eligible projects missing pickup/validation timestamp (waiting)."}, {"column": "pct_completed_pickup_or_validation", "type": "float", "description": "projects_with_pickup_or_validation / eligible_projects."}, {"column": "avg_cycle_time_days_completed_only", "type": "float", "description": "Average days between availability and pickup/validation, computed only for completed pickups."}, {"column": "min_cycle_time_days_completed_only", "type": "float", "description": "Minimum completed cycle time in days."}, {"column": "max_cycle_time_days_completed_only", "type": "float", "description": "Maximum completed cycle time in days."}, {"column": "avg_waiting_days_open_only", "type": "float", "description": "Average days since availability for projects still waiting (open)."}, {"column": "overdue_projects_vs_sla", "type": "int", "description": "Count of eligible projects whose cycle/wait time exceeds sla_days."}, {"column": "pct_overdue_vs_sla", "type": "float", "description": "overdue_projects_vs_sla / eligible_projects."}, {"column": "sla_days", "type": "float", "description": "SLA threshold used for overdue classification."}, {"column": "detail_rows", "type": "array", "description": "Per-project rows with timestamps and computed cycle_time_days and overdue flag."}]', kpi_business_logic: '1) For each project in Material/Equipment, identify material_available_ts using pj_a_3950_aav_bom_at_msl_finish (fallback pj_a_3925_msl_pickup_date_finish).\n2) Identify pickup_validated_ts using ms_1461_pickup_tower_materials_and_validate_actual (fallback ms_14610_gc_material_pickup_actual).\n3) Eligible set: projects with material_available_ts not null (optionally within start_date/end_date).\n4) If pickup_validated_ts exists, cycle_time_days = pickup_validated_ts - material_available_ts; aggregate avg/min/max over completed.\n5) If pickup_validated_ts is null, project is \'waiting\'; compute waiting_days = now - material_available_ts; aggregate avg_waiting_days over open.\n6) Overdue flag: cycle_time_days (or waiting_days if open) > sla_days (default 2) and compute overdue counts and percentages.\n7) Enrich output dimensions (market/area/region/gc/site) from the material_equipment row, with fallback to Project/Site accessors.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Include projects whose material_available_ts is on/after this timestamp (ISO format recommended)."}, {"name": "end_date", "type": "date", "description": "Include projects whose material_available_ts is on/before this timestamp (ISO format recommended)."}, {"name": "m_market", "type": "string", "description": "Filter to a specific market."}, {"name": "m_area", "type": "string", "description": "Filter to a specific area."}, {"name": "rgn_region", "type": "string", "description": "Filter to a specific region."}, {"name": "construction_gc", "type": "string", "description": "Filter to a specific general contractor."}, {"name": "pj_project_status", "type": "string", "description": "Filter to a project status (e.g., Active/Dead/etc.)."}, {"name": "sla_days", "type": "number", "description": "Threshold (days) used to classify a project as overdue waiting for pickup/validation; defaults to 2."}]', kpi_contract: '{"function_name": "get_material_pickup_timeliness", "node_type": "kpi", "node_id": "72cf6b23-27b4-4a7d-92ba-e258e2444be2", "node_label": "Material Pickup Timeliness", "description": "Reveals whether projects are waiting on GC material pickup/validation after materials become available, helping reduce idle time before construction and integration.", "parameters": [], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'Reveals whether projects are waiting on GC material pickup/validation after materials become available, helping reduce idle time before construction and integration.', node_type: 'CORE', definition: 'Reveals whether projects are waiting on GC material pickup/validation after materials become available, helping reduce idle time before construction and integration.', kpi_python_function: '', kpi_source_columns: ['pj_project_id', 's_site_id', 'm_market', 'm_area', 'rgn_region', 'construction_gc', 'pj_project_status', 'pj_a_3950_aav_bom_at_msl_finish', 'pj_a_3925_msl_pickup_date_finish', 'ms_14610_gc_material_pickup_actual', 'ms_1461_pickup_tower_materials_and_validate_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Material Pickup Timeliness', kpi_related_core_node_ids: [], kpi_relationship_type: '', kpi_kpi_id: '72cf6b23-27b4-4a7d-92ba-e258e2444be2', entity_type: 'kpi', kpi_name: 'Material Pickup Timeliness', name: '72cf6b23-27b4-4a7d-92ba-e258e2444be2', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_status', 'site_code', 'pj_project_id'], kpi_description: 'Reveals whether projects are waiting on GC material pickup/validation after materials become available, helping reduce idle time before construction and integration.', status: 'mentioned', node_id: '72cf6b23-27b4-4a7d-92ba-e258e2444be2'});
CREATE (:BKGNode {map_table_name: 'stg_nas_planned_outage_activity', map_key_column: 'id', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Planned Outage', map_sql_template: 'SELECT "id", "nas_status", "nas_project_category", "nas_site_id", "nas_nest_type", "nas_workorder_id", "nas_market", "nas_activity_details", "nas_activity_start_date", "nas_activity_end_date", "nas_activity_duration", "nas_request_time", "nas_colocated_sites", "nas_company_name", "nas_wm_connected_sites" FROM "public"."stg_nas_planned_outage_activity"', map_label_column: 'nas_workorder_id', nl_description: 'A scheduled NAS maintenance/outage window for a primary Site during which network services are intentionally taken offline to enable integration/construction completion/troubleshooting. Includes requested start/end, duration, NEST type (e.g., NSI/SI), status lifecycle, work-order identifier, and tracks secondary impacted co-located/neighbor Sites.', map_contract: '{"function_name": "get_planned_outage", "node_type": "core", "node_id": "planned_outage", "node_label": "Planned Outage", "description": "Query Planned Outage data from stg_nas_planned_outage_activity", "parameters": [{"name": "id", "type": "number", "description": "Filter by id (primary key)", "required": false, "sample_values": ["2340", "2341", "2342"]}, {"name": "nas_workorder_id", "type": "string", "description": "Filter by nas_workorder_id", "required": false, "sample_values": ["CHG084348788", "CHG0290391330", "CHG0291029710"]}, {"name": "nas_nest_type", "type": "string", "description": "Filter by nas_nest_type", "required": false, "sample_values": ["NSI", "SI"]}, {"name": "nas_status", "type": "string", "description": "Filter by nas_status", "required": false, "sample_values": ["cancelled", "rejected", "approved"]}, {"name": "nas_market", "type": "string", "description": "Filter by nas_market", "required": false, "sample_values": ["Chicago", "Detroit", "Indianapolis"]}, {"name": "nas_project_category", "type": "string", "description": "Filter by nas_project_category", "required": false, "sample_values": ["ACS DAS Venue", "AHLOA-B SWAP", "Microwave"]}, {"name": "nas_colocated_sites", "type": "string", "description": "Filter by nas_colocated_sites", "required": false, "sample_values": ["IN10002A, ML10003A"]}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas_site_id", "required": false, "sample_values": ["CH10000A", "DE10001A", "IN10002A"]}, {"name": "nas_request_time", "type": "string", "description": "Filter by nas_request_time", "required": false, "sample_values": ["2026-02-24 17:49:34", "2026-03-05 18:23:43", "2025-12-30 01:37:44"]}, {"name": "nas_company_name", "type": "string", "description": "Filter by nas_company_name", "required": false, "sample_values": ["Nokia", "Telcom Construction", "KCCTech"]}, {"name": "nas_activity_start_date", "type": "string", "description": "Filter by nas_activity_start_date", "required": false, "sample_values": ["2026-03-01 17:49:34", "2026-03-09 18:23:43", "2026-01-08 01:37:44"]}, {"name": "nas_activity_end_date", "type": "string", "description": "Filter by nas_activity_end_date", "required": false, "sample_values": ["2026-03-02 00:49:34", "2026-03-10 01:23:43", "2026-01-08 11:37:44"]}], "output_columns": [{"name": "id", "type": "number", "nullable": false}, {"name": "nas_status", "type": "string", "nullable": false}, {"name": "nas_project_category", "type": "string", "nullable": false}, {"name": "nas_site_id", "type": "string", "nullable": false}, {"name": "nas_nest_type", "type": "string", "nullable": false}, {"name": "nas_workorder_id", "type": "string", "nullable": false}, {"name": "nas_market", "type": "string", "nullable": false}, {"name": "nas_activity_details", "type": "string", "nullable": false}, {"name": "nas_activity_start_date", "type": "string", "nullable": false}, {"name": "nas_activity_end_date", "type": "string", "nullable": false}, {"name": "nas_activity_duration", "type": "string", "nullable": true}, {"name": "nas_request_time", "type": "string", "nullable": false}, {"name": "nas_colocated_sites", "type": "string", "nullable": true}, {"name": "nas_company_name", "type": "string", "nullable": false}, {"name": "nas_wm_connected_sites", "type": "string", "nullable": true}], "sample_output": [], "row_count": 3}', entity_type: 'transaction', node_type: 'CORE', map_python_function: 'def get_planned_outage(execute_query: callable, filters: dict = None) -> list[dict]:\n    """Fetch Planned Outage records with curated columns and common filters.\n\n    Supported equality filters (by column name):\n      - nas_status, nas_market, nas_site_id, nas_nest_type, nas_project_category, nas_company_name\n\n    Supported date range filters (applied to nas_activity_start_date):\n      - start_date_from: inclusive lower bound (ISO timestamp string)\n      - start_date_to: exclusive upper bound (ISO timestamp string)\n\n    Node: Planned Outage | Table: stg_nas_planned_outage_activity | Key: id | DB: public\n    """\n\n    select_sql = (\n        \'SELECT "id", "nas_status", "nas_project_category", "nas_site_id", "nas_nest_type", \'\n        \'"nas_workorder_id", "nas_market", "nas_activity_details", "nas_activity_start_date", \'\n        \'"nas_activity_end_date", "nas_activity_duration", "nas_request_time", \'\n        \'"nas_colocated_sites", "nas_company_name", "nas_wm_connected_sites" \'\n        \'FROM "public"."stg_nas_planned_outage_activity"\'\n    )\n\n    where_parts = []\n\n    if filters:\n        # Date range filters (special keys)\n        start_from = filters.get(\'start_date_from\')\n        start_to = filters.get(\'start_date_to\')\n        if start_from is not None:\n            escaped = str(start_from).replace("\'", "\'\'")\n            where_parts.append(f\'"nas_activity_start_date" >= \\\'{escaped}\\\'\')\n        if start_to is not None:\n            escaped = str(start_to).replace("\'", "\'\'")\n            where_parts.append(f\'"nas_activity_start_date" < \\\'{escaped}\\\'\')\n\n        # Column equality filters\n        allowed_eq = {\n            \'nas_status\',\n            \'nas_market\',\n            \'nas_site_id\',\n            \'nas_nest_type\',\n            \'nas_project_category\',\n            \'nas_company_name\',\n        }\n\n        for k, v in filters.items():\n            if k in (\'start_date_from\', \'start_date_to\'):\n                continue\n            if k not in allowed_eq:\n                continue\n\n            if v is None:\n                where_parts.append(f\'"{k}" IS NULL\')\n            elif isinstance(v, (list, tuple, set)):\n                values = [item for item in v if item is not None]\n                if not values:\n                    where_parts.append(\'1=0\')\n                else:\n                    in_list = []\n                    for item in values:\n                        escaped = str(item).replace("\'", "\'\'")\n                        in_list.append(f"\'{escaped}\'")\n                    where_parts.append(f\'"{k}" IN ({", ".join(in_list)})\')\n            else:\n                escaped = str(v).replace("\'", "\'\'")\n                where_parts.append(f\'"{k}" = \\\'{escaped}\\\'\')\n\n    sql = select_sql\n    if where_parts:\n        sql += \' WHERE \' + \' AND \'.join(where_parts)\n\n    rows = execute_query(sql)\n    return rows if rows else []\n', is_skipped: false, name: 'planned_outage', definition: 'A scheduled NAS maintenance/outage window for a primary Site during which network services are intentionally taken offline to enable integration/construction completion/troubleshooting. Includes requested start/end, duration, NEST type (e.g., NSI/SI), status lifecycle, work-order identifier, and tracks secondary impacted co-located/neighbor Sites.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'planned_outage'});
