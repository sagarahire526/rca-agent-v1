CREATE (:BKGNode {map_key_column: 'vendor_name', map_table_name: 'stg_ndpd_mbt_tmobile_macro_combined', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'External Vendor', map_sql_template: 'SELECT DISTINCT vendor_name\nFROM (\n  SELECT UPPER(TRIM(construction_gc)) AS vendor_name\n  FROM stg_ndpd_mbt_tmobile_macro_combined\n  WHERE construction_gc IS NOT NULL AND TRIM(construction_gc) <> \'\'\n\n  UNION\n\n  SELECT UPPER(TRIM(ms_1321_spo_issued_p20_vendor_name)) AS vendor_name\n  FROM stg_ndpd_mbt_tmobile_macro_combined\n  WHERE ms_1321_spo_issued_p20_vendor_name IS NOT NULL AND TRIM(ms_1321_spo_issued_p20_vendor_name) <> \'\'\n\n  UNION\n\n  SELECT UPPER(TRIM(ms_1551_spo_issued_p20_vendor_name)) AS vendor_name\n  FROM stg_ndpd_mbt_tmobile_macro_combined\n  WHERE ms_1551_spo_issued_p20_vendor_name IS NOT NULL AND TRIM(ms_1551_spo_issued_p20_vendor_name) <> \'\'\n\n  UNION\n\n  SELECT UPPER(TRIM(ms_1970_spo_issued_p20_vendor_name)) AS vendor_name\n  FROM stg_ndpd_mbt_tmobile_macro_combined\n  WHERE ms_1970_spo_issued_p20_vendor_name IS NOT NULL AND TRIM(ms_1970_spo_issued_p20_vendor_name) <> \'\'\n\n  UNION\n\n  SELECT UPPER(TRIM(ms_1559_spo_issued_p20_vendor_name)) AS vendor_name\n  FROM stg_ndpd_mbt_tmobile_macro_combined\n  WHERE ms_1559_spo_issued_p20_vendor_name IS NOT NULL AND TRIM(ms_1559_spo_issued_p20_vendor_name) <> \'\'\n) v\nORDER BY vendor_name', map_label_column: 'vendor_name', nl_description: 'A third-party company (non-GC) that performs specialized services in the program, such as drone surveys. Example: Talon.', map_contract: '{"function_name": "get_external_vendor", "node_type": "core", "node_id": "external_vendor", "node_label": "external_vendor", "description": "Query external_vendor data from stg_ndpd_mbt_tmobile_macro_combined", "parameters": [{"name": "DISTINCT vendor_name", "type": "string", "description": "Filter by DISTINCT vendor_name", "required": false, "sample_values": []}], "output_columns": [{"name": "DISTINCT vendor_name", "type": "string", "nullable": false}], "sample_output": [], "row_count": 3}', node_type: 'CORE', entity_type: 'core', map_python_function: 'def get_external_vendor(execute_query, filters=None):\n    """Fetch External Vendor records derived from distinct vendor names across GC + SPO vendor-name columns.\n\n    Node: External Vendor | Derived from: stg_ndpd_mbt_tmobile_macro_combined | Key/Label: vendor_name | DB: public\n\n    Notes:\n      - Derived dimension: no vendor master table exists in the staging schema.\n      - Vendor names are normalized with UPPER(TRIM(...)) to reduce case/whitespace duplicates.\n      - Includes General Contractors (from construction_gc) and other third-party vendors referenced on SPO-related milestone fields.\n    """\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    base_sql = (\n        "SELECT DISTINCT vendor_name "\n        "FROM ("\n        "  SELECT UPPER(TRIM(construction_gc)) AS vendor_name "\n        "  FROM stg_ndpd_mbt_tmobile_macro_combined "\n        "  WHERE construction_gc IS NOT NULL AND TRIM(construction_gc) <> \'\' "\n        "  UNION "\n        "  SELECT UPPER(TRIM(ms_1321_spo_issued_p20_vendor_name)) AS vendor_name "\n        "  FROM stg_ndpd_mbt_tmobile_macro_combined "\n        "  WHERE ms_1321_spo_issued_p20_vendor_name IS NOT NULL AND TRIM(ms_1321_spo_issued_p20_vendor_name) <> \'\' "\n        "  UNION "\n        "  SELECT UPPER(TRIM(ms_1551_spo_issued_p20_vendor_name)) AS vendor_name "\n        "  FROM stg_ndpd_mbt_tmobile_macro_combined "\n        "  WHERE ms_1551_spo_issued_p20_vendor_name IS NOT NULL AND TRIM(ms_1551_spo_issued_p20_vendor_name) <> \'\' "\n        "  UNION "\n        "  SELECT UPPER(TRIM(ms_1970_spo_issued_p20_vendor_name)) AS vendor_name "\n        "  FROM stg_ndpd_mbt_tmobile_macro_combined "\n        "  WHERE ms_1970_spo_issued_p20_vendor_name IS NOT NULL AND TRIM(ms_1970_spo_issued_p20_vendor_name) <> \'\' "\n        "  UNION "\n        "  SELECT UPPER(TRIM(ms_1559_spo_issued_p20_vendor_name)) AS vendor_name "\n        "  FROM stg_ndpd_mbt_tmobile_macro_combined "\n        "  WHERE ms_1559_spo_issued_p20_vendor_name IS NOT NULL AND TRIM(ms_1559_spo_issued_p20_vendor_name) <> \'\' "\n        ") v"\n    )\n\n    where_parts = []\n    if filters.get("vendor_name"):\n        # Expect caller to pass normalized name; we also normalize on the DB side to be safe.\n        where_parts.append("vendor_name = UPPER(TRIM(\'" + esc(filters["vendor_name"]) + "\'))")\n\n    sql = base_sql\n    if where_parts:\n        sql += " WHERE " + " AND ".join(where_parts)\n\n    sql += " ORDER BY vendor_name"\n\n    rows = execute_query(sql)\n    return rows if rows else []\n', is_skipped: false, name: 'external_vendor', definition: 'A third-party company (non-GC) that performs specialized services in the program, such as drone surveys. Example: Talon.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'external_vendor'});
