MATCH (a:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'site'}), (b:BKGNode {session_id: '69a3d22f26e208edc083a06e', node_id: 'general_contractor_assignment'}) CREATE (a)-[:RELATES_TO {relationship_type: 'HAS_GC_ASSIGNMENT', edge_id: '379570f6-2e69-4655-a054-462505f041d4', session_id: '69a3d22f26e208edc083a06e', style: 'solid', relationship: 'has_gc_assignment', status: 'confirmed'}]->(b);
