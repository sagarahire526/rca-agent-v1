project_category", "required": false, "sample_values": ["Equipment Upgrade", "ABIO Swap plus 5G Midband", "Anchor Phase 3"]}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas_site_id", "required": false, "sample_values": ["CH10000A", "DE10001A", "IN10002A"]}, {"name": "nas_session_id", "type": "string", "description": "Filter by nas_session_id", "required": false, "sample_values": ["300000", "300001", "300002"]}, {"name": "nas_sla_nest", "type": "string", "description": "Filter by nas_sla_nest", "required": false, "sample_values": ["5", "2", "6"]}, {"name": "nas_event_time", "type": "string", "description": "Filter by nas_event_time", "required": false, "sample_values": ["2025-11-12 16:41:35", "2026-02-08 01:50:07", "2025-11-12 18:41:44"]}, {"name": "nas_user_id", "type": "string", "description": "Filter by nas_user_id", "required": false, "sample_values": ["dre.longoria.ext@nokia.com", "pradeep.r.ext@nokia.com", "cuthbert.cuffy.ext@nokia.com"]}], "output_columns": [{"name": "id", "type": "number", "nullable": false}, {"name": "nas_region", "type": "string", "nullable": false}, {"name": "nas_market", "type": "string", "nullable": false}, {"name": "nas_site_id", "type": "string", "nullable": false}, {"name": "nas_session_id", "type": "string", "nullable": false}, {"name": "nas_activity_type", "type": "string", "nullable": false}, {"name": "nas_nest_type", "type": "string", "nullable": false}, {"name": "nas_project_category", "type": "string", "nullable": false}, {"name": "nas_event_type", "type": "string", "nullable": false}, {"name": "nas_sla_nest", "type": "string", "nullable": false}, {"name": "nas_event_time", "type": "string", "nullable": false}, {"name": "nas_user_id", "type": "string", "nullable": false}], "sample_output": [], "row_count": 3}', entity_type: 'transaction', node_type: 'CORE', map_python_function: 'def get_nas_event_log_event(execute_query: callable, filters: dict | None = None) -> list[dict]:\n    """Fetch NAS Event Log Event records with curated filters.\n\n    Node: NAS Event Log Event | Table: stg_nas_log_data | Key: id | DB: public\n\n    Allowed filters:\n      - nas_session_id, nas_site_id, nas_market, nas_region, nas_event_type,\n        nas_nest_type, nas_project_category, nas_user_id\n      - nas_event_time_from (inclusive), nas_event_time_to (exclusive)\n\n    Notes:\n      - List values create an IN (...) predicate.\n      - Timestamp filters expect values castable by PostgreSQL (e.g., \'2026-02-01\', \'2026-02-01T00:00:00\').\n    """\n\n    base_sql = (\n        \'SELECT "id", "nas_region", "nas_market", "nas_site_id", "nas_session_id", \'\n        \'"nas_activity_type", "nas_nest_type", "nas_project_category", "nas_event_type", \'\n        \'"nas_sla_nest", "nas_event_time", "nas_user_id" \'\n        \'FROM "public"."stg_nas_log_data"\'\n    )\n\n    allowed_eq = {\n        "nas_session_id",\n        "nas_site_id",\n        "nas_market",\n        "nas_region",\n        "nas_event_type",\n        "nas_nest_type",\n        "nas_project_category",\n        "nas_user_id",\n    }\n\n    where_parts: list[str] = []\n\n    def esc(val: object) -> str:\n        return str(val).replace("\'", "\'\'")\n\n    if filters:\n        # equality / IN filters\n        for k in sorted(set(filters.keys()) & allowed_eq):\n            v = filters.get(k)\n            if v is None:\n                where_parts.append(f\'"{k}" IS NULL\')\n            elif isinstance(v, (list, tuple, set)):\n                vals = list(v)\n                if not vals:\n                    where_parts.append("1=0")\n                else:\n                    escaped_vals = [f"\'{esc(item)}\'" for item in vals]\n                    where_parts.append(f\'"{k}" IN ({", ".join(escaped_vals)})\')\n            else:\n                where_parts.append(f\'"{k}" = \\\'{esc(v)}\\\'\')\n\n        # time range filters\n        t_from = filters.get("nas_event_time_from")\n        t_to = filters.get("nas_event_time_to")\n        if t_from is not None:\n            where_parts.append(f\'"nas_event_time" >= \\\'{esc(t_from)}\\\'\')\n        if t_to is not None:\n            where_parts.append(f\'"nas_event_time" < \\\'{esc(t_to)}\\\'\')\n\n    if where_parts:\n        base_sql += " WHERE " + " AND ".join(where_parts)\n\n    rows = execute_query(base_sql)\n    return rows if rows else []\n', is_skipped: false, name: 'nas_event_log_event', definition: 'A timestamped audit-trail record of a discrete NAS session lifecycle event (e.g., NEST approved, check-in, check-out, extension requested, session cancelled). Used for process mining/forensics; ties to a NAS Integration Activity session and to the acting user.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'nas_event_log_event'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_log_data', 'public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'E911 FTR Rate = (count of distinct sites whose FIRST (earliest) E911 RIOT validation record is PASS/PASS) / (count of distinct sites with ANY E911 RIOT validation attempt). Source of truth is stg_nas_e911_readiness_riot_validation. Attempted sites are those with nas_e911_validation_date IS NOT NULL. First-time-right pass requires nas_validate_e911_readiness = \'PASS\' AND nas_consolidation_check_all_layers = \'PASS\' on the earliest (MIN) nas_e911_validation_date per site. Uses the same filters and site enrichment logic as E911 Readiness Rate; only change vs readiness is MIN(...) instead of MAX(...).', kpi_output_schema: '[{"column": "kpi_name", "type": "string", "description": "KPI label."}, {"column": "attempted_sites", "type": "integer", "description": "Distinct sites with an E911 validation attempt (any E911-related NAS event in the filter window)."}, {"column": "first_time_right_pass_sites", "type": "integer", "description": "Distinct sites whose first observed E911 outcome event is a pass."}, {"column": "e911_ftr_rate", "type": "float", "description": "first_time_right_pass_sites / attempted_sites; null if attempted_sites is 0."}, {"column": "start_date", "type": "string", "description": "Echo of the applied start_date filter."}, {"column": "end_date", "type": "string", "description": "Echo of the applied end_date filter."}, {"column": "site_id", "type": "string", "description": "Echo of the applied site_id filter."}, {"column": "m_market", "type": "string", "description": "Echo of the applied market filter."}, {"column": "rgn_region", "type": "string", "description": "Echo of the applied region filter."}]', kpi_business_logic: '1) Pull NAS Event Log Events and keep only events where nas_activity_type contains \'E911\'. 2) Apply optional filters: start_date/end_date on nas_event_time and optional site/market/region filters (market/region derived by joining to Site on site_code=nas_site_id). 3) Denominator: count distinct nas_site_id among remaining events (sites with any E911 attempt). 4) For each site, sort its E911 events by nas_event_time and find the first outcome event where nas_event_type text indicates PASS (approved/accepted/passed) or FAIL (rejected/failed). 5) Numerator: count sites whose first outcome is PASS. 6) KPI rate = numerator/denominator; return attempted_sites, first_time_right_pass_sites, and e911_ftr_rate.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Include only E911 NAS events with nas_event_time >= start_date (string compare assumes ISO timestamp formatting)."}, {"name": "end_date", "type": "date", "description": "Include only E911 NAS events with nas_event_time <= end_date (string compare assumes ISO timestamp formatting)."}, {"name": "site_id", "type": "string", "description": "Restrict to a single site (matches nas_site_id / site_code)."}, {"name": "m_market", "type": "string", "description": "Restrict to sites in a specific market (derived from Site table). Accepts \'market\' alias."}, {"name": "rgn_region", "type": "string", "description": "Restrict to sites in a specific region (derived from Site table). Accepts \'region\' alias."}]', kpi_contract: '{"function_name": "get_e911_ftr_rate", "node_type": "kpi", "node_id": "a90dec51-0e24-4d89-9c5e-e153d3cbea93", "node_label": "E911 FTR Rate", "description": "Measures the share of sites that pass E911 validation on the first attempt out of all sites where E911 validation has been attempted. This KPI distinguishes clean executions from passes achieved only after rework, helping prioritize corrective actions, highlight recurring readiness issues by market/region/vendor, and reduce cycle-time impacts caused by repeated E911 validation failures.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "site_id", "type": "string", "description": "Filter by site id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "market", "type": "string", "description": "Filter by market", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "region", "type": "string", "description": "Filter by region", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}], "output_columns": [{"name": "kpi_name", "type": "string", "nullable": false}, {"name": "attempted_sites", "type": "number", "nullable": false}, {"name": "first_time_right_pass_sites", "type": "number", "nullable": false}, {"name": "e911_ftr_rate", "type": "number", "nullable": false}, {"name": "start_date", "type": "null", "nullable": true}, {"name": "end_date", "type": "null", "nullable": true}, {"name": "site_id", "type": "null", "nullable": true}, {"name": "m_market", "type": "null", "nullable": true}, {"name": "rgn_region", "type": "null", "nullable": true}], "sample_output": [], "row_count": 1}', nl_description: 'E911 FTR Rate = (count of distinct sites whose FIRST (earliest) E911 RIOT validation record is PASS/PASS) / (count of distinct sites with ANY E911 RIOT validation attempt). Source of truth is stg_nas_e911_readiness_riot_validation. Attempted sites are those with nas_e911_validation_date IS NOT NULL. First-time-right pass requires nas_validate_e911_readiness = \'PASS\' AND nas_consolidation_check_all_layers = \'PASS\' on the earliest (MIN) nas_e911_validation_date per site. Uses the same filters and site enrichment logic as E911 Readiness Rate; only change vs readiness is MIN(...) instead of MAX(...).', node_type: 'CORE', definition: 'E911 FTR Rate = (count of distinct sites whose FIRST (earliest) E911 RIOT validation record is PASS/PASS) / (count of distinct sites with ANY E911 RIOT validation attempt). Source of truth is stg_nas_e911_readiness_riot_validation. Attempted sites are those with nas_e911_validation_date IS NOT NULL. First-time-right pass requires nas_validate_e911_readiness = \'PASS\' AND nas_consolidation_check_all_layers = \'PASS\' on the earliest (MIN) nas_e911_validation_date per site. Uses the same filters and site enrichment logic as E911 Readiness Rate; only change vs readiness is MIN(...) instead of MAX(...).', kpi_python_function: 'def get_e911_ftr_rate(execute_query, filters=None) -> list[dict]:\n    """E911 FTR Rate computed from RIOT validation table.\n\n    Mirrors the corrected E911 Readiness Rate pattern, except:\n      - uses MIN(nas_e911_validation_date) (first attempt) instead of MAX(...) (latest)\n\n    Numerator: distinct sites whose first validation is PASS/PASS.\n    Denominator: distinct sites with any validation attempt (nas_e911_validation_date IS NOT NULL).\n    """\n\n    filters = filters or {}\n\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n\n    f_site_id = filters.get("site_id") or filters.get("s_site_id")\n    f_market = filters.get("market") or filters.get("m_market")\n    f_region = filters.get("region") or filters.get("rgn_region")\n\n    # Optional enrichment (same approach as prior version)\n    sites = get_site(execute_query, filters=None) or []\n\n    def _to_lower(v):\n        return (str(v).strip().lower()) if v is not None else ""\n\n    site_dim = {}\n    for s in sites:\n        sc = s.get("site_code")\n        if sc:\n            site_dim[sc] = {\n                "rgn_region": s.get("rgn_region"),\n                "m_area": s.get("m_area"),\n                "m_market": s.get("m_market"),\n                "s_state": s.get("s_state"),\n                "s_city": s.get("s_city"),\n            }\n\n    # Build SQL (Tier 2) because RIOT validation table is the required source\n    # Pattern: CTE-free subquery selecting MIN(date) per site, then join back to evaluate pass criteria on that first record.\n    where = ["v.nas_e911_validation_date IS NOT NULL"]\n\n    if start_date:\n        where.append(f"v.nas_e911_validation_date >= \'{str(start_date)}\'")\n    if end_date:\n        where.append(f"v.nas_e911_validation_date <= \'{str(end_date)}\'")\n\n    if f_site_id:\n        # Assumes site identifier column on the table is nas_site_id (aligned with prior KPI usage patterns)\n        where.append(f"v.nas_site_id = \'{str(f_site_id)}\'")\n\n    where_sql = " AND ".join(where)\n\n    sql = f"""\n    SELECT\n      COUNT(DISTINCT v.nas_site_id) AS attempted_sites,\n      COUNT(DISTINCT CASE\n        WHEN v.nas_validate_e911_readiness = \'PASS\'\n         AND v.nas_consolidation_check_all_layers = \'PASS\'\n        THEN v.nas_site_id END) AS first_time_right_pass_sites\n    FROM stg_nas_e911_readiness_riot_validation v\n    INNER JOIN (\n      SELECT\n        nas_site_id,\n        MIN(nas_e911_validation_date) AS first_validation_date\n      FROM stg_nas_e911_readiness_riot_validation\n      WHERE nas_e911_validation_date IS NOT NULL\n      GROUP BY nas_site_id\n    ) first_v\n      ON first_v.nas_site_id = v.nas_site_id\n     AND first_v.first_validation_date = v.nas_e911_validation_date\n    WHERE {where_sql}\n    """\n\n    rows = execute_query(sql) or []\n    r0 = rows[0] if rows else {}\n\n    attempted = r0.get("attempted_sites")\n    ftr_pass = r0.get("first_time_right_pass_sites")\n\n    try:\n        denom = int(attempted) if attempted is not None else 0\n    except Exception:\n        denom = 0\n\n    try:\n        numer = int(ftr_pass) if ftr_pass is not None else 0\n    except Exception:\n        numer = 0\n\n    rate = (float(numer) / float(denom)) if denom else None\n\n    # Apply optional dimension filters that depend on site enrichment (market/region)\n    # We do this post-query by restricting the *reported* population to only matching sites.\n    # To keep the SQL pattern identical to readiness rate (per your instruction), we avoid adding joins/CTEs here.\n    # If market/region filters are provided, we recompute counts by enumerating eligible sites and re-running a constrained query.\n\n    if f_market or f_region:\n        eligible_sites = []\n        for sc, dim in site_dim.items():\n            if f_market:\n                if dim.get("m_market") is None or _to_lower(dim.get("m_market")) != _to_lower(f_market):\n                    continue\n            if f_region:\n                if dim.get("rgn_region") is None or _to_lower(dim.get("rgn_region")) != _to_lower(f_region):\n                    continue\n            eligible_sites.append(sc)\n\n        # If filters eliminate everything, return zeros.\n        if not eligible_sites:\n            denom = 0\n            numer = 0\n            rate = None\n        else:\n            # Re-run with site IN (...) constraint.\n            # Note: chunking omitted for brevity; add if IN list can be large.\n            in_list = ",".join([f"\'{str(x)}\'" for x in eligible_sites])\n            where2 = ["v.nas_e911_validation_date IS NOT NULL", f"v.nas_site_id IN ({in_list})"]\n            if start_date:\n                where2.append(f"v.nas_e911_validation_date >= \'{str(start_date)}\'")\n            if end_date:\n                where2.append(f"v.nas_e911_validation_date <= \'{str(end_date)}\'")\n            if f_site_id:\n                where2.append(f"v.nas_site_id = \'{str(f_site_id)}\'")\n            where2_sql = " AND ".join(where2)\n\n            sql2 = f"""\n            SELECT\n              COUNT(DISTINCT v.nas_site_id) AS attempted_sites,\n              COUNT(DISTINCT CASE\n                WHEN v.nas_validate_e911_readiness = \'PASS\'\n                 AND v.nas_consolidation_check_all_layers = \'PASS\'\n                THEN v.nas_site_id END) AS first_time_right_pass_sites\n            FROM stg_nas_e911_readiness_riot_validation v\n            INNER JOIN (\n              SELECT\n                nas_site_id,\n                MIN(nas_e911_validation_date) AS first_validation_date\n              FROM stg_nas_e911_readiness_riot_validation\n              WHERE nas_e911_validation_date IS NOT NULL\n              GROUP BY nas_site_id\n            ) first_v\n              ON first_v.nas_site_id = v.nas_site_id\n             AND first_v.first_validation_date = v.nas_e911_validation_date\n            WHERE {where2_sql}\n            """\n\n            rows2 = execute_query(sql2) or []\n            rr = rows2[0] if rows2 else {}\n\n            try:\n                denom = int(rr.get("attempted_sites")) if rr.get("attempted_sites") is not None else 0\n            except Exception:\n                denom = 0\n            try:\n                numer = int(rr.get("first_time_right_pass_sites")) if rr.get("first_time_right_pass_sites") is not None else 0\n            except Exception:\n                numer = 0\n            rate = (float(numer) / float(denom)) if denom else None\n\n    out = {\n        "kpi_name": "E911 FTR Rate",\n        "attempted_sites": denom,\n        "first_time_right_pass_sites": numer,\n        "e911_ftr_rate": rate,\n        "start_date": start_date,\n        "end_date": end_date,\n        "site_id": f_site_id,\n        "m_market": f_market,\n        "rgn_region": f_region,\n    }\n\n    return [out]\n', kpi_source_columns: ['stg_nas_log_data.nas_site_id', 'stg_nas_log_data.nas_session_id', 'stg_nas_log_data.nas_activity_type', 'stg_nas_log_data.nas_event_type', 'stg_nas_log_data.nas_event_time', 'stg_ndpd_mbt_tmobile_macro_combined.s_site_id', 'stg_ndpd_mbt_tmobile_macro_combined.m_market', 'stg_ndpd_mbt_tmobile_macro_combined.m_area', 'stg_ndpd_mbt_tmobile_macro_combined.rgn_region'], session_id: '69a3d22f26e208edc083a06e', label: 'E911 FTR Rate', kpi_related_core_node_ids: ['stg_nas_e911_readiness_riot_validation', 'site', 'market', 'project', 'milestone', 'integration_activity', 'person'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'a90dec51-0e24-4d89-9c5e-e153d3cbea93', entity_type: 'kpi', kpi_name: 'E911 FTR Rate', name: 'a90dec51-0e24-4d89-9c5e-e153d3cbea93', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'time_window'], kpi_description: 'Measures the share of sites that pass E911 validation on the first attempt out of all sites where E911 validation has been attempted. This KPI distinguishes clean executions from passes achieved only after rework, helping prioritize corrective actions, highlight recurring readiness issues by market/region/vendor, and reduce cycle-time impacts caused by repeated E911 validation failures.', status: 'mentioned', node_id: 'a90dec51-0e24-4d89-9c5e-e153d3cbea93'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_log_data', 'public.stg_nas_planned_outage_activity', 'public.stg_nas_session_level_combined_data', 'public.stg_tmo_nas_daily_dashboard'], nl_business_rule: '', kpi_formula_description: 'Check-In SLA Rate computed by joining session-level NEST start time from public.stg_nas_session_level_combined_data (s) with check-in time from public.stg_tmo_nas_daily_dashboard (d). Join key: CAST(d.session_id AS TEXT) = CAST(s.nas_session_id AS TEXT) to handle type mismatches. Denominator = COUNT(DISTINCT s.nas_session_id) where d.checkin_latest_start_time IS NOT NULL and s.nas_nest_start_time IS NOT NULL (and optional filters). Numerator = COUNT(DISTINCT s.nas_session_id) from the same population where delta_minutes = EXTRACT(EPOCH FROM (d.checkin_latest_start_time - s.nas_nest_start_time))/60.0 is <= sla_minutes (default 30). Date filters (optional) apply to d.checkin_latest_start_time. Output includes denominator_sessions, numerator_within_sla, check_in_sla_rate, and sla_minutes. No CTEs and no INTERVAL literals.', kpi_output_schema: '[{"column": "metric_name", "type": "string", "description": "Metric identifier (check_in_sla_rate)."}, {"column": "numerator_sessions_within_sla", "type": "integer", "description": "Count of aligned on-site sessions whose check-in occurred within the SLA threshold."}, {"column": "denominator_on_site_sessions", "type": "integer", "description": "Count of aligned on-site sessions included in the calculation."}, {"column": "check_in_sla_rate", "type": "float", "description": "Numerator divided by denominator."}, {"column": "sla_minutes", "type": "integer", "description": "SLA threshold in minutes used for the computation."}]', kpi_business_logic: '1) Select Planned Outage windows with nas_activity_start_date within [start_date, end_date] (and optional site/market/category/company filters). 2) Select Integration Activity sessions for those sites (and optional vendor/company/activity-type filters). 3) From NAS Event Log, find the earliest \'Check-in\' event timestamp per nas_session_id. 4) Align each session to the nearest planned outage start for the same site (by absolute time difference). 5) Optionally restrict to sessions flagged on-site in NAS Daily Dashboard. 6) Denominator = aligned on-site sessions; Numerator = denominator sessions whose check-in is within SLA threshold (outage_start + sla_minutes). 7) Rate = Numerator / Denominator.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Include planned outages whose nas_activity_start_date is on/after this timestamp."}, {"name": "end_date", "type": "date", "description": "Include planned outages whose nas_activity_start_date is on/before this timestamp."}, {"name": "nas_region", "type": "string", "description": "Filter sessions/outages to a NAS region (applied indirectly where available)."}, {"name": "nas_market", "type": "string", "description": "Filter sessions/outages to a NAS market."}, {"name": "nas_site_id", "type": "string", "description": "Filter to a specific site."}, {"name": "nas_project_category", "type": "string", "description": "Filter to a project category."}, {"name": "nas_activity_type", "type": "string", "description": "Filter to an activity type."}, {"name": "nas_vendor_name", "type": "string", "description": "Filter to a vendor (from integration_activity)."}, {"name": "nas_company_name", "type": "string", "description": "Filter to a company (from integration_activity/outage)."}, {"name": "sla_minutes", "type": "integer", "description": "Allowed minutes after scheduled outage start for check-in to still be considered within SLA (default 0)."}, {"name": "require_on_site", "type": "boolean", "description": "If true (default), only include sessions marked on_site in NAS daily dashboard when available."}]', kpi_contract: '{"function_name": "get_check_in_sla_rate", "node_type": "kpi", "node_id": "ab4754a9-dca8-46dc-bf86-c2758dcd703a", "node_label": "Check-In SLA Rate", "description": "Measures the percentage of NAS on-site integration sessions where the engineer check-in occurs within the allowed SLA threshold relative to the scheduled outage start. This indicates operational discipline and effective use of the approved maintenance window, and serves as a leading indicator of capacity strain and process non-adherence by market, vendor/company, and activity type.", "parameters": [{"name": "sla_minutes", "type": "string", "description": "Filter by sla minutes", "required": false, "sample_values": []}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas site id", "required": false, "sample_values": []}, {"name": "nas_market", "type": "string", "description": "Filter by nas market", "required": false, "sample_values": []}, {"name": "nas_project_category", "type": "string", "description": "Filter by nas project category", "required": false, "sample_values": []}, {"name": "nas_company_name", "type": "string", "description": "Filter by nas company name", "required": false, "sample_values": []}, {"name": "nas_vendor_name", "type": "string", "description": "Filter by nas vendor name", "required": false, "sample_values": []}, {"name": "nas_activity_type", "type": "string", "description": "Filter by nas activity type", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "metric_name", "type": "string", "nullable": false}, {"name": "sla_minutes", "type": "number", "nullable": false}, {"name": "denominator_sessions", "type": "number", "nullable": false}, {"name": "numerator_within_sla", "type": "number", "nullable": false}, {"name": "check_in_sla_rate", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'Check-In SLA Rate computed by joining session-level NEST start time from public.stg_nas_session_level_combined_data (s) with check-in time from public.stg_tmo_nas_daily_dashboard (d). Join key: CAST(d.session_id AS TEXT) = CAST(s.nas_session_id AS TEXT) to handle type mismatches. Denominator = COUNT(DISTINCT s.nas_session_id) where d.checkin_latest_start_time IS NOT NULL and s.nas_nest_start_time IS NOT NULL (and optional filters). Numerator = COUNT(DISTINCT s.nas_session_id) from the same population where delta_minutes = EXTRACT(EPOCH FROM (d.checkin_latest_start_time - s.nas_nest_start_time))/60.0 is <= sla_minutes (default 30). Date filters (optional) apply to d.checkin_latest_start_time. Output includes denominator_sessions, numerator_within_sla, check_in_sla_rate, and sla_minutes. No CTEs and no INTERVAL literals.', node_type: 'CORE', definition: 'Check-In SLA Rate computed by joining session-level NEST start time from public.stg_nas_session_level_combined_data (s) with check-in time from public.stg_tmo_nas_daily_dashboard (d). Join key: CAST(d.session_id AS TEXT) = CAST(s.nas_session_id AS TEXT) to handle type mismatches. Denominator = COUNT(DISTINCT s.nas_session_id) where d.checkin_latest_start_time IS NOT NULL and s.nas_nest_start_time IS NOT NULL (and optional filters). Numerator = COUNT(DISTINCT s.nas_session_id) from the same population where delta_minutes = EXTRACT(EPOCH FROM (d.checkin_latest_start_time - s.nas_nest_start_time))/60.0 is <= sla_minutes (default 30). Date filters (optional) apply to d.checkin_latest_start_time. Output includes denominator_sessions, numerator_within_sla, check_in_sla_rate, and sla_minutes. No CTEs and no INTERVAL literals.', kpi_python_function: 'def get_check_in_sla_rate(execute_query, filters=None) -> list[dict]:\n    """Check-In SLA Rate (two-table join).\n\n    Core SQL pattern is intentionally kept identical to the working diagnostic:\n      - same SELECT aggregates\n      - same JOIN with CAST(... AS TEXT)\n      - same EXTRACT(EPOCH...) / 60.0 delta computation\n      - same s.nas_nest_start_time::timestamp cast\n\n    Adds:\n      - sla_minutes parameter (default 30)\n      - optional equality filters on s-dimension columns\n      - optional date range filters on d.checkin_latest_start_time\n\n    No CTEs, no INTERVAL, no additional joins.\n    """\n\n    filters = filters or {}\n    sla_minutes = int(filters.get(\'sla_minutes\', 30))\n\n    def _sql_literal(value):\n        if value is None:\n            return \'NULL\'\n        if isinstance(value, bool):\n            return \'TRUE\' if value else \'FALSE\'\n        if isinstance(value, (int, float)):\n            return str(value)\n        return "\'" + str(value).replace("\'", "\'\'") + "\'"\n\n    where_clauses = [\n        "d.checkin_latest_start_time IS NOT NULL",\n        "s.nas_nest_start_time IS NOT NULL",\n    ]\n\n    # Equality filters on session dimensions\n    eq_map = {\n        \'nas_site_id\': filters.get(\'nas_site_id\'),\n        \'nas_market\': filters.get(\'nas_market\'),\n        \'nas_project_category\': filters.get(\'nas_project_category\'),\n        \'nas_company_name\': filters.get(\'nas_company_name\'),\n        \'nas_vendor_name\': filters.get(\'nas_vendor_name\'),\n        \'nas_activity_type\': filters.get(\'nas_activity_type\'),\n    }\n\n    for col, val in eq_map.items():\n        if val is None or val == \'\':\n            continue\n        where_clauses.append(f"s.{col} = {_sql_literal(val)}")\n\n    # Date range filters on dashboard check-in time\n    start_date = filters.get(\'start_date\')\n    end_date = filters.get(\'end_date\')\n    if start_date:\n        where_clauses.append(f"d.checkin_latest_start_time >= {_sql_literal(start_date)}")\n    if end_date:\n        where_clauses.append(f"d.checkin_latest_start_time < {_sql_literal(end_date)}")\n\n    where_sql = " AND ".join(where_clauses)\n\n    sql = (\n        "SELECT "\n        "COUNT(DISTINCT s.nas_session_id) AS denominator_sessions, "\n        "COUNT(DISTINCT CASE "\n        f"WHEN (EXTRACT(EPOCH FROM (d.checkin_latest_start_time - s.nas_nest_start_time::timestamp)) / 60.0) <= {sla_minutes} "\n        "THEN s.nas_session_id END) AS numerator_within_sla "\n        "FROM stg_nas_session_level_combined_data s "\n        "JOIN stg_tmo_nas_daily_dashboard d "\n        "ON CAST(d.session_id AS TEXT) = CAST(s.nas_session_id AS TEXT) "\n        f"WHERE {where_sql}"\n    )\n\n    rows = execute_query(sql) or []\n    r = rows[0] if rows else {}\n\n    denom = int(r.get("denominator_sessions") or 0)\n    num = int(r.get("numerator_within_sla") or 0)\n    rate = (float(num) / float(denom)) if denom else None\n\n    return [{\n        "metric_name": "check_in_sla_rate",\n        "sla_minutes": sla_minutes,\n        "denominator_sessions": denom,\n        "numerator_within_sla": num,\n        "check_in_sla_rate": rate\n    }]\n', kpi_source_columns: ['stg_nas_log_data.nas_session_id', 'stg_nas_log_data.nas_site_id', 'stg_nas_log_data.nas_event_type', 'stg_nas_log_data.nas_event_time', 'stg_nas_planned_outage_activity.nas_site_id', 'stg_nas_planned_outage_activity.nas_activity_start_date', 'stg_nas_planned_outage_activity.nas_market', 'stg_nas_planned_outage_activity.nas_project_category', 'stg_nas_planned_outage_activity.nas_company_name', 'stg_nas_session_level_combined_data.nas_session_id', 'stg_nas_session_level_combined_data.nas_site_id', 'stg_nas_session_level_combined_data.nas_market', 'stg_nas_session_level_combined_data.nas_vendor_name', 'stg_nas_session_level_combined_data.nas_company_name', 'stg_nas_session_level_combined_data.nas_activity_type', 'stg_tmo_nas_daily_dashboard.session_id', 'stg_tmo_nas_daily_dashboard.on_site'], session_id: '69a3d22f26e208edc083a06e', label: 'Check-In SLA Rate', kpi_related_core_node_ids: ['nas_session_level_combined_data', 'stg_tmo_nas_daily_dashboard', 'integration_activity', 'site', 'market', 'external_vendor', 'person'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'ab4754a9-dca8-46dc-bf86-c2758dcd703a', entity_type: 'kpi', kpi_name: 'Check-In SLA Rate', name: 'ab4754a9-dca8-46dc-bf86-c2758dcd703a', kpi_dimensions: ['nas_region', 'nas_market', 'nas_company_name', 'nas_vendor_name', 'nas_activity_type', 'nas_project_category', 'time_period'], kpi_description: 'Measures the percentage of NAS on-site integration sessions where the engineer check-in occurs within the allowed SLA threshold relative to the scheduled outage start. This indicates operational discipline and effective use of the approved maintenance window, and serves as a leading indicator of capacity strain and process non-adherence by market, vendor/company, and activity type.', status: 'mentioned', node_id: 'ab4754a9-dca8-46dc-bf86-c2758dcd703a'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_nas_log_data', 'public.stg_nas_planned_outage_activity', 'public.stg_tmo_nas_daily_dashboard', 'public.stg_nas_nest_ext_raw_by_session'], nl_business_rule: '', kpi_formula_description: 'Check-Out SLA Rate = (# NAS on-site integration sessions with latest check-out time on/before approved outage end time + approved extension hours) / (# such sessions with a matched approved outage window and a check-out time).', kpi_output_schema: '[{"column": "check_out_sla_rate", "type": "float", "description": "Share of sessions that checked out on/before approved outage end (including extensions if extension hours are available)."}, {"column": "sessions_in_scope", "type": "integer", "description": "Count of sessions included in the denominator (must have a check-out event and a matched planned outage window)."}, {"column": "sessions_on_time", "type": "integer", "description": "Count of sessions meeting the SLA (on-time checkout)."}, {"column": "sessions_late", "type": "integer", "description": "Count of sessions breaching the SLA (late checkout)."}]', kpi_business_logic: '1) Identify NAS integration sessions in scope by finding the latest \'check-out\' event per nas_session_id from NAS Event Log within optional date/site/market/region filters. 2) For each session, match an approved outage window by selecting a Planned Outage for the same nas_site_id whose start/end overlaps the session check-out time (or nearest end time if none overlap). 3) Determine approved outage end as nas_activity_end_date plus any extension hours (prefer nest_extension_hrs from NAS Daily Dashboard; if unavailable, treat extension duration as 0 while still allowing a flag that an extension existed). 4) Mark session on-time if checkout_time <= approved_end_with_extensions, else late. 5) Compute rate as on_time_sessions / sessions_in_scope; optionally return grouped results by region/market/site.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Include only sessions whose check-out event_time is on/after this timestamp."}, {"name": "end_date", "type": "date", "description": "Include only sessions whose check-out event_time is on/before this timestamp."}, {"name": "nas_site_id", "type": "string", "description": "Restrict to a specific site (maps to nas_site_id/site_id)."}, {"name": "nas_market", "type": "string", "description": "Restrict to a specific NAS market."}, {"name": "nas_region", "type": "string", "description": "Restrict to a specific NAS region."}, {"name": "nas_session_id", "type": "string", "description": "Restrict to a specific NAS session id."}, {"name": "group_by", "type": "string", "description": "Optional aggregation dimension: one of [\'nas_market\',\'nas_region\',\'nas_site_id\']."}]', kpi_contract: '{"function_name": "get_check_out_sla_rate", "node_type": "kpi", "node_id": "11e30252-98cd-42c0-be71-ea837f02e3c6", "node_label": "Check-Out SLA Rate", "description": "Measures the share of NAS on-site integration sessions that check out on or before the approved outage window end (including any approved extensions). This KPI surfaces outage governance risk and vendor/market non-adherence patterns, enabling sustained-breach detection and escalation when repeated overruns occur.", "parameters": [{"name": "sla_minutes", "type": "string", "description": "Filter by sla minutes", "required": false, "sample_values": []}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas site id", "required": false, "sample_values": []}, {"name": "nas_market", "type": "string", "description": "Filter by nas market", "required": false, "sample_values": []}, {"name": "nas_project_category", "type": "string", "description": "Filter by nas project category", "required": false, "sample_values": []}, {"name": "nas_company_name", "type": "string", "description": "Filter by nas company name", "required": false, "sample_values": []}, {"name": "nas_vendor_name", "type": "string", "description": "Filter by nas vendor name", "required": false, "sample_values": []}, {"name": "nas_activity_type", "type": "string", "description": "Filter by nas activity type", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "metric_name", "type": "string", "nullable": false}, {"name": "sla_minutes", "type": "number", "nullable": false}, {"name": "denominator_sessions", "type": "number", "nullable": false}, {"name": "numerator_within_sla", "type": "number", "nullable": false}, {"name": "check_out_sla_rate", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'Check-Out SLA Rate = (# NAS on-site integration sessions with latest check-out time on/before approved outage end time + approved extension hours) / (# such sessions with a matched approved outage window and a check-out time).', node_type: 'CORE', definition: 'Check-Out SLA Rate = (# NAS on-site integration sessions with latest check-out time on/before approved outage end time + approved extension hours) / (# such sessions with a matched approved outage window and a check-out time).', kpi_python_function: 'def get_check_out_sla_rate(execute_query, filters=None) -> list[dict]:\n    """Check-Out SLA Rate (two-table join, no CTEs, no INTERVAL).\n\n    Source tables:\n      - stg_nas_session_level_combined_data s (NEST start time + approved duration)\n      - stg_tmo_nas_daily_dashboard d (checkout timestamp)\n\n    Denominator: sessions with non-null checkout_os, nas_nest_start_time, nas_nest_time_requested_cng\n    Numerator: sessions where checkout <= window end (nest_start + requested_minutes), plus sla_minutes tolerance\n\n    Filters (optional):\n      - nas_site_id, nas_market, nas_project_category, nas_company_name,\n        nas_vendor_name, nas_activity_type (equality on session table)\n      - start_date / end_date (applied to d.checkout_os)\n      - sla_minutes: default 0\n    """\n\n    filters = filters or {}\n    sla_minutes = int(filters.get(\'sla_minutes\', 0))\n\n    def _sql_literal(value):\n        if value is None:\n            return \'NULL\'\n        if isinstance(value, (int, float)):\n            return str(value)\n        return "\'" + str(value).replace("\'", "\'\'") + "\'"\n\n    where_clauses = [\n        "d.checkout_os IS NOT NULL",\n        "s.nas_nest_start_time IS NOT NULL",\n        "s.nas_nest_time_requested_cng IS NOT NULL",\n    ]\n\n    eq_map = {\n        \'nas_site_id\': filters.get(\'nas_site_id\'),\n        \'nas_market\': filters.get(\'nas_market\'),\n        \'nas_project_category\': filters.get(\'nas_project_category\'),\n        \'nas_company_name\': filters.get(\'nas_company_name\'),\n        \'nas_vendor_name\': filters.get(\'nas_vendor_name\'),\n        \'nas_activity_type\': filters.get(\'nas_activity_type\'),\n    }\n\n    for col, val in eq_map.items():\n        if val is None or val == \'\':\n            continue\n        where_clauses.append(f"s.{col} = {_sql_literal(val)}")\n\n    start_date = filters.get(\'start_date\')\n    end_date = filters.get(\'end_date\')\n    if start_date:\n        where_clauses.append(f"d.checkout_os >= {_sql_literal(start_date)}")\n    if end_date:\n        where_clauses.append(f"d.checkout_os < {_sql_literal(end_date)}")\n\n    where_sql = " AND ".join(where_clauses)\n\n    sql = (\n        "SELECT "\n        "COUNT(DISTINCT s.nas_session_id) AS denominator_sessions, "\n        "COUNT(DISTINCT CASE "\n        "WHEN ((EXTRACT(EPOCH FROM d.checkout_os) - "\n        "(EXTRACT(EPOCH FROM s.nas_nest_start_time::timestamp) + "\n        f"CAST(s.nas_nest_time_requested_cng AS NUMERIC) * 60)) / 60.0) <= {sla_minutes} "\n        "THEN s.nas_session_id END) AS numerator_within_sla "\n        "FROM stg_nas_session_level_combined_data s "\n        "JOIN stg_tmo_nas_daily_dashboard d "\n        "ON CAST(d.session_id AS TEXT) = CAST(s.nas_session_id AS TEXT) "\n        f"WHERE {where_sql}"\n    )\n\n    rows = execute_query(sql) or []\n    r = rows[0] if rows else {}\n\n    denom = int(r.get("denominator_sessions") or 0)\n    num = int(r.get("numerator_within_sla") or 0)\n    rate = (float(num) / float(denom)) if denom else None\n\n    return [{\n        "metric_name": "check_out_sla_rate",\n        "sla_minutes": sla_minutes,\n        "denominator_sessions": denom,\n        "numerator_within_sla": num,\n        "check_out_sla_rate": rate\n    }]\n', kpi_source_columns: ['stg_nas_log_data.nas_session_id', 'stg_nas_log_data.nas_site_id', 'stg_nas_log_data.nas_market', 'stg_nas_log_data.nas_region', 'stg_nas_log_data.nas_event_type', 'stg_nas_log_data.nas_event_time', 'stg_nas_planned_outage_activity.nas_site_id', 'stg_nas_planned_outage_activity.nas_activity_start_date', 'stg_nas_planned_outage_activity.nas_activity_end_date', 'stg_nas_planned_outage_activity.nas_status', 'stg_tmo_nas_daily_dashboard.session_id', 'stg_tmo_nas_daily_dashboard.site_id', 'stg_tmo_nas_daily_dashboard.checkout_os', 'stg_tmo_nas_daily_dashboard.initial_nest_approved', 'stg_tmo_nas_daily_dashboard.nest_extension_hrs', 'stg_nas_nest_ext_raw_by_session.nas_session_id', 'stg_nas_nest_ext_raw_by_session.nas_date_requested'], session_id: '69a3d22f26e208edc083a06e', label: 'Check-Out SLA Rate', kpi_related_core_node_ids: ['planned_outage', 'nas_event_log_event', 'nest_extension', 'integration_activity', 'site'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '11e30252-98cd-42c0-be71-ea837f02e3c6', entity_type: 'kpi', kpi_name: 'Check-Out SLA Rate', name: '11e30252-98cd-42c0-be71-ea837f02e3c6', kpi_dimensions: ['nas_region', 'nas_market', 'nas_site_id', 'time_period'], kpi_description: 'Measures the share of NAS on-site integration sessions that check out on or before the approved outage window end (including any approved extensions). This KPI surfaces outage governance risk and vendor/market non-adherence patterns, enabling sustained-breach detection and escalation when repeated overruns occur.', status: 'mentioned', node_id: '11e30252-98cd-42c0-be71-ea837f02e3c6'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'RF010 Overdue Count = count(distinct pj_project_id) where integration_start (pj_a_5270_integration_start_finish) is not null AND planned_technologies_integrated (ms_1899_all_planned_technologies_integrated_actual) is null AND (now - integration_start) > overdue_days, grouped by region/area/market/GC.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension (nullable for overall total row)."}, {"column": "m_area", "type": "string", "description": "Area dimension (nullable for overall total row)."}, {"column": "m_market", "type": "string", "description": "Market dimension (nullable for overall total row)."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension as stored on the project record (nullable for overall total row)."}, {"column": "overdue_days_threshold", "type": "integer", "description": "The overdue-days threshold used in the calculation."}, {"column": "rf010_overdue_project_count", "type": "float", "description": "Distinct count of overdue projects for the dimension slice."}]', kpi_business_logic: '1) Start from the macro combined project table (one row per project).\n2) Apply optional filters for rgn_region, m_area, m_market, construction_gc and optional integration-start date range.\n3) Keep projects where pj_a_5270_integration_start_finish is populated (integration has started).\n4) Exclude projects where ms_1899_all_planned_technologies_integrated_actual is populated (milestone completed).\n5) Compute days_since_start = (NOW() - integration_start) in days using EXTRACT(EPOCH)/86400 and keep only days_since_start > overdue_days (configurable, default 7).\n6) Count distinct pj_project_id overall and by (rgn_region, m_area, m_market, construction_gc).', kpi_filters: '[{"name": "overdue_days", "type": "integer", "description": "Number of days after integration start beyond which a project is considered overdue (default 7)."}, {"name": "start_date", "type": "date", "description": "Include only projects with integration start timestamp >= start_date."}, {"name": "end_date", "type": "date", "description": "Include only projects with integration start timestamp <= end_date."}, {"name": "rgn_region", "type": "string", "description": "Filter to a specific region."}, {"name": "m_area", "type": "string", "description": "Filter to a specific area."}, {"name": "m_market", "type": "string", "description": "Filter to a specific market."}, {"name": "construction_gc", "type": "string", "description": "Filter to a specific general contractor (free-text in source)."}]', kpi_contract: '{"function_name": "get_rf010_overdue_count", "node_type": "kpi", "node_id": "00ca1547-a729-48d4-85da-2e886c6630a2", "node_label": "RF010 Overdue Count", "description": "Counts distinct projects where integration has started but the planned-technologies-integrated completion milestone is still missing beyond a configurable number of days since integration start. This matters because it identifies the overdue population that triggers the RF010 Delivery Delay escalation and indicates near-term on-air slippage risk. Intended to be sliced by region/area/market and general contractor for accountability and escalation routing.", "parameters": [{"name": "overdue_days", "type": "string", "description": "Filter by overdue days", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "null", "nullable": true}, {"name": "m_area", "type": "null", "nullable": true}, {"name": "m_market", "type": "null", "nullable": true}, {"name": "construction_gc", "type": "null", "nullable": true}, {"name": "overdue_days_threshold", "type": "number", "nullable": false}, {"name": "rf010_overdue_project_count", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'RF010 Overdue Count = count(distinct pj_project_id) where integration_start (pj_a_5270_integration_start_finish) is not null AND planned_technologies_integrated (ms_1899_all_planned_technologies_integrated_actual) is null AND (now - integration_start) > overdue_days, grouped by region/area/market/GC.', node_type: 'CORE', definition: 'RF010 Overdue Count = count(distinct pj_project_id) where integration_start (pj_a_5270_integration_start_finish) is not null AND planned_technologies_integrated (ms_1899_all_planned_technologies_integrated_actual) is null AND (now - integration_start) > overdue_days, grouped by region/area/market/GC.', kpi_python_function: 'def get_rf010_overdue_count(execute_query, filters=None) -> list[dict]:\n    """RF010 Overdue Count\n\n    Counts distinct projects where integration has started but the\n    \'all planned technologies integrated\' milestone is still missing AND the\n    project is overdue by > N days from integration start.\n\n    Filters (allowlist only):\n      - start_date (date/datetime string): restricts integration start to >= this\n      - end_date (date/datetime string): restricts integration start to <= this\n      - rgn_region (string)\n      - m_area (string)\n      - m_market (string)\n      - construction_gc (string)\n      - overdue_days (int, default 7)\n\n    Output grain: one row per (region, area, market, general_contractor) plus overall total.\n    """\n\n    filters = filters or {}\n\n    # configurable threshold (days since integration start)\n    try:\n        overdue_days = int(filters.get(\'overdue_days\', 7))\n    except Exception:\n        overdue_days = 7\n\n    # Core KPI conditions must always be present so WHERE is always emitted.\n    # Note: use epoch arithmetic; no INTERVAL literals.\n    where_parts = [\n        \'"pj_a_5270_integration_start_finish" IS NOT NULL\',\n        \'"ms_1899_all_planned_technologies_integrated_actual" IS NULL\',\n        f\'(EXTRACT(EPOCH FROM (NOW() - ("pj_a_5270_integration_start_finish"::timestamp))) / 86400.0) > {overdue_days}\',\n    ]\n\n    # allowlisted dimensional filters\n    if filters.get(\'rgn_region\'):\n        v = str(filters[\'rgn_region\']).replace("\'", "\'\'")\n        where_parts.append(f\'"rgn_region" = \\\'{v}\\\'\')\n    if filters.get(\'m_area\'):\n        v = str(filters[\'m_area\']).replace("\'", "\'\'")\n        where_parts.append(f\'"m_area" = \\\'{v}\\\'\')\n    if filters.get(\'m_market\'):\n        v = str(filters[\'m_market\']).replace("\'", "\'\'")\n        where_parts.append(f\'"m_market" = \\\'{v}\\\'\')\n    if filters.get(\'construction_gc\'):\n        v = str(filters[\'construction_gc\']).replace("\'", "\'\'")\n        where_parts.append(f\'"construction_gc" = \\\'{v}\\\'\')\n\n    # allowlisted date range filters apply to integration start\n    # (stored in a milestone column; cast defensively)\n    if filters.get(\'start_date\'):\n        v = str(filters[\'start_date\']).replace("\'", "\'\'")\n        where_parts.append(f\'("pj_a_5270_integration_start_finish"::timestamp) >= \\\'{v}\\\'::timestamp\')\n    if filters.get(\'end_date\'):\n        v = str(filters[\'end_date\']).replace("\'", "\'\'")\n        where_parts.append(f\'("pj_a_5270_integration_start_finish"::timestamp) <= \\\'{v}\\\'::timestamp\')\n\n    where_clause = "WHERE " + " AND ".join(where_parts)\n\n    # Single-table query (no JOIN needed)\n    sql = f"""\n        SELECT\n            \\"pj_project_id\\" AS project_id,\n            \\"rgn_region\\" AS rgn_region,\n            \\"m_area\\" AS m_area,\n            \\"m_market\\" AS m_market,\n            \\"construction_gc\\" AS construction_gc\n        FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"\n        {where_clause}\n    """\n\n    rows = execute_query(sql)\n\n    # Aggregate distinct projects by requested escalation/accountability dimensions.\n    by_dim = {}\n    overall_projects = set()\n\n    for r in rows or []:\n        pid = r.get(\'project_id\')\n        if pid is None:\n            continue\n        overall_projects.add(pid)\n\n        key = (\n            r.get(\'rgn_region\'),\n            r.get(\'m_area\'),\n            r.get(\'m_market\'),\n            r.get(\'construction_gc\')\n        )\n        if key not in by_dim:\n            by_dim[key] = set()\n        by_dim[key].add(pid)\n\n    out = []\n    # overall total row\n    out.append({\n        \'rgn_region\': None,\n        \'m_area\': None,\n        \'m_market\': None,\n        \'construction_gc\': None,\n        \'overdue_days_threshold\': overdue_days,\n        \'rf010_overdue_project_count\': float(len(overall_projects))\n    })\n\n    # dimensional rows\n    for (rgn_region, m_area, m_market, gc), pset in sorted(\n        by_dim.items(),\n        key=lambda x: (str(x[0][0]), str(x[0][1]), str(x[0][2]), str(x[0][3]))\n    ):\n        out.append({\n            \'rgn_region\': rgn_region,\n            \'m_area\': m_area,\n            \'m_market\': m_market,\n            \'construction_gc\': gc,\n            \'overdue_days_threshold\': overdue_days,\n            \'rf010_overdue_project_count\': float(len(pset))\n        })\n\n    return out\n', kpi_source_columns: ['pj_project_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_a_5270_integration_start_finish', 'ms_1899_all_planned_technologies_integrated_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'RF010 Overdue Count', kpi_related_core_node_ids: ['integration_artifact', 'project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '00ca1547-a729-48d4-85da-2e886c6630a2', entity_type: 'kpi', kpi_name: 'RF010 Overdue Count', name: '00ca1547-a729-48d4-85da-2e886c6630a2', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Counts distinct projects where integration has started but the planned-technologies-integrated completion milestone is still missing beyond a configurable number of days since integration start. This matters because it identifies the overdue population that triggers the RF010 Delivery Delay escalation and indicates near-term on-air slippage risk. Intended to be sliced by region/area/market and general contractor for accountability and escalation routing.', status: 'mentioned', node_id: '00ca1547-a729-48d4-85da-2e886c6630a2'});
CREATE (:BKGNode {kpi_source_tables: ['stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'RF010 Completion Rate = (# distinct projects with integration start in period and ms_1899_all_planned_technologies_integrated_actual populated) ÷ (# distinct projects with integration start in period), grouped by region/area/market/general contractor.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension (as recorded on the project)."}, {"column": "integration_started_projects", "type": "int", "description": "Denominator: distinct projects with integration start in the selected period."}, {"column": "planned_technologies_integrated_projects", "type": "int", "description": "Numerator: distinct projects in denominator with planned technologies integrated milestone completed."}, {"column": "rf010_completion_rate", "type": "float", "description": "Numerator divided by denominator; null when denominator is 0."}]', kpi_business_logic: '1) Pull project-level integration milestone fields from Integration Artifact (wide project table). 2) Denominator set: projects where pj_a_5270_integration_start_finish exists and falls within [start_date, end_date] (if provided). 3) Numerator set: subset of denominator where ms_1899_all_planned_technologies_integrated_actual is not null. 4) Group by rgn_region, m_area, m_market, construction_gc and compute rate = numerator/denominator; also return numerator and denominator counts.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Start of integration-start window (inclusive) applied to pj_a_5270_integration_start_finish."}, {"name": "end_date", "type": "date", "description": "End of integration-start window (inclusive) applied to pj_a_5270_integration_start_finish."}, {"name": "rgn_region", "type": "string", "description": "Limit KPI to a specific region."}, {"name": "m_area", "type": "string", "description": "Limit KPI to a specific area."}, {"name": "m_market", "type": "string", "description": "Limit KPI to a specific market."}, {"name": "construction_gc", "type": "string", "description": "Limit KPI to a specific general contractor (free-text field)."}, {"name": "pj_project_status", "type": "string", "description": "Optional filter on project status (e.g., Active/Dead)."}, {"name": "por_category", "type": "string", "description": "Optional filter on POR category (e.g., LTW/NTM)."}]', kpi_contract: '{"function_name": "get_rf010_completion_rate", "node_type": "kpi", "node_id": "97e41968-84fe-434d-823e-2fae706ce764", "node_label": "RF010 Completion Rate", "description": "Measures the share of projects that have completed the planned-technologies-integrated milestone among all projects that have started integration within the selected period. This matters because it quantifies integration throughput and predictability, enabling early detection of delivery slowdowns by market, region, and general contractor.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "pj_project_status", "type": "string", "description": "Filter by pj project status", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "integration_started_projects", "type": "number", "nullable": false}, {"name": "planned_technologies_integrated_projects", "type": "number", "nullable": false}, {"name": "rf010_completion_rate", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'RF010 Completion Rate = (# distinct projects with integration start in period and ms_1899_all_planned_technologies_integrated_actual populated) ÷ (# distinct projects with integration start in period), grouped by region/area/market/general contractor.', node_type: 'CORE', definition: 'RF010 Completion Rate = (# distinct projects with integration start in period and ms_1899_all_planned_technologies_integrated_actual populated) ÷ (# distinct projects with integration start in period), grouped by region/area/market/general contractor.', kpi_python_function: 'def get_rf010_completion_rate(execute_query, filters=None) -> list[dict]:\n    """RF010 Completion Rate\n\n    Share of projects that completed \'All planned technologies integrated\' among projects\n    that started integration within the selected period.\n\n    Numerator: count(distinct pj_project_id) with ms_1899_all_planned_technologies_integrated_actual NOT NULL\n               AND integration start timestamp within [start_date, end_date]\n    Denominator: count(distinct pj_project_id) with integration start timestamp within [start_date, end_date]\n\n    Dimensions: rgn_region, m_area, m_market, construction_gc\n\n    Filters (allowlist): start_date, end_date, rgn_region, m_area, m_market, construction_gc, pj_project_status, por_category\n    """\n\n    # Use Integration Artifact node because it exposes both integration start and planned-tech completion milestone.\n    rows = get_integration_artifact(execute_query, filters=None)\n\n    # ---- helpers ----\n    def _to_ts(val):\n        if val is None:\n            return None\n        s = str(val).strip()\n        if not s:\n            return None\n        # Best-effort parsing without external libs\n        # Expected forms: \'YYYY-MM-DD\' or \'YYYY-MM-DD HH:MM:SS\' (possibly with timezone)\n        try:\n            # Python 3.11+ supports fromisoformat for many variants\n            from datetime import datetime\n            s2 = s.replace(\'Z\', \'+00:00\')\n            return datetime.fromisoformat(s2)\n        except Exception:\n            # Fallback: try common \'YYYY-MM-DD HH:MM:SS\'\n            try:\n                from datetime import datetime\n                return datetime.strptime(s[:19], \'%Y-%m-%d %H:%M:%S\')\n            except Exception:\n                try:\n                    from datetime import datetime\n                    return datetime.strptime(s[:10], \'%Y-%m-%d\')\n                except Exception:\n                    return None\n\n    from datetime import datetime\n\n    start_dt = None\n    end_dt = None\n    if filters:\n        if filters.get(\'start_date\'):\n            start_dt = _to_ts(filters.get(\'start_date\'))\n        if filters.get(\'end_date\'):\n            end_dt = _to_ts(filters.get(\'end_date\'))\n            # If end_date provided as a date (no time), treat as inclusive end-of-day\n            if end_dt and len(str(filters.get(\'end_date\')).strip()) <= 10:\n                end_dt = end_dt.replace(hour=23, minute=59, second=59)\n\n    def _matches_dim_filters(r):\n        if not filters:\n            return True\n        if filters.get(\'rgn_region\') and str(r.get(\'rgn_region\')) != str(filters.get(\'rgn_region\')):\n            return False\n        if filters.get(\'m_area\') and str(r.get(\'m_area\')) != str(filters.get(\'m_area\')):\n            return False\n        if filters.get(\'m_market\') and str(r.get(\'m_market\')) != str(filters.get(\'m_market\')):\n            return False\n        if filters.get(\'construction_gc\') and str(r.get(\'construction_gc\')) != str(filters.get(\'construction_gc\')):\n            return False\n        if filters.get(\'pj_project_status\') and str(r.get(\'pj_project_status\')) != str(filters.get(\'pj_project_status\')):\n            return False\n        if filters.get(\'por_category\') and str(r.get(\'por_category\')) != str(filters.get(\'por_category\')):\n            return False\n        return True\n\n    def _in_range(dt):\n        if dt is None:\n            return False\n        if start_dt and dt < start_dt:\n            return False\n        if end_dt and dt > end_dt:\n            return False\n        return True\n\n    # ---- aggregate ----\n    # group_key -> {\'started_projects\': set(), \'completed_projects\': set()}\n    groups = {}\n\n    for r in rows:\n        if not _matches_dim_filters(r):\n            continue\n\n        project_id = r.get(\'pj_project_id\')\n        if not project_id:\n            continue\n\n        # Integration start for denominator\n        integ_start = _to_ts(r.get(\'pj_a_5270_integration_start_finish\'))\n        if not _in_range(integ_start):\n            continue\n\n        # Dimensional attributes\n        key = (\n            r.get(\'rgn_region\'),\n            r.get(\'m_area\'),\n            r.get(\'m_market\'),\n            r.get(\'construction_gc\')\n        )\n\n        if key not in groups:\n            groups[key] = {\n                \'started_projects\': set(),\n                \'completed_projects\': set()\n            }\n\n        groups[key][\'started_projects\'].add(project_id)\n\n        # Numerator condition: planned-technologies-integrated milestone completed (timestamp exists)\n        planned_tech_done = _to_ts(r.get(\'ms_1899_all_planned_technologies_integrated_actual\'))\n        if planned_tech_done is not None:\n            groups[key][\'completed_projects\'].add(project_id)\n\n    # ---- format output ----\n    out = []\n    for (rgn_region, m_area, m_market, construction_gc), agg in groups.items():\n        denom = len(agg[\'started_projects\'])\n        numer = len(agg[\'completed_projects\'])\n        rate = (float(numer) / float(denom)) if denom else None\n\n        out.append({\n            \'rgn_region\': rgn_region,\n            \'m_area\': m_area,\n            \'m_market\': m_market,\n            \'construction_gc\': construction_gc,\n            \'integration_started_projects\': denom,\n            \'planned_technologies_integrated_projects\': numer,\n            \'rf010_completion_rate\': rate\n        })\n\n    # Stable ordering for BI consumers\n    out.sort(key=lambda x: (\n        str(x.get(\'rgn_region\') or \'\'),\n        str(x.get(\'m_area\') or \'\'),\n        str(x.get(\'m_market\') or \'\'),\n        str(x.get(\'construction_gc\') or \'\')\n    ))\n\n    return out\n', kpi_source_columns: ['pj_project_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_status', 'por_category', 'pj_a_5270_integration_start_finish', 'ms_1899_all_planned_technologies_integrated_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'RF010 Completion Rate', kpi_related_core_node_ids: ['integration_artifact', 'project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '97e41968-84fe-434d-823e-2fae706ce764', entity_type: 'kpi', kpi_name: 'RF010 Completion Rate', name: '97e41968-84fe-434d-823e-2fae706ce764', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Measures the share of projects that have completed the planned-technologies-integrated milestone among all projects that have started integration within the selected period. This matters because it quantifies integration throughput and predictability, enabling early detection of delivery slowdowns by market, region, and general contractor.', status: 'mentioned', node_id: '97e41968-84fe-434d-823e-2fae706ce764'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Document Gate Compliance backlog counts Active projects that are stuck at the pre-construction document gate, computed as: (1) arrived_not_validated_count = distinct Active projects with ms_1310_pre_construction_package_received_actual not null AND ms_1313_pre_construction_package_validated_actual is null AND ms_1315_pre_construction_package_rejected_actual is null; plus (2) rejected_without_subsequent_validation_count = distinct Active projects with ms_1315_pre_construction_package_rejected_actual not null AND (ms_1313_pre_construction_package_validated_actual is null OR ms_1313_pre_construction_package_validated_actual::timestamp <= ms_1315_pre_construction_package_rejected_actual::timestamp). The output is grouped by an optional group_by dimension list (default: rgn_region, m_area, m_market; optional additionally: construction_gc).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension from the project record."}, {"column": "m_area", "type": "string", "description": "Area dimension from the project record."}, {"column": "m_market", "type": "string", "description": "Market dimension from the project record."}, {"column": "arrived_not_validated_count", "type": "integer", "description": "Distinct active projects where the pre-con package has been received but neither validated nor rejected."}, {"column": "rejected_without_subsequent_validation_count", "type": "integer", "description": "Distinct active projects where the pre-con package has been rejected and has not been validated after that rejection."}, {"column": "document_gate_backlog_total_count", "type": "integer", "description": "Distinct active projects meeting either backlog condition (union of the two states)."}]', kpi_business_logic: 'Filter source rows to pj_project_status = \'Active\'.\nOptionally filter by start_date/end_date such that either package received timestamp OR package rejected timestamp falls within the provided bounds.\nOptionally filter by rgn_region, m_area, m_market, construction_gc, pj_project_type, por_category, s_site_id, pj_project_id when provided.\nDetermine grouping dimensions from filters[\'group_by\']; default to [\'rgn_region\',\'m_area\',\'m_market\']; allow rgn_region, m_area, m_market, construction_gc only.\nCompute arrived_not_validated_count as COUNT(DISTINCT pj_project_id) where received_actual is not null AND validated_actual is null AND rejected_actual is null.\nCompute rejected_without_subsequent_validation_count as COUNT(DISTINCT pj_project_id) where rejected_actual is not null AND (validated_actual is null OR validated_ts <= rejected_ts), treating a later rejection as superseding any earlier validation.\nCompute document_gate_backlog_total_count as COUNT(DISTINCT pj_project_id) where either of the above conditions is true (union of the two sets).\nReturn the grouped rows ordered by the same group_by dimensions.', kpi_filters: '[{"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_project_type", "type": "string", "description": ""}, {"name": "por_category", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "group_by", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_document_gate_compliance", "node_type": "kpi", "node_id": "2802fe3a-0451-46ff-849f-7c302aa99335", "node_label": "Document Gate Compliance", "description": "Tracks how many active projects are stuck at the pre-construction document gate after the package has arrived but has not been validated, and how many active projects have had the package rejected without subsequent validation. This highlights process/compliance bottlenecks and audit risk, and is used to trigger Process & Compliance escalation when backlog grows.", "parameters": [{"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "pj_project_type", "type": "string", "description": "Filter by pj project type", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "arrived_not_validated_count", "type": "number", "nullable": false}, {"name": "rejected_without_subsequent_validation_count", "type": "number", "nullable": false}, {"name": "document_gate_backlog_total_count", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Document Gate Compliance backlog counts Active projects that are stuck at the pre-construction document gate, computed as: (1) arrived_not_validated_count = distinct Active projects with ms_1310_pre_construction_package_received_actual not null AND ms_1313_pre_construction_package_validated_actual is null AND ms_1315_pre_construction_package_rejected_actual is null; plus (2) rejected_without_subsequent_validation_count = distinct Active projects with ms_1315_pre_construction_package_rejected_actual not null AND (ms_1313_pre_construction_package_validated_actual is null OR ms_1313_pre_construction_package_validated_actual::timestamp <= ms_1315_pre_construction_package_rejected_actual::timestamp). The output is grouped by an optional group_by dimension list (default: rgn_region, m_area, m_market; optional additionally: construction_gc).', node_type: 'CORE', definition: 'Document Gate Compliance backlog counts Active projects that are stuck at the pre-construction document gate, computed as: (1) arrived_not_validated_count = distinct Active projects with ms_1310_pre_construction_package_received_actual not null AND ms_1313_pre_construction_package_validated_actual is null AND ms_1315_pre_construction_package_rejected_actual is null; plus (2) rejected_without_subsequent_validation_count = distinct Active projects with ms_1315_pre_construction_package_rejected_actual not null AND (ms_1313_pre_construction_package_validated_actual is null OR ms_1313_pre_construction_package_validated_actual::timestamp <= ms_1315_pre_construction_package_rejected_actual::timestamp). The output is grouped by an optional group_by dimension list (default: rgn_region, m_area, m_market; optional additionally: construction_gc).', kpi_python_function: 'def get_document_gate_compliance(execute_query, filters=None) -> list[dict]:\n    """KPI: Document Gate Compliance backlog for active projects.\n\n    Returns counts of active projects stuck at the pre-con doc gate, grouped by requested dimensions.\n\n    Supported group_by dimensions (via filters[\'group_by\']):\n      - rgn_region\n      - m_area\n      - m_market\n      - construction_gc\n\n    If group_by is not provided, defaults to [\'rgn_region\', \'m_area\', \'m_market\'].\n    """\n\n    filters = filters or {}\n\n    # --- Dimensions (optional) ---\n    allowed_group_by = {\n        \'rgn_region\': \'"rgn_region"\',\n        \'m_area\': \'"m_area"\',\n        \'m_market\': \'"m_market"\',\n        \'construction_gc\': \'"construction_gc"\',\n    }\n\n    group_by = filters.get(\'group_by\')\n    if group_by is None:\n        group_by = [\'rgn_region\', \'m_area\', \'m_market\']\n    elif isinstance(group_by, str):\n        group_by = [group_by]\n\n    # validate group_by\n    for d in group_by:\n        if d not in allowed_group_by:\n            raise ValueError(\n                f"Unsupported group_by dimension: {d}. Allowed: {sorted(allowed_group_by.keys())}"\n            )\n\n    select_dim_sql = ", ".join([f"{allowed_group_by[d]} AS \\"{d}\\"" for d in group_by])\n    group_by_sql = ", ".join([allowed_group_by[d] for d in group_by])\n    order_by_sql = ", ".join([allowed_group_by[d] for d in group_by])\n\n    # --- WHERE clause ---\n    where_parts = [\'"pj_project_status" = \\\'Active\\\'\']\n\n    # Allowlist filters (explicit)\n    if filters.get(\'start_date\'):\n        sd = str(filters[\'start_date\']).replace("\'", "\'\'")\n        # Gate is triggered by package arrival OR rejection; include if either occurs in range\n        where_parts.append(\n            "(\\"ms_1310_pre_construction_package_received_actual\\"::timestamp >= \'" + sd + "\'::timestamp "\n            "OR \\"ms_1315_pre_construction_package_rejected_actual\\"::timestamp >= \'" + sd + "\'::timestamp)"\n        )\n\n    if filters.get(\'end_date\'):\n        ed = str(filters[\'end_date\']).replace("\'", "\'\'")\n        where_parts.append(\n            "(\\"ms_1310_pre_construction_package_received_actual\\"::timestamp <= \'" + ed + "\'::timestamp "\n            "OR \\"ms_1315_pre_construction_package_rejected_actual\\"::timestamp <= \'" + ed + "\'::timestamp)"\n        )\n\n    if filters.get(\'rgn_region\'):\n        rr = str(filters[\'rgn_region\']).replace("\'", "\'\'")\n        where_parts.append(f\'"rgn_region" = \\\'{rr}\\\'\')\n\n    if filters.get(\'m_area\'):\n        ma = str(filters[\'m_area\']).replace("\'", "\'\'")\n        where_parts.append(f\'"m_area" = \\\'{ma}\\\'\')\n\n    if filters.get(\'m_market\'):\n        mm = str(filters[\'m_market\']).replace("\'", "\'\'")\n        where_parts.append(f\'"m_market" = \\\'{mm}\\\'\')\n\n    if filters.get(\'construction_gc\'):\n        gc = str(filters[\'construction_gc\']).replace("\'", "\'\'")\n        where_parts.append(f\'"construction_gc" = \\\'{gc}\\\'\')\n\n    if filters.get(\'pj_project_type\'):\n        pt = str(filters[\'pj_project_type\']).replace("\'", "\'\'")\n        where_parts.append(f\'"pj_project_type" = \\\'{pt}\\\'\')\n\n    if filters.get(\'por_category\'):\n        pc = str(filters[\'por_category\']).replace("\'", "\'\'")\n        where_parts.append(f\'"por_category" = \\\'{pc}\\\'\')\n\n    if filters.get(\'s_site_id\'):\n        sid = str(filters[\'s_site_id\']).replace("\'", "\'\'")\n        where_parts.append(f\'"s_site_id" = \\\'{sid}\\\'\')\n\n    if filters.get(\'pj_project_id\'):\n        pid = str(filters[\'pj_project_id\']).replace("\'", "\'\'")\n        where_parts.append(f\'"pj_project_id" = \\\'{pid}\\\'\')\n\n    where_sql = " WHERE " + " AND ".join(where_parts)\n\n    # --- KPI SQL ---\n    # arrived_not_validated_count:\n    #   received is not null AND validated is null AND rejected is null\n    # rejected_without_subsequent_validation_count:\n    #   rejected is not null AND (validated is null OR validated_ts <= rejected_ts)\n    sql = (\n        "SELECT "\n        + select_dim_sql\n        + (", " if select_dim_sql else "")\n        + "COUNT(DISTINCT CASE "\n        + "  WHEN \\"ms_1310_pre_construction_package_received_actual\\" IS NOT NULL "\n        + "   AND \\"ms_1313_pre_construction_package_validated_actual\\" IS NULL "\n        + "   AND \\"ms_1315_pre_construction_package_rejected_actual\\" IS NULL "\n        + "  THEN \\"pj_project_id\\" END) AS \\"arrived_not_validated_count\\", "\n        + "COUNT(DISTINCT CASE "\n        + "  WHEN \\"ms_1315_pre_construction_package_rejected_actual\\" IS NOT NULL "\n        + "   AND (\\"ms_1313_pre_construction_package_validated_actual\\" IS NULL "\n        + "        OR \\"ms_1313_pre_construction_package_validated_actual\\"::timestamp <= \\"ms_1315_pre_construction_package_rejected_actual\\"::timestamp) "\n        + "  THEN \\"pj_project_id\\" END) AS \\"rejected_without_subsequent_validation_count\\", "\n        + "COUNT(DISTINCT CASE "\n        + "  WHEN (\\"ms_1310_pre_construction_package_received_actual\\" IS NOT NULL "\n        + "        AND \\"ms_1313_pre_construction_package_validated_actual\\" IS NULL "\n        + "        AND \\"ms_1315_pre_construction_package_rejected_actual\\" IS NULL) "\n        + "    OR (\\"ms_1315_pre_construction_package_rejected_actual\\" IS NOT NULL "\n        + "        AND (\\"ms_1313_pre_construction_package_validated_actual\\" IS NULL "\n        + "             OR \\"ms_1313_pre_construction_package_validated_actual\\"::timestamp <= \\"ms_1315_pre_construction_package_rejected_actual\\"::timestamp)) "\n        + "  THEN \\"pj_project_id\\" END) AS \\"document_gate_backlog_total_count\\" "\n        + "FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\" "\n        + where_sql\n        + (" GROUP BY " + group_by_sql if group_by_sql else "")\n        + (" ORDER BY " + order_by_sql if order_by_sql else "")\n    )\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_type', 'por_category', 's_site_id', 'ms_1310_pre_construction_package_received_actual', 'ms_1313_pre_construction_package_validated_actual', 'ms_1315_pre_construction_package_rejected_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Document Gate Compliance', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market', 'scoping_package'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '2802fe3a-0451-46ff-849f-7c302aa99335', entity_type: 'kpi', kpi_name: 'Document Gate Compliance', name: '2802fe3a-0451-46ff-849f-7c302aa99335', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Tracks how many active projects are stuck at the pre-construction document gate after the package has arrived but has not been validated, and how many active projects have had the package rejected without subsequent validation. This highlights process/compliance bottlenecks and audit risk, and is used to trigger Process & Compliance escalation when backlog grows.', status: 'mentioned', node_id: '2802fe3a-0451-46ff-849f-7c302aa99335'});
CREATE (:BKGNode {kpi_source_tables: ['stg_nas_log_data', 'stg_nas_nest_ext_raw_by_session'], nl_business_rule: '', kpi_formula_description: 'Outage Compliance Rate (%) computed from public.stg_nas_session_level_combined_data (single source table). Denominator = count of sessions where nas_checkout_approve_time IS NOT NULL (completed) AND nas_nest_start_time IS NOT NULL (had a NEST window). Numerator = denominator sessions where nas_status_nest_ext IS NULL OR nas_status_nest_ext=\'0\' (no extension requested). Rate = (Numerator ÷ Denominator) × 100. Filters apply to nas_checkout_approve_time (start_date/end_date cast to timestamp). Supports optional single-dimension grouping by nas_market, nas_activity_type, nas_company_name, nas_primary_gc, or nas_site_id.', kpi_output_schema: '[{"column": "outage_compliance_rate_pct", "type": "float", "description": "Percent of completed NAS sessions with NEST approved and no NEST extension request."}, {"column": "completed_sessions_count", "type": "int", "description": "Denominator: number of completed sessions."}, {"column": "compliant_sessions_count", "type": "int", "description": "Numerator: completed sessions with NEST approved and no extension."}, {"column": "noncompliant_sessions_count", "type": "int", "description": "Completed sessions that failed compliance criteria."}]', kpi_business_logic: '1) From NAS Event Log, collapse events to session-level flags: has_completed if any check-out/completed event exists; has_nest_approved if any \'Nest Approved\' event exists; has_extension_event if any extension-request event exists. 2) Define denominator as all sessions with has_completed = true. 3) From NEST Extension table, collect all nas_session_id values with any extension request (optionally filtered by date_requested/region/market/site). 4) A completed session is compliant if has_nest_approved = true AND it is NOT present in the extension set AND has_extension_event = false. 5) Rate = compliant_completed / completed * 100; also return counts.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Include sessions/events on or after this timestamp (applied to nas_event_time and nas_date_requested as text comparisons)."}, {"name": "end_date", "type": "date", "description": "Include sessions/events on or before this timestamp (applied to nas_event_time and nas_date_requested as text comparisons)."}, {"name": "nas_region", "type": "string", "description": "Filter to a NAS region (e.g., \'Central\')."}, {"name": "nas_market", "type": "string", "description": "Filter to a NAS market (e.g., \'Chicago\')."}, {"name": "nas_site_id", "type": "string", "description": "Filter to a specific site code."}, {"name": "nas_session_id", "type": "string", "description": "Filter to a specific NAS session id."}, {"name": "nas_project_category", "type": "string", "description": "Filter to a NAS project category."}, {"name": "nas_nest_type", "type": "string", "description": "Filter to a NEST type (e.g., NSI/SI) if populated in event log."}]', kpi_contract: '{"function_name": "get_outage_compliance_rate", "node_type": "kpi", "node_id": "af90e98a-a8be-4f00-a97f-39b56c7ad2d1", "node_label": "Outage Compliance Rate", "description": "Measures the percentage of completed NAS integration sessions that had an approved NEST outage window and finished without any NEST extension request, indicating adherence to outage governance and reducing audit/process non-compliance risk. A low rate signals frequent maintenance-window overruns and potential governance escalation needs.", "parameters": [], "output_columns": [{"name": "total_completed_with_nest", "type": "number", "nullable": false}, {"name": "compliant_sessions", "type": "number", "nullable": false}, {"name": "noncompliant_sessions", "type": "number", "nullable": false}, {"name": "outage_compliance_rate_pct", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'Outage Compliance Rate (%) computed from public.stg_nas_session_level_combined_data (single source table). Denominator = count of sessions where nas_checkout_approve_time IS NOT NULL (completed) AND nas_nest_start_time IS NOT NULL (had a NEST window). Numerator = denominator sessions where nas_status_nest_ext IS NULL OR nas_status_nest_ext=\'0\' (no extension requested). Rate = (Numerator ÷ Denominator) × 100. Filters apply to nas_checkout_approve_time (start_date/end_date cast to timestamp). Supports optional single-dimension grouping by nas_market, nas_activity_type, nas_company_name, nas_primary_gc, or nas_site_id.', node_type: 'CORE', definition: 'Outage Compliance Rate (%) computed from public.stg_nas_session_level_combined_data (single source table). Denominator = count of sessions where nas_checkout_approve_time IS NOT NULL (completed) AND nas_nest_start_time IS NOT NULL (had a NEST window). Numerator = denominator sessions where nas_status_nest_ext IS NULL OR nas_status_nest_ext=\'0\' (no extension requested). Rate = (Numerator ÷ Denominator) × 100. Filters apply to nas_checkout_approve_time (start_date/end_date cast to timestamp). Supports optional single-dimension grouping by nas_market, nas_activity_type, nas_company_name, nas_primary_gc, or nas_site_id.', kpi_python_function: 'def get_outage_compliance_rate(execute_query, filters=None) -> list[dict]:\n    """Outage Compliance Rate (%) computed from public.stg_nas_session_level_combined_data.\n\n    Denominator: completed sessions with a NEST window\n      - nas_checkout_approve_time IS NOT NULL\n      - nas_nest_start_time IS NOT NULL\n\n    Numerator: denominator sessions with no extension request\n      - nas_status_nest_ext IS NULL OR nas_status_nest_ext = \'0\'\n\n    Supported filters:\n      - nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id\n      - start_date, end_date applied to nas_checkout_approve_time (timestamp)\n\n    Optional grouping:\n      - group_by in {nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id}\n        (single dimension)\n    """\n\n    f = filters or {}\n\n    allowed_filters = {\n        "nas_market",\n        "nas_activity_type",\n        "nas_company_name",\n        "nas_primary_gc",\n        "nas_site_id",\n        "start_date",\n        "end_date",\n        "group_by",\n    }\n    # Ignore any non-allowlisted keys\n    start_date = f.get("start_date")\n    end_date = f.get("end_date")\n    group_by = f.get("group_by")\n\n    allowed_group_bys = {\n        None,\n        "nas_market",\n        "nas_activity_type",\n        "nas_company_name",\n        "nas_primary_gc",\n        "nas_site_id",\n    }\n    if group_by not in allowed_group_bys:\n        raise ValueError(f"Unsupported group_by: {group_by}. Allowed: {sorted([g for g in allowed_group_bys if g])}")\n\n    where_parts = [\n        "nas_checkout_approve_time IS NOT NULL",\n        "nas_nest_start_time IS NOT NULL",\n    ]\n\n    # Dimension filters\n    if f.get("nas_market") is not None:\n        where_parts.append("nas_market = %(nas_market)s")\n    if f.get("nas_activity_type") is not None:\n        where_parts.append("nas_activity_type = %(nas_activity_type)s")\n    if f.get("nas_company_name") is not None:\n        where_parts.append("nas_company_name = %(nas_company_name)s")\n    if f.get("nas_primary_gc") is not None:\n        where_parts.append("nas_primary_gc = %(nas_primary_gc)s")\n    if f.get("nas_site_id") is not None:\n        where_parts.append("nas_site_id = %(nas_site_id)s")\n\n    # Date filters on completion time\n    if start_date is not None:\n        where_parts.append("nas_checkout_approve_time >= %(start_date)s::timestamp")\n    if end_date is not None:\n        where_parts.append("nas_checkout_approve_time <= %(end_date)s::timestamp")\n\n    where_sql = " AND ".join(where_parts)\n\n    # Build SELECT/GROUP BY\n    select_dim = ""\n    group_sql = ""\n    order_sql = ""\n    if group_by:\n        select_dim = f"{group_by} AS group_value,\\n"\n        group_sql = f"GROUP BY {group_by}"\n        order_sql = f"ORDER BY {group_by}"\n\n    sql = f"""\n        SELECT\n            {select_dim}\n            COUNT(*)::float AS total_completed_with_nest,\n            SUM(CASE WHEN (nas_status_nest_ext IS NULL OR nas_status_nest_ext = \'0\') THEN 1 ELSE 0 END)::float AS compliant_sessions,\n            SUM(CASE WHEN NOT (nas_status_nest_ext IS NULL OR nas_status_nest_ext = \'0\') THEN 1 ELSE 0 END)::float AS noncompliant_sessions,\n            CASE\n                WHEN COUNT(*) = 0 THEN NULL\n                ELSE (SUM(CASE WHEN (nas_status_nest_ext IS NULL OR nas_status_nest_ext = \'0\') THEN 1 ELSE 0 END)::float / COUNT(*)::float) * 100.0\n            END AS outage_compliance_rate_pct\n        FROM public.stg_nas_session_level_combined_data\n        WHERE {where_sql}\n        {group_sql}\n        {order_sql}\n    """\n\n    params = {\n        "nas_market": f.get("nas_market"),\n        "nas_activity_type": f.get("nas_activity_type"),\n        "nas_company_name": f.get("nas_company_name"),\n        "nas_primary_gc": f.get("nas_primary_gc"),\n        "nas_site_id": f.get("nas_site_id"),\n        "start_date": start_date,\n        "end_date": end_date,\n    }\n\n    return execute_query(sql, params)\n', kpi_source_columns: ['stg_nas_log_data.nas_session_id', 'stg_nas_log_data.nas_event_type', 'stg_nas_log_data.nas_event_time', 'stg_nas_log_data.nas_region', 'stg_nas_log_data.nas_market', 'stg_nas_log_data.nas_site_id', 'stg_nas_log_data.nas_project_category', 'stg_nas_log_data.nas_nest_type', 'stg_nas_nest_ext_raw_by_session.nas_session_id', 'stg_nas_nest_ext_raw_by_session.nas_date_requested', 'stg_nas_nest_ext_raw_by_session.nas_region', 'stg_nas_nest_ext_raw_by_session.nas_market', 'stg_nas_nest_ext_raw_by_session.nas_site_id', 'stg_nas_nest_ext_raw_by_session.nas_project_category'], session_id: '69a3d22f26e208edc083a06e', label: 'Outage Compliance Rate', kpi_related_core_node_ids: ['integration_activity', 'nest_extension', 'planned_outage', 'site'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'af90e98a-a8be-4f00-a97f-39b56c7ad2d1', entity_type: 'kpi', kpi_name: 'Outage Compliance Rate', name: 'af90e98a-a8be-4f00-a97f-39b56c7ad2d1', kpi_dimensions: ['nas_region', 'nas_market', 'nas_project_category', 'nas_nest_type'], kpi_description: 'Measures the percentage of completed NAS integration sessions that had an approved NEST outage window and finished without any NEST extension request, indicating adherence to outage governance and reducing audit/process non-compliance risk. A low rate signals frequent maintenance-window overruns and potential governance escalation needs.', status: 'mentioned', node_id: 'af90e98a-a8be-4f00-a97f-39b56c7ad2d1'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Governance Risk Metrics selected by filters[\'metric_type\'] (one result set per call; schemas differ). All metrics support geo filters (rgn_region, m_area, m_market) and query public.stg_ndpd_mbt_tmobile_macro_combined. metric_type=\'action_closure\' returns closeout backlog by geo and construction_gc for Active projects where ms_1555_construction_complete_actual is not null and ms_1559_cop_approved_by_t_mobile_actual is null; includes project_count plus avg/max days since construction complete. metric_type=\'vendor_concentration\' returns vendor concentration by geo and pj_hard_cost_vendor_assignment_po: distinct project_count per (geo, vendor), total_projects_in_geo (sum across vendors within geo), and vendor_project_share = project_count / total_projects_in_geo. metric_type=\'binder_approval_rate\' returns binder_received_count (distinct projects with pj_a_5500_receive_close_out_binder_finish not null), binder_approved_count (distinct projects with pj_a_5525_approve_close_out_binder_finish not null), and binder_approval_rate_pct = 100 * binder_approved_count / binder_received_count, grouped by geo and construction_gc. metric_type=\'scop_pending_mb\' returns scop_pending_count as distinct projects where pj_a_5500_receive_close_out_binder_finish is not null and pj_a_5525_approve_close_out_binder_finish is null, grouped by geo and construction_gc.', kpi_output_schema: '[{"column": "view_name", "type": "string", "description": "Which companion view the row belongs to: \'closeout_backlog\' or \'vendor_concentration\'."}, {"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor (only populated for closeout_backlog rows)."}, {"column": "hard_cost_vendor", "type": "string", "description": "Hard-cost vendor used for concentration (COALESCE(construction_gc, construction_gc)); only populated for vendor_concentration rows."}, {"column": "project_count", "type": "integer", "description": "Distinct count of projects in the group."}, {"column": "avg_days_since_construction_complete", "type": "float", "description": "Average days since construction completion for backlog projects (NULL for vendor_concentration)."}, {"column": "max_days_since_construction_complete", "type": "float", "description": "Maximum days since construction completion for backlog projects (NULL for vendor_concentration)."}, {"column": "total_projects_in_geo", "type": "integer", "description": "Total distinct projects in the geo partition (only for vendor_concentration)."}, {"column": "vendor_project_share", "type": "float", "description": "Vendor concentration share within geo = project_count / total_projects_in_geo (only for vendor_concentration)."}]', kpi_business_logic: 'Read filters[\'metric_type\'] (default \'action_closure\'); reject values other than \'action_closure\', \'vendor_concentration\', \'binder_approval_rate\', \'scop_pending_mb\'.\nApply allowlisted geo filters rgn_region, m_area, m_market to whichever metric runs.\nIf metric_type=\'action_closure\': filter pj_project_status=\'Active\', ms_1555_construction_complete_actual is not null, ms_1559_cop_approved_by_t_mobile_actual is null; optionally filter construction_gc; optionally filter ms_1555_construction_complete_actual between start_date (inclusive) and end_date (exclusive); group by geo + construction_gc; compute COUNT(DISTINCT pj_project_id), AVG and MAX days since construction complete.\nIf metric_type=\'vendor_concentration\': filter non-null/non-blank pj_hard_cost_vendor_assignment_po; compute vendor_counts as COUNT(DISTINCT pj_project_id) grouped by geo + trimmed vendor; compute geo_totals as SUM(vendor_counts.project_count) per geo; join to compute vendor_project_share = project_count / total_projects_in_geo.\nIf metric_type=\'binder_approval_rate\': compute binder_received_count as COUNT(DISTINCT pj_project_id) where pj_a_5500_receive_close_out_binder_finish is not null; compute binder_approved_count as COUNT(DISTINCT pj_project_id) where pj_a_5525_approve_close_out_binder_finish is not null; compute binder_approval_rate_pct = 100 * binder_approved_count / binder_received_count; group by geo + construction_gc.\nIf metric_type=\'scop_pending_mb\': filter rows where pj_a_5500_receive_close_out_binder_finish is not null and pj_a_5525_approve_close_out_binder_finish is null; group by geo + construction_gc; compute COUNT(DISTINCT pj_project_id) as scop_pending_count.', kpi_filters: '[{"name": "metric_type", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc (action_closure only)", "type": "string", "description": ""}, {"name": "start_date (action_closure only)", "type": "string", "description": ""}, {"name": "end_date (action_closure only)", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_governance_risk_metrics", "node_type": "kpi", "node_id": "083e5b8b-61d1-4bed-83c2-5daa8446fb29", "node_label": "Governance Risk Metrics", "description": "Tracks governance and strategic risk through two companion views: (1) the backlog of active projects where construction is complete but customer closeout package approval has not occurred, indicating stalled action closure and acceptance risk; and (2) vendor concentration by hard-cost vendor assignment PO to highlight potential single-vendor dependency and exposure. Supports slicing by geography and general contractor to pinpoint where governance delays or vendor concentration risk is accumulating.", "parameters": [{"name": "metric_type", "type": "string", "description": "Filter by metric type", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "project_count", "type": "number", "nullable": false}, {"name": "avg_days_since_construction_complete", "type": "number", "nullable": false}, {"name": "max_days_since_construction_complete", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Governance Risk Metrics selected by filters[\'metric_type\'] (one result set per call; schemas differ). All metrics support geo filters (rgn_region, m_area, m_market) and query public.stg_ndpd_mbt_tmobile_macro_combined. metric_type=\'action_closure\' returns closeout backlog by geo and construction_gc for Active projects where ms_1555_construction_complete_actual is not null and ms_1559_cop_approved_by_t_mobile_actual is null; includes project_count plus avg/max days since construction complete. metric_type=\'vendor_concentration\' returns vendor concentration by geo and pj_hard_cost_vendor_assignment_po: distinct project_count per (geo, vendor), total_projects_in_geo (sum across vendors within geo), and vendor_project_share = project_count / total_projects_in_geo. metric_type=\'binder_approval_rate\' returns binder_received_count (distinct projects with pj_a_5500_receive_close_out_binder_finish not null), binder_approved_count (distinct projects with pj_a_5525_approve_close_out_binder_finish not null), and binder_approval_rate_pct = 100 * binder_approved_count / binder_received_count, grouped by geo and construction_gc. metric_type=\'scop_pending_mb\' returns scop_pending_count as distinct projects where pj_a_5500_receive_close_out_binder_finish is not null and pj_a_5525_approve_close_out_binder_finish is null, grouped by geo and construction_gc.', node_type: 'CORE', definition: 'Governance Risk Metrics selected by filters[\'metric_type\'] (one result set per call; schemas differ). All metrics support geo filters (rgn_region, m_area, m_market) and query public.stg_ndpd_mbt_tmobile_macro_combined. metric_type=\'action_closure\' returns closeout backlog by geo and construction_gc for Active projects where ms_1555_construction_complete_actual is not null and ms_1559_cop_approved_by_t_mobile_actual is null; includes project_count plus avg/max days since construction complete. metric_type=\'vendor_concentration\' returns vendor concentration by geo and pj_hard_cost_vendor_assignment_po: distinct project_count per (geo, vendor), total_projects_in_geo (sum across vendors within geo), and vendor_project_share = project_count / total_projects_in_geo. metric_type=\'binder_approval_rate\' returns binder_received_count (distinct projects with pj_a_5500_receive_close_out_binder_finish not null), binder_approved_count (distinct projects with pj_a_5525_approve_close_out_binder_finish not null), and binder_approval_rate_pct = 100 * binder_approved_count / binder_received_count, grouped by geo and construction_gc. metric_type=\'scop_pending_mb\' returns scop_pending_count as distinct projects where pj_a_5500_receive_close_out_binder_finish is not null and pj_a_5525_approve_close_out_binder_finish is null, grouped by geo and construction_gc.', kpi_python_function: 'def get_governance_risk_metrics(execute_query, filters=None) -> list[dict]:\n    """Returns one of four governance risk metric result sets depending on filters[\'metric_type\'].\n\n    metric_type =\n      - \'action_closure\': closeout backlog for active projects where construction complete date is set and COP approval is null.\n      - \'vendor_concentration\': per-geo distribution of hard-cost vendors based on pj_hard_cost_vendor_assignment_po.\n      - \'binder_approval_rate\': close-out binder approval rate per geo/GC.\n      - \'scop_pending_mb\': count of projects where binder received but approval is still pending per geo/GC.\n\n    Platform constraints: no CTEs; use subqueries instead.\n    """\n\n    filters = filters or {}\n    metric_type = filters.get(\'metric_type\', \'action_closure\')\n\n    allowed = (\'action_closure\', \'vendor_concentration\', \'binder_approval_rate\', \'scop_pending_mb\')\n    if metric_type not in allowed:\n        raise ValueError(f"filters[\'metric_type\'] must be one of {allowed}")\n\n    # -------------------------\n    # Allowlisted filters\n    # -------------------------\n    # Shared geo filters\n    geo_predicates = []\n    if filters.get(\'rgn_region\'):\n        val = str(filters[\'rgn_region\']).replace("\'", "\'\'")\n        geo_predicates.append(f\'"rgn_region" = \\\'{val}\\\'\')\n    if filters.get(\'m_area\'):\n        val = str(filters[\'m_area\']).replace("\'", "\'\'")\n        geo_predicates.append(f\'"m_area" = \\\'{val}\\\'\')\n    if filters.get(\'m_market\'):\n        val = str(filters[\'m_market\']).replace("\'", "\'\'")\n        geo_predicates.append(f\'"m_market" = \\\'{val}\\\'\')\n\n    # Date filters apply ONLY to action_closure and are anchored on construction complete actual.\n    date_predicates = []\n    if metric_type == \'action_closure\':\n        if filters.get(\'start_date\'):\n            val = str(filters[\'start_date\']).replace("\'", "\'\'")\n            date_predicates.append(f\'("ms_1555_construction_complete_actual"::timestamp) >= \\\'{val}\\\'::timestamp\')\n        if filters.get(\'end_date\'):\n            val = str(filters[\'end_date\']).replace("\'", "\'\'")\n            date_predicates.append(f\'("ms_1555_construction_complete_actual"::timestamp) < \\\'{val}\\\'::timestamp\')\n\n    # GC filter applies ONLY to action_closure and uses construction_gc.\n    gc_predicates = []\n    if metric_type == \'action_closure\' and filters.get(\'construction_gc\'):\n        val = str(filters[\'construction_gc\']).replace("\'", "\'\'")\n        gc_predicates.append(f\'"construction_gc" = \\\'{val}\\\'\')\n\n    # -------------------------\n    # Metric: action_closure (closeout backlog)\n    # -------------------------\n    if metric_type == \'action_closure\':\n        where_parts = [\n            \'"pj_project_status" = \\\'Active\\\'\',\n            \'"ms_1555_construction_complete_actual" IS NOT NULL\',\n            \'"ms_1559_cop_approved_by_t_mobile_actual" IS NULL\',\n        ]\n        where_parts += geo_predicates + gc_predicates + date_predicates\n        where_sql = \' AND \'.join(where_parts)\n\n        sql = f"""\n        SELECT\n            "rgn_region" AS "rgn_region",\n            "m_area" AS "m_area",\n            "m_market" AS "m_market",\n            "construction_gc" AS "construction_gc",\n            COUNT(DISTINCT "pj_project_id")::bigint AS "project_count",\n            AVG(EXTRACT(EPOCH FROM (NOW()::timestamp - ("ms_1555_construction_complete_actual"::timestamp))) / 86400.0)::double precision\n                AS "avg_days_since_construction_complete",\n            MAX(EXTRACT(EPOCH FROM (NOW()::timestamp - ("ms_1555_construction_complete_actual"::timestamp))) / 86400.0)::double precision\n                AS "max_days_since_construction_complete"\n        FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n        WHERE {where_sql}\n        GROUP BY\n            "rgn_region", "m_area", "m_market", "construction_gc"\n        ORDER BY\n            "rgn_region", "m_area", "m_market", "project_count" DESC;\n        """\n        return execute_query(sql)\n\n    # -------------------------\n    # Metric: binder_approval_rate\n    # -------------------------\n    if metric_type == \'binder_approval_rate\':\n        where_parts = []\n        where_parts += geo_predicates\n        where_sql = \' AND \'.join(where_parts) if where_parts else \'1=1\'\n\n        sql = f"""\n        SELECT\n            "rgn_region" AS "rgn_region",\n            "m_area" AS "m_area",\n            "m_market" AS "m_market",\n            "construction_gc" AS "construction_gc",\n            COUNT(DISTINCT CASE\n                WHEN "pj_a_5500_receive_close_out_binder_finish" IS NOT NULL THEN "pj_project_id"\n            END)::bigint AS "binder_received_count",\n            COUNT(DISTINCT CASE\n                WHEN "pj_a_5525_approve_close_out_binder_finish" IS NOT NULL THEN "pj_project_id"\n            END)::bigint AS "binder_approved_count",\n            (\n                100.0\n                * COUNT(DISTINCT CASE\n                    WHEN "pj_a_5525_approve_close_out_binder_finish" IS NOT NULL THEN "pj_project_id"\n                  END)::double precision\n                / NULLIF(\n                    COUNT(DISTINCT CASE\n                        WHEN "pj_a_5500_receive_close_out_binder_finish" IS NOT NULL THEN "pj_project_id"\n                    END)::double precision,\n                    0.0\n                  )\n            )::double precision AS "binder_approval_rate_pct"\n        FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n        WHERE {where_sql}\n        GROUP BY\n            "rgn_region", "m_area", "m_market", "construction_gc"\n        ORDER BY\n            "rgn_region", "m_area", "m_market", "binder_received_count" DESC;\n        """\n        return execute_query(sql)\n\n    # -------------------------\n    # Metric: scop_pending_mb\n    # -------------------------\n    if metric_type == \'scop_pending_mb\':\n        where_parts = [\n            \'"pj_a_5500_receive_close_out_binder_finish" IS NOT NULL\',\n            \'"pj_a_5525_approve_close_out_binder_finish" IS NULL\'\n        ]\n        where_parts += geo_predicates\n        where_sql = \' AND \'.join(where_parts)\n\n        sql = f"""\n        SELECT\n            "rgn_region" AS "rgn_region",\n            "m_area" AS "m_area",\n            "m_market" AS "m_market",\n            "construction_gc" AS "construction_gc",\n            COUNT(DISTINCT "pj_project_id")::bigint AS "scop_pending_count"\n        FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n        WHERE {where_sql}\n        GROUP BY\n            "rgn_region", "m_area", "m_market", "construction_gc"\n        ORDER BY\n            "rgn_region", "m_area", "m_market", "scop_pending_count" DESC;\n        """\n        return execute_query(sql)\n\n    # -------------------------\n    # Metric: vendor_concentration\n    # -------------------------\n    vendor_where_parts = [\n        \'"pj_hard_cost_vendor_assignment_po" IS NOT NULL\',\n        \'NULLIF(TRIM("pj_hard_cost_vendor_assignment_po"), \\\'\\\') IS NOT NULL\'\n    ]\n    vendor_where_parts += geo_predicates\n    vendor_where_sql = \' AND \'.join(vendor_where_parts)\n\n    sql = f"""\n    SELECT\n        v."rgn_region" AS "rgn_region",\n        v."m_area" AS "m_area",\n        v."m_market" AS "m_market",\n        v."hard_cost_vendor" AS "hard_cost_vendor",\n        v."project_count"::bigint AS "project_count",\n        g."total_projects_in_geo"::bigint AS "total_projects_in_geo",\n        (v."project_count"::double precision / NULLIF(g."total_projects_in_geo"::double precision, 0.0))::double precision\n            AS "vendor_project_share"\n    FROM (\n        SELECT\n            "rgn_region",\n            "m_area",\n            "m_market",\n            TRIM("pj_hard_cost_vendor_assignment_po") AS "hard_cost_vendor",\n            COUNT(DISTINCT "pj_project_id") AS "project_count"\n        FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n        WHERE {vendor_where_sql}\n        GROUP BY\n            "rgn_region", "m_area", "m_market", TRIM("pj_hard_cost_vendor_assignment_po")\n    ) v\n    JOIN (\n        SELECT\n            vc."rgn_region",\n            vc."m_area",\n            vc."m_market",\n            SUM(vc."project_count") AS "total_projects_in_geo"\n        FROM (\n            SELECT\n                "rgn_region",\n                "m_area",\n                "m_market",\n                TRIM("pj_hard_cost_vendor_assignment_po") AS "hard_cost_vendor",\n                COUNT(DISTINCT "pj_project_id") AS "project_count"\n            FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n            WHERE {vendor_where_sql}\n            GROUP BY\n                "rgn_region", "m_area", "m_market", TRIM("pj_hard_cost_vendor_assignment_po")\n        ) vc\n        GROUP BY\n            vc."rgn_region", vc."m_area", vc."m_market"\n    ) g\n      ON v."rgn_region" = g."rgn_region"\n     AND v."m_area" = g."m_area"\n     AND v."m_market" = g."m_market"\n    ORDER BY\n        v."rgn_region", v."m_area", v."m_market", v."project_count" DESC, v."hard_cost_vendor";\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'ms_1555_construction_complete_actual', 'ms_1559_cop_approved_by_t_mobile_actual', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_hard_cost_vendor_assignment_po', 'pj_a_5500_receive_close_out_binder_finish', 'pj_a_5525_approve_close_out_binder_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Governance Risk Metrics', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market', 'closeout_package'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '083e5b8b-61d1-4bed-83c2-5daa8446fb29', entity_type: 'kpi', kpi_name: 'Governance Risk Metrics', name: '083e5b8b-61d1-4bed-83c2-5daa8446fb29', kpi_dimensions: ['action_closure: rgn_region, m_area, m_market, construction_gc', 'vendor_concentration: rgn_region, m_area, m_market, hard_cost_vendor', 'binder_approval_rate: rgn_region, m_area, m_market, construction_gc', 'scop_pending_mb: rgn_region, m_area, m_market, construction_gc'], kpi_description: 'Tracks governance and strategic risk through two companion views: (1) the backlog of active projects where construction is complete but customer closeout package approval has not occurred, indicating stalled action closure and acceptance risk; and (2) vendor concentration by hard-cost vendor assignment PO to highlight potential single-vendor dependency and exposure. Supports slicing by geography and general contractor to pinpoint where governance delays or vendor concentration risk is accumulating.', status: 'mentioned', node_id: '083e5b8b-61d1-4bed-83c2-5daa8446fb29'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Customer Approval Gap (Active Projects) computed from public.stg_ndpd_mbt_tmobile_macro_combined. Outputs two counts: (1) distinct Active projects with Nokia pre-con package validated (ms_1313_pre_construction_package_validated_actual not null) but scoping package not yet customer-approved (ms_1333_scoping_package_approved_by_customer_actual null); and (2) distinct Active projects with Nokia pre-con package rejected (ms_1315_pre_construction_package_rejected_actual not null) and not yet re-validated (ms_1313_pre_construction_package_validated_actual null). Default returns a single aggregate row; optionally groups by a caller-provided subset of dimensions (rgn_region, m_area, m_market, construction_gc, por_category, confirm_split_spo).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension from the project record."}, {"column": "m_area", "type": "string", "description": "Area dimension from the project record."}, {"column": "m_market", "type": "string", "description": "Market dimension from the project record."}, {"column": "construction_gc", "type": "string", "description": "General contractor name associated to the project."}, {"column": "por_category", "type": "string", "description": "Scope/POR category used for reporting."}, {"column": "confirm_split_spo", "type": "string", "description": "Split-SPO indicator used to distinguish split-scope cases."}, {"column": "validated_not_customer_approved_active_projects", "type": "integer", "description": "Count of active projects internally validated by Nokia but still lacking customer scoping approval."}, {"column": "internally_rejected_not_revalidated_active_projects", "type": "integer", "description": "Count of active projects internally rejected by Nokia and not yet re-validated (QC backlog)."}]', kpi_business_logic: 'Filter to pj_project_id is not null and pj_project_status = \'Active\'.\nApply optional equality filters: rgn_region, m_area, m_market, construction_gc, por_category, confirm_split_spo.\nIf filters.group_by is empty/omitted: return one row with the two KPI counts (no GROUP BY).\nIf filters.group_by is provided: validate requested dimensions are in the allowlist; then SELECT/GROUP BY/ORDER BY only those dimensions.\nvalidated_not_customer_approved_active_projects = COUNT(DISTINCT pj_project_id) where ms_1313_pre_construction_package_validated_actual is not null AND ms_1333_scoping_package_approved_by_customer_actual is null.\ninternally_rejected_not_revalidated_active_projects = COUNT(DISTINCT pj_project_id) where ms_1315_pre_construction_package_rejected_actual is not null AND ms_1313_pre_construction_package_validated_actual is null.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Optional. Exact match."}, {"name": "m_area", "type": "string", "description": "Optional. Exact match."}, {"name": "m_market", "type": "string", "description": "Optional. Exact match."}, {"name": "construction_gc", "type": "string", "description": "Optional. Exact match."}, {"name": "por_category", "type": "string", "description": "Optional. Exact match."}, {"name": "confirm_split_spo", "type": "string", "description": "Optional. Exact match."}, {"name": "group_by", "type": "string", "description": "Optional. List[str] of dimensions to group by. Allowed: rgn_region, m_area, m_market, construction_gc, por_category, confirm_split_spo. Default [] (no grouping)."}]', kpi_contract: '{"function_name": "get_customer_approval_gap", "node_type": "kpi", "node_id": "aea80d8b-9e94-40af-989b-ba08f76927f9", "node_label": "Customer Approval Gap", "description": "Tracks misalignment risk between Nokia internal validation and pending T-Mobile scoping approval by counting active projects that are internally validated but not yet customer-approved. Also reports a companion count of active projects that are internally rejected and not yet re-validated, to distinguish Nokia QC issues from customer-approval delays. Used to trigger and monitor Customer Impact escalation risk by region/market/GC and scope category.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "confirm_split_spo", "type": "string", "description": "Filter by confirm split spo", "required": false, "sample_values": []}, {"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}], "output_columns": [{"name": "validated_not_customer_approved_active_projects", "type": "number", "nullable": false}, {"name": "internally_rejected_not_revalidated_active_projects", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'Customer Approval Gap (Active Projects) computed from public.stg_ndpd_mbt_tmobile_macro_combined. Outputs two counts: (1) distinct Active projects with Nokia pre-con package validated (ms_1313_pre_construction_package_validated_actual not null) but scoping package not yet customer-approved (ms_1333_scoping_package_approved_by_customer_actual null); and (2) distinct Active projects with Nokia pre-con package rejected (ms_1315_pre_construction_package_rejected_actual not null) and not yet re-validated (ms_1313_pre_construction_package_validated_actual null). Default returns a single aggregate row; optionally groups by a caller-provided subset of dimensions (rgn_region, m_area, m_market, construction_gc, por_category, confirm_split_spo).', node_type: 'CORE', definition: 'Customer Approval Gap (Active Projects) computed from public.stg_ndpd_mbt_tmobile_macro_combined. Outputs two counts: (1) distinct Active projects with Nokia pre-con package validated (ms_1313_pre_construction_package_validated_actual not null) but scoping package not yet customer-approved (ms_1333_scoping_package_approved_by_customer_actual null); and (2) distinct Active projects with Nokia pre-con package rejected (ms_1315_pre_construction_package_rejected_actual not null) and not yet re-validated (ms_1313_pre_construction_package_validated_actual null). Default returns a single aggregate row; optionally groups by a caller-provided subset of dimensions (rgn_region, m_area, m_market, construction_gc, por_category, confirm_split_spo).', kpi_python_function: 'def get_customer_approval_gap(execute_query, filters=None) -> list[dict]:\n    """Customer Approval Gap KPI.\n\n    Default: returns a single aggregate row (no grouping).\n    Optional: pass filters[\'group_by\'] as a list of allowed dimension keys to group.\n    """\n\n    filters = filters or {}\n\n    # Allowed dimensions for grouping/filters (maps request key -> physical column)\n    dim_map = {\n        "rgn_region": \'"rgn_region"\',\n        "m_area": \'"m_area"\',\n        "m_market": \'"m_market"\',\n        "construction_gc": \'"construction_gc"\',\n        "por_category": \'"por_category"\',\n        "confirm_split_spo": \'"confirm_split_spo"\',\n    }\n\n    where_parts = [\n        \'"pj_project_id" IS NOT NULL\',\n        \'"pj_project_status" = \\\'Active\\\'\'\n    ]\n\n    # Explicit allowlist of filterable columns\n    if filters.get("rgn_region") is not None:\n        v = str(filters["rgn_region"]).replace("\'", "\'\'")\n        where_parts.append(f\'{dim_map["rgn_region"]} = \\\'{v}\\\'\')\n    if filters.get("m_area") is not None:\n        v = str(filters["m_area"]).replace("\'", "\'\'")\n        where_parts.append(f\'{dim_map["m_area"]} = \\\'{v}\\\'\')\n    if filters.get("m_market") is not None:\n        v = str(filters["m_market"]).replace("\'", "\'\'")\n        where_parts.append(f\'{dim_map["m_market"]} = \\\'{v}\\\'\')\n    if filters.get("construction_gc") is not None:\n        v = str(filters["construction_gc"]).replace("\'", "\'\'")\n        where_parts.append(f\'{dim_map["construction_gc"]} = \\\'{v}\\\'\')\n    if filters.get("por_category") is not None:\n        v = str(filters["por_category"]).replace("\'", "\'\'")\n        where_parts.append(f\'{dim_map["por_category"]} = \\\'{v}\\\'\')\n    if filters.get("confirm_split_spo") is not None:\n        v = str(filters["confirm_split_spo"]).replace("\'", "\'\'")\n        where_parts.append(f\'{dim_map["confirm_split_spo"]} = \\\'{v}\\\'\')\n\n    where_sql = " AND ".join(where_parts)\n\n    # Optional grouping\n    group_by = filters.get("group_by")\n    if group_by is None:\n        group_by = []\n    if not isinstance(group_by, list):\n        raise ValueError("filters[\'group_by\'] must be a list of dimension keys")\n\n    invalid = [g for g in group_by if g not in dim_map]\n    if invalid:\n        raise ValueError(f"Invalid group_by dimensions: {invalid}. Allowed: {list(dim_map.keys())}")\n\n    if group_by:\n        select_prefix = ", ".join([f"{dim_map[g]} AS \\"{g}\\"" for g in group_by]) + ","\n        group_by_sql = "\\n        GROUP BY " + ", ".join([dim_map[g] for g in group_by])\n        order_by_sql = "\\n        ORDER BY " + ", ".join([dim_map[g] for g in group_by])\n    else:\n        select_prefix = ""\n        group_by_sql = ""\n        order_by_sql = ""\n\n    sql = f"""\n        SELECT\n            {select_prefix}\n            COUNT(DISTINCT CASE\n                WHEN "ms_1313_pre_construction_package_validated_actual" IS NOT NULL\n                 AND "ms_1333_scoping_package_approved_by_customer_actual" IS NULL\n                THEN "pj_project_id"\n            END) AS "validated_not_customer_approved_active_projects",\n\n            COUNT(DISTINCT CASE\n                WHEN "ms_1315_pre_construction_package_rejected_actual" IS NOT NULL\n                 AND "ms_1313_pre_construction_package_validated_actual" IS NULL\n                THEN "pj_project_id"\n            END) AS "internally_rejected_not_revalidated_active_projects"\n\n        FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n        WHERE {where_sql}\n        {group_by_sql}\n        {order_by_sql}\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'confirm_split_spo', 'ms_1313_pre_construction_package_validated_actual', 'ms_1333_scoping_package_approved_by_customer_actual', 'ms_1315_pre_construction_package_rejected_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Customer Approval Gap', kpi_related_core_node_ids: ['project', 'approval', 'site', 'general_contractor', 'market', 'scoping_package'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'aea80d8b-9e94-40af-989b-ba08f76927f9', entity_type: 'kpi', kpi_name: 'Customer Approval Gap', name: 'aea80d8b-9e94-40af-989b-ba08f76927f9', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'confirm_split_spo'], kpi_description: 'Tracks misalignment risk between Nokia internal validation and pending T-Mobile scoping approval by counting active projects that are internally validated but not yet customer-approved. Also reports a companion count of active projects that are internally rejected and not yet re-validated, to distinguish Nokia QC issues from customer-approval delays. Used to trigger and monitor Customer Impact escalation risk by region/market/GC and scope category.', status: 'mentioned', node_id: 'aea80d8b-9e94-40af-989b-ba08f76927f9'});
CREATE (:BKGNode {kpi_source_tables: ['stg_nas_log_data', 'stg_nas_nest_ext_raw_by_session'], nl_business_rule: '', kpi_formula_description: 'Active Outage Violations (point-in-time snapshot) = COUNT(DISTINCT nas_session_id) from public.stg_nas_session_level_combined_data where: (1) nas_nest_start_time IS NOT NULL (NEST window started), (2) nas_checkout_approve_time IS NULL (session still open), and (3) nas_nest_start_time_requested IS NULL (no extension initiated). Optional filters (allowlist): nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id. Optional group_by over: nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id. Caveats: Computed from public.stg_nas_session_level_combined_data using three direct column checks—no event parsing, no cross-table joins. nas_nest_start_time is CHARACTER VARYING; IS NOT NULL works without casting. Snapshot KPI (no date filters); counts fluctuate with currently open sessions. Any count > 0 warrants immediate Escalation #2 action.', kpi_output_schema: '[{"column": "kpi_name", "type": "string", "description": "Static label for the KPI."}, {"column": "active_outage_violations", "type": "float", "description": "Number of violating (currently open) NAS sessions."}, {"column": "violating_session_count", "type": "int", "description": "Same as active_outage_violations, as an integer."}]', kpi_business_logic: '1) From NAS Event Log Event, group records by nas_session_id. 2) Mark each session as \'outage started\' if any event_type contains both \'NEST\' and \'APPROV\' (i.e., Nest Approved). 3) Mark each session as checked out if any event_type indicates checkout; and checkout approved if checkout event also contains \'APPROV\'. 4) From NEST Extension, build a set of session_ids that have any extension request row (extension initiated). 5) A session is an Active Outage Violation if: has_nest_approved = true AND has_checkout = false AND has_checkout_approved = false AND session_id not in extension_sessions. 6) KPI returns the count of such sessions.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Optional lower bound on nas_event_time (best-effort string compare if timestamps are text)."}, {"name": "end_date", "type": "date", "description": "Optional upper bound on nas_event_time (best-effort string compare if timestamps are text)."}, {"name": "nas_region", "type": "string", "description": "Filter to a NAS region (matches nas_region in event log and extension tables)."}, {"name": "nas_market", "type": "string", "description": "Filter to a NAS market (matches nas_market in event log and extension tables)."}, {"name": "nas_site_id", "type": "string", "description": "Filter to a specific site_id (matches nas_site_id in event log and extension tables)."}, {"name": "nas_session_id", "type": "string", "description": "Filter to a specific NAS session."}]', kpi_contract: '{"function_name": "get_active_outage_violations", "node_type": "kpi", "node_id": "38b69e8f-1d2d-4ca1-8067-1503119b9924", "node_label": "Active Outage Violations", "description": "Counts the number of currently open NAS sessions where the NEST outage window has started but checkout has not yet been approved and no outage extension request has been initiated. This KPI is a real-time governance/compliance trigger used to determine whether Escalation #2 actions are required, since it indicates crews are operating beyond the approved outage window without attempting to regularize the window through a formal extension request.", "parameters": [{"name": "nas_market", "type": "string", "description": "Filter by nas market", "required": false, "sample_values": []}, {"name": "market", "type": "string", "description": "Filter by market", "required": false, "sample_values": []}, {"name": "nas_activity_type", "type": "string", "description": "Filter by nas activity type", "required": false, "sample_values": []}, {"name": "nas_company_name", "type": "string", "description": "Filter by nas company name", "required": false, "sample_values": []}, {"name": "nas_primary_gc", "type": "string", "description": "Filter by nas primary gc", "required": false, "sample_values": []}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas site id", "required": false, "sample_values": []}, {"name": "site_id", "type": "string", "description": "Filter by site id", "required": false, "sample_values": []}, {"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}], "output_columns": [{"name": "kpi_name", "type": "string", "nullable": false}, {"name": "active_violation_count", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'Active Outage Violations (point-in-time snapshot) = COUNT(DISTINCT nas_session_id) from public.stg_nas_session_level_combined_data where: (1) nas_nest_start_time IS NOT NULL (NEST window started), (2) nas_checkout_approve_time IS NULL (session still open), and (3) nas_nest_start_time_requested IS NULL (no extension initiated). Optional filters (allowlist): nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id. Optional group_by over: nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id. Caveats: Computed from public.stg_nas_session_level_combined_data using three direct column checks—no event parsing, no cross-table joins. nas_nest_start_time is CHARACTER VARYING; IS NOT NULL works without casting. Snapshot KPI (no date filters); counts fluctuate with currently open sessions. Any count > 0 warrants immediate Escalation #2 action.', node_type: 'CORE', definition: 'Active Outage Violations (point-in-time snapshot) = COUNT(DISTINCT nas_session_id) from public.stg_nas_session_level_combined_data where: (1) nas_nest_start_time IS NOT NULL (NEST window started), (2) nas_checkout_approve_time IS NULL (session still open), and (3) nas_nest_start_time_requested IS NULL (no extension initiated). Optional filters (allowlist): nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id. Optional group_by over: nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id. Caveats: Computed from public.stg_nas_session_level_combined_data using three direct column checks—no event parsing, no cross-table joins. nas_nest_start_time is CHARACTER VARYING; IS NOT NULL works without casting. Snapshot KPI (no date filters); counts fluctuate with currently open sessions. Any count > 0 warrants immediate Escalation #2 action.', kpi_python_function: 'def get_active_outage_violations(execute_query, filters=None) -> list[dict]:\n    """Active Outage Violations (point-in-time snapshot).\n\n    Counts distinct NAS sessions that are currently in an active NEST outage window,\n    have not yet been checkout-approved, and have no extension initiated.\n\n    Source of truth: public.stg_nas_session_level_combined_data\n    (NO event parsing, NO Python-side joins).\n\n    Optional filters (allowlist):\n      - nas_market\n      - nas_activity_type\n      - nas_company_name\n      - nas_primary_gc\n      - nas_site_id\n      - group_by: list/CSV of dimensions to group results by\n\n    Returns rows with active_violation_count and any requested grouping dimensions.\n    """\n\n    # ---- allowlisted filters ----\n    nas_market = None\n    nas_activity_type = None\n    nas_company_name = None\n    nas_primary_gc = None\n    nas_site_id = None\n    group_by = None\n\n    if filters:\n        nas_market = filters.get("nas_market") or filters.get("market")\n        nas_activity_type = filters.get("nas_activity_type")\n        nas_company_name = filters.get("nas_company_name")\n        nas_primary_gc = filters.get("nas_primary_gc")\n        nas_site_id = filters.get("nas_site_id") or filters.get("site_id")\n        group_by = filters.get("group_by")\n\n    allowed_dims = {\n        "nas_market": \'"nas_market"\',\n        "nas_activity_type": \'"nas_activity_type"\',\n        "nas_company_name": \'"nas_company_name"\',\n        "nas_primary_gc": \'"nas_primary_gc"\',\n        "nas_site_id": \'"nas_site_id"\',\n    }\n\n    # Normalize group_by input\n    group_dims = []\n    if group_by:\n        if isinstance(group_by, str):\n            req = [x.strip() for x in group_by.split(",") if x.strip()]\n        elif isinstance(group_by, (list, tuple)):\n            req = [str(x).strip() for x in group_by if str(x).strip()]\n        else:\n            req = []\n        for d in req:\n            if d in allowed_dims and d not in group_dims:\n                group_dims.append(d)\n\n    select_cols = []\n    group_cols = []\n    for d in group_dims:\n        select_cols.append(f"{allowed_dims[d]} AS {d}")\n        group_cols.append(allowed_dims[d])\n\n    select_prefix = (", ".join(select_cols) + ", ") if select_cols else ""\n\n    # Core 3-condition WHERE pattern from the confirmed document\n    sql = (\n        "SELECT "\n        + select_prefix\n        + "COUNT(DISTINCT \\"nas_session_id\\") AS active_violation_count "\n        + "FROM public.stg_nas_session_level_combined_data "\n        + "WHERE \\"nas_nest_start_time\\" IS NOT NULL "\n        + "AND \\"nas_checkout_approve_time\\" IS NULL "\n        + "AND \\"nas_nest_start_time_requested\\" IS NULL "\n    )\n\n    # Add optional filters (explicit allowlist; no generic loops)\n    if nas_market is not None and str(nas_market).strip() != "":\n        sql += f"AND \\"nas_market\\" = \'{str(nas_market).replace("\'", "\'\'")}\' "\n    if nas_activity_type is not None and str(nas_activity_type).strip() != "":\n        sql += f"AND \\"nas_activity_type\\" = \'{str(nas_activity_type).replace("\'", "\'\'")}\' "\n    if nas_company_name is not None and str(nas_company_name).strip() != "":\n        sql += f"AND \\"nas_company_name\\" = \'{str(nas_company_name).replace("\'", "\'\'")}\' "\n    if nas_primary_gc is not None and str(nas_primary_gc).strip() != "":\n        sql += f"AND \\"nas_primary_gc\\" = \'{str(nas_primary_gc).replace("\'", "\'\'")}\' "\n    if nas_site_id is not None and str(nas_site_id).strip() != "":\n        sql += f"AND \\"nas_site_id\\" = \'{str(nas_site_id).replace("\'", "\'\'")}\' "\n\n    if group_cols:\n        sql += "GROUP BY " + ", ".join(group_cols) + " "\n\n    rows = execute_query(sql) or []\n\n    # Standardize output keys\n    out = []\n    for r in rows:\n        rec = {"kpi_name": "Active Outage Violations"}\n        for d in group_dims:\n            rec[d] = r.get(d)\n        # ensure numeric\n        avc = r.get("active_violation_count")\n        rec["active_violation_count"] = float(avc) if avc is not None else 0.0\n        out.append(rec)\n\n    # If no group_by, always return a single row\n    if not group_dims and not out:\n        out = [{"kpi_name": "Active Outage Violations", "active_violation_count": 0.0}]\n\n    return out\n', kpi_source_columns: ['stg_nas_log_data.nas_session_id', 'stg_nas_log_data.nas_event_type', 'stg_nas_log_data.nas_event_time', 'stg_nas_log_data.nas_region', 'stg_nas_log_data.nas_market', 'stg_nas_log_data.nas_site_id', 'stg_nas_nest_ext_raw_by_session.nas_session_id', 'stg_nas_nest_ext_raw_by_session.nas_date_requested', 'stg_nas_nest_ext_raw_by_session.nas_region', 'stg_nas_nest_ext_raw_by_session.nas_market', 'stg_nas_nest_ext_raw_by_session.nas_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'Active Outage Violations', kpi_related_core_node_ids: ['integration_activity', 'nest_extension', 'planned_outage', 'site'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '38b69e8f-1d2d-4ca1-8067-1503119b9924', entity_type: 'kpi', kpi_name: 'Active Outage Violations', name: '38b69e8f-1d2d-4ca1-8067-1503119b9924', kpi_dimensions: ['nas_region', 'nas_market', 'nas_site_id', 'nas_session_id'], kpi_description: 'Counts the number of currently open NAS sessions where the NEST outage window has started but checkout has not yet been approved and no outage extension request has been initiated. This KPI is a real-time governance/compliance trigger used to determine whether Escalation #2 actions are required, since it indicates crews are operating beyond the approved outage window without attempting to regularize the window through a formal extension request.', status: 'mentioned', node_id: '38b69e8f-1d2d-4ca1-8067-1503119b9924'});
CREATE (:BKGNode {kpi_source_tables: ['stg_nas_nest_ext_raw_by_session', 'stg_tmo_nas_daily_dashboard'], nl_business_rule: '', kpi_formula_description: 'Pending NEST Extensions = count(distinct nas_session_id) from public.stg_nas_session_level_combined_data where nas_nest_start_time_requested IS NOT NULL (extension requested) AND nas_checkout_approve_time IS NULL (session still open). Supports the same SQL-only filtering and optional group_by dimensional breakdowns as the Active Outage Violations KPI. Dimensions: nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id.', kpi_output_schema: '[{"column": "pending_nest_extensions", "type": "float", "description": "Count of distinct NAS sessions that are open and have at least one NEST extension request."}, {"column": "pending_session_count", "type": "integer", "description": "Same as pending_nest_extensions but as an integer."}, {"column": "as_of_session_rows_considered", "type": "integer", "description": "Number of session rows meeting the condition after filtering (useful for sanity checks)."}]', kpi_business_logic: '1) Pull all NEST Extension rows and group by nas_session_id (optionally filter by nas_date_requested within start_date/end_date). 2) Pull NAS Daily Dashboard rows keyed by session_id. 3) For each session with >=1 extension request, keep it only if the dashboard row exists and checkout_os is null/blank (interpreted as not yet checked out). 4) Apply optional dimension filters (region, market, site_id, nest_type, project_category, nas_session_id). 5) KPI value is the number of distinct remaining session_ids.', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Include only extension requests with nas_date_requested >= start_date (interpreted at 00:00:00 if date-only)."}, {"name": "end_date", "type": "date", "description": "Include only extension requests with nas_date_requested <= end_date (interpreted at 23:59:59 if date-only)."}, {"name": "region", "type": "string", "description": "Filter to a NAS region (from NAS Daily Dashboard Entry.region)."}, {"name": "market", "type": "string", "description": "Filter to a NAS market (from NAS Daily Dashboard Entry.market)."}, {"name": "site_id", "type": "string", "description": "Filter to a site (from NAS Daily Dashboard Entry.site_id)."}, {"name": "nas_session_id", "type": "string", "description": "Filter to a specific NAS session id."}, {"name": "nest_type", "type": "string", "description": "Filter to a NEST type (from NAS Daily Dashboard Entry.nest_type)."}, {"name": "project_category", "type": "string", "description": "Filter to a project category (from NAS Daily Dashboard Entry.project_category)."}]', kpi_contract: '{"function_name": "get_pending_nest_extensions", "node_type": "kpi", "node_id": "b3c481e0-cb8d-4c81-ae35-0e01f0c69f46", "node_label": "Pending NEST Extensions", "description": "Counts NAS sessions that are currently open and have a NEST extension request initiated but are not yet checked out. This measures the volume of in-progress sessions that followed the extension process and are at risk of overrunning their outage window, supporting proactive monitoring and escalation management alongside Active Outage Violations.", "parameters": [{"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}, {"name": "nas_market", "type": "string", "description": "Filter by nas market", "required": false, "sample_values": []}, {"name": "nas_activity_type", "type": "string", "description": "Filter by nas activity type", "required": false, "sample_values": []}, {"name": "nas_company_name", "type": "string", "description": "Filter by nas company name", "required": false, "sample_values": []}, {"name": "nas_primary_gc", "type": "string", "description": "Filter by nas primary gc", "required": false, "sample_values": []}, {"name": "nas_site_id", "type": "string", "description": "Filter by nas site id", "required": false, "sample_values": []}, {"name": "nas_session_id", "type": "string", "description": "Filter by nas session id", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "pending_nest_extensions", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'Pending NEST Extensions = count(distinct nas_session_id) from public.stg_nas_session_level_combined_data where nas_nest_start_time_requested IS NOT NULL (extension requested) AND nas_checkout_approve_time IS NULL (session still open). Supports the same SQL-only filtering and optional group_by dimensional breakdowns as the Active Outage Violations KPI. Dimensions: nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id.', node_type: 'CORE', definition: 'Pending NEST Extensions = count(distinct nas_session_id) from public.stg_nas_session_level_combined_data where nas_nest_start_time_requested IS NOT NULL (extension requested) AND nas_checkout_approve_time IS NULL (session still open). Supports the same SQL-only filtering and optional group_by dimensional breakdowns as the Active Outage Violations KPI. Dimensions: nas_market, nas_activity_type, nas_company_name, nas_primary_gc, nas_site_id.', kpi_python_function: 'def get_pending_nest_extensions(execute_query, filters=None) -> list[dict]:\n    """Pending NEST Extensions (SQL-only, single source table).\n\n    Single source of truth: public.stg_nas_session_level_combined_data\n\n    Pending = extension requested AND session still open:\n      - nas_nest_start_time_requested IS NOT NULL\n      - nas_checkout_approve_time IS NULL\n\n    Supports optional group_by across allowed dimensions and allowlisted filters,\n    matching the pattern used for the Active Outage Violations KPI.\n    """\n\n    filters = filters or {}\n\n    # ---- Allowlisted dimensions (for group_by) ----\n    allowed_group_bys = {\n        "nas_market",\n        "nas_activity_type",\n        "nas_company_name",\n        "nas_primary_gc",\n        "nas_site_id",\n    }\n\n    group_by = filters.get("group_by") or []\n    if isinstance(group_by, str):\n        group_by = [group_by]\n    group_by = [g for g in group_by if g in allowed_group_bys]\n\n    # ---- Allowlisted filters (keep aligned with Active Outage Violations pattern) ----\n    # NOTE: We intentionally do not iterate arbitrary filters to avoid SQL injection / silent failures.\n    where = [\n        "nas_nest_start_time_requested IS NOT NULL",\n        "nas_checkout_approve_time IS NULL",\n    ]\n\n    params = {}\n\n    # Common dimension filters\n    if filters.get("nas_market") is not None:\n        where.append("nas_market = %(nas_market)s")\n        params["nas_market"] = filters["nas_market"]\n\n    if filters.get("nas_activity_type") is not None:\n        where.append("nas_activity_type = %(nas_activity_type)s")\n        params["nas_activity_type"] = filters["nas_activity_type"]\n\n    if filters.get("nas_company_name") is not None:\n        where.append("nas_company_name = %(nas_company_name)s")\n        params["nas_company_name"] = filters["nas_company_name"]\n\n    if filters.get("nas_primary_gc") is not None:\n        where.append("nas_primary_gc = %(nas_primary_gc)s")\n        params["nas_primary_gc"] = filters["nas_primary_gc"]\n\n    if filters.get("nas_site_id") is not None:\n        where.append("nas_site_id = %(nas_site_id)s")\n        params["nas_site_id"] = filters["nas_site_id"]\n\n    # Optional session filter (commonly used for debugging)\n    if filters.get("nas_session_id") is not None:\n        where.append("nas_session_id = %(nas_session_id)s")\n        params["nas_session_id"] = filters["nas_session_id"]\n\n    # Optional date range handling (kept consistent with the Active Outage Violations approach)\n    # We apply date range to the request timestamp column since it is the event defining this KPI.\n    if filters.get("start_date") is not None:\n        where.append("nas_nest_start_time_requested >= %(start_date)s::timestamp")\n        params["start_date"] = str(filters["start_date"])  # accept \'YYYY-MM-DD\' or full timestamp\n\n    if filters.get("end_date") is not None:\n        where.append("nas_nest_start_time_requested <= %(end_date)s::timestamp")\n        params["end_date"] = str(filters["end_date"])  # accept \'YYYY-MM-DD\' or full timestamp\n\n    select_dims = (", ".join(group_by) + ", ") if group_by else ""\n    group_clause = (" GROUP BY " + ", ".join(group_by)) if group_by else ""\n    order_clause = (" ORDER BY " + ", ".join(group_by)) if group_by else ""\n\n    sql = (\n        "SELECT "\n        + select_dims\n        + "COUNT(DISTINCT nas_session_id) AS pending_nest_extensions "\n        + "FROM public.stg_nas_session_level_combined_data "\n        + "WHERE " + " AND ".join(where)\n        + group_clause\n        + order_clause\n    )\n\n    rows = execute_query(sql, params) or []\n\n    # Normalize output shape: always return numeric metric key plus any grouped dimensions\n    out = []\n    for r in rows:\n        rec = {}\n        for d in group_by:\n            rec[d] = r.get(d)\n        rec["pending_nest_extensions"] = float(r.get("pending_nest_extensions") or 0)\n        out.append(rec)\n\n    # If no group_by, still return one row (even if empty result set)\n    if not group_by and not out:\n        out = [{"pending_nest_extensions": 0.0}]\n\n    return out\n', kpi_source_columns: ['stg_nas_nest_ext_raw_by_session.nas_session_id', 'stg_nas_nest_ext_raw_by_session.nas_date_requested', 'stg_nas_nest_ext_raw_by_session.nas_region', 'stg_nas_nest_ext_raw_by_session.nas_market', 'stg_nas_nest_ext_raw_by_session.nas_site_id', 'stg_tmo_nas_daily_dashboard.session_id', 'stg_tmo_nas_daily_dashboard.region', 'stg_tmo_nas_daily_dashboard.market', 'stg_tmo_nas_daily_dashboard.site_id', 'stg_tmo_nas_daily_dashboard.project_category', 'stg_tmo_nas_daily_dashboard.nest_type', 'stg_tmo_nas_daily_dashboard.checkout_os'], session_id: '69a3d22f26e208edc083a06e', label: 'Pending NEST Extensions', kpi_related_core_node_ids: ['integration_activity', 'nest_extension', 'planned_outage', 'site'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'b3c481e0-cb8d-4c81-ae35-0e01f0c69f46', entity_type: 'kpi', kpi_name: 'Pending NEST Extensions', name: 'b3c481e0-cb8d-4c81-ae35-0e01f0c69f46', kpi_dimensions: ['region', 'market', 'site_id', 'project_category', 'nest_type'], kpi_description: 'Counts NAS sessions that are currently open and have a NEST extension request initiated but are not yet checked out. This measures the volume of in-progress sessions that followed the extension process and are at risk of overrunning their outage window, supporting proactive monitoring and escalation management alongside Active Outage Violations.', status: 'mentioned', node_id: 'b3c481e0-cb8d-4c81-ae35-0e01f0c69f46'});
CREATE (:BKGNode {kpi_source_tables: ['stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Market Dependency Blocked = COUNT(DISTINCT pj_project_id) from stg_ndpd_mbt_tmobile_macro_combined where pj_project_status = \'Active\' AND ms_1310_pre_construction_package_received_actual IS NOT NULL AND pj_a_5250_intp_clearance_received_finish IS NULL. Optional filters: m_market, m_area, rgn_region, construction_gc, s_site_id. Optional grouping: rgn_region, m_area, m_market, construction_gc.', kpi_output_schema: '[{"column": "metric", "type": "string", "description": "Metric identifier (market_dependency_blocked)."}, {"column": "blocked_project_count", "type": "integer", "description": "Number of active projects blocked by pending INTP/market clearance after pre-con package received."}, {"column": "dimension", "type": "string", "description": "Returned only when group_by is provided."}, {"column": "dimension_value", "type": "string", "description": "Returned only when group_by is provided."}]', kpi_business_logic: '1) Start from Project rows (optionally filtered by region/area/market/GC). 2) Keep only Active projects (unless caller explicitly provides pj_project_status). 3) For each project, look up Site Survey milestone ms_1310_pre_construction_package_received_actual; require it to be populated (pre-con package received). 4) Look up Integration Artifact clearance: treat INTP/market clearance as received if pj_a_5250_intp_clearance_received_finish is populated; otherwise fall back to i_ntp_received when available. 5) Count projects meeting: pre-con received AND INTP clearance not received. 6) Optionally return counts by a requested dimension (market/area/region/GC).', kpi_filters: '[{"name": "m_market", "type": "string", "description": "Filter projects to a specific market (exact match as stored)."}, {"name": "m_area", "type": "string", "description": "Filter projects to a specific area."}, {"name": "rgn_region", "type": "string", "description": "Filter projects to a specific region."}, {"name": "pj_project_status", "type": "string", "description": "Override default Active-only behavior (e.g., include all statuses)."}, {"name": "group_by", "type": "string", "description": "Optional rollup dimension: one of rgn_region, m_area, m_market, construction_gc."}]', kpi_contract: '{"function_name": "get_market_dependency_blocked", "node_type": "kpi", "node_id": "2dbe987e-8f55-41c5-aad0-f11abeb78580", "node_label": "Market Dependency Blocked", "description": "Counts active projects where the pre-construction package has been received but INTP/market clearance is still pending. This highlights sites blocked by external market/customer dependencies despite Nokia readiness, and serves as the escalation trigger for Market Dependency Risk (Escalation #6) to drive timely cross-party action.", "parameters": [{"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "group_by", "type": "string", "description": "Filter by group by", "required": false, "sample_values": []}], "output_columns": [{"name": "metric", "type": "string", "nullable": false}, {"name": "blocked_project_count", "type": "number", "nullable": false}], "sample_output": [], "row_count": 1}', nl_description: 'Market Dependency Blocked = COUNT(DISTINCT pj_project_id) from stg_ndpd_mbt_tmobile_macro_combined where pj_project_status = \'Active\' AND ms_1310_pre_construction_package_received_actual IS NOT NULL AND pj_a_5250_intp_clearance_received_finish IS NULL. Optional filters: m_market, m_area, rgn_region, construction_gc, s_site_id. Optional grouping: rgn_region, m_area, m_market, construction_gc.', node_type: 'CORE', definition: 'Market Dependency Blocked = COUNT(DISTINCT pj_project_id) from stg_ndpd_mbt_tmobile_macro_combined where pj_project_status = \'Active\' AND ms_1310_pre_construction_package_received_actual IS NOT NULL AND pj_a_5250_intp_clearance_received_finish IS NULL. Optional filters: m_market, m_area, rgn_region, construction_gc, s_site_id. Optional grouping: rgn_region, m_area, m_market, construction_gc.', kpi_python_function: 'def get_market_dependency_blocked(execute_query, filters=None) -> list[dict]:\n    """Market Dependency Blocked: Active projects where pre-construction package received but INTP clearance not received."""\n\n    filters = filters or {}\n\n    # Explicit allowlist filters (no generic loops)\n    m_market = filters.get("m_market")\n    m_area = filters.get("m_area")\n    rgn_region = filters.get("rgn_region")\n    construction_gc = filters.get("construction_gc")\n    s_site_id = filters.get("s_site_id")\n\n    group_by = filters.get("group_by")\n    allowed_group_bys = {"rgn_region", "m_area", "m_market", "construction_gc"}\n    if group_by is not None and group_by not in allowed_group_bys:\n        raise ValueError(f"Unsupported group_by \'{group_by}\'. Allowed: {sorted(allowed_group_bys)}")\n\n    base_where = """\n        pj_project_status = \'Active\'\n        AND ms_1310_pre_construction_package_received_actual IS NOT NULL\n        AND pj_a_5250_intp_clearance_received_finish IS NULL\n    """\n\n    where_clauses = [base_where]\n    params = {}\n\n    if m_market:\n        where_clauses.append("m_market = %(m_market)s")\n        params["m_market"] = m_market\n    if m_area:\n        where_clauses.append("m_area = %(m_area)s")\n        params["m_area"] = m_area\n    if rgn_region:\n        where_clauses.append("rgn_region = %(rgn_region)s")\n        params["rgn_region"] = rgn_region\n    if construction_gc:\n        where_clauses.append("construction_gc = %(construction_gc)s")\n        params["construction_gc"] = construction_gc\n    if s_site_id:\n        where_clauses.append("s_site_id = %(s_site_id)s")\n        params["s_site_id"] = s_site_id\n\n    where_sql = " WHERE " + " AND ".join(f"({c.strip()})" for c in where_clauses)\n\n    if group_by:\n        sql = f"""\n            SELECT\n                {group_by} AS dimension_value,\n                COUNT(DISTINCT pj_project_id) AS blocked_project_count\n            FROM stg_ndpd_mbt_tmobile_macro_combined\n            {where_sql}\n            GROUP BY {group_by}\n            ORDER BY {group_by}\n        """\n        rows = execute_query(sql, params)\n        return [\n            {\n                "metric": "market_dependency_blocked",\n                "dimension": group_by,\n                "dimension_value": r.get("dimension_value") if r.get("dimension_value") is not None else "(NULL)",\n                "blocked_project_count": r.get("blocked_project_count") or 0,\n            }\n            for r in (rows or [])\n        ]\n\n    sql = f"""\n        SELECT\n            COUNT(DISTINCT pj_project_id) AS blocked_project_count\n        FROM stg_ndpd_mbt_tmobile_macro_combined\n        {where_sql}\n    """\n    rows = execute_query(sql, params)\n    count_val = 0\n    if rows and isinstance(rows, list):\n        count_val = rows[0].get("blocked_project_count") or 0\n\n    return [{\n        "metric": "market_dependency_blocked",\n        "blocked_project_count": count_val\n    }]\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 's_site_id', 'm_market', 'm_area', 'rgn_region', 'construction_gc', 'ms_1310_pre_construction_package_received_actual', 'pj_a_5250_intp_clearance_received_finish', 'i_ntp_received'], session_id: '69a3d22f26e208edc083a06e', label: 'Market Dependency Blocked', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '2dbe987e-8f55-41c5-aad0-f11abeb78580', entity_type: 'kpi', kpi_name: 'Market Dependency Blocked', name: '2dbe987e-8f55-41c5-aad0-f11abeb78580', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Counts active projects where the pre-construction package has been received but INTP/market clearance is still pending. This highlights sites blocked by external market/customer dependencies despite Nokia readiness, and serves as the escalation trigger for Market Dependency Risk (Escalation #6) to drive timely cross-party action.', status: 'mentioned', node_id: '2dbe987e-8f55-41c5-aad0-f11abeb78580'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Tool Access Blocked = count of distinct Active projects where construction PO has been pulled (milestone pj_a_4200_pull_construction_po_number_finish is not null) and tool access is blocked because CR is missing/blank OR CR status is null or not in the caller-provided resolved_statuses set (default: [\'approved\',\'SCHEDULED\'], overridable via filter). Output is grouped by region/area/market/general_contractor/construction_gc and split into CR missing vs CR stuck.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region of the project/site."}, {"column": "m_area", "type": "string", "description": "Area of the project/site."}, {"column": "m_market", "type": "string", "description": "Market of the project/site."}, {"column": "construction_gc", "type": "string", "description": "General contractor assigned on the project record (free-text)."}, {"column": "construction_gc", "type": "string", "description": "Construction GC field on the project record (may differ from construction_gc in split-scope cases)."}, {"column": "tool_access_blocked_projects", "type": "integer", "description": "Distinct active projects with construction NTP accepted and CR missing or not resolved."}, {"column": "cr_missing_projects", "type": "integer", "description": "Distinct active projects where CR id is missing/blank (subset of tool_access_blocked_projects)."}, {"column": "cr_stuck_projects", "type": "integer", "description": "Distinct active projects where CR exists but status is null or not in the resolved set (subset of tool_access_blocked_projects)."}]', kpi_business_logic: '1) Start from stg_ndpd_mbt_tmobile_macro_combined (one row per project).\n2) Keep only pj_project_status = \'Active\'.\n3) Identify projects where construction has pulled a PO: pj_a_4200_pull_construction_po_number_finish IS NOT NULL.\n4) Among those, flag as tool-access-blocked if pj_cr_id IS NULL/blank OR pj_cr_status IS NULL OR LOWER(TRIM(pj_cr_status)) NOT IN the caller-provided resolved_statuses set (default: [\'approved\', \'scheduled\'], overridable via filter).\n5) Aggregate counts of distinct pj_project_id grouped by rgn_region, m_area, m_market, construction_gc, construction_gc, split into CR missing vs CR stuck (CR exists but not resolved).', kpi_filters: '[{"name": "start_date", "type": "date", "description": "Include projects whose construction NTP accepted timestamp is on/after this datetime (pj_a_4100_construction_ntp_accepted_by_gc_finish)."}, {"name": "end_date", "type": "date", "description": "Include projects whose construction NTP accepted timestamp is before this datetime (pj_a_4100_construction_ntp_accepted_by_gc_finish)."}, {"name": "rgn_region", "type": "string", "description": "Filter to a specific region."}, {"name": "m_area", "type": "string", "description": "Filter to a specific area."}, {"name": "m_market", "type": "string", "description": "Filter to a specific market."}, {"name": "construction_gc", "type": "string", "description": "Filter to a specific general contractor (free-text field)."}, {"name": "construction_gc", "type": "string", "description": "Filter to a specific construction GC alias field."}]', kpi_contract: '{"function_name": "get_tool_access_blocked", "node_type": "kpi", "node_id": "d43ba249-174c-46e6-9ba2-cce0c84cd312", "node_label": "Tool Access Blocked", "description": "Counts active projects that have reached the point where construction has pulled a PO but tool access is blocked because the project\\u2019s Change Request is missing or not yet in a resolved state. This KPI is used as an escalation trigger to prevent integration delays by separating cases where a CR was never raised from cases where a CR exists but is stuck in approval/processing, enabling targeted follow-up by market and contractor.", "parameters": [{"name": "resolved_statuses", "type": "string", "description": "Filter by resolved statuses", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by pj general contractor", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "tool_access_blocked_projects", "type": "number", "nullable": false}, {"name": "cr_missing_projects", "type": "number", "nullable": false}, {"name": "cr_stuck_projects", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Tool Access Blocked = count of distinct Active projects where construction PO has been pulled (milestone pj_a_4200_pull_construction_po_number_finish is not null) and tool access is blocked because CR is missing/blank OR CR status is null or not in the caller-provided resolved_statuses set (default: [\'approved\',\'SCHEDULED\'], overridable via filter). Output is grouped by region/area/market/general_contractor/construction_gc and split into CR missing vs CR stuck.', node_type: 'CORE', definition: 'Tool Access Blocked = count of distinct Active projects where construction PO has been pulled (milestone pj_a_4200_pull_construction_po_number_finish is not null) and tool access is blocked because CR is missing/blank OR CR status is null or not in the caller-provided resolved_statuses set (default: [\'approved\',\'SCHEDULED\'], overridable via filter). Output is grouped by region/area/market/general_contractor/construction_gc and split into CR missing vs CR stuck.', kpi_python_function: 'def get_tool_access_blocked(execute_query, filters=None) -> list[dict]:\n    """Counts active projects where construction has pulled a PO (via PO pull milestone)\n    but tool access is blocked because CR is missing or not resolved.\n\n    Output is grouped by region/area/market/GC with split into CR missing vs CR stuck.\n\n    Filters (allowlist):\n      - start_date, end_date (applied to pj_a_4200_pull_construction_po_number_finish)\n      - rgn_region, m_area, m_market, construction_gc, construction_gc\n      - resolved_statuses: list[str] or comma-separated str; defaults to [\'approved\',\'SCHEDULED\']\n    """\n\n    filters = filters or {}\n\n    # Parse/normalize resolved statuses\n    resolved_statuses = filters.get("resolved_statuses", ["approved", "SCHEDULED"])\n    if isinstance(resolved_statuses, str):\n        resolved_statuses = [s.strip() for s in resolved_statuses.split(",") if s.strip()]\n    elif isinstance(resolved_statuses, (list, tuple, set)):\n        resolved_statuses = [str(s).strip() for s in resolved_statuses if str(s).strip()]\n    else:\n        resolved_statuses = ["approved", "SCHEDULED"]\n\n    # SQL list literal (lowercased to match LOWER(TRIM()))\n    resolved_list_sql = ", ".join([f"\'{str(s).lower().replace("\'", "\'\'")}\'" for s in resolved_statuses])\n    if not resolved_list_sql:\n        # If caller passes an empty list, treat as "no statuses are resolved"\n        # so NOT IN () doesn\'t break SQL.\n        resolved_list_sql = "\'\'"\n\n    # Allowlisted filters\n    where_parts = [\n        \'p."pj_project_status" = \\\'Active\\\'\',\n        # Proxy for "construction has pulled a PO": PO pull milestone completed\n        \'p."pj_a_4200_pull_construction_po_number_finish" IS NOT NULL\',\n        # Tool access blocked because CR missing or not resolved\n        f\'(p."pj_cr_id" IS NULL OR NULLIF(TRIM(p."pj_cr_id"), \\\'\\\') IS NULL \'\n        f\'OR p."pj_cr_status" IS NULL OR LOWER(TRIM(p."pj_cr_status")) NOT IN ({resolved_list_sql}))\'\n    ]\n\n    if filters.get("start_date"):\n        sd = str(filters["start_date"]).replace("\'", "\'\'")\n        where_parts.append(\n            f\'p."pj_a_4200_pull_construction_po_number_finish"::timestamp >= \\\'{sd}\\\'::timestamp\'\n        )\n    if filters.get("end_date"):\n        ed = str(filters["end_date"]).replace("\'", "\'\'")\n        where_parts.append(\n            f\'p."pj_a_4200_pull_construction_po_number_finish"::timestamp < \\\'{ed}\\\'::timestamp\'\n        )\n\n    if filters.get("rgn_region"):\n        v = str(filters["rgn_region"]).replace("\'", "\'\'")\n        where_parts.append(f\'p."rgn_region" = \\\'{v}\\\'\')\n    if filters.get("m_area"):\n        v = str(filters["m_area"]).replace("\'", "\'\'")\n        where_parts.append(f\'p."m_area" = \\\'{v}\\\'\')\n    if filters.get("m_market"):\n        v = str(filters["m_market"]).replace("\'", "\'\'")\n        where_parts.append(f\'p."m_market" = \\\'{v}\\\'\')\n    if filters.get("construction_gc"):\n        v = str(filters["construction_gc"]).replace("\'", "\'\'")\n        where_parts.append(f\'p."construction_gc" = \\\'{v}\\\'\')\n    if filters.get("construction_gc"):\n        v = str(filters["construction_gc"]).replace("\'", "\'\'")\n        where_parts.append(f\'p."construction_gc" = \\\'{v}\\\'\')\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = f"""\n    SELECT\n      p."rgn_region" AS "rgn_region",\n      p."m_area" AS "m_area",\n      p."m_market" AS "m_market",\n      p."construction_gc" AS "construction_gc",\n      p."construction_gc" AS "construction_gc",\n      COUNT(DISTINCT p."pj_project_id") AS "tool_access_blocked_projects",\n      COUNT(DISTINCT CASE\n        WHEN (p."pj_cr_id" IS NULL OR NULLIF(TRIM(p."pj_cr_id"), \'\') IS NULL)\n          THEN p."pj_project_id"\n      END) AS "cr_missing_projects",\n      COUNT(DISTINCT CASE\n        WHEN (p."pj_cr_id" IS NOT NULL AND NULLIF(TRIM(p."pj_cr_id"), \'\') IS NOT NULL)\n         AND (p."pj_cr_status" IS NULL OR LOWER(TRIM(p."pj_cr_status")) NOT IN ({resolved_list_sql}))\n          THEN p."pj_project_id"\n      END) AS "cr_stuck_projects"\n    FROM public."stg_ndpd_mbt_tmobile_macro_combined" p\n    WHERE {where_sql}\n    GROUP BY\n      p."rgn_region", p."m_area", p."m_market", p."construction_gc", p."construction_gc"\n    ORDER BY\n      p."rgn_region", p."m_area", p."m_market", p."construction_gc", p."construction_gc";\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'pj_a_4100_construction_ntp_accepted_by_gc_finish', 'pj_cr_id', 'pj_cr_status', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'construction_gc'], session_id: '69a3d22f26e208edc083a06e', label: 'Tool Access Blocked', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'change_request'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'd43ba249-174c-46e6-9ba2-cce0c84cd312', entity_type: 'kpi', kpi_name: 'Tool Access Blocked', name: 'd43ba249-174c-46e6-9ba2-cce0c84cd312', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'construction_gc'], kpi_description: 'Counts active projects that have reached the point where construction has pulled a PO but tool access is blocked because the project’s Change Request is missing or not yet in a resolved state. This KPI is used as an escalation trigger to prevent integration delays by separating cases where a CR was never raised from cases where a CR exists but is stuck in approval/processing, enabling targeted follow-up by market and contractor.', status: 'mentioned', node_id: 'd43ba249-174c-46e6-9ba2-cce0c84cd312'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'For active projects, returns market-level counts of distinct projects in WIP for four indicators: (1) civil_wip_ndpd where ms_1549_civil_construction_start_actual is not null AND ms_1551_civil_construction_complete_actual_date is null; (2) tower_wip_ndpd where ms_1550_construction_start_actual is not null AND ms_1555_construction_complete_actual is null; (3) civil_wip_mb where pj_a_4250_civil_construction_start_finish is not null AND pj_a_4750_civil_construction_complete_finish is null; (4) tower_wip_mb where pj_a_4225_construction_start_finish is not null AND pj_a_5175_construction_complete_finish is null. Also computes active_vendor_count as the distinct non-blank construction_gc values among rows where any of the four WIP conditions is true. Results are grouped by rgn_region, m_area, m_market, and por_category (construction_gc is filter-only).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "civil_wip_project_count", "type": "integer", "description": "Distinct active projects currently in Civil WIP."}, {"column": "tower_wip_project_count", "type": "integer", "description": "Distinct active projects currently in Tower WIP."}, {"column": "total_wip_project_count_dedup", "type": "integer", "description": "Distinct active projects in either Civil WIP or Tower WIP (deduplicated across the two signals)."}, {"column": "civil_wip_site_count", "type": "integer", "description": "Distinct sites with at least one active project in Civil WIP."}, {"column": "tower_wip_site_count", "type": "integer", "description": "Distinct sites with at least one active project in Tower WIP."}, {"column": "total_wip_site_count_dedup", "type": "integer", "description": "Distinct sites with any WIP signal (civil or tower), deduplicated."}, {"column": "wip_distinct_gc_count", "type": "integer", "description": "Distinct general contractors (construction_gc) associated with any WIP project/site in the group."}]', kpi_business_logic: '1) Filter rows to Active projects (pj_project_status=\'Active\') with non-null pj_project_id and s_site_id. 2) Apply optional filters: rgn_region, m_area, m_market, construction_gc (filter-only), site_code (mapped to s_site_id), por_category. 3) Group remaining rows by rgn_region, m_area, m_market, por_category. 4) Compute: civil_wip_ndpd = COUNT(DISTINCT pj_project_id) where ms_1549_civil_construction_start_actual is not null and ms_1551_civil_construction_complete_actual_date is null; tower_wip_ndpd = COUNT(DISTINCT pj_project_id) where ms_1550_construction_start_actual is not null and ms_1555_construction_complete_actual is null; civil_wip_mb = COUNT(DISTINCT pj_project_id) where pj_a_4250_civil_construction_start_finish is not null and pj_a_4750_civil_construction_complete_finish is null; tower_wip_mb = COUNT(DISTINCT pj_project_id) where pj_a_4225_construction_start_finish is not null and pj_a_5175_construction_complete_finish is null. 5) active_vendor_count = COUNT(DISTINCT trimmed construction_gc) over rows meeting any WIP condition; blank strings are excluded via NULLIF(BTRIM(construction_gc),\'\').', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "por_category", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "site_code", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_tower_civil_wip", "node_type": "kpi", "node_id": "0087a40d-da6f-4622-98d5-f3e9b02c81df", "node_label": "Tower & Civil WIP", "description": "Counts distinct projects/sites with active work-in-progress in civil and tower construction, combining both NDPd milestone tracking and Magenta Tracker milestone tracking so WIP is captured regardless of which system a site uses. Provides separate civil WIP and tower WIP counts (which may overlap) plus a deduplicated total WIP count across any WIP signal, and includes the number of distinct active general contractors associated with WIP to support capacity planning and workload balancing by region/area/market and contractor.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "site_code", "type": "string", "description": "Filter by site code", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "civil_wip_ndpd", "type": "number", "nullable": false}, {"name": "tower_wip_ndpd", "type": "number", "nullable": false}, {"name": "civil_wip_mb", "type": "number", "nullable": false}, {"name": "tower_wip_mb", "type": "number", "nullable": false}, {"name": "active_vendor_count", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'For active projects, returns market-level counts of distinct projects in WIP for four indicators: (1) civil_wip_ndpd where ms_1549_civil_construction_start_actual is not null AND ms_1551_civil_construction_complete_actual_date is null; (2) tower_wip_ndpd where ms_1550_construction_start_actual is not null AND ms_1555_construction_complete_actual is null; (3) civil_wip_mb where pj_a_4250_civil_construction_start_finish is not null AND pj_a_4750_civil_construction_complete_finish is null; (4) tower_wip_mb where pj_a_4225_construction_start_finish is not null AND pj_a_5175_construction_complete_finish is null. Also computes active_vendor_count as the distinct non-blank construction_gc values among rows where any of the four WIP conditions is true. Results are grouped by rgn_region, m_area, m_market, and por_category (construction_gc is filter-only).', node_type: 'CORE', definition: 'For active projects, returns market-level counts of distinct projects in WIP for four indicators: (1) civil_wip_ndpd where ms_1549_civil_construction_start_actual is not null AND ms_1551_civil_construction_complete_actual_date is null; (2) tower_wip_ndpd where ms_1550_construction_start_actual is not null AND ms_1555_construction_complete_actual is null; (3) civil_wip_mb where pj_a_4250_civil_construction_start_finish is not null AND pj_a_4750_civil_construction_complete_finish is null; (4) tower_wip_mb where pj_a_4225_construction_start_finish is not null AND pj_a_5175_construction_complete_finish is null. Also computes active_vendor_count as the distinct non-blank construction_gc values among rows where any of the four WIP conditions is true. Results are grouped by rgn_region, m_area, m_market, and por_category (construction_gc is filter-only).', kpi_python_function: 'def get_tower_civil_wip(execute_query, filters=None) -> list[dict]:\n    # KPI: Civil/Tower WIP (NDPd + Magenta Builder Tracker)\n    # Source of truth: public.stg_ndpd_mbt_tmobile_macro_combined\n\n    where_parts = [\n        \'"pj_project_id" IS NOT NULL\',\n        \'"s_site_id" IS NOT NULL\',\n        \'"pj_project_status" = \\\'Active\\\'\'\n    ]\n\n    # Explicit allowlist filters only (no date logic; no pj_program_name / pj_project_type)\n    if filters:\n        if filters.get(\'rgn_region\'):\n            val = str(filters[\'rgn_region\']).replace("\'", "\'\'")\n            where_parts.append(f\'"rgn_region" = \\\'{val}\\\'\')\n        if filters.get(\'m_area\'):\n            val = str(filters[\'m_area\']).replace("\'", "\'\'")\n            where_parts.append(f\'"m_area" = \\\'{val}\\\'\')\n        if filters.get(\'m_market\'):\n            val = str(filters[\'m_market\']).replace("\'", "\'\'")\n            where_parts.append(f\'"m_market" = \\\'{val}\\\'\')\n        # filter-only (not a grouping dimension)\n        if filters.get(\'construction_gc\'):\n            val = str(filters[\'construction_gc\']).replace("\'", "\'\'")\n            where_parts.append(f\'"construction_gc" = \\\'{val}\\\'\')\n        if filters.get(\'site_code\'):\n            val = str(filters[\'site_code\']).replace("\'", "\'\'")\n            where_parts.append(f\'"s_site_id" = \\\'{val}\\\'\')\n        if filters.get(\'por_category\'):\n            val = str(filters[\'por_category\']).replace("\'", "\'\'")\n            where_parts.append(f\'"por_category" = \\\'{val}\\\'\')\n\n    where_sql = \' AND \'.join(where_parts)\n\n    # WIP is a current-state snapshot based on milestone presence/absence.\n    # All logic is inline CASE expressions on the same table (no CTE, no subquery).\n    sql = f"""\n        SELECT\n            "rgn_region" AS "rgn_region",\n            "m_area" AS "m_area",\n            "m_market" AS "m_market",\n            "por_category" AS "por_category",\n\n            COUNT(DISTINCT CASE\n                WHEN "ms_1549_civil_construction_start_actual" IS NOT NULL\n                 AND "ms_1551_civil_construction_complete_actual_date" IS NULL\n                THEN "pj_project_id" END\n            ) AS "civil_wip_ndpd",\n\n            COUNT(DISTINCT CASE\n                WHEN "ms_1550_construction_start_actual" IS NOT NULL\n                 AND "ms_1555_construction_complete_actual" IS NULL\n                THEN "pj_project_id" END\n            ) AS "tower_wip_ndpd",\n\n            COUNT(DISTINCT CASE\n                WHEN "pj_a_4250_civil_construction_start_finish" IS NOT NULL\n                 AND "pj_a_4750_civil_construction_complete_finish" IS NULL\n                THEN "pj_project_id" END\n            ) AS "civil_wip_mb",\n\n            COUNT(DISTINCT CASE\n                WHEN "pj_a_4225_construction_start_finish" IS NOT NULL\n                 AND "pj_a_5175_construction_complete_finish" IS NULL\n                THEN "pj_project_id" END\n            ) AS "tower_wip_mb",\n\n            COUNT(DISTINCT CASE\n                WHEN (\n                    ("ms_1549_civil_construction_start_actual" IS NOT NULL AND "ms_1551_civil_construction_complete_actual_date" IS NULL)\n                    OR ("ms_1550_construction_start_actual" IS NOT NULL AND "ms_1555_construction_complete_actual" IS NULL)\n                    OR ("pj_a_4250_civil_construction_start_finish" IS NOT NULL AND "pj_a_4750_civil_construction_complete_finish" IS NULL)\n                    OR ("pj_a_4225_construction_start_finish" IS NOT NULL AND "pj_a_5175_construction_complete_finish" IS NULL)\n                )\n                THEN NULLIF(BTRIM("construction_gc"), \'\')\n                END\n            ) AS "active_vendor_count"\n\n        FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n        WHERE {where_sql}\n        GROUP BY\n            "rgn_region",\n            "m_area",\n            "m_market",\n            "por_category"\n        ORDER BY\n            "rgn_region",\n            "m_area",\n            "m_market",\n            "por_category";\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 's_site_id', 'pj_project_status', 'rgn_region', 'm_area', 'm_market', 'por_category', 'construction_gc', 'ms_1549_civil_construction_start_actual', 'ms_1551_civil_construction_complete_actual_date', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual', 'pj_a_4250_civil_construction_start_finish', 'pj_a_4750_civil_construction_complete_finish', 'pj_a_4225_construction_start_finish', 'pj_a_5175_construction_complete_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Tower & Civil WIP', kpi_related_core_node_ids: ['project', 'site', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '0087a40d-da6f-4622-98d5-f3e9b02c81df', entity_type: 'kpi', kpi_name: 'Tower & Civil WIP', name: '0087a40d-da6f-4622-98d5-f3e9b02c81df', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'por_category'], kpi_description: 'Counts distinct projects/sites with active work-in-progress in civil and tower construction, combining both NDPd milestone tracking and Magenta Tracker milestone tracking so WIP is captured regardless of which system a site uses. Provides separate civil WIP and tower WIP counts (which may overlap) plus a deduplicated total WIP count across any WIP signal, and includes the number of distinct active general contractors associated with WIP to support capacity planning and workload balancing by region/area/market and contractor.', status: 'mentioned', node_id: '0087a40d-da6f-4622-98d5-f3e9b02c81df'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Vendor Utilization Rate (%) = 100 * (count of distinct Active projects assigned to a General Contractor that are Work-In-Progress) / (count of distinct Active assigned projects), grouped by construction_gc and geography (region/area/market). A project is considered WIP if ANY of four start/complete milestone pairs indicates started (start field not null) and not completed (complete field null): (ms_1549/ms_1551) OR (ms_1550/ms_1555) OR (pj_a_4250/pj_a_4750) OR (pj_a_4225/pj_a_5175).', kpi_output_schema: '[{"column": "construction_gc", "type": "string", "description": "General Contractor (vendor) name from the project record."}, {"column": "rgn_region", "type": "string", "description": "Region associated with the project/site."}, {"column": "m_area", "type": "string", "description": "Area associated with the project/site."}, {"column": "m_market", "type": "string", "description": "Market associated with the project/site."}, {"column": "active_assigned_projects", "type": "integer", "description": "Count of distinct active projects assigned to the GC in the selected slice."}, {"column": "wip_projects", "type": "integer", "description": "Count of distinct active projects currently in construction WIP (started, not completed)."}, {"column": "vendor_utilization_rate", "type": "float", "description": "wip_projects divided by active_assigned_projects."}]', kpi_business_logic: '1) Filter to rows with non-null pj_project_id, non-empty construction_gc, and pj_project_status = \'Active\'. 2) Apply optional filters from the allowlist (construction_gc, rgn_region, m_area, m_market, por_category, s_site_id). 3) For each group (construction_gc, rgn_region, m_area, m_market), compute active_assigned_projects = COUNT(DISTINCT pj_project_id). 4) Compute wip_sites = COUNT(DISTINCT pj_project_id) where any of the four WIP start/complete conditions is true. 5) Compute utilization_rate_pct = 100.0 * wip_sites / NULLIF(active_assigned_projects, 0). 6) Return grouped results ordered by utilization_rate_pct desc (nulls last), then wip_sites desc.', kpi_filters: '[{"name": "construction_gc", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "por_category", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_vendor_utilization_rate", "node_type": "kpi", "node_id": "7768c79b-8ad0-43a5-87f6-88081b7d3296", "node_label": "Vendor Utilization Rate", "description": "Measures how much of each general contractor\\u2019s active assigned project portfolio is currently in work-in-progress (civil or tower). It indicates whether a vendor is capacity-constrained or underutilized, supporting capacity rebalancing and assignment decisions across markets and regions.", "parameters": [{"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "construction_gc", "type": "string", "nullable": false}, {"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "active_assigned_projects", "type": "number", "nullable": false}, {"name": "wip_sites", "type": "number", "nullable": false}, {"name": "utilization_rate_pct", "type": "string", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Vendor Utilization Rate (%) = 100 * (count of distinct Active projects assigned to a General Contractor that are Work-In-Progress) / (count of distinct Active assigned projects), grouped by construction_gc and geography (region/area/market). A project is considered WIP if ANY of four start/complete milestone pairs indicates started (start field not null) and not completed (complete field null): (ms_1549/ms_1551) OR (ms_1550/ms_1555) OR (pj_a_4250/pj_a_4750) OR (pj_a_4225/pj_a_5175).', node_type: 'CORE', definition: 'Vendor Utilization Rate (%) = 100 * (count of distinct Active projects assigned to a General Contractor that are Work-In-Progress) / (count of distinct Active assigned projects), grouped by construction_gc and geography (region/area/market). A project is considered WIP if ANY of four start/complete milestone pairs indicates started (start field not null) and not completed (complete field null): (ms_1549/ms_1551) OR (ms_1550/ms_1555) OR (pj_a_4250/pj_a_4750) OR (pj_a_4225/pj_a_5175).', kpi_python_function: 'def get_vendor_utilization_rate(execute_query, filters=None) -> list[dict]:\n    # Vendor Utilization Rate (%) = WIP active assigned projects / active assigned projects * 100\n    # WIP is true if ANY of the 4 construction pathways indicates started but not completed.\n\n    where_parts = [\n        \'"pj_project_id" IS NOT NULL\',\n        \'"construction_gc" IS NOT NULL\',\n        \'TRIM("construction_gc") <> \\\'\\\'\',\n        \'"pj_project_status" = \\\'Active\\\'\'\n    ]\n\n    # Explicit allowlist of supported filters (no date filters; snapshot KPI)\n    if filters:\n        if filters.get(\'construction_gc\'):\n            escaped = str(filters[\'construction_gc\']).replace("\'", "\'\'")\n            where_parts.append(f\'"construction_gc" = \\\'{escaped}\\\'\')\n\n        if filters.get(\'m_market\'):\n            escaped = str(filters[\'m_market\']).replace("\'", "\'\'")\n            where_parts.append(f\'"m_market" = \\\'{escaped}\\\'\')\n\n        if filters.get(\'m_area\'):\n            escaped = str(filters[\'m_area\']).replace("\'", "\'\'")\n            where_parts.append(f\'"m_area" = \\\'{escaped}\\\'\')\n\n        if filters.get(\'rgn_region\'):\n            escaped = str(filters[\'rgn_region\']).replace("\'", "\'\'")\n            where_parts.append(f\'"rgn_region" = \\\'{escaped}\\\'\')\n\n        if filters.get(\'por_category\'):\n            escaped = str(filters[\'por_category\']).replace("\'", "\'\'")\n            where_parts.append(f\'"por_category" = \\\'{escaped}\\\'\')\n\n        if filters.get(\'s_site_id\'):\n            escaped = str(filters[\'s_site_id\']).replace("\'", "\'\'")\n            where_parts.append(f\'"s_site_id" = \\\'{escaped}\\\'\')\n\n    where_sql = \' WHERE \' + \' AND \'.join(where_parts)\n\n    # NOTE: No CTEs; single-table SQL; explicit column references only.\n    sql = (\n        \'SELECT \'\n        \'  "construction_gc" AS "construction_gc", \'\n        \'  "rgn_region" AS "rgn_region", \'\n        \'  "m_area" AS "m_area", \'\n        \'  "m_market" AS "m_market", \'\n        \'  COUNT(DISTINCT "pj_project_id") AS "active_assigned_projects", \'\n        \'  COUNT(DISTINCT CASE WHEN ( \'\n        \'    ("ms_1549_civil_construction_start_actual" IS NOT NULL AND "ms_1551_civil_construction_complete_actual_date" IS NULL) \'\n        \'    OR ("ms_1550_construction_start_actual" IS NOT NULL AND "ms_1555_construction_complete_actual" IS NULL) \'\n        \'    OR ("pj_a_4250_civil_construction_start_finish" IS NOT NULL AND "pj_a_4750_civil_construction_complete_finish" IS NULL) \'\n        \'    OR ("pj_a_4225_construction_start_finish" IS NOT NULL AND "pj_a_5175_construction_complete_finish" IS NULL) \'\n        \'  ) THEN "pj_project_id" END) AS "wip_sites", \'\n        \'  (100.0 * \'\n        \'     COUNT(DISTINCT CASE WHEN ( \'\n        \'       ("ms_1549_civil_construction_start_actual" IS NOT NULL AND "ms_1551_civil_construction_complete_actual_date" IS NULL) \'\n        \'       OR ("ms_1550_construction_start_actual" IS NOT NULL AND "ms_1555_construction_complete_actual" IS NULL) \'\n        \'       OR ("pj_a_4250_civil_construction_start_finish" IS NOT NULL AND "pj_a_4750_civil_construction_complete_finish" IS NULL) \'\n        \'       OR ("pj_a_4225_construction_start_finish" IS NOT NULL AND "pj_a_5175_construction_complete_finish" IS NULL) \'\n        \'     ) THEN "pj_project_id" END)::numeric \'\n        \'     / NULLIF(COUNT(DISTINCT "pj_project_id")::numeric, 0) \'\n        \'  ) AS "utilization_rate_pct" \'\n        \'FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\'\n        + where_sql +\n        \' GROUP BY "construction_gc", "rgn_region", "m_area", "m_market" \'\n        \'ORDER BY "utilization_rate_pct" DESC NULLS LAST, "wip_sites" DESC\'\n    )\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'construction_gc', 'pj_project_status', 'rgn_region', 'm_area', 'm_market', 'por_category', 's_site_id', 'ms_1549_civil_construction_start_actual', 'ms_1551_civil_construction_complete_actual_date', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual', 'pj_a_4250_civil_construction_start_finish', 'pj_a_4750_civil_construction_complete_finish', 'pj_a_4225_construction_start_finish', 'pj_a_5175_construction_complete_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Vendor Utilization Rate', kpi_related_core_node_ids: ['general_contractor', 'project'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '7768c79b-8ad0-43a5-87f6-88081b7d3296', entity_type: 'kpi', kpi_name: 'Vendor Utilization Rate', name: '7768c79b-8ad0-43a5-87f6-88081b7d3296', kpi_dimensions: ['construction_gc', 'rgn_region', 'm_area', 'm_market'], kpi_description: 'Measures how much of each general contractor’s active assigned project portfolio is currently in work-in-progress (civil or tower). It indicates whether a vendor is capacity-constrained or underutilized, supporting capacity rebalancing and assignment decisions across markets and regions.', status: 'mentioned', node_id: '7768c79b-8ad0-43a5-87f6-88081b7d3296'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Snapshot of Active projects grouped by rgn_region/m_area/m_market/construction_gc/por_category. Computes conditional distinct-project counts: (1) SCOP Pending (NDPD) where ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl is not null AND ms_1559_cop_approved_by_t_mobile_actual is null; (2) SCOP Pending (MB) where pj_a_5500_receive_close_out_binder_finish is not null AND pj_a_5525_approve_close_out_binder_finish is null; (3) Resubmissions where scop_tw_punch_list_re_submitted_to_tmo is not null; (4) First-time-right approved where ms_1559 is not null AND scop_tw_checklist_rejected_by_tmo is null; (5) Total approved where ms_1559 is not null; (6) FTR rate % = 100 * FTR approved / total approved. No pending-only WHERE filter; all metrics are conditional counts over the Active population.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "scop_approval_pending_projects", "type": "integer", "description": "Distinct count of projects with closeout submitted/received but not yet approved by T-Mobile."}, {"column": "first_time_right_pending_projects", "type": "integer", "description": "Distinct count of pending projects flagged as first_time_right (string contains \'Y\')."}, {"column": "not_first_time_right_pending_projects", "type": "integer", "description": "Distinct count of pending projects flagged as not first-time-right (string contains \'N\')."}, {"column": "resubmitted_pending_projects", "type": "integer", "description": "Distinct count of pending projects with a resubmission indicator populated."}, {"column": "avg_punch_checklist_completion_percent_pending", "type": "float", "description": "Average punch_checklist_completion_percent across pending projects (numeric cast)."}]', kpi_business_logic: 'Start from public.stg_ndpd_mbt_tmobile_macro_combined.\nRestrict population to rows with pj_project_status = \'Active\'.\nApply optional exact-match filters (allowlist): rgn_region, m_area, m_market, construction_gc, por_category, pj_project_id, s_site_id.\nGroup by rgn_region, m_area, m_market, construction_gc, por_category.\nCompute scop_pending_ndpd as COUNT(DISTINCT pj_project_id) where ms_1557 is not null and ms_1559 is null.\nCompute scop_pending_mb as COUNT(DISTINCT pj_project_id) where pj_a_5500 is not null and pj_a_5525 is null.\nCompute scop_resubmission_count as COUNT(DISTINCT pj_project_id) where scop_tw_punch_list_re_submitted_to_tmo is not null.\nCompute scop_first_time_right_count as COUNT(DISTINCT pj_project_id) where ms_1559 is not null and scop_tw_checklist_rejected_by_tmo is null.\nCompute scop_total_approved_count as COUNT(DISTINCT pj_project_id) where ms_1559 is not null.\nCompute scop_ftr_rate_pct as 100.0 * scop_first_time_right_count / NULLIF(scop_total_approved_count, 0).', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "por_category", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_scop_approval_pending", "node_type": "kpi", "node_id": "aa4376f5-f790-4cc0-ae24-cabaf23fcd0a", "node_label": "SCOP Approval Pending", "description": "Measures the volume of projects where the closeout package/binder has been submitted or received but is still awaiting T-Mobile approval, and summarizes resubmissions and first-time-right approval performance. This KPI helps identify closeout bottlenecks that delay customer acceptance and downstream payment triggers, and highlights where process or documentation quality is driving rework.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "scop_pending_ndpd", "type": "number", "nullable": false}, {"name": "scop_pending_mb", "type": "number", "nullable": false}, {"name": "scop_resubmission_count", "type": "number", "nullable": false}, {"name": "scop_first_time_right_count", "type": "number", "nullable": false}, {"name": "scop_total_approved_count", "type": "number", "nullable": false}, {"name": "scop_ftr_rate_pct", "type": "null", "nullable": true}], "sample_output": [], "row_count": 10}', nl_description: 'Snapshot of Active projects grouped by rgn_region/m_area/m_market/construction_gc/por_category. Computes conditional distinct-project counts: (1) SCOP Pending (NDPD) where ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl is not null AND ms_1559_cop_approved_by_t_mobile_actual is null; (2) SCOP Pending (MB) where pj_a_5500_receive_close_out_binder_finish is not null AND pj_a_5525_approve_close_out_binder_finish is null; (3) Resubmissions where scop_tw_punch_list_re_submitted_to_tmo is not null; (4) First-time-right approved where ms_1559 is not null AND scop_tw_checklist_rejected_by_tmo is null; (5) Total approved where ms_1559 is not null; (6) FTR rate % = 100 * FTR approved / total approved. No pending-only WHERE filter; all metrics are conditional counts over the Active population.', node_type: 'CORE', definition: 'Snapshot of Active projects grouped by rgn_region/m_area/m_market/construction_gc/por_category. Computes conditional distinct-project counts: (1) SCOP Pending (NDPD) where ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl is not null AND ms_1559_cop_approved_by_t_mobile_actual is null; (2) SCOP Pending (MB) where pj_a_5500_receive_close_out_binder_finish is not null AND pj_a_5525_approve_close_out_binder_finish is null; (3) Resubmissions where scop_tw_punch_list_re_submitted_to_tmo is not null; (4) First-time-right approved where ms_1559 is not null AND scop_tw_checklist_rejected_by_tmo is null; (5) Total approved where ms_1559 is not null; (6) FTR rate % = 100 * FTR approved / total approved. No pending-only WHERE filter; all metrics are conditional counts over the Active population.', kpi_python_function: 'def get_scop_approval_pending(execute_query, filters=None) -> list[dict]:\n    """SCOP closeout pipeline snapshot metrics grouped by region/area/market/GC/POR."""\n\n    # Seed conditions define the snapshot population first\n    where_parts = [\n        \'1=1\',\n        \'"pj_project_status" = \\\'Active\\\'\'\n    ]\n\n    # Explicit allowlist of optional filters (exact match only)\n    rgn_region = None\n    m_area = None\n    m_market = None\n    construction_gc = None\n    por_category = None\n    pj_project_id = None\n    s_site_id = None\n\n    if filters:\n        rgn_region = filters.get(\'rgn_region\')\n        m_area = filters.get(\'m_area\')\n        m_market = filters.get(\'m_market\')\n        construction_gc = filters.get(\'construction_gc\')\n        por_category = filters.get(\'por_category\')\n        pj_project_id = filters.get(\'pj_project_id\')\n        s_site_id = filters.get(\'s_site_id\')\n\n    def _eq(col: str, val):\n        if val is None or val == \'\':\n            return\n        esc = str(val).replace("\'", "\'\'")\n        where_parts.append(f\'{col} = \\\'{esc}\\\'\')\n\n    _eq(\'"rgn_region"\', rgn_region)\n    _eq(\'"m_area"\', m_area)\n    _eq(\'"m_market"\', m_market)\n    _eq(\'"construction_gc"\', construction_gc)\n    _eq(\'"por_category"\', por_category)\n    _eq(\'"pj_project_id"\', pj_project_id)\n    _eq(\'"s_site_id"\', s_site_id)\n\n    where_clause = \' AND \'.join(where_parts)\n\n    sql = (\n        \'SELECT \'\n        \'  "rgn_region" AS "rgn_region",\'\n        \'  "m_area" AS "m_area",\'\n        \'  "m_market" AS "m_market",\'\n        \'  "construction_gc" AS "construction_gc",\'\n        \'  "por_category" AS "por_category",\'\n        \'  COUNT(DISTINCT CASE \'\n        \'    WHEN "ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl" IS NOT NULL \'\n        \'     AND "ms_1559_cop_approved_by_t_mobile_actual" IS NULL \'\n        \'    THEN "pj_project_id" END) AS "scop_pending_ndpd",\'\n        \'  COUNT(DISTINCT CASE \'\n        \'    WHEN "pj_a_5500_receive_close_out_binder_finish" IS NOT NULL \'\n        \'     AND "pj_a_5525_approve_close_out_binder_finish" IS NULL \'\n        \'    THEN "pj_project_id" END) AS "scop_pending_mb",\'\n        \'  COUNT(DISTINCT CASE \'\n        \'    WHEN "scop_tw_punch_list_re_submitted_to_tmo" IS NOT NULL \'\n        \'    THEN "pj_project_id" END) AS "scop_resubmission_count",\'\n        \'  COUNT(DISTINCT CASE \'\n        \'    WHEN "ms_1559_cop_approved_by_t_mobile_actual" IS NOT NULL \'\n        \'     AND "scop_tw_checklist_rejected_by_tmo" IS NULL \'\n        \'    THEN "pj_project_id" END) AS "scop_first_time_right_count",\'\n        \'  COUNT(DISTINCT CASE \'\n        \'    WHEN "ms_1559_cop_approved_by_t_mobile_actual" IS NOT NULL \'\n        \'    THEN "pj_project_id" END) AS "scop_total_approved_count",\'\n        \'  100.0 * \'\n        \'    COUNT(DISTINCT CASE \'\n        \'      WHEN "ms_1559_cop_approved_by_t_mobile_actual" IS NOT NULL \'\n        \'       AND "scop_tw_checklist_rejected_by_tmo" IS NULL \'\n        \'      THEN "pj_project_id" END) \'\n        \'    / NULLIF(COUNT(DISTINCT CASE \'\n        \'      WHEN "ms_1559_cop_approved_by_t_mobile_actual" IS NOT NULL \'\n        \'      THEN "pj_project_id" END), 0) AS "scop_ftr_rate_pct" \'\n        \'FROM "public"."stg_ndpd_mbt_tmobile_macro_combined" \'\n        f\'WHERE {where_clause} \'\n        \'GROUP BY "rgn_region", "m_area", "m_market", "construction_gc", "por_category" \'\n        \'ORDER BY "rgn_region", "m_area", "m_market", "construction_gc", "por_category"\'\n    )\n\n    return execute_query(sql, db=None, max_rows=None)\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'pj_project_id', 's_site_id', 'pj_project_status', 'ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl', 'ms_1559_cop_approved_by_t_mobile_actual', 'pj_a_5500_receive_close_out_binder_finish', 'pj_a_5525_approve_close_out_binder_finish', 'scop_tw_punch_list_re_submitted_to_tmo', 'scop_tw_checklist_rejected_by_tmo'], session_id: '69a3d22f26e208edc083a06e', label: 'SCOP Approval Pending', kpi_related_core_node_ids: ['closeout_package', 'project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'aa4376f5-f790-4cc0-ae24-cabaf23fcd0a', entity_type: 'kpi', kpi_name: 'SCOP Approval Pending', name: 'aa4376f5-f790-4cc0-ae24-cabaf23fcd0a', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Measures the volume of projects where the closeout package/binder has been submitted or received but is still awaiting T-Mobile approval, and summarizes resubmissions and first-time-right approval performance. This KPI helps identify closeout bottlenecks that delay customer acceptance and downstream payment triggers, and highlights where process or documentation quality is driving rework.', status: 'mentioned', node_id: 'aa4376f5-f790-4cc0-ae24-cabaf23fcd0a'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: Site Integrated Pending Alarm = COUNT(DISTINCT Project.pj_project_id) for rows where ms_1899_all_planned_technologies_integrated_actual is not null and ms_1970_integration_complete_actual is null, grouped by rgn_region, m_area, m_market, construction_gc, por_category, with avg/max days pending computed from NOW() - ms_1899 timestamp.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension."}, {"column": "por_category", "type": "string", "description": "POR category dimension."}, {"column": "pending_alarm_clearance_count", "type": "integer", "description": "Count of distinct projects in the integrated-pending (alarm-clearance validation) state."}, {"column": "avg_days_pending", "type": "float", "description": "Average days since ms_1899_all_planned_technologies_integrated_actual for projects in this state."}, {"column": "max_days_pending", "type": "float", "description": "Maximum days since ms_1899_all_planned_technologies_integrated_actual for projects in this state."}]', kpi_business_logic: '1) Start from public.stg_ndpd_mbt_tmobile_macro_combined (one row per project/site).\n2) Keep only records where ms_1899_all_planned_technologies_integrated_actual IS NOT NULL and ms_1970_integration_complete_actual IS NULL.\n3) Apply optional exact-match filters on: rgn_region, m_area, m_market, construction_gc, por_category, pj_project_id, s_site_id.\n4) Group by rgn_region, m_area, m_market, construction_gc, por_category.\n5) For each group compute: pending_alarm_clearance_count = COUNT(DISTINCT pj_project_id); avg_days_pending = AVG((NOW() - ms_1899::timestamp) in days); max_days_pending = MAX((NOW() - ms_1899::timestamp) in days).', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact-match filter on region (rgn_region)."}, {"name": "m_area", "type": "string", "description": "Exact-match filter on area (m_area)."}, {"name": "m_market", "type": "string", "description": "Exact-match filter on market (m_market)."}, {"name": "construction_gc", "type": "string", "description": "Exact-match filter on general contractor (construction_gc)."}, {"name": "por_category", "type": "string", "description": "Exact-match filter on POR category (por_category)."}, {"name": "pj_project_id", "type": "string", "description": "Exact-match filter on project id (pj_project_id)."}, {"name": "s_site_id", "type": "string", "description": "Exact-match filter on site code (s_site_id)."}]', kpi_contract: '{"function_name": "get_integrated_pending_alarm", "node_type": "kpi", "node_id": "7bdb116a-719c-475b-ad04-da1f796b9209", "node_label": "Integrated Pending Alarm", "description": "Counts active sites/projects where all planned technologies have been integrated (tech integration timestamp present) but full integration completion/sign-off has not yet occurred (integration complete timestamp still null). This represents the transient 48-hour alarm-clearance validation window after technology integration; monitoring volume and aging helps prevent sites from stalling in final validation and improves on-time integration closure.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "pending_alarm_clearance_count", "type": "number", "nullable": false}, {"name": "avg_days_pending", "type": "string", "nullable": false}, {"name": "max_days_pending", "type": "string", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: Site Integrated Pending Alarm = COUNT(DISTINCT Project.pj_project_id) for rows where ms_1899_all_planned_technologies_integrated_actual is not null and ms_1970_integration_complete_actual is null, grouped by rgn_region, m_area, m_market, construction_gc, por_category, with avg/max days pending computed from NOW() - ms_1899 timestamp.', node_type: 'CORE', definition: 'One-sentence formula: Site Integrated Pending Alarm = COUNT(DISTINCT Project.pj_project_id) for rows where ms_1899_all_planned_technologies_integrated_actual is not null and ms_1970_integration_complete_actual is null, grouped by rgn_region, m_area, m_market, construction_gc, por_category, with avg/max days pending computed from NOW() - ms_1899 timestamp.', kpi_python_function: 'def get_site_integrated_pending_alarm(execute_query, filters=None) -> list[dict]:\n    # KPI: Site Integrated Pending Alarm\n    # COUNT(DISTINCT pj_project_id) where:\n    #   ms_1899_all_planned_technologies_integrated_actual IS NOT NULL\n    #   ms_1970_integration_complete_actual IS NULL\n    # plus aging: avg/max days since ms_1899...\n\n    where_parts = [\n        "1=1",\n        \'"ms_1899_all_planned_technologies_integrated_actual" IS NOT NULL\',\n        \'"ms_1970_integration_complete_actual" IS NULL\'\n    ]\n\n    allowed_filter_columns = {\n        "rgn_region": "rgn_region",\n        "m_area": "m_area",\n        "m_market": "m_market",\n        "construction_gc": "construction_gc",\n        "por_category": "por_category",\n        "pj_project_id": "pj_project_id",\n        "s_site_id": "s_site_id"\n    }\n\n    if filters:\n        if filters.get("rgn_region") is not None:\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f\'"{allowed_filter_columns["rgn_region"]}" = \\\'{v}\\\'\')\n        if filters.get("m_area") is not None:\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f\'"{allowed_filter_columns["m_area"]}" = \\\'{v}\\\'\')\n        if filters.get("m_market") is not None:\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f\'"{allowed_filter_columns["m_market"]}" = \\\'{v}\\\'\')\n        if filters.get("construction_gc") is not None:\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f\'"{allowed_filter_columns["construction_gc"]}" = \\\'{v}\\\'\')\n        if filters.get("por_category") is not None:\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f\'"{allowed_filter_columns["por_category"]}" = \\\'{v}\\\'\')\n        if filters.get("pj_project_id") is not None:\n            v = str(filters["pj_project_id"]).replace("\'", "\'\'")\n            where_parts.append(f\'"{allowed_filter_columns["pj_project_id"]}" = \\\'{v}\\\'\')\n        if filters.get("s_site_id") is not None:\n            v = str(filters["s_site_id"]).replace("\'", "\'\'")\n            where_parts.append(f\'"{allowed_filter_columns["s_site_id"]}" = \\\'{v}\\\'\')\n\n    where_clause = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\", "\n        "  \\"m_area\\", "\n        "  \\"m_market\\", "\n        "  \\"construction_gc\\", "\n        "  \\"por_category\\", "\n        "  COUNT(DISTINCT \\"pj_project_id\\") AS \\"pending_alarm_clearance_count\\", "\n        "  AVG(EXTRACT(EPOCH FROM (NOW() - \\"ms_1899_all_planned_technologies_integrated_actual\\"::timestamp)) / 86400.0) AS \\"avg_days_pending\\", "\n        "  MAX(EXTRACT(EPOCH FROM (NOW() - \\"ms_1899_all_planned_technologies_integrated_actual\\"::timestamp)) / 86400.0) AS \\"max_days_pending\\" "\n        "FROM public.\\"stg_ndpd_mbt_tmobile_macro_combined\\" "\n        f"WHERE {where_clause} "\n        "GROUP BY "\n        "  \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\" "\n        "ORDER BY "\n        "  \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\""\n    )\n\n    return execute_query(sql, db="public")\n', kpi_source_columns: ['pj_project_id', 's_site_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'ms_1899_all_planned_technologies_integrated_actual', 'ms_1970_integration_complete_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Integrated Pending Alarm', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '7bdb116a-719c-475b-ad04-da1f796b9209', entity_type: 'kpi', kpi_name: 'Integrated Pending Alarm', name: '7bdb116a-719c-475b-ad04-da1f796b9209', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Counts active sites/projects where all planned technologies have been integrated (tech integration timestamp present) but full integration completion/sign-off has not yet occurred (integration complete timestamp still null). This represents the transient 48-hour alarm-clearance validation window after technology integration; monitoring volume and aging helps prevent sites from stalling in final validation and improves on-time integration closure.', status: 'mentioned', node_id: '7bdb116a-719c-475b-ad04-da1f796b9209'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: Material Availability Rate (%) = 100.0 * COUNT(DISTINCT pj_project_id with planned construction start scheduled AND all BAT orders received) / NULLIF(COUNT(DISTINCT pj_project_id with planned construction start scheduled), 0), grouped by region/area/market/GC/POR category, optionally restricted to an upcoming construction-start date window.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension (free-text)."}, {"column": "por_category", "type": "string", "description": "POR category dimension."}, {"column": "total_upcoming_sites", "type": "integer", "description": "Count of distinct projects with planned construction start scheduled (and within the optional upcoming window, if provided)."}, {"column": "material_ready_sites", "type": "integer", "description": "Count of distinct projects with planned construction start scheduled (and within optional upcoming window) and all BAT orders received."}, {"column": "material_availability_rate_pct", "type": "float", "description": "100.0 * material_ready_sites / total_upcoming_sites (NULL when total_upcoming_sites = 0)."}]', kpi_business_logic: '1) Start from public.stg_ndpd_mbt_tmobile_macro_combined (one row per project/site).\n2) Define upcoming sites as distinct pj_project_id where pj_p_4225_construction_start_finish IS NOT NULL.\n3) If upcoming_window_days is provided, further restrict to pj_p_4225_construction_start_finish::date between CURRENT_DATE and CURRENT_DATE + upcoming_window_days (integer day arithmetic).\n4) Count total_upcoming_sites = COUNT(DISTINCT pj_project_id) under those conditions.\n5) Count material_ready_sites = COUNT(DISTINCT pj_project_id) where (same denominator conditions) AND pj_a_3900_all_bat_orders_received_finish IS NOT NULL.\n6) Compute material_availability_rate_pct = 100.0 * material_ready_sites / NULLIF(total_upcoming_sites, 0).\n7) Apply optional exact-match filters (rgn_region, m_area, m_market, construction_gc, por_category, pj_project_id, s_site_id).\n8) Group results by rgn_region, m_area, m_market, construction_gc, por_category.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact-match filter on rgn_region."}, {"name": "m_area", "type": "string", "description": "Exact-match filter on m_area."}, {"name": "m_market", "type": "string", "description": "Exact-match filter on m_market."}, {"name": "construction_gc", "type": "string", "description": "Exact-match filter on construction_gc."}, {"name": "por_category", "type": "string", "description": "Exact-match filter on por_category."}, {"name": "pj_project_id", "type": "string", "description": "Exact-match filter on pj_project_id."}, {"name": "s_site_id", "type": "string", "description": "Exact-match filter on s_site_id."}, {"name": "upcoming_window_days", "type": "integer", "description": "Optional. When provided, restricts upcoming sites to those with planned construction start date between CURRENT_DATE and CURRENT_DATE + upcoming_window_days."}]', kpi_contract: '{"function_name": "get_material_availability_rate", "node_type": "kpi", "node_id": "89292bce-c820-4fca-afb4-c3d4e1937916", "node_label": "Material Availability Rate", "description": "Measures the percentage of upcoming construction sites (projects with a planned construction start scheduled) that have full material delivery confirmed (all BAT orders received). Used to identify material readiness gaps before construction starts; critical for capacity planning because sites without materials cannot begin construction even when crews are available.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}, {"name": "upcoming_window_days", "type": "string", "description": "Filter by upcoming window days", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "total_upcoming_sites", "type": "number", "nullable": false}, {"name": "material_ready_sites", "type": "number", "nullable": false}, {"name": "material_availability_rate_pct", "type": "string", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: Material Availability Rate (%) = 100.0 * COUNT(DISTINCT pj_project_id with planned construction start scheduled AND all BAT orders received) / NULLIF(COUNT(DISTINCT pj_project_id with planned construction start scheduled), 0), grouped by region/area/market/GC/POR category, optionally restricted to an upcoming construction-start date window.', node_type: 'CORE', definition: 'One-sentence formula: Material Availability Rate (%) = 100.0 * COUNT(DISTINCT pj_project_id with planned construction start scheduled AND all BAT orders received) / NULLIF(COUNT(DISTINCT pj_project_id with planned construction start scheduled), 0), grouped by region/area/market/GC/POR category, optionally restricted to an upcoming construction-start date window.', kpi_python_function: 'def get_material_availability_rate(execute_query, filters=None) -> list[dict]:\n    where_parts = [\n        "1=1",\n        "\\"pj_p_4225_construction_start_finish\\" IS NOT NULL"\n    ]\n\n    if filters is None:\n        filters = {}\n\n    # Exact-match filters (allowlist)\n    if filters.get("rgn_region"):\n        val = str(filters["rgn_region"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"rgn_region\\" = \'{val}\'")\n\n    if filters.get("m_area"):\n        val = str(filters["m_area"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"m_area\\" = \'{val}\'")\n\n    if filters.get("m_market"):\n        val = str(filters["m_market"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"m_market\\" = \'{val}\'")\n\n    if filters.get("construction_gc"):\n        val = str(filters["construction_gc"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"construction_gc\\" = \'{val}\'")\n\n    if filters.get("por_category"):\n        val = str(filters["por_category"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"por_category\\" = \'{val}\'")\n\n    if filters.get("pj_project_id"):\n        val = str(filters["pj_project_id"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"pj_project_id\\" = \'{val}\'")\n\n    if filters.get("s_site_id"):\n        val = str(filters["s_site_id"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"s_site_id\\" = \'{val}\'")\n\n    # Optional upcoming window scoping\n    # Restrict denominator to planned construction start between CURRENT_DATE and CURRENT_DATE + upcoming_window_days\n    if filters.get("upcoming_window_days") is not None:\n        try:\n            days = int(filters["upcoming_window_days"])\n        except Exception:\n            raise ValueError("upcoming_window_days must be an integer or null")\n        where_parts.append(\n            f"(\\"pj_p_4225_construction_start_finish\\"::date BETWEEN CURRENT_DATE AND (CURRENT_DATE + {days}))"\n        )\n\n    where_clause = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\" AS \\"rgn_region\\", "\n        "  \\"m_area\\" AS \\"m_area\\", "\n        "  \\"m_market\\" AS \\"m_market\\", "\n        "  \\"construction_gc\\" AS \\"construction_gc\\", "\n        "  \\"por_category\\" AS \\"por_category\\", "\n        "  COUNT(DISTINCT \\"pj_project_id\\") AS \\"total_upcoming_sites\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"pj_a_3900_all_bat_orders_received_finish\\" IS NOT NULL THEN \\"pj_project_id\\" END) AS \\"material_ready_sites\\", "\n        "  (100.0 * COUNT(DISTINCT CASE WHEN \\"pj_a_3900_all_bat_orders_received_finish\\" IS NOT NULL THEN \\"pj_project_id\\" END) "\n        "     / NULLIF(COUNT(DISTINCT \\"pj_project_id\\"), 0)) AS \\"material_availability_rate_pct\\" "\n        "FROM public.\\"stg_ndpd_mbt_tmobile_macro_combined\\" "\n        f"WHERE {where_clause} "\n        "GROUP BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\" "\n        "ORDER BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\""\n    )\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 's_site_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'pj_p_4225_construction_start_finish', 'pj_a_3900_all_bat_orders_received_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Material Availability Rate', kpi_related_core_node_ids: ['project', 'site', 'material_equipment', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '89292bce-c820-4fca-afb4-c3d4e1937916', entity_type: 'kpi', kpi_name: 'Material Availability Rate', name: '89292bce-c820-4fca-afb4-c3d4e1937916', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Measures the percentage of upcoming construction sites (projects with a planned construction start scheduled) that have full material delivery confirmed (all BAT orders received). Used to identify material readiness gaps before construction starts; critical for capacity planning because sites without materials cannot begin construction even when crews are available.', status: 'mentioned', node_id: '89292bce-c820-4fca-afb4-c3d4e1937916'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: KPI = COUNT(DISTINCT pj_project_id) for Active projects where (site walk completed OR Talon drone survey completed) AND scoping package submitted is NULL, with avg/max days since the most recent survey completion timestamp (GREATEST of the two survey completion dates).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Project/site region."}, {"column": "m_area", "type": "string", "description": "Project/site area."}, {"column": "m_market", "type": "string", "description": "Project/site market."}, {"column": "construction_gc", "type": "string", "description": "Assigned general contractor."}, {"column": "por_category", "type": "string", "description": "POR category."}, {"column": "survey_to_scoping_gap_count", "type": "integer", "description": "Distinct active projects with survey complete but scoping package not submitted."}, {"column": "avg_days_since_survey", "type": "float", "description": "Average days elapsed since the most recent survey completion timestamp (max of site-walk vs Talon)."}, {"column": "max_days_since_survey", "type": "float", "description": "Maximum days elapsed since the most recent survey completion timestamp (max of site-walk vs Talon)."}]', kpi_business_logic: '1) Start from public.stg_ndpd_mbt_tmobile_macro_combined (one row per project/site). 2) Keep only pj_project_status=\'Active\'. 3) Require at least one survey completion timestamp present: ms_1316_pre_con_site_walk_completed_actual OR ms_1321_talon_view_drone_svcs_actual. 4) Require scoping not submitted: ms_1331_scoping_package_submitted_actual IS NULL. 5) Compute survey_to_scoping_gap_count as COUNT(DISTINCT pj_project_id) grouped by rgn_region, m_area, m_market, construction_gc, por_category. 6) For aging, compute days_since_survey per row as EXTRACT(EPOCH FROM (NOW() - GREATEST(ms_1316_pre_con_site_walk_completed_actual, ms_1321_talon_view_drone_svcs_actual)))/86400.0, then aggregate AVG and MAX over the group. 7) Apply optional equality filters (rgn_region, m_area, m_market, construction_gc, por_category, pj_project_id, s_site_id) in the WHERE clause in addition to the core conditions.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact-match filter on region."}, {"name": "m_area", "type": "string", "description": "Exact-match filter on area."}, {"name": "m_market", "type": "string", "description": "Exact-match filter on market."}, {"name": "construction_gc", "type": "string", "description": "Exact-match filter on assigned general contractor."}, {"name": "por_category", "type": "string", "description": "Exact-match filter on POR category."}, {"name": "pj_project_id", "type": "string", "description": "Exact-match filter on project id."}, {"name": "s_site_id", "type": "string", "description": "Exact-match filter on site id."}]', kpi_contract: '{"function_name": "get_survey_to_scoping_gap", "node_type": "kpi", "node_id": "5b7f66f2-fa22-45a9-87f5-178ef86d7501", "node_label": "Survey to Scoping Gap", "description": "Counts active projects/sites where survey is complete (manual site walk or Talon drone) but the scoping package has not yet been submitted, indicating a handoff/capacity bottleneck between survey output and scoping deliverable creation. Includes aging metrics (avg/max days since the most recent survey completion timestamp) to quantify how long sites have been waiting, and supports slicing by region/area/market/GC and POR category for scoping team capacity management and delay remediation.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "survey_to_scoping_gap_count", "type": "number", "nullable": false}, {"name": "avg_days_since_survey", "type": "string", "nullable": false}, {"name": "max_days_since_survey", "type": "string", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: KPI = COUNT(DISTINCT pj_project_id) for Active projects where (site walk completed OR Talon drone survey completed) AND scoping package submitted is NULL, with avg/max days since the most recent survey completion timestamp (GREATEST of the two survey completion dates).', node_type: 'CORE', definition: 'One-sentence formula: KPI = COUNT(DISTINCT pj_project_id) for Active projects where (site walk completed OR Talon drone survey completed) AND scoping package submitted is NULL, with avg/max days since the most recent survey completion timestamp (GREATEST of the two survey completion dates).', kpi_python_function: 'def get_survey_to_scoping_gap(execute_query, filters=None) -> list[dict]:\n    # KPI: Survey to Scoping Gap\n    # Postgres SQL; single-table aggregation from public.stg_ndpd_mbt_tmobile_macro_combined\n\n    where_parts = [\n        \'1=1\',\n        \'"pj_project_status" = \\\'Active\\\'\',\n        \'(("ms_1316_pre_con_site_walk_completed_actual" IS NOT NULL) OR ("ms_1321_talon_view_drone_svcs_actual" IS NOT NULL))\',\n        \'"ms_1331_scoping_package_submitted_actual" IS NULL\'\n    ]\n\n    if filters:\n        if filters.get(\'rgn_region\') is not None and str(filters.get(\'rgn_region\')) != \'\':\n            v = str(filters[\'rgn_region\']).replace("\'", "\'\'")\n            where_parts.append(f\'"rgn_region" = \\\'{v}\\\'\')\n        if filters.get(\'m_area\') is not None and str(filters.get(\'m_area\')) != \'\':\n            v = str(filters[\'m_area\']).replace("\'", "\'\'")\n            where_parts.append(f\'"m_area" = \\\'{v}\\\'\')\n        if filters.get(\'m_market\') is not None and str(filters.get(\'m_market\')) != \'\':\n            v = str(filters[\'m_market\']).replace("\'", "\'\'")\n            where_parts.append(f\'"m_market" = \\\'{v}\\\'\')\n        if filters.get(\'construction_gc\') is not None and str(filters.get(\'construction_gc\')) != \'\':\n            v = str(filters[\'construction_gc\']).replace("\'", "\'\'")\n            where_parts.append(f\'"construction_gc" = \\\'{v}\\\'\')\n        if filters.get(\'por_category\') is not None and str(filters.get(\'por_category\')) != \'\':\n            v = str(filters[\'por_category\']).replace("\'", "\'\'")\n            where_parts.append(f\'"por_category" = \\\'{v}\\\'\')\n        if filters.get(\'pj_project_id\') is not None and str(filters.get(\'pj_project_id\')) != \'\':\n            v = str(filters[\'pj_project_id\']).replace("\'", "\'\'")\n            where_parts.append(f\'"pj_project_id" = \\\'{v}\\\'\')\n        if filters.get(\'s_site_id\') is not None and str(filters.get(\'s_site_id\')) != \'\':\n            v = str(filters[\'s_site_id\']).replace("\'", "\'\'")\n            where_parts.append(f\'"s_site_id" = \\\'{v}\\\'\')\n\n    where_clause = \' AND \'.join(where_parts)\n\n    sql = (\n        \'SELECT \'\\\n        \'  "rgn_region", \'\\\n        \'  "m_area", \'\\\n        \'  "m_market", \'\\\n        \'  "construction_gc", \'\\\n        \'  "por_category", \'\\\n        \'  COUNT(DISTINCT "pj_project_id") AS "survey_to_scoping_gap_count", \'\\\n        \'  AVG(EXTRACT(EPOCH FROM (NOW() - GREATEST("ms_1316_pre_con_site_walk_completed_actual", "ms_1321_talon_view_drone_svcs_actual"))) / 86400.0) AS "avg_days_since_survey", \'\\\n        \'  MAX(EXTRACT(EPOCH FROM (NOW() - GREATEST("ms_1316_pre_con_site_walk_completed_actual", "ms_1321_talon_view_drone_svcs_actual"))) / 86400.0) AS "max_days_since_survey" \'\\\n        \'FROM "public"."stg_ndpd_mbt_tmobile_macro_combined" \'\\\n        f\'WHERE {where_clause} \'\\\n        \'GROUP BY "rgn_region", "m_area", "m_market", "construction_gc", "por_category" \'\n        \'ORDER BY "rgn_region", "m_area", "m_market", "construction_gc", "por_category"\'\n    )\n\n    return execute_query(sql, db=None, max_rows=None)\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'ms_1316_pre_con_site_walk_completed_actual', 'ms_1321_talon_view_drone_svcs_actual', 'ms_1331_scoping_package_submitted_actual', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'Survey to Scoping Gap', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '5b7f66f2-fa22-45a9-87f5-178ef86d7501', entity_type: 'kpi', kpi_name: 'Survey to Scoping Gap', name: '5b7f66f2-fa22-45a9-87f5-178ef86d7501', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Counts active projects/sites where survey is complete (manual site walk or Talon drone) but the scoping package has not yet been submitted, indicating a handoff/capacity bottleneck between survey output and scoping deliverable creation. Includes aging metrics (avg/max days since the most recent survey completion timestamp) to quantify how long sites have been waiting, and supports slicing by region/area/market/GC and POR category for scoping team capacity management and delay remediation.', status: 'mentioned', node_id: '5b7f66f2-fa22-45a9-87f5-178ef86d7501'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: Pending Building Permit KPI = grouped counts of distinct active projects with building permit applied but not approved, plus pending aging (avg/max days since application) and average apply-to-approve cycle time for approved permits (non-negative durations), using stg_ndpd_mbt_tmobile_macro_combined.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension (free-text)."}, {"column": "por_category", "type": "string", "description": "POR category dimension."}, {"column": "pending_permit_count", "type": "integer", "description": "Count of distinct active projects with building permit applied but not yet approved."}, {"column": "avg_days_pending", "type": "float", "description": "Average days since building permit application for pending permits."}, {"column": "max_days_pending", "type": "float", "description": "Maximum days since building permit application for pending permits."}, {"column": "permit_approved_count", "type": "integer", "description": "Count of distinct projects with building permit applied and approved."}, {"column": "avg_approval_cycle_days", "type": "float", "description": "Average application-to-approval cycle time in days for approved permits, excluding negative durations."}]', kpi_business_logic: '1) Start from public.stg_ndpd_mbt_tmobile_macro_combined at project grain. 2) Group results by rgn_region, m_area, m_market, construction_gc, por_category. 3) pending_permit_count: count distinct pj_project_id where pj_a_3650_ran_building_permit_applied_finish is not null AND pj_a_3675_ran_building_permit_approved_finish is null AND pj_project_status=\'Active\'. 4) avg_days_pending/max_days_pending: compute days between NOW() and applied_finish (cast to timestamp) for the same pending rows, then take AVG/MAX. 5) permit_approved_count: count distinct pj_project_id where both applied_finish and approved_finish are not null. 6) avg_approval_cycle_days: average (approved_finish::date - applied_finish::date) only when both are not null and the duration is >= 0; negative durations are excluded by returning NULL in the AVG CASE. 7) Apply optional exact-match filters (seeded by 1=1): rgn_region, m_area, m_market, construction_gc, por_category, pj_project_id, s_site_id.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact match filter on region (\\"rgn_region\\")."}, {"name": "m_area", "type": "string", "description": "Exact match filter on area (\\"m_area\\")."}, {"name": "m_market", "type": "string", "description": "Exact match filter on market (\\"m_market\\")."}, {"name": "construction_gc", "type": "string", "description": "Exact match filter on general contractor (\\"construction_gc\\")."}, {"name": "por_category", "type": "string", "description": "Exact match filter on POR category (\\"por_category\\")."}, {"name": "pj_project_id", "type": "string", "description": "Exact match filter on project id (\\"pj_project_id\\")."}, {"name": "s_site_id", "type": "string", "description": "Exact match filter on site code (\\"s_site_id\\")."}]', kpi_contract: '{"function_name": "get_pending_building_permit", "node_type": "kpi", "node_id": "5839ab81-baa8-4a76-b9c0-d1b1ab946bc2", "node_label": "Pending Building Permit", "description": "Counts active projects/sites where the building permit has been applied for but is not yet approved (a hard prerequisite for civil start), to surface permit/regulatory bottlenecks and forecast civil start delays. Also computes aging for pending permits (avg/max days since application) and the average application-to-approval cycle time for projects where the permit was approved, excluding negative durations.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "pending_permit_count", "type": "number", "nullable": false}, {"name": "avg_days_pending", "type": "null", "nullable": true}, {"name": "max_days_pending", "type": "null", "nullable": true}, {"name": "permit_approved_count", "type": "number", "nullable": false}, {"name": "avg_approval_cycle_days", "type": "null", "nullable": true}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: Pending Building Permit KPI = grouped counts of distinct active projects with building permit applied but not approved, plus pending aging (avg/max days since application) and average apply-to-approve cycle time for approved permits (non-negative durations), using stg_ndpd_mbt_tmobile_macro_combined.', node_type: 'CORE', definition: 'One-sentence formula: Pending Building Permit KPI = grouped counts of distinct active projects with building permit applied but not approved, plus pending aging (avg/max days since application) and average apply-to-approve cycle time for approved permits (non-negative durations), using stg_ndpd_mbt_tmobile_macro_combined.', kpi_python_function: 'def get_pending_building_permit(execute_query, filters=None) -> list[dict]:\n    where_parts = ["1=1"]\n\n    # Allowlist filters (exact match)\n    if filters:\n        if filters.get("rgn_region"):\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f\'"rgn_region" = \\\'{v}\\\'\')\n        if filters.get("m_area"):\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f\'"m_area" = \\\'{v}\\\'\')\n        if filters.get("m_market"):\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f\'"m_market" = \\\'{v}\\\'\')\n        if filters.get("construction_gc"):\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f\'"construction_gc" = \\\'{v}\\\'\')\n        if filters.get("por_category"):\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f\'"por_category" = \\\'{v}\\\'\')\n        if filters.get("pj_project_id"):\n            v = str(filters["pj_project_id"]).replace("\'", "\'\'")\n            where_parts.append(f\'"pj_project_id" = \\\'{v}\\\'\')\n        if filters.get("s_site_id"):\n            v = str(filters["s_site_id"]).replace("\'", "\'\'")\n            where_parts.append(f\'"s_site_id" = \\\'{v}\\\'\')\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\", "\n        "  \\"m_area\\", "\n        "  \\"m_market\\", "\n        "  \\"construction_gc\\", "\n        "  \\"por_category\\", "\n        "  COUNT(DISTINCT CASE "\n        "    WHEN \\"pj_a_3650_ran_building_permit_applied_finish\\" IS NOT NULL "\n        "     AND \\"pj_a_3675_ran_building_permit_approved_finish\\" IS NULL "\n        "     AND \\"pj_project_status\\" = \'Active\' "\n        "    THEN \\"pj_project_id\\" END "\n        "  ) AS \\"pending_permit_count\\", "\n        "  AVG(CASE "\n        "    WHEN \\"pj_a_3650_ran_building_permit_applied_finish\\" IS NOT NULL "\n        "     AND \\"pj_a_3675_ran_building_permit_approved_finish\\" IS NULL "\n        "     AND \\"pj_project_status\\" = \'Active\' "\n        "    THEN (EXTRACT(EPOCH FROM (NOW() - \\"pj_a_3650_ran_building_permit_applied_finish\\"::timestamp)) / 86400.0) "\n        "  END) AS \\"avg_days_pending\\", "\n        "  MAX(CASE "\n        "    WHEN \\"pj_a_3650_ran_building_permit_applied_finish\\" IS NOT NULL "\n        "     AND \\"pj_a_3675_ran_building_permit_approved_finish\\" IS NULL "\n        "     AND \\"pj_project_status\\" = \'Active\' "\n        "    THEN (EXTRACT(EPOCH FROM (NOW() - \\"pj_a_3650_ran_building_permit_applied_finish\\"::timestamp)) / 86400.0) "\n        "  END) AS \\"max_days_pending\\", "\n        "  COUNT(DISTINCT CASE "\n        "    WHEN \\"pj_a_3650_ran_building_permit_applied_finish\\" IS NOT NULL "\n        "     AND \\"pj_a_3675_ran_building_permit_approved_finish\\" IS NOT NULL "\n        "    THEN \\"pj_project_id\\" END "\n        "  ) AS \\"permit_approved_count\\", "\n        "  AVG(CASE "\n        "    WHEN \\"pj_a_3650_ran_building_permit_applied_finish\\" IS NOT NULL "\n        "     AND \\"pj_a_3675_ran_building_permit_approved_finish\\" IS NOT NULL "\n        "     AND (\\"pj_a_3675_ran_building_permit_approved_finish\\"::date - \\"pj_a_3650_ran_building_permit_applied_finish\\"::date) >= 0 "\n        "    THEN (\\"pj_a_3675_ran_building_permit_approved_finish\\"::date - \\"pj_a_3650_ran_building_permit_applied_finish\\"::date) "\n        "  END) AS \\"avg_approval_cycle_days\\" "\n        "FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\" "\n        f"WHERE {where_sql} "\n        "GROUP BY "\n        "  \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\" "\n        "ORDER BY "\n        "  \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\""\n    )\n\n    return execute_query(sql, db="public")\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'pj_project_id', 's_site_id', 'pj_project_status', 'pj_a_3650_ran_building_permit_applied_finish', 'pj_a_3675_ran_building_permit_approved_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Pending Building Permit', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '5839ab81-baa8-4a76-b9c0-d1b1ab946bc2', entity_type: 'kpi', kpi_name: 'Pending Building Permit', name: '5839ab81-baa8-4a76-b9c0-d1b1ab946bc2', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Counts active projects/sites where the building permit has been applied for but is not yet approved (a hard prerequisite for civil start), to surface permit/regulatory bottlenecks and forecast civil start delays. Also computes aging for pending permits (avg/max days since application) and the average application-to-approval cycle time for projects where the permit was approved, excluding negative durations.', status: 'mentioned', node_id: '5839ab81-baa8-4a76-b9c0-d1b1ab946bc2'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: Pending Power Installation = grouped counts and aging/cycle-time aggregates on Project/Site rows where permanent power ordered date exists, segmented into pending (ordered not installed AND Active) vs installed (ordered AND installed), with pending aging computed as NOW()-ordered and cycle time as installed_date-ordered_date excluding negatives.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "Construction general contractor dimension."}, {"column": "por_category", "type": "string", "description": "POR category dimension."}, {"column": "pending_power_count", "type": "integer", "description": "Distinct count of active projects with permanent power ordered but not yet installed."}, {"column": "avg_days_pending", "type": "float", "description": "Average days since power was ordered for pending (active, not installed) projects."}, {"column": "max_days_pending", "type": "float", "description": "Maximum days since power was ordered for pending (active, not installed) projects."}, {"column": "power_installed_count", "type": "integer", "description": "Distinct count of projects where permanent power has both been ordered and installed."}, {"column": "avg_installation_cycle_days", "type": "float", "description": "Average days from power ordered to power installed (installed_date - ordered_date), excluding negative durations."}]', kpi_business_logic: '1) Use stg_ndpd_mbt_tmobile_macro_combined as the single source and group by (rgn_region, m_area, m_market, construction_gc, por_category). 2) pending_power_count: distinct pj_project_id where ordered_finish is not null, installed_finish is null, and pj_project_status=\'Active\'. 3) avg_days_pending/max_days_pending: for those same pending rows, compute days since ordered as EXTRACT(EPOCH FROM (NOW() - ordered_finish::timestamp))/86400.0, then AVG/MAX. 4) power_installed_count: distinct pj_project_id where ordered_finish and installed_finish are both not null. 5) avg_installation_cycle_days: across rows where both dates exist, compute (installed_finish::date - ordered_finish::date) only when the result is >= 0, then average.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Filter to a specific region (exact match on rgn_region)."}, {"name": "m_area", "type": "string", "description": "Filter to a specific area (exact match on m_area)."}, {"name": "m_market", "type": "string", "description": "Filter to a specific market (exact match on m_market)."}, {"name": "construction_gc", "type": "string", "description": "Filter to a specific construction general contractor (exact match on construction_gc)."}, {"name": "por_category", "type": "string", "description": "Filter to a specific POR category (exact match on por_category)."}, {"name": "pj_project_id", "type": "string", "description": "Filter to a specific project id (exact match on pj_project_id)."}, {"name": "s_site_id", "type": "string", "description": "Filter to a specific site id/code (exact match on s_site_id)."}]', kpi_contract: '{"function_name": "get_pending_power_installation", "node_type": "kpi", "node_id": "016f1231-f5d4-451e-a5ec-cd79f63511af", "node_label": "Pending Power Installation", "description": "Counts active sites where permanent power has been ordered but not yet installed (a critical prerequisite for tower commissioning/integration). Helps identify utility/power vendor delays and forecast integration start blockers. Also reports pending aging (avg/max days since power was ordered) and, for completed sites, the average power installation cycle time (days from ordered to installed), excluding negative durations.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "pending_power_count", "type": "number", "nullable": false}, {"name": "avg_days_pending", "type": "null", "nullable": true}, {"name": "max_days_pending", "type": "null", "nullable": true}, {"name": "power_installed_count", "type": "number", "nullable": false}, {"name": "avg_installation_cycle_days", "type": "null", "nullable": true}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: Pending Power Installation = grouped counts and aging/cycle-time aggregates on Project/Site rows where permanent power ordered date exists, segmented into pending (ordered not installed AND Active) vs installed (ordered AND installed), with pending aging computed as NOW()-ordered and cycle time as installed_date-ordered_date excluding negatives.', node_type: 'CORE', definition: 'One-sentence formula: Pending Power Installation = grouped counts and aging/cycle-time aggregates on Project/Site rows where permanent power ordered date exists, segmented into pending (ordered not installed AND Active) vs installed (ordered AND installed), with pending aging computed as NOW()-ordered and cycle time as installed_date-ordered_date excluding negatives.', kpi_python_function: 'def get_pending_power_installation(execute_query, filters=None) -> list[dict]:\n    # KPI: Pending Power Installation\n    # Source: public.stg_ndpd_mbt_tmobile_macro_combined (PostgreSQL)\n\n    where_parts = ["1=1"]\n\n    # Allowlisted filters (exact match)\n    if filters:\n        if filters.get("rgn_region"):\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"rgn_region\\" = \'{v}\'")\n        if filters.get("m_area"):\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_area\\" = \'{v}\'")\n        if filters.get("m_market"):\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_market\\" = \'{v}\'")\n        if filters.get("construction_gc"):\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"construction_gc\\" = \'{v}\'")\n        if filters.get("por_category"):\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"por_category\\" = \'{v}\'")\n        if filters.get("pj_project_id"):\n            v = str(filters["pj_project_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"pj_project_id\\" = \'{v}\'")\n        if filters.get("s_site_id"):\n            v = str(filters["s_site_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"s_site_id\\" = \'{v}\'")\n\n    where_clause = " AND ".join(where_parts)\n\n    sql = f"""\n    SELECT\n      \\"rgn_region\\",\n      \\"m_area\\",\n      \\"m_market\\",\n      \\"construction_gc\\",\n      \\"por_category\\",\n\n      COUNT(DISTINCT CASE\n        WHEN \\"pj_a_4450_permanent_power_ordered_finish\\" IS NOT NULL\n         AND \\"pj_a_4550_permanent_power_installed_finish\\" IS NULL\n         AND \\"pj_project_status\\" = \'Active\'\n        THEN \\"pj_project_id\\" END\n      ) AS \\"pending_power_count\\",\n\n      AVG(CASE\n        WHEN \\"pj_a_4450_permanent_power_ordered_finish\\" IS NOT NULL\n         AND \\"pj_a_4550_permanent_power_installed_finish\\" IS NULL\n         AND \\"pj_project_status\\" = \'Active\'\n        THEN (EXTRACT(EPOCH FROM (NOW() - \\"pj_a_4450_permanent_power_ordered_finish\\"::timestamp)) / 86400.0)\n      END) AS \\"avg_days_pending\\",\n\n      MAX(CASE\n        WHEN \\"pj_a_4450_permanent_power_ordered_finish\\" IS NOT NULL\n         AND \\"pj_a_4550_permanent_power_installed_finish\\" IS NULL\n         AND \\"pj_project_status\\" = \'Active\'\n        THEN (EXTRACT(EPOCH FROM (NOW() - \\"pj_a_4450_permanent_power_ordered_finish\\"::timestamp)) / 86400.0)\n      END) AS \\"max_days_pending\\",\n\n      COUNT(DISTINCT CASE\n        WHEN \\"pj_a_4450_permanent_power_ordered_finish\\" IS NOT NULL\n         AND \\"pj_a_4550_permanent_power_installed_finish\\" IS NOT NULL\n        THEN \\"pj_project_id\\" END\n      ) AS \\"power_installed_count\\",\n\n      AVG(\n        CASE\n          WHEN \\"pj_a_4450_permanent_power_ordered_finish\\" IS NOT NULL\n           AND \\"pj_a_4550_permanent_power_installed_finish\\" IS NOT NULL\n           AND (\\"pj_a_4550_permanent_power_installed_finish\\"::date - \\"pj_a_4450_permanent_power_ordered_finish\\"::date) >= 0\n          THEN (\\"pj_a_4550_permanent_power_installed_finish\\"::date - \\"pj_a_4450_permanent_power_ordered_finish\\"::date)\n        END\n      ) AS \\"avg_installation_cycle_days\\"\n\n    FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\"\n    WHERE {where_clause}\n    GROUP BY\n      \\"rgn_region\\",\n      \\"m_area\\",\n      \\"m_market\\",\n      \\"construction_gc\\",\n      \\"por_category\\"\n    ORDER BY\n      \\"rgn_region\\",\n      \\"m_area\\",\n      \\"m_market\\",\n      \\"construction_gc\\",\n      \\"por_category\\";\n    """\n\n    return execute_query(sql, db="public")\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'pj_project_id', 's_site_id', 'pj_project_status', 'pj_a_4450_permanent_power_ordered_finish', 'pj_a_4550_permanent_power_installed_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Pending Power Installation', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '016f1231-f5d4-451e-a5ec-cd79f63511af', entity_type: 'kpi', kpi_name: 'Pending Power Installation', name: '016f1231-f5d4-451e-a5ec-cd79f63511af', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Counts active sites where permanent power has been ordered but not yet installed (a critical prerequisite for tower commissioning/integration). Helps identify utility/power vendor delays and forecast integration start blockers. Also reports pending aging (avg/max days since power was ordered) and, for completed sites, the average power installation cycle time (days from ordered to installed), excluding negative durations.', status: 'mentioned', node_id: '016f1231-f5d4-451e-a5ec-cd79f63511af'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_hse_site_checklist'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: Stop Work Count = COUNT(DISTINCT site_id) and Stop Work With Notification Count = COUNT(DISTINCT site_id) for rows where level_4_status = \'Not resolved\', with the second count additionally requiring remarks ILIKE \'%Stop Work%\', grouped by gc_name, market, region.', kpi_output_schema: '[{"column": "gc_name", "type": "string", "description": "General contractor name."}, {"column": "market", "type": "string", "description": "Market."}, {"column": "region", "type": "string", "description": "Region."}, {"column": "stop_work_count", "type": "integer", "description": "Count of distinct site_id with level_4_status = \'Not resolved\'."}, {"column": "stop_work_with_notification_count", "type": "integer", "description": "Count of distinct site_id with level_4_status = \'Not resolved\' and remarks containing \'Stop Work\' (case-insensitive)."}]', kpi_business_logic: '1) Read rows from public.stg_ndpd_hse_site_checklist. 2) Apply optional exact-match filters on gc_name, market, region, and site_id (seed WHERE 1=1). 3) For each (gc_name, market, region) group, compute: (a) distinct count of site_id where level_4_status = \'Not resolved\'; (b) distinct count of site_id where level_4_status = \'Not resolved\' AND remarks ILIKE \'%Stop Work%\'.', kpi_filters: '[{"name": "gc_name", "type": "string", "description": "Exact-match filter on gc_name."}, {"name": "market", "type": "string", "description": "Exact-match filter on market."}, {"name": "region", "type": "string", "description": "Exact-match filter on region."}, {"name": "site_id", "type": "string", "description": "Exact-match filter on site_id."}]', kpi_contract: '{"function_name": "get_stop_work_count", "node_type": "kpi", "node_id": "8c997583-11e3-487f-86d8-52057dc753cc", "node_label": "Stop Work Count", "description": "Counts sites with an unresolved HSE Level-4 stop-work status, and separately counts unresolved sites where the remarks indicate a stop-work notification was sent. Used for executive HSE governance to monitor highest-severity safety escalations that halt field work until resolved, and to track whether stop-work notification communication has been recorded.", "parameters": [{"name": "gc_name", "type": "string", "description": "Filter by gc name", "required": false, "sample_values": []}, {"name": "market", "type": "string", "description": "Filter by market", "required": false, "sample_values": []}, {"name": "region", "type": "string", "description": "Filter by region", "required": false, "sample_values": []}, {"name": "site_id", "type": "string", "description": "Filter by site id", "required": false, "sample_values": []}], "output_columns": [{"name": "gc_name", "type": "string", "nullable": false}, {"name": "market", "type": "string", "nullable": false}, {"name": "region", "type": "null", "nullable": true}, {"name": "stop_work_count", "type": "number", "nullable": false}, {"name": "stop_work_with_notification_count", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: Stop Work Count = COUNT(DISTINCT site_id) and Stop Work With Notification Count = COUNT(DISTINCT site_id) for rows where level_4_status = \'Not resolved\', with the second count additionally requiring remarks ILIKE \'%Stop Work%\', grouped by gc_name, market, region.', node_type: 'CORE', definition: 'One-sentence formula: Stop Work Count = COUNT(DISTINCT site_id) and Stop Work With Notification Count = COUNT(DISTINCT site_id) for rows where level_4_status = \'Not resolved\', with the second count additionally requiring remarks ILIKE \'%Stop Work%\', grouped by gc_name, market, region.', kpi_python_function: 'def get_stop_work_count(execute_query, filters=None) -> list[dict]:\n    # KPI: Stop Work Count\n    # Source: public.stg_ndpd_hse_site_checklist (single-table)\n\n    where_parts = ["1=1"]\n\n    if filters:\n        if filters.get("gc_name") is not None and str(filters.get("gc_name")).strip() != "":\n            val = str(filters["gc_name"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"gc_name\\" = \'{val}\'")\n\n        if filters.get("market") is not None and str(filters.get("market")).strip() != "":\n            val = str(filters["market"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"market\\" = \'{val}\'")\n\n        if filters.get("region") is not None and str(filters.get("region")).strip() != "":\n            val = str(filters["region"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"region\\" = \'{val}\'")\n\n        if filters.get("site_id") is not None and str(filters.get("site_id")).strip() != "":\n            val = str(filters["site_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"site_id\\" = \'{val}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"gc_name\\" AS \\"gc_name\\", "\n        "  \\"market\\" AS \\"market\\", "\n        "  \\"region\\" AS \\"region\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"level_4_status\\" = \'Not resolved\' THEN \\"site_id\\" END) AS \\"stop_work_count\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"level_4_status\\" = \'Not resolved\' "\n        "                      AND \\"remarks\\" ILIKE \'%Stop Work%\' "\n        "                 THEN \\"site_id\\" END) AS \\"stop_work_with_notification_count\\" "\n        "FROM \\"public\\".\\"stg_ndpd_hse_site_checklist\\" "\n        f"WHERE {where_sql} "\n        "GROUP BY \\"gc_name\\", \\"market\\", \\"region\\" "\n        "ORDER BY \\"gc_name\\", \\"market\\", \\"region\\""\n    )\n\n    return execute_query(sql, db="public")\n', kpi_source_columns: ['gc_name', 'market', 'region', 'site_id', 'level_4_status', 'remarks'], session_id: '69a3d22f26e208edc083a06e', label: 'Stop Work Count', kpi_related_core_node_ids: ['site', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '8c997583-11e3-487f-86d8-52057dc753cc', entity_type: 'kpi', kpi_name: 'Stop Work Count', name: '8c997583-11e3-487f-86d8-52057dc753cc', kpi_dimensions: ['gc_name', 'market', 'region'], kpi_description: 'Counts sites with an unresolved HSE Level-4 stop-work status, and separately counts unresolved sites where the remarks indicate a stop-work notification was sent. Used for executive HSE governance to monitor highest-severity safety escalations that halt field work until resolved, and to track whether stop-work notification communication has been recorded.', status: 'mentioned', node_id: '8c997583-11e3-487f-86d8-52057dc753cc'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: For Active projects in stg_ndpd_mbt_tmobile_macro_combined grouped by (rgn_region, m_area, m_market, construction_gc, por_category), compute distinct active site counts split by CPO missing, CPO present but SPO missing, both present, and CPO-unavailable rate = 100*cpo_missing/total.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension."}, {"column": "por_category", "type": "string", "description": "POR category dimension."}, {"column": "total_active_sites", "type": "integer", "description": "Distinct count of active projects/sites."}, {"column": "cpo_not_available_count", "type": "integer", "description": "Distinct count of active projects where CPO (SO header) is missing."}, {"column": "cpo_available_spo_pending_count", "type": "integer", "description": "Distinct count of active projects where CPO exists but SPO is missing."}, {"column": "both_available_count", "type": "integer", "description": "Distinct count of active projects where both CPO and SPO exist."}, {"column": "cpo_unavailable_rate_pct", "type": "float", "description": "100 * cpo_not_available_count / total_active_sites (safe divide by NULLIF)."}]', kpi_business_logic: '1) Filter rows to pj_project_status = \'Active\' (and apply optional dimension/entity filters).\n2) Group by rgn_region, m_area, m_market, construction_gc, por_category.\n3) total_active_sites = COUNT(DISTINCT pj_project_id).\n4) cpo_not_available_count = COUNT(DISTINCT CASE WHEN ms1555_construction_complete_so_header IS NULL THEN pj_project_id END).\n5) cpo_available_spo_pending_count = COUNT(DISTINCT CASE WHEN ms1555_construction_complete_so_header IS NOT NULL AND ms1555_construction_complete_spo IS NULL THEN pj_project_id END).\n6) both_available_count = COUNT(DISTINCT CASE WHEN ms1555_construction_complete_so_header IS NOT NULL AND ms1555_construction_complete_spo IS NOT NULL THEN pj_project_id END).\n7) cpo_unavailable_rate_pct = 100.0 * cpo_not_available_count / NULLIF(total_active_sites, 0).', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact match filter on region."}, {"name": "m_area", "type": "string", "description": "Exact match filter on area."}, {"name": "m_market", "type": "string", "description": "Exact match filter on market."}, {"name": "construction_gc", "type": "string", "description": "Exact match filter on general contractor."}, {"name": "por_category", "type": "string", "description": "Exact match filter on POR category (e.g., NTM)."}, {"name": "pj_project_id", "type": "string", "description": "Exact match filter for a specific project id."}, {"name": "s_site_id", "type": "string", "description": "Exact match filter for a specific site code."}]', kpi_contract: '{"function_name": "get_cpo_spo_availability_gap", "node_type": "kpi", "node_id": "152a2392-d39a-4f5e-8e8f-45f4d3e5701d", "node_label": "CPO/SPO Availability Gap", "description": "Tracks the financial pipeline gap between Customer Purchase Order (CPO) availability and Supplier Purchase Order (SPO) creation for active NTM sites, to support cash-flow forecasting and identify commercial bottlenecks. Measures total active sites, count missing CPO, count with CPO but SPO pending, count with both CPO and SPO available, and the CPO-unavailable rate.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "total_active_sites", "type": "number", "nullable": false}, {"name": "cpo_not_available_count", "type": "number", "nullable": false}, {"name": "cpo_available_spo_pending_count", "type": "number", "nullable": false}, {"name": "both_available_count", "type": "number", "nullable": false}, {"name": "cpo_unavailable_rate_pct", "type": "string", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: For Active projects in stg_ndpd_mbt_tmobile_macro_combined grouped by (rgn_region, m_area, m_market, construction_gc, por_category), compute distinct active site counts split by CPO missing, CPO present but SPO missing, both present, and CPO-unavailable rate = 100*cpo_missing/total.', node_type: 'CORE', definition: 'One-sentence formula: For Active projects in stg_ndpd_mbt_tmobile_macro_combined grouped by (rgn_region, m_area, m_market, construction_gc, por_category), compute distinct active site counts split by CPO missing, CPO present but SPO missing, both present, and CPO-unavailable rate = 100*cpo_missing/total.', kpi_python_function: 'def get_cpo_spo_availability_gap(execute_query, filters=None) -> list[dict]:\n    # KPI computed from a single wide staging table using SQL-side aggregation.\n    where_parts = [\n        "1=1",\n        "\\"pj_project_status\\" = \'Active\'"\n    ]\n\n    # Allowlist filters (exact match to spec)\n    if filters:\n        if filters.get("rgn_region"):\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"rgn_region\\" = \'{v}\'")\n        if filters.get("m_area"):\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_area\\" = \'{v}\'")\n        if filters.get("m_market"):\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_market\\" = \'{v}\'")\n        if filters.get("construction_gc"):\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"construction_gc\\" = \'{v}\'")\n        if filters.get("por_category"):\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"por_category\\" = \'{v}\'")\n        if filters.get("pj_project_id"):\n            v = str(filters["pj_project_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"pj_project_id\\" = \'{v}\'")\n        if filters.get("s_site_id"):\n            v = str(filters["s_site_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"s_site_id\\" = \'{v}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\", "\n        "  \\"m_area\\", "\n        "  \\"m_market\\", "\n        "  \\"construction_gc\\", "\n        "  \\"por_category\\", "\n        "  COUNT(DISTINCT \\"pj_project_id\\") AS \\"total_active_sites\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"ms1555_construction_complete_so_header\\" IS NULL THEN \\"pj_project_id\\" END) AS \\"cpo_not_available_count\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"ms1555_construction_complete_so_header\\" IS NOT NULL AND \\"ms1555_construction_complete_spo\\" IS NULL THEN \\"pj_project_id\\" END) AS \\"cpo_available_spo_pending_count\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"ms1555_construction_complete_so_header\\" IS NOT NULL AND \\"ms1555_construction_complete_spo\\" IS NOT NULL THEN \\"pj_project_id\\" END) AS \\"both_available_count\\", "\n        "  100.0 * "\n        "    COUNT(DISTINCT CASE WHEN \\"ms1555_construction_complete_so_header\\" IS NULL THEN \\"pj_project_id\\" END) "\n        "    / NULLIF(COUNT(DISTINCT \\"pj_project_id\\"), 0) AS \\"cpo_unavailable_rate_pct\\" "\n        "FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\" "\n        f"WHERE {where_sql} "\n        "GROUP BY "\n        "  \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\" "\n        "ORDER BY "\n        "  \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\""\n    )\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'ms1555_construction_complete_so_header', 'ms1555_construction_complete_spo', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'CPO/SPO Availability Gap', kpi_related_core_node_ids: ['project', 'closeout_package', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '152a2392-d39a-4f5e-8e8f-45f4d3e5701d', entity_type: 'kpi', kpi_name: 'CPO/SPO Availability Gap', name: '152a2392-d39a-4f5e-8e8f-45f4d3e5701d', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Tracks the financial pipeline gap between Customer Purchase Order (CPO) availability and Supplier Purchase Order (SPO) creation for active NTM sites, to support cash-flow forecasting and identify commercial bottlenecks. Measures total active sites, count missing CPO, count with CPO but SPO pending, count with both CPO and SPO available, and the CPO-unavailable rate.', status: 'mentioned', node_id: '152a2392-d39a-4f5e-8e8f-45f4d3e5701d'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: For Active projects, group by (rgn_region, m_area, m_market, construction_gc, por_category), count distinct projects by backhaul selection (AAV vs Microwave/MW vs other), then compute AAV% and MW% over total_with_backhaul and compute aav_to_mw_ratio = aav_count/mw_count.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension."}, {"column": "por_category", "type": "string", "description": "POR category dimension."}, {"column": "aav_count", "type": "integer", "description": "Count of distinct active projects whose backhaul selection contains \'AAV\'."}, {"column": "mw_count", "type": "integer", "description": "Count of distinct active projects whose backhaul selection contains \'Microwave\' or \'MW\'."}, {"column": "other_backhaul_count", "type": "integer", "description": "Count of distinct active projects with a non-null backhaul selection that is neither AAV nor Microwave/MW."}, {"column": "total_with_backhaul", "type": "integer", "description": "Count of distinct active projects with a non-null backhaul selection."}, {"column": "aav_pct", "type": "float", "description": "AAV share (%) among active projects with non-null backhaul selection."}, {"column": "mw_pct", "type": "float", "description": "Microwave/MW share (%) among active projects with non-null backhaul selection."}, {"column": "aav_to_mw_ratio", "type": "float", "description": "Ratio of AAV-count to MW-count among active projects (null if mw_count is 0)."}]', kpi_business_logic: '1) Filter to pj_project_status = \'Active\' plus optional equality filters on rgn_region, m_area, m_market, construction_gc, por_category, pj_project_id, s_site_id.\n2) Within each group (rgn_region, m_area, m_market, construction_gc, por_category), compute:\n   - aav_count = distinct pj_project_id where pj_backhaul_task_selection ILIKE \'%AAV%\'\n   - mw_count = distinct pj_project_id where pj_backhaul_task_selection ILIKE \'%Microwave%\' OR ILIKE \'%MW%\'\n   - other_backhaul_count = distinct pj_project_id where pj_backhaul_task_selection is not null and matches none of the above patterns\n   - total_with_backhaul = distinct pj_project_id where pj_backhaul_task_selection is not null\n3) Compute aav_pct = 100.0 * aav_count / NULLIF(total_with_backhaul,0) and mw_pct similarly.\n4) Compute aav_to_mw_ratio = aav_count::float / NULLIF(mw_count,0).', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact match filter on region."}, {"name": "m_area", "type": "string", "description": "Exact match filter on area."}, {"name": "m_market", "type": "string", "description": "Exact match filter on market."}, {"name": "construction_gc", "type": "string", "description": "Exact match filter on general contractor."}, {"name": "por_category", "type": "string", "description": "Exact match filter on POR category."}, {"name": "pj_project_id", "type": "string", "description": "Exact match filter on project id."}, {"name": "s_site_id", "type": "string", "description": "Exact match filter on site id."}]', kpi_contract: '{"function_name": "get_aav_vs_mw_ratio", "node_type": "kpi", "node_id": "6241f4e8-f4f5-4a72-b293-d8cbf6359528", "node_label": "AAV vs MW Ratio", "description": "Tracks the backhaul technology mix across active sites by counting projects with AAV vs Microwave selections (and other backhaul values), and computing AAV%/MW% and the AAV-to-MW ratio. Used to monitor market shifts away from microwave, forecast AAV vendor capacity needs, and understand vendor/timeline dependencies driven by backhaul choice.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "aav_count", "type": "number", "nullable": false}, {"name": "mw_count", "type": "number", "nullable": false}, {"name": "other_backhaul_count", "type": "number", "nullable": false}, {"name": "total_with_backhaul", "type": "number", "nullable": false}, {"name": "aav_pct", "type": "string", "nullable": true}, {"name": "mw_pct", "type": "string", "nullable": true}, {"name": "aav_to_mw_ratio", "type": "null", "nullable": true}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: For Active projects, group by (rgn_region, m_area, m_market, construction_gc, por_category), count distinct projects by backhaul selection (AAV vs Microwave/MW vs other), then compute AAV% and MW% over total_with_backhaul and compute aav_to_mw_ratio = aav_count/mw_count.', node_type: 'CORE', definition: 'One-sentence formula: For Active projects, group by (rgn_region, m_area, m_market, construction_gc, por_category), count distinct projects by backhaul selection (AAV vs Microwave/MW vs other), then compute AAV% and MW% over total_with_backhaul and compute aav_to_mw_ratio = aav_count/mw_count.', kpi_python_function: 'def get_aav_vs_mw_ratio(execute_query, filters=None) -> list[dict]:\n    \n    where_parts = [\n        "1=1",\n        "\\"pj_project_status\\" = \'Active\'"\n    ]\n\n    # Allowlist filters (exact-match equality)\n    if filters:\n        if filters.get("rgn_region") is not None:\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"rgn_region\\" = \'{v}\'")\n        if filters.get("m_area") is not None:\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_area\\" = \'{v}\'")\n        if filters.get("m_market") is not None:\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_market\\" = \'{v}\'")\n        if filters.get("construction_gc") is not None:\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"construction_gc\\" = \'{v}\'")\n        if filters.get("por_category") is not None:\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"por_category\\" = \'{v}\'")\n        if filters.get("pj_project_id") is not None:\n            v = str(filters["pj_project_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"pj_project_id\\" = \'{v}\'")\n        if filters.get("s_site_id") is not None:\n            v = str(filters["s_site_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"s_site_id\\" = \'{v}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\", "\n        "  \\"m_area\\", "\n        "  \\"m_market\\", "\n        "  \\"construction_gc\\", "\n        "  \\"por_category\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" ILIKE \'%AAV%\' THEN \\"pj_project_id\\" END) AS \\"aav_count\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" ILIKE \'%Microwave%\' OR \\"pj_backhaul_task_selection\\" ILIKE \'%MW%\' THEN \\"pj_project_id\\" END) AS \\"mw_count\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" IS NOT NULL "\n        "    AND \\"pj_backhaul_task_selection\\" NOT ILIKE \'%AAV%\' "\n        "    AND \\"pj_backhaul_task_selection\\" NOT ILIKE \'%Microwave%\' "\n        "    AND \\"pj_backhaul_task_selection\\" NOT ILIKE \'%MW%\' "\n        "    THEN \\"pj_project_id\\" END) AS \\"other_backhaul_count\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" IS NOT NULL THEN \\"pj_project_id\\" END) AS \\"total_with_backhaul\\", "\n        "  100.0 * "\n        "    COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" ILIKE \'%AAV%\' THEN \\"pj_project_id\\" END) "\n        "    / NULLIF(COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" IS NOT NULL THEN \\"pj_project_id\\" END), 0) "\n        "    AS \\"aav_pct\\", "\n        "  100.0 * "\n        "    COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" ILIKE \'%Microwave%\' OR \\"pj_backhaul_task_selection\\" ILIKE \'%MW%\' THEN \\"pj_project_id\\" END) "\n        "    / NULLIF(COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" IS NOT NULL THEN \\"pj_project_id\\" END), 0) "\n        "    AS \\"mw_pct\\", "\n        "  (COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" ILIKE \'%AAV%\' THEN \\"pj_project_id\\" END))::float "\n        "    / NULLIF(COUNT(DISTINCT CASE WHEN \\"pj_backhaul_task_selection\\" ILIKE \'%Microwave%\' OR \\"pj_backhaul_task_selection\\" ILIKE \'%MW%\' THEN \\"pj_project_id\\" END), 0) "\n        "    AS \\"aav_to_mw_ratio\\" "\n        "FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\" "\n        f"WHERE {where_sql} "\n        "GROUP BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\" "\n        "ORDER BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\""\n    )\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_status', 'pj_backhaul_task_selection', 'pj_project_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'AAV vs MW Ratio', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '6241f4e8-f4f5-4a72-b293-d8cbf6359528', entity_type: 'kpi', kpi_name: 'AAV vs MW Ratio', name: '6241f4e8-f4f5-4a72-b293-d8cbf6359528', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Tracks the backhaul technology mix across active sites by counting projects with AAV vs Microwave selections (and other backhaul values), and computing AAV%/MW% and the AAV-to-MW ratio. Used to monitor market shifts away from microwave, forecast AAV vendor capacity needs, and understand vendor/timeline dependencies driven by backhaul choice.', status: 'mentioned', node_id: '6241f4e8-f4f5-4a72-b293-d8cbf6359528'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_services_ndpc_sessions_daily_from_sdb', 'public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: For each sessiontitle, take the row with maximum lastactivity, cast completed/approved/rejected percent strings to numeric safely, join to macro_combined by sessiontitle=scop_title, then by (rgn_region,m_area,m_market,construction_gc,por_category) compute AVG completed/approved/rejected %, COUNT(DISTINCT sessiontitle), and COUNT(DISTINCT sessiontitle) with approved%>=95.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension from macro_combined."}, {"column": "m_area", "type": "string", "description": "Area dimension from macro_combined."}, {"column": "m_market", "type": "string", "description": "Market dimension from macro_combined."}, {"column": "construction_gc", "type": "string", "description": "General contractor dimension from macro_combined."}, {"column": "por_category", "type": "string", "description": "PoR category dimension from macro_combined."}, {"column": "session_count", "type": "integer", "description": "Count of distinct sessiontitle values after selecting the latest record per sessiontitle."}, {"column": "avg_completed_pct", "type": "numeric", "description": "Average of latest completed percent across sessions in the group (non-numeric/blank treated as NULL)."}, {"column": "avg_approved_pct", "type": "numeric", "description": "Average of latest approved percent across sessions in the group (non-numeric/blank treated as NULL)."}, {"column": "avg_rejected_pct", "type": "numeric", "description": "Average of latest rejected percent across sessions in the group (non-numeric/blank treated as NULL)."}, {"column": "sessions_above_95_count", "type": "integer", "description": "Count of distinct sessions whose latest approved percent is >= 95."}]', kpi_business_logic: '1) From stg_services_ndpc_sessions_daily_from_sdb, identify the latest record per sessiontitle using MAX(lastactivity) and keep only that row. 2) For that latest row, cast completedpercent/approvedpercent/rejectedpercent (varchar) to numeric only when the trimmed string is non-empty and matches regex ^[0-9]+(\\.[0-9]+)?$; otherwise treat as NULL. 3) Join the latest-per-session dataset to stg_ndpd_mbt_tmobile_macro_combined on sessiontitle = scop_title to attach rgn_region, m_area, m_market, construction_gc, por_category (and enable filtering on pj_project_id, s_site_id). 4) Group by rgn_region, m_area, m_market, construction_gc, por_category and compute: avg_completed_pct=AVG(completed_pct), avg_approved_pct=AVG(approved_pct), avg_rejected_pct=AVG(rejected_pct), session_count=COUNT(DISTINCT sessiontitle), sessions_above_95_count=COUNT(DISTINCT CASE WHEN approved_pct>=95 THEN sessiontitle END).', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact match filter on project region (macro_combined.rgn_region)."}, {"name": "m_area", "type": "string", "description": "Exact match filter on project area (macro_combined.m_area)."}, {"name": "m_market", "type": "string", "description": "Exact match filter on project market (macro_combined.m_market)."}, {"name": "construction_gc", "type": "string", "description": "Exact match filter on general contractor (macro_combined.construction_gc)."}, {"name": "por_category", "type": "string", "description": "Exact match filter on PoR category (macro_combined.por_category)."}, {"name": "pj_project_id", "type": "string", "description": "Exact match filter on project id (macro_combined.pj_project_id)."}, {"name": "s_site_id", "type": "string", "description": "Exact match filter on site code (macro_combined.s_site_id)."}]', kpi_contract: '{"function_name": "get_ndpc_session_quality_metrics", "node_type": "kpi", "node_id": "86da412d-44c9-4f7f-bc59-9c4ebfa82972", "node_label": "NDPC Session Quality Metrics", "description": "Aggregates NDPC session quality percentages (completed/upload, approved, rejected) using the latest record per session title, then averages these percentages across sessions by region/area/market, general contractor, and PoR category. Includes counts of total sessions and sessions meeting the >95% approval threshold to identify GCs/markets with low photo completion, poor customer approval, or high rejection rates.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'One-sentence formula: For each sessiontitle, take the row with maximum lastactivity, cast completed/approved/rejected percent strings to numeric safely, join to macro_combined by sessiontitle=scop_title, then by (rgn_region,m_area,m_market,construction_gc,por_category) compute AVG completed/approved/rejected %, COUNT(DISTINCT sessiontitle), and COUNT(DISTINCT sessiontitle) with approved%>=95.', node_type: 'CORE', definition: 'One-sentence formula: For each sessiontitle, take the row with maximum lastactivity, cast completed/approved/rejected percent strings to numeric safely, join to macro_combined by sessiontitle=scop_title, then by (rgn_region,m_area,m_market,construction_gc,por_category) compute AVG completed/approved/rejected %, COUNT(DISTINCT sessiontitle), and COUNT(DISTINCT sessiontitle) with approved%>=95.', kpi_python_function: 'def get_ndpc_session_quality_metrics(execute_query, filters=None) -> list[dict]:\n    """Aggregates NDPC session quality percentages using latest record per sessiontitle,\n    then averages across sessions by region/area/market, GC, and PoR category.\n    """\n\n    where_parts = ["1=1"]\n\n    # Allowlist filters (exact match)\n    if filters:\n        if filters.get("rgn_region"):\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f\'pj."rgn_region" = \\\'{v}\\\'\')\n        if filters.get("m_area"):\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f\'pj."m_area" = \\\'{v}\\\'\')\n        if filters.get("m_market"):\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f\'pj."m_market" = \\\'{v}\\\'\')\n        if filters.get("construction_gc"):\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f\'pj."construction_gc" = \\\'{v}\\\'\')\n        if filters.get("por_category"):\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f\'pj."por_category" = \\\'{v}\\\'\')\n        if filters.get("pj_project_id"):\n            v = str(filters["pj_project_id"]).replace("\'", "\'\'")\n            where_parts.append(f\'pj."pj_project_id" = \\\'{v}\\\'\')\n        if filters.get("s_site_id"):\n            v = str(filters["s_site_id"]).replace("\'", "\'\'")\n            where_parts.append(f\'pj."s_site_id" = \\\'{v}\\\'\')\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = f"""\nSELECT\n  pj."rgn_region" AS "rgn_region",\n  pj."m_area" AS "m_area",\n  pj."m_market" AS "m_market",\n  pj."construction_gc" AS "construction_gc",\n  pj."por_category" AS "por_category",\n  COUNT(DISTINCT latest."sessiontitle") AS "session_count",\n  AVG(latest."completed_pct") AS "avg_completed_pct",\n  AVG(latest."approved_pct") AS "avg_approved_pct",\n  AVG(latest."rejected_pct") AS "avg_rejected_pct",\n  COUNT(DISTINCT CASE WHEN latest."approved_pct" >= 95 THEN latest."sessiontitle" END) AS "sessions_above_95_count"\nFROM\n  (\n    SELECT\n      s."sessiontitle" AS "sessiontitle",\n      s."lastactivity" AS "lastactivity",\n      CASE\n        WHEN s."completedpercent" IS NOT NULL\n         AND TRIM(s."completedpercent") <> \'\'\n         AND TRIM(s."completedpercent") ~ \'^[0-9]+(\\\\.[0-9]+)?$\'\n        THEN NULLIF(TRIM(s."completedpercent"), \'\')::numeric\n        ELSE NULL\n      END AS "completed_pct",\n      CASE\n        WHEN s."approvedpercent" IS NOT NULL\n         AND TRIM(s."approvedpercent") <> \'\'\n         AND TRIM(s."approvedpercent") ~ \'^[0-9]+(\\\\.[0-9]+)?$\'\n        THEN NULLIF(TRIM(s."approvedpercent"), \'\')::numeric\n        ELSE NULL\n      END AS "approved_pct",\n      CASE\n        WHEN s."rejectedpercent" IS NOT NULL\n         AND TRIM(s."rejectedpercent") <> \'\'\n         AND TRIM(s."rejectedpercent") ~ \'^[0-9]+(\\\\.[0-9]+)?$\'\n        THEN NULLIF(TRIM(s."rejectedpercent"), \'\')::numeric\n        ELSE NULL\n      END AS "rejected_pct"\n    FROM public."stg_services_ndpc_sessions_daily_from_sdb" s\n    INNER JOIN (\n      SELECT\n        "sessiontitle",\n        MAX("lastactivity") AS "max_lastactivity"\n      FROM public."stg_services_ndpc_sessions_daily_from_sdb"\n      GROUP BY "sessiontitle"\n    ) mx\n      ON s."sessiontitle" = mx."sessiontitle"\n     AND s."lastactivity" = mx."max_lastactivity"\n  ) latest\nINNER JOIN public."stg_ndpd_mbt_tmobile_macro_combined" pj\n  ON latest."sessiontitle" = pj."scop_title"\nWHERE {where_sql}\nGROUP BY\n  pj."rgn_region",\n  pj."m_area",\n  pj."m_market",\n  pj."construction_gc",\n  pj."por_category"\nORDER BY\n  pj."rgn_region",\n  pj."m_area",\n  pj."m_market",\n  pj."construction_gc",\n  pj."por_category";\n"""\n\n    return execute_query(sql, db="public")\n', kpi_source_columns: ['stg_services_ndpc_sessions_daily_from_sdb.sessiontitle', 'stg_services_ndpc_sessions_daily_from_sdb.lastactivity', 'stg_services_ndpc_sessions_daily_from_sdb.completedpercent', 'stg_services_ndpc_sessions_daily_from_sdb.approvedpercent', 'stg_services_ndpc_sessions_daily_from_sdb.rejectedpercent', 'stg_ndpd_mbt_tmobile_macro_combined.scop_title', 'stg_ndpd_mbt_tmobile_macro_combined.rgn_region', 'stg_ndpd_mbt_tmobile_macro_combined.m_area', 'stg_ndpd_mbt_tmobile_macro_combined.m_market', 'stg_ndpd_mbt_tmobile_macro_combined.construction_gc', 'stg_ndpd_mbt_tmobile_macro_combined.por_category', 'stg_ndpd_mbt_tmobile_macro_combined.pj_project_id', 'stg_ndpd_mbt_tmobile_macro_combined.s_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'NDPC Session Quality Metrics', kpi_related_core_node_ids: ['project', 'quality_session_ndpc', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '86da412d-44c9-4f7f-bc59-9c4ebfa82972', entity_type: 'kpi', kpi_name: 'NDPC Session Quality Metrics', name: '86da412d-44c9-4f7f-bc59-9c4ebfa82972', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Aggregates NDPC session quality percentages (completed/upload, approved, rejected) using the latest record per session title, then averages these percentages across sessions by region/area/market, general contractor, and PoR category. Includes counts of total sessions and sessions meeting the >95% approval threshold to identify GCs/markets with low photo completion, poor customer approval, or high rejection rates.', status: 'mentioned', node_id: '86da412d-44c9-4f7f-bc59-9c4ebfa82972'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'One-sentence formula: Group by region/area/market/GC/PoR category and compute distinct-project counts for ordered/received-but-not-finally-approved (Active only), distinct approved count, plus average (non-negative) days from ordered→approved and received→approved using date differences.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "Construction general contractor dimension."}, {"column": "por_category", "type": "string", "description": "PoR category dimension."}, {"column": "drawings_ordered_pending_count", "type": "integer", "description": "Distinct active projects with drawings ordered but not finally approved."}, {"column": "drawings_received_pending_count", "type": "integer", "description": "Distinct active projects with drawings received but not finally approved."}, {"column": "drawings_approved_count", "type": "integer", "description": "Distinct projects with final construction drawings approved."}, {"column": "avg_approval_cycle_days", "type": "float", "description": "Average non-negative days from drawings ordered to final approval."}, {"column": "avg_received_to_approved_days", "type": "float", "description": "Average non-negative days from drawings received to final approval."}]', kpi_business_logic: '1) Start from public.stg_ndpd_mbt_tmobile_macro_combined.\n2) Apply exact-match filters (rgn_region, m_area, m_market, construction_gc, por_category, pj_project_id, s_site_id).\n3) Group by rgn_region, m_area, m_market, construction_gc, por_category.\n4) drawings_ordered_pending_count = COUNT(DISTINCT pj_project_id) for projects with pj_a_2200_construction_drawings_ordered_finish not null AND pj_a_2275_final_construction_drawings_approved_finish null AND pj_project_status=\'Active\'.\n5) drawings_received_pending_count = COUNT(DISTINCT pj_project_id) for projects with pj_a_2225_construction_drawings_received_finish not null AND pj_a_2275_final_construction_drawings_approved_finish null AND pj_project_status=\'Active\'.\n6) drawings_approved_count = COUNT(DISTINCT pj_project_id) where pj_a_2275_final_construction_drawings_approved_finish is not null.\n7) avg_approval_cycle_days = AVG(approved_date - ordered_date) only when both dates exist and duration >= 0.\n8) avg_received_to_approved_days = AVG(approved_date - received_date) only when both dates exist and duration >= 0.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact-match filter on region."}, {"name": "m_area", "type": "string", "description": "Exact-match filter on area."}, {"name": "m_market", "type": "string", "description": "Exact-match filter on market."}, {"name": "construction_gc", "type": "string", "description": "Exact-match filter on construction general contractor."}, {"name": "por_category", "type": "string", "description": "Exact-match filter on PoR category."}, {"name": "pj_project_id", "type": "string", "description": "Exact-match filter on project id."}, {"name": "s_site_id", "type": "string", "description": "Exact-match filter on site id."}]', kpi_contract: '{"function_name": "get_construction_drawing_approval", "node_type": "kpi", "node_id": "63b24ac0-e82b-4a1b-b738-9614d4150bd0", "node_label": "Construction Drawing Approval", "description": "Tracks the construction drawing approval pipeline by counting active projects where drawings are ordered or received but not yet finally approved, and computes average drawing approval cycle times. This is a prerequisite gate for construction start and helps identify design/drafting bottlenecks, forecast design-team capacity, and anticipate downstream construction delays by region/market/GC and PoR category.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "drawings_ordered_pending_count", "type": "number", "nullable": false}, {"name": "drawings_received_pending_count", "type": "number", "nullable": false}, {"name": "drawings_approved_count", "type": "number", "nullable": false}, {"name": "avg_approval_cycle_days", "type": "null", "nullable": true}, {"name": "avg_received_to_approved_days", "type": "string", "nullable": true}], "sample_output": [], "row_count": 10}', nl_description: 'One-sentence formula: Group by region/area/market/GC/PoR category and compute distinct-project counts for ordered/received-but-not-finally-approved (Active only), distinct approved count, plus average (non-negative) days from ordered→approved and received→approved using date differences.', node_type: 'CORE', definition: 'One-sentence formula: Group by region/area/market/GC/PoR category and compute distinct-project counts for ordered/received-but-not-finally-approved (Active only), distinct approved count, plus average (non-negative) days from ordered→approved and received→approved using date differences.', kpi_python_function: 'def get_construction_drawing_approval(execute_query, filters=None) -> list[dict]:\n    where_parts = ["1=1"]\n\n    # Allowlisted exact-match filters\n    if filters:\n        if filters.get("rgn_region") is not None and str(filters.get("rgn_region")).strip() != "":\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"rgn_region\\" = \'{v}\'")\n\n        if filters.get("m_area") is not None and str(filters.get("m_area")).strip() != "":\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_area\\" = \'{v}\'")\n\n        if filters.get("m_market") is not None and str(filters.get("m_market")).strip() != "":\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_market\\" = \'{v}\'")\n\n        if filters.get("construction_gc") is not None and str(filters.get("construction_gc")).strip() != "":\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"construction_gc\\" = \'{v}\'")\n\n        if filters.get("por_category") is not None and str(filters.get("por_category")).strip() != "":\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"por_category\\" = \'{v}\'")\n\n        if filters.get("pj_project_id") is not None and str(filters.get("pj_project_id")).strip() != "":\n            v = str(filters["pj_project_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"pj_project_id\\" = \'{v}\'")\n\n        if filters.get("s_site_id") is not None and str(filters.get("s_site_id")).strip() != "":\n            v = str(filters["s_site_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"s_site_id\\" = \'{v}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = f"""\n        SELECT\n            "rgn_region",\n            "m_area",\n            "m_market",\n            "construction_gc",\n            "por_category",\n\n            COUNT(DISTINCT CASE\n                WHEN "pj_a_2200_construction_drawings_ordered_finish" IS NOT NULL\n                 AND "pj_a_2275_final_construction_drawings_approved_finish" IS NULL\n                 AND "pj_project_status" = \'Active\'\n                THEN "pj_project_id"\n            END) AS "drawings_ordered_pending_count",\n\n            COUNT(DISTINCT CASE\n                WHEN "pj_a_2225_construction_drawings_received_finish" IS NOT NULL\n                 AND "pj_a_2275_final_construction_drawings_approved_finish" IS NULL\n                 AND "pj_project_status" = \'Active\'\n                THEN "pj_project_id"\n            END) AS "drawings_received_pending_count",\n\n            COUNT(DISTINCT CASE\n                WHEN "pj_a_2275_final_construction_drawings_approved_finish" IS NOT NULL\n                THEN "pj_project_id"\n            END) AS "drawings_approved_count",\n\n            AVG(CASE\n                WHEN "pj_a_2275_final_construction_drawings_approved_finish" IS NOT NULL\n                 AND "pj_a_2200_construction_drawings_ordered_finish" IS NOT NULL\n                 AND ("pj_a_2275_final_construction_drawings_approved_finish"::date - "pj_a_2200_construction_drawings_ordered_finish"::date) >= 0\n                THEN ("pj_a_2275_final_construction_drawings_approved_finish"::date - "pj_a_2200_construction_drawings_ordered_finish"::date)\n            END) AS "avg_approval_cycle_days",\n\n            AVG(CASE\n                WHEN "pj_a_2275_final_construction_drawings_approved_finish" IS NOT NULL\n                 AND "pj_a_2225_construction_drawings_received_finish" IS NOT NULL\n                 AND ("pj_a_2275_final_construction_drawings_approved_finish"::date - "pj_a_2225_construction_drawings_received_finish"::date) >= 0\n                THEN ("pj_a_2275_final_construction_drawings_approved_finish"::date - "pj_a_2225_construction_drawings_received_finish"::date)\n            END) AS "avg_received_to_approved_days"\n\n        FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n        WHERE {where_sql}\n        GROUP BY\n            "rgn_region",\n            "m_area",\n            "m_market",\n            "construction_gc",\n            "por_category"\n        ORDER BY\n            "rgn_region",\n            "m_area",\n            "m_market",\n            "construction_gc",\n            "por_category";\n    """\n\n    return execute_query(sql)', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'pj_project_id', 's_site_id', 'pj_project_status', 'pj_a_2200_construction_drawings_ordered_finish', 'pj_a_2225_construction_drawings_received_finish', 'pj_a_2275_final_construction_drawings_approved_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Construction Drawing Approval', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '63b24ac0-e82b-4a1b-b738-9614d4150bd0', entity_type: 'kpi', kpi_name: 'Construction Drawing Approval', name: '63b24ac0-e82b-4a1b-b738-9614d4150bd0', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Tracks the construction drawing approval pipeline by counting active projects where drawings are ordered or received but not yet finally approved, and computes average drawing approval cycle times. This is a prerequisite gate for construction start and helps identify design/drafting bottlenecks, forecast design-team capacity, and anticipate downstream construction delays by region/market/GC and PoR category.', status: 'mentioned', node_id: '63b24ac0-e82b-4a1b-b738-9614d4150bd0'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Counts distinct active WIP projects (construction started and not complete) by region/area/market/GC/POR category and computes counts with start delay code, complete delay code, any delay code, and delay-coded percent.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region."}, {"column": "m_area", "type": "string", "description": "Area."}, {"column": "m_market", "type": "string", "description": "Market."}, {"column": "construction_gc", "type": "string", "description": "Construction general contractor."}, {"column": "por_category", "type": "string", "description": "POR category."}, {"column": "tower_wip_total", "type": "integer", "description": "Distinct count of active WIP construction projects (started, not complete)."}, {"column": "tower_wip_with_start_delay", "type": "integer", "description": "Distinct count of active WIP projects with a construction start delay code."}, {"column": "tower_wip_with_complete_delay", "type": "integer", "description": "Distinct count of active WIP projects with a construction complete delay code."}, {"column": "tower_wip_with_any_delay_code", "type": "integer", "description": "Distinct count of active WIP projects with either a start or complete delay code."}, {"column": "delay_coded_pct", "type": "float", "description": "Percent of active WIP projects that have any delay code (0-100)."}]', kpi_business_logic: '1) Define WIP base set: pj_a_4225_construction_start_finish IS NOT NULL AND pj_a_5175_construction_complete_finish IS NULL AND pj_project_status=\'Active\'. 2) Group by rgn_region, m_area, m_market, construction_gc, por_category. 3) Compute tower_wip_total = COUNT(DISTINCT pj_project_id). 4) Compute tower_wip_with_start_delay = COUNT(DISTINCT pj_project_id) where pj_construction_start_delay_code IS NOT NULL. 5) Compute tower_wip_with_complete_delay = COUNT(DISTINCT pj_project_id) where pj_construction_complete_delay_code IS NOT NULL. 6) Compute tower_wip_with_any_delay_code = COUNT(DISTINCT pj_project_id) where either delay code is NOT NULL. 7) Compute delay_coded_pct = 100.0 * tower_wip_with_any_delay_code / NULLIF(tower_wip_total,0). 8) Apply optional exact-match filters for rgn_region, m_area, m_market, construction_gc, por_category, pj_project_id, s_site_id.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Exact match filter on region."}, {"name": "m_area", "type": "string", "description": "Exact match filter on area."}, {"name": "m_market", "type": "string", "description": "Exact match filter on market."}, {"name": "construction_gc", "type": "string", "description": "Exact match filter on construction general contractor."}, {"name": "por_category", "type": "string", "description": "Exact match filter on POR category."}, {"name": "pj_project_id", "type": "string", "description": "Exact match filter on project id."}, {"name": "s_site_id", "type": "string", "description": "Exact match filter on site id."}]', kpi_contract: '{"function_name": "get_cx_wip_delay_code", "node_type": "kpi", "node_id": "ebcbc8c7-2e16-4f75-81e6-f6a16de5aa79", "node_label": "CX WIP Delay Code", "description": "Counts active construction WIP (construction started but not complete) projects that have documented delay codes (start and/or complete). Breaks out WIP with start delay code, WIP with complete delay code, and WIP with any delay code, plus the percent of WIP that is delay-coded. Used to identify systemic construction delay patterns and prioritize escalation by GC, market, region, and POR category.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "tower_wip_total", "type": "number", "nullable": false}, {"name": "tower_wip_with_start_delay", "type": "number", "nullable": false}, {"name": "tower_wip_with_complete_delay", "type": "number", "nullable": false}, {"name": "tower_wip_with_any_delay_code", "type": "number", "nullable": false}, {"name": "delay_coded_pct", "type": "string", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Counts distinct active WIP projects (construction started and not complete) by region/area/market/GC/POR category and computes counts with start delay code, complete delay code, any delay code, and delay-coded percent.', node_type: 'CORE', definition: 'Counts distinct active WIP projects (construction started and not complete) by region/area/market/GC/POR category and computes counts with start delay code, complete delay code, any delay code, and delay-coded percent.', kpi_python_function: 'def get_cx_wip_delay_code(execute_query, filters=None) -> list[dict]:\n    # KPI: CX WIP Delay Code (PostgreSQL)\n    where_parts = [\n        "1=1",\n        "\\"pj_a_4225_construction_start_finish\\" IS NOT NULL",\n        "\\"pj_a_5175_construction_complete_finish\\" IS NULL",\n        "\\"pj_project_status\\" = \'Active\'"\n    ]\n\n    if filters is None:\n        filters = {}\n\n    # Allowlist filters (exact-match equality)\n    if filters.get("rgn_region"):\n        val = str(filters["rgn_region"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"rgn_region\\" = \'{val}\'")\n\n    if filters.get("m_area"):\n        val = str(filters["m_area"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"m_area\\" = \'{val}\'")\n\n    if filters.get("m_market"):\n        val = str(filters["m_market"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"m_market\\" = \'{val}\'")\n\n    if filters.get("construction_gc"):\n        val = str(filters["construction_gc"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"construction_gc\\" = \'{val}\'")\n\n    if filters.get("por_category"):\n        val = str(filters["por_category"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"por_category\\" = \'{val}\'")\n\n    if filters.get("pj_project_id"):\n        val = str(filters["pj_project_id"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"pj_project_id\\" = \'{val}\'")\n\n    if filters.get("s_site_id"):\n        val = str(filters["s_site_id"]).replace("\'", "\'\'")\n        where_parts.append(f"\\"s_site_id\\" = \'{val}\'")\n\n    where_clause = " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\", "\n        "  \\"m_area\\", "\n        "  \\"m_market\\", "\n        "  \\"construction_gc\\", "\n        "  \\"por_category\\", "\n        "  COUNT(DISTINCT \\"pj_project_id\\") AS \\"tower_wip_total\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"pj_construction_start_delay_code\\" IS NOT NULL THEN \\"pj_project_id\\" END) AS \\"tower_wip_with_start_delay\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"pj_construction_complete_delay_code\\" IS NOT NULL THEN \\"pj_project_id\\" END) AS \\"tower_wip_with_complete_delay\\", "\n        "  COUNT(DISTINCT CASE WHEN (\\"pj_construction_start_delay_code\\" IS NOT NULL OR \\"pj_construction_complete_delay_code\\" IS NOT NULL) THEN \\"pj_project_id\\" END) AS \\"tower_wip_with_any_delay_code\\", "\n        "  100.0 * "\n        "    (COUNT(DISTINCT CASE WHEN (\\"pj_construction_start_delay_code\\" IS NOT NULL OR \\"pj_construction_complete_delay_code\\" IS NOT NULL) THEN \\"pj_project_id\\" END)) "\n        "    / NULLIF(COUNT(DISTINCT \\"pj_project_id\\"), 0) AS \\"delay_coded_pct\\" "\n        "FROM \\"public\\".\\"stg_ndpd_mbt_tmobile_macro_combined\\" "\n        f"WHERE {where_clause} "\n        "GROUP BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\" "\n        "ORDER BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\", \\"por_category\\""\n    )\n\n    return execute_query(sql)', kpi_source_columns: ['pj_project_id', 'pj_project_status', 'pj_a_4225_construction_start_finish', 'pj_a_5175_construction_complete_finish', 'pj_construction_start_delay_code', 'pj_construction_complete_delay_code', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 's_site_id'], session_id: '69a3d22f26e208edc083a06e', label: 'CX WIP Delay Code', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'ebcbc8c7-2e16-4f75-81e6-f6a16de5aa79', entity_type: 'kpi', kpi_name: 'CX WIP Delay Code', name: 'ebcbc8c7-2e16-4f75-81e6-f6a16de5aa79', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Counts active construction WIP (construction started but not complete) projects that have documented delay codes (start and/or complete). Breaks out WIP with start delay code, WIP with complete delay code, and WIP with any delay code, plus the percent of WIP that is delay-coded. Used to identify systemic construction delay patterns and prioritize escalation by GC, market, region, and POR category.', status: 'mentioned', node_id: 'ebcbc8c7-2e16-4f75-81e6-f6a16de5aa79'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Civil NTP Acceptance CT = f(Project/Site/Market/General Contractor) computed per (rgn_region, m_area, m_market, construction_gc, por_category) as pending Civil NTP counts and pending/acceptance time deltas using pj_a_4025_* submitted and pj_a_4050_* accepted milestone timestamps.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region dimension."}, {"column": "m_area", "type": "string", "description": "Area dimension."}, {"column": "m_market", "type": "string", "description": "Market dimension."}, {"column": "construction_gc", "type": "string", "description": "General Contractor dimension."}, {"column": "por_category", "type": "string", "description": "PoR category dimension."}, {"column": "ntp_pending_count", "type": "integer", "description": "Count of distinct Active projects with Civil NTP submitted but not yet accepted by GC."}, {"column": "avg_days_pending", "type": "float", "description": "Average days since Civil NTP submission for pending Active projects."}, {"column": "max_days_pending", "type": "float", "description": "Maximum days since Civil NTP submission for pending Active projects."}, {"column": "ntp_accepted_count", "type": "integer", "description": "Count of distinct projects with both Civil NTP submitted and accepted timestamps populated."}, {"column": "avg_acceptance_cycle_days", "type": "float", "description": "Average (accepted_date - submitted_date) in days for accepted projects, excluding negative durations."}]', kpi_business_logic: '1) Group records by rgn_region, m_area, m_market, construction_gc, por_category.\n2) Pending/WIP definition (Active only): pj_a_4025_civil_ntp_submitted_to_gc_finish IS NOT NULL AND pj_a_4050_civil_ntp_accepted_by_gc_finish IS NULL AND pj_project_status = \'Active\'.\n3) ntp_pending_count: count distinct pj_project_id that meet pending definition.\n4) avg_days_pending: average over pending rows of (NOW() - submitted_ts) in days, where submitted_ts = pj_a_4025_civil_ntp_submitted_to_gc_finish::timestamp.\n5) max_days_pending: max over pending rows of (NOW() - submitted_ts) in days.\n6) ntp_accepted_count: count distinct pj_project_id where both submitted and accepted timestamps are NOT NULL.\n7) avg_acceptance_cycle_days: average over accepted rows of (accepted_date - submitted_date) in days, excluding negative durations.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Equality filter on rgn_region."}, {"name": "m_area", "type": "string", "description": "Equality filter on m_area."}, {"name": "m_market", "type": "string", "description": "Equality filter on m_market."}, {"name": "construction_gc", "type": "string", "description": "Equality filter on construction_gc (General Contractor)."}, {"name": "por_category", "type": "string", "description": "Equality filter on por_category (PoR category)."}, {"name": "pj_project_id", "type": "string", "description": "Equality filter on pj_project_id."}, {"name": "s_site_id", "type": "string", "description": "Equality filter on s_site_id (site code)."}]', kpi_contract: '{"function_name": "get_civil_ntp_acceptance_ct", "node_type": "kpi", "node_id": "e928950b-4f04-4016-9c75-c9d82fcb97d7", "node_label": "Civil NTP Acceptance CT", "description": "Measures General Contractor responsiveness to Civil Notice-To-Proceed (NTP) submissions by tracking how long it takes for a GC to accept the Civil NTP after Nokia submits it, plus how many Civil NTPs remain pending. This is a prerequisite for civil construction start; delays indicate vendor bottlenecks and predict downstream civil start slippage. Reported by region/area/market/GC/PoR to support vendor management and forecasting.", "parameters": [{"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "construction_gc", "type": "string", "description": "Filter by construction gc", "required": false, "sample_values": []}, {"name": "por_category", "type": "string", "description": "Filter by por category", "required": false, "sample_values": []}, {"name": "pj_project_id", "type": "string", "description": "Filter by pj project id", "required": false, "sample_values": []}, {"name": "s_site_id", "type": "string", "description": "Filter by s site id", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "ntp_pending_count", "type": "number", "nullable": false}, {"name": "avg_days_pending", "type": "null", "nullable": true}, {"name": "max_days_pending", "type": "null", "nullable": true}, {"name": "ntp_accepted_count", "type": "number", "nullable": false}, {"name": "avg_acceptance_cycle_days", "type": "null", "nullable": true}], "sample_output": [], "row_count": 10}', nl_description: 'Civil NTP Acceptance CT = f(Project/Site/Market/General Contractor) computed per (rgn_region, m_area, m_market, construction_gc, por_category) as pending Civil NTP counts and pending/acceptance time deltas using pj_a_4025_* submitted and pj_a_4050_* accepted milestone timestamps.', node_type: 'CORE', definition: 'Civil NTP Acceptance CT = f(Project/Site/Market/General Contractor) computed per (rgn_region, m_area, m_market, construction_gc, por_category) as pending Civil NTP counts and pending/acceptance time deltas using pj_a_4025_* submitted and pj_a_4050_* accepted milestone timestamps.', kpi_python_function: 'def get_civil_ntp_acceptance_ct(execute_query, filters=None) -> list[dict]:\n    where_parts = ["1=1"]\n\n    # Allowlisted equality filters\n    if filters:\n        if filters.get("rgn_region"):\n            v = str(filters["rgn_region"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"rgn_region\\" = \'{v}\'")\n        if filters.get("m_area"):\n            v = str(filters["m_area"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_area\\" = \'{v}\'")\n        if filters.get("m_market"):\n            v = str(filters["m_market"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"m_market\\" = \'{v}\'")\n        if filters.get("construction_gc"):\n            v = str(filters["construction_gc"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"construction_gc\\" = \'{v}\'")\n        if filters.get("por_category"):\n            v = str(filters["por_category"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"por_category\\" = \'{v}\'")\n        if filters.get("pj_project_id"):\n            v = str(filters["pj_project_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"pj_project_id\\" = \'{v}\'")\n        if filters.get("s_site_id"):\n            v = str(filters["s_site_id"]).replace("\'", "\'\'")\n            where_parts.append(f"\\"s_site_id\\" = \'{v}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = f"""\n    SELECT\n      "rgn_region",\n      "m_area",\n      "m_market",\n      "construction_gc",\n      "por_category",\n\n      COUNT(DISTINCT CASE\n        WHEN "pj_a_4025_civil_ntp_submitted_to_gc_finish" IS NOT NULL\n         AND "pj_a_4050_civil_ntp_accepted_by_gc_finish" IS NULL\n         AND "pj_project_status" = \'Active\'\n        THEN "pj_project_id" END\n      ) AS "ntp_pending_count",\n\n      AVG(CASE\n        WHEN "pj_a_4025_civil_ntp_submitted_to_gc_finish" IS NOT NULL\n         AND "pj_a_4050_civil_ntp_accepted_by_gc_finish" IS NULL\n         AND "pj_project_status" = \'Active\'\n        THEN (EXTRACT(EPOCH FROM (NOW() - "pj_a_4025_civil_ntp_submitted_to_gc_finish"::timestamp)) / 86400.0)\n        ELSE NULL END\n      ) AS "avg_days_pending",\n\n      MAX(CASE\n        WHEN "pj_a_4025_civil_ntp_submitted_to_gc_finish" IS NOT NULL\n         AND "pj_a_4050_civil_ntp_accepted_by_gc_finish" IS NULL\n         AND "pj_project_status" = \'Active\'\n        THEN (EXTRACT(EPOCH FROM (NOW() - "pj_a_4025_civil_ntp_submitted_to_gc_finish"::timestamp)) / 86400.0)\n        ELSE NULL END\n      ) AS "max_days_pending",\n\n      COUNT(DISTINCT CASE\n        WHEN "pj_a_4025_civil_ntp_submitted_to_gc_finish" IS NOT NULL\n         AND "pj_a_4050_civil_ntp_accepted_by_gc_finish" IS NOT NULL\n        THEN "pj_project_id" END\n      ) AS "ntp_accepted_count",\n\n      AVG(CASE\n        WHEN "pj_a_4025_civil_ntp_submitted_to_gc_finish" IS NOT NULL\n         AND "pj_a_4050_civil_ntp_accepted_by_gc_finish" IS NOT NULL\n         AND ("pj_a_4050_civil_ntp_accepted_by_gc_finish"::date - "pj_a_4025_civil_ntp_submitted_to_gc_finish"::date) >= 0\n        THEN ("pj_a_4050_civil_ntp_accepted_by_gc_finish"::date - "pj_a_4025_civil_ntp_submitted_to_gc_finish"::date)\n        ELSE NULL END\n      ) AS "avg_acceptance_cycle_days"\n\n    FROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\n    WHERE {where_sql}\n    GROUP BY\n      "rgn_region",\n      "m_area",\n      "m_market",\n      "construction_gc",\n      "por_category"\n    ORDER BY\n      "rgn_region",\n      "m_area",\n      "m_market",\n      "construction_gc",\n      "por_category"\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 'pj_project_id', 's_site_id', 'pj_project_status', 'pj_a_4025_civil_ntp_submitted_to_gc_finish', 'pj_a_4050_civil_ntp_accepted_by_gc_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'Civil NTP Acceptance CT', kpi_related_core_node_ids: ['project', 'site', 'general_contractor', 'market'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'e928950b-4f04-4016-9c75-c9d82fcb97d7', entity_type: 'kpi', kpi_name: 'Civil NTP Acceptance CT', name: 'e928950b-4f04-4016-9c75-c9d82fcb97d7', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category'], kpi_description: 'Measures General Contractor responsiveness to Civil Notice-To-Proceed (NTP) submissions by tracking how long it takes for a GC to accept the Civil NTP after Nokia submits it, plus how many Civil NTPs remain pending. This is a prerequisite for civil construction start; delays indicate vendor bottlenecks and predict downstream civil start slippage. Reported by region/area/market/GC/PoR to support vendor management and forecasting.', status: 'mentioned', node_id: 'e928950b-4f04-4016-9c75-c9d82fcb97d7'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Computes On-Air Cycle Time as the average end-to-end delivery time from construction start (ms_1550_construction_start_actual) to integration complete (ms_1970_integration_complete_actual), in days, using public.stg_ndpd_mbt_tmobile_macro_combined and grouping by rgn_region, m_area, m_market, construction_gc. Cycle time AVG and cycle_time_project_count include only projects where both ms_1970 and ms_1550 dates are present and (ms_1970::date - ms_1550::date) is non-negative (negative durations excluded from cycle time only). Also outputs On-Air Completion Rate (%) as 100.0 * COUNT(DISTINCT pj_project_id with pj_completion_objective_actual_date not null) / NULLIF(COUNT(DISTINCT pj_project_id in scope), 0), unaffected by the non-negative duration rule. Optional denominator_scope=\'entitled\' restricts the base project set to rows with pj_a_3710_ran_entitlement_complete_finish IS NOT NULL. start_date/end_date (when provided) constrain the base row set by ms_1970_integration_complete_actual::date for BOTH metrics. Outputs: rgn_region, m_area, m_market, construction_gc, avg_cycle_time_days, cycle_time_project_count, total_projects_in_scope, on_air_projects, on_air_completion_rate_pct.', kpi_output_schema: '[{"column": "kpi", "type": "string", "description": "KPI name."}, {"column": "avg_cycle_time_days", "type": "float", "description": "Average on-air cycle time in days."}, {"column": "projects_count", "type": "int", "description": "Number of projects/sites included in the average after filtering and data-quality exclusions."}, {"column": "filters_applied", "type": "string", "description": "Filters echoed back in the output (start_date, end_date, site_code, market, gc)."}]', kpi_business_logic: 'Initialize WHERE conditions with \'1=1\', then append allowlisted filter predicates.\nIf start_date/end_date are provided, constrain the base row set to ms_1970_integration_complete_actual::date within the provided date range (applies to BOTH cycle time and completion rate by restricting the base rows).\nApply optional dimension filters: rgn_region, m_area, m_market, construction_gc (via filter key \'gc\').\nIf denominator_scope=\'entitled\', further restrict the base row set to pj_a_3710_ran_entitlement_complete_finish IS NOT NULL.\nGroup results by rgn_region, m_area, m_market, construction_gc.\nCompute duration_days = ms_1970_integration_complete_actual::date - ms_1550_construction_start_actual::date.\nCompute avg_cycle_time_days as AVG(CASE WHEN duration_days >= 0 THEN duration_days END)::float (negative durations excluded; nulls ignored).\nCompute cycle_time_project_count as COUNT(DISTINCT pj_project_id) where ms_1970 and ms_1550 are not null and duration_days >= 0.\nCompute total_projects_in_scope as COUNT(DISTINCT pj_project_id) over the filtered base row set (no duration constraint).\nCompute on_air_projects as COUNT(DISTINCT pj_project_id) where pj_completion_objective_actual_date is not null (no duration constraint).\nCompute on_air_completion_rate_pct as 100.0 * on_air_projects / NULLIF(total_projects_in_scope, 0).', kpi_filters: '[{"name": "start_date", "type": "date_string_yyyy_mm_dd", "description": "Lower bound applied to ms_1970_integration_complete_actual::date (constrains BOTH cycle time and completion rate)."}, {"name": "end_date", "type": "date_string_yyyy_mm_dd", "description": "Upper bound applied to ms_1970_integration_complete_actual::date (constrains BOTH cycle time and completion rate)."}, {"name": "rgn_region", "type": "string", "description": "Exact match filter on rgn_region."}, {"name": "m_area", "type": "string", "description": "Exact match filter on m_area."}, {"name": "m_market", "type": "string", "description": "Exact match filter on m_market."}, {"name": "gc", "type": "string", "description": "Exact match filter on construction_gc."}, {"name": "denominator_scope", "type": "enum", "allowed_values": ["all_active", "entitled"], "default": "all_active", "description": "If \'entitled\', restricts the base set to rows with pj_a_3710_ran_entitlement_complete_finish IS NOT NULL; otherwise uses all projects in the filtered set."}]', kpi_contract: '{"function_name": "get_on_air_cycle_time", "node_type": "kpi", "node_id": "d7ffcd7d-93e1-4c31-a9f2-b430e2843f28", "node_label": "On-Air Cycle Time", "description": "Average end-to-end delivery time from construction start to the first On-Air milestone.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m area", "required": false, "sample_values": []}, {"name": "m_market", "type": "string", "description": "Filter by m market", "required": false, "sample_values": []}, {"name": "gc", "type": "string", "description": "Filter by gc", "required": false, "sample_values": []}, {"name": "denominator_scope", "type": "string", "description": "Filter by denominator scope", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "avg_cycle_time_days", "type": "null", "nullable": true}, {"name": "cycle_time_project_count", "type": "number", "nullable": false}, {"name": "total_projects_in_scope", "type": "number", "nullable": false}, {"name": "on_air_projects", "type": "number", "nullable": false}, {"name": "on_air_completion_rate_pct", "type": "string", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Computes On-Air Cycle Time as the average end-to-end delivery time from construction start (ms_1550_construction_start_actual) to integration complete (ms_1970_integration_complete_actual), in days, using public.stg_ndpd_mbt_tmobile_macro_combined and grouping by rgn_region, m_area, m_market, construction_gc. Cycle time AVG and cycle_time_project_count include only projects where both ms_1970 and ms_1550 dates are present and (ms_1970::date - ms_1550::date) is non-negative (negative durations excluded from cycle time only). Also outputs On-Air Completion Rate (%) as 100.0 * COUNT(DISTINCT pj_project_id with pj_completion_objective_actual_date not null) / NULLIF(COUNT(DISTINCT pj_project_id in scope), 0), unaffected by the non-negative duration rule. Optional denominator_scope=\'entitled\' restricts the base project set to rows with pj_a_3710_ran_entitlement_complete_finish IS NOT NULL. start_date/end_date (when provided) constrain the base row set by ms_1970_integration_complete_actual::date for BOTH metrics. Outputs: rgn_region, m_area, m_market, construction_gc, avg_cycle_time_days, cycle_time_project_count, total_projects_in_scope, on_air_projects, on_air_completion_rate_pct.', node_type: 'CORE', definition: 'Computes On-Air Cycle Time as the average end-to-end delivery time from construction start (ms_1550_construction_start_actual) to integration complete (ms_1970_integration_complete_actual), in days, using public.stg_ndpd_mbt_tmobile_macro_combined and grouping by rgn_region, m_area, m_market, construction_gc. Cycle time AVG and cycle_time_project_count include only projects where both ms_1970 and ms_1550 dates are present and (ms_1970::date - ms_1550::date) is non-negative (negative durations excluded from cycle time only). Also outputs On-Air Completion Rate (%) as 100.0 * COUNT(DISTINCT pj_project_id with pj_completion_objective_actual_date not null) / NULLIF(COUNT(DISTINCT pj_project_id in scope), 0), unaffected by the non-negative duration rule. Optional denominator_scope=\'entitled\' restricts the base project set to rows with pj_a_3710_ran_entitlement_complete_finish IS NOT NULL. start_date/end_date (when provided) constrain the base row set by ms_1970_integration_complete_actual::date for BOTH metrics. Outputs: rgn_region, m_area, m_market, construction_gc, avg_cycle_time_days, cycle_time_project_count, total_projects_in_scope, on_air_projects, on_air_completion_rate_pct.', kpi_python_function: 'def get_on_air_cycle_time(execute_query, filters=None) -> list[dict]:\n    """On-Air Cycle Time (Construction Start -> Integration Complete) + On-Air Completion Rate.\n\n    Source: public.stg_ndpd_mbt_tmobile_macro_combined\n    Grouped by: rgn_region, m_area, m_market, construction_gc\n\n    Cycle time (days):\n      AVG(CASE WHEN (ms_1970_integration_complete_actual::date - ms_1550_construction_start_actual::date) >= 0\n          THEN (ms_1970_integration_complete_actual::date - ms_1550_construction_start_actual::date) END)::float\n      (excludes negative durations and nulls).\n\n    Cycle time project count:\n      COUNT(DISTINCT pj_project_id) where both ms_1970 and ms_1550 are present AND duration >= 0.\n\n    Completion rate (%):\n      100.0 * COUNT(DISTINCT CASE WHEN pj_completion_objective_actual_date IS NOT NULL THEN pj_project_id END)\n            / NULLIF(COUNT(DISTINCT pj_project_id), 0)\n\n    Denominator scope:\n      - all_active (default): all projects in the filtered set\n      - entitled: only rows with pj_a_3710_ran_entitlement_complete_finish IS NOT NULL (added to WHERE)\n\n    Date filtering:\n      start_date/end_date apply to ms_1970_integration_complete_actual::date for BOTH metrics.\n\n    Allowlisted filters: start_date, end_date, rgn_region, m_area, m_market, gc, denominator_scope\n    """\n\n    filters = filters or {}\n\n    start_date = filters.get(\'start_date\')  # expected YYYY-MM-DD\n    end_date = filters.get(\'end_date\')      # expected YYYY-MM-DD\n    rgn_region = filters.get(\'rgn_region\')\n    m_area = filters.get(\'m_area\')\n    m_market = filters.get(\'m_market\')\n    gc = filters.get(\'gc\')\n    denominator_scope = (filters.get(\'denominator_scope\') or \'all_active\').strip().lower()\n    if denominator_scope not in (\'all_active\', \'entitled\'):\n        denominator_scope = \'all_active\'\n\n    def _esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Seed with defining condition first\n    where_parts = ["1=1"]\n\n    # Date filters apply to ms_1970 for BOTH metrics\n    if start_date:\n        where_parts.append(f"\\"ms_1970_integration_complete_actual\\"::date >= \'{_esc(start_date)}\'::date")\n    if end_date:\n        where_parts.append(f"\\"ms_1970_integration_complete_actual\\"::date <= \'{_esc(end_date)}\'::date")\n\n    if rgn_region:\n        where_parts.append(f"\\"rgn_region\\" = \'{_esc(rgn_region)}\'")\n    if m_area:\n        where_parts.append(f"\\"m_area\\" = \'{_esc(m_area)}\'")\n    if m_market:\n        where_parts.append(f"\\"m_market\\" = \'{_esc(m_market)}\'")\n    if gc:\n        where_parts.append(f"\\"construction_gc\\" = \'{_esc(gc)}\'")\n\n    if denominator_scope == \'entitled\':\n        where_parts.append("\\"pj_a_3710_ran_entitlement_complete_finish\\" IS NOT NULL")\n\n    where_sql = "WHERE " + " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\", "\n        "  \\"m_area\\", "\n        "  \\"m_market\\", "\n        "  \\"construction_gc\\", "\n        "  AVG(CASE WHEN (\\"ms_1970_integration_complete_actual\\"::date - \\"ms_1550_construction_start_actual\\"::date) >= 0 "\n        "      THEN (\\"ms_1970_integration_complete_actual\\"::date - \\"ms_1550_construction_start_actual\\"::date) END)::float AS \\"avg_cycle_time_days\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"ms_1970_integration_complete_actual\\" IS NOT NULL "\n        "        AND \\"ms_1550_construction_start_actual\\" IS NOT NULL "\n        "        AND (\\"ms_1970_integration_complete_actual\\"::date - \\"ms_1550_construction_start_actual\\"::date) >= 0 "\n        "      THEN \\"pj_project_id\\" END) AS \\"cycle_time_project_count\\", "\n        "  COUNT(DISTINCT \\"pj_project_id\\") AS \\"total_projects_in_scope\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"pj_completion_objective_actual_date\\" IS NOT NULL THEN \\"pj_project_id\\" END) AS \\"on_air_projects\\", "\n        "  100.0 * COUNT(DISTINCT CASE WHEN \\"pj_completion_objective_actual_date\\" IS NOT NULL THEN \\"pj_project_id\\" END) "\n        "    / NULLIF(COUNT(DISTINCT \\"pj_project_id\\"), 0) AS \\"on_air_completion_rate_pct\\" "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        f"{where_sql} "\n        "GROUP BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\""\n    )\n\n    return execute_query(sql)\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_id', 'ms_1970_integration_complete_actual', 'ms_1550_construction_start_actual', 'pj_a_3710_ran_entitlement_complete_finish', 'pj_completion_objective_actual_date'], session_id: '69a3d22f26e208edc083a06e', label: 'On-Air Cycle Time', kpi_related_core_node_ids: ['project', 'site'], kpi_relationship_type: 'DERIVED_FROM', kpi_kpi_id: 'd7ffcd7d-93e1-4c31-a9f2-b430e2843f28', entity_type: 'kpi', kpi_name: 'On-Air Cycle Time', name: 'd7ffcd7d-93e1-4c31-a9f2-b430e2843f28', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Average end-to-end delivery time from construction start to the first On-Air milestone.', status: 'mentioned', node_id: 'd7ffcd7d-93e1-4c31-a9f2-b430e2843f28'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'CX to On-Air Lead Time (calendar days) = (ms_1970_integration_complete_actual::date − ms_1550_construction_start_actual::date), computed only when both dates are present and the result is >= 0; summarized by average, P50, P90, and maximum, grouped by rgn_region, m_area, m_market, and construction_gc.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping dimension."}, {"column": "m_area", "type": "string", "description": "Area grouping dimension."}, {"column": "m_market", "type": "string", "description": "Market grouping dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping dimension."}, {"column": "n", "type": "int", "description": "Number of qualifying records in the group."}, {"column": "avg_days", "type": "float", "description": "Average lead time in calendar days."}, {"column": "p50_days", "type": "float", "description": "Median (50th percentile) lead time in calendar days."}, {"column": "p90_days", "type": "float", "description": "90th percentile lead time in calendar days."}, {"column": "max_days", "type": "float", "description": "Maximum lead time in calendar days."}]', kpi_business_logic: '1) Filter rows from public.stg_ndpd_mbt_tmobile_macro_combined where ms_1970_integration_complete_actual is not null and ms_1550_construction_start_actual is not null. 2) Compute day_diff = ms_1970_integration_complete_actual::date - ms_1550_construction_start_actual::date. 3) Exclude rows where day_diff < 0. 4) Apply optional equality filters for rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id, pj_project_status, pj_project_type, pj_program_name. 5) Apply optional start_date/end_date filters to ms_1970_integration_complete_actual::date. 6) Group by rgn_region, m_area, m_market, construction_gc and return n, avg_days, p50_days, p90_days, max_days based on day_diff.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}, {"name": "pj_project_status", "type": "string", "description": ""}, {"name": "pj_project_type", "type": "string", "description": ""}, {"name": "pj_program_name", "type": "string", "description": ""}, {"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_cx_to_on_air_lead_time", "node_type": "kpi", "node_id": "6b91dd88-d284-4ba1-b95a-b66c1ee08d91", "node_label": "CX to On-Air Lead Time", "description": "Measures the calendar-day lead time from construction completion to On-Air for projects that have reached On-Air. This helps quantify how long it takes to progress from construction completion to On-Air and supports monitoring for delays and data quality issues.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "n", "type": "number", "nullable": false}, {"name": "avg_days", "type": "number", "nullable": false}, {"name": "p50_days", "type": "number", "nullable": false}, {"name": "p90_days", "type": "number", "nullable": false}, {"name": "max_days", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'CX to On-Air Lead Time (calendar days) = (ms_1970_integration_complete_actual::date − ms_1550_construction_start_actual::date), computed only when both dates are present and the result is >= 0; summarized by average, P50, P90, and maximum, grouped by rgn_region, m_area, m_market, and construction_gc.', node_type: 'CORE', definition: 'CX to On-Air Lead Time (calendar days) = (ms_1970_integration_complete_actual::date − ms_1550_construction_start_actual::date), computed only when both dates are present and the result is >= 0; summarized by average, P50, P90, and maximum, grouped by rgn_region, m_area, m_market, and construction_gc.', kpi_python_function: 'def get_cx_to_on_air_lead_time(execute_query, filters=None) -> list[dict]:\n    """CX to On-Air Lead Time distribution by (rgn_region, m_area, m_market, construction_gc).\n\n    Lead time (calendar days) = (ms_1970_integration_complete_actual::date - ms_1550_construction_start_actual::date)\n    where both dates are not null and diff >= 0.\n\n    Returns list of dicts with avg_days, p50_days, p90_days, max_days, n.\n    """\n\n    filters = filters or {}\n\n    def _escape(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Build WHERE clause from provided filters.\n    # Note: start/end_date are applied to ms_1970_integration_complete_actual (Integration Complete) by default.\n    where_parts = [\n        "1=1",\n        "\\"ms_1970_integration_complete_actual\\" IS NOT NULL",\n        "\\"ms_1550_construction_start_actual\\" IS NOT NULL",\n        "(\\"ms_1970_integration_complete_actual\\"::date - \\"ms_1550_construction_start_actual\\"::date) >= 0"\n    ]\n\n    # Common dimensional filters\n    passthrough_keys = [\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "pj_project_id",\n        "s_site_id",\n        "pj_project_status",\n        "pj_project_type",\n        "pj_program_name"\n    ]\n\n    # Explicit allowlist mapping to quoted SQL columns\n    allowed_filter_columns = {\n        "rgn_region": "\\"rgn_region\\"",\n        "m_area": "\\"m_area\\"",\n        "m_market": "\\"m_market\\"",\n        "construction_gc": "\\"construction_gc\\"",\n        "pj_project_id": "\\"pj_project_id\\"",\n        "s_site_id": "\\"s_site_id\\"",\n        "pj_project_status": "\\"pj_project_status\\"",\n        "pj_project_type": "\\"pj_project_type\\"",\n        "pj_program_name": "\\"pj_program_name\\""\n    }\n\n    for k in passthrough_keys:\n        v = filters.get(k)\n        if v is not None and v != "":\n            where_parts.append(f"{allowed_filter_columns[k]} = \'{_escape(v)}\'")\n\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n    if start_date:\n        where_parts.append(f"\\"ms_1970_integration_complete_actual\\"::date >= \'{_escape(start_date)}\'::date")\n    if end_date:\n        where_parts.append(f"\\"ms_1970_integration_complete_actual\\"::date <= \'{_escape(end_date)}\'::date")\n\n    where_sql = " WHERE " + " AND ".join(where_parts)\n\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\", "\n        "  \\"m_area\\", "\n        "  \\"m_market\\", "\n        "  \\"construction_gc\\", "\n        "  COUNT(*) AS n, "\n        "  AVG((\\"ms_1970_integration_complete_actual\\"::date - \\"ms_1550_construction_start_actual\\"::date))::double precision AS avg_days, "\n        "  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY (\\"ms_1970_integration_complete_actual\\"::date - \\"ms_1550_construction_start_actual\\"::date))::double precision AS p50_days, "\n        "  PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY (\\"ms_1970_integration_complete_actual\\"::date - \\"ms_1550_construction_start_actual\\"::date))::double precision AS p90_days, "\n        "  MAX((\\"ms_1970_integration_complete_actual\\"::date - \\"ms_1550_construction_start_actual\\"::date))::double precision AS max_days "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined"\n        + where_sql +\n        " GROUP BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\" "\n        " ORDER BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\""\n    )\n\n    return execute_query(sql)\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_id', 's_site_id', 'pj_project_status', 'pj_project_type', 'pj_program_name', 'ms_1970_integration_complete_actual', 'ms_1550_construction_start_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'CX to On-Air Lead Time', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '6b91dd88-d284-4ba1-b95a-b66c1ee08d91', entity_type: 'kpi', kpi_name: 'CX to On-Air Lead Time', name: '6b91dd88-d284-4ba1-b95a-b66c1ee08d91', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Measures the calendar-day lead time from construction completion to On-Air for projects that have reached On-Air. This helps quantify how long it takes to progress from construction completion to On-Air and supports monitoring for delays and data quality issues.', status: 'mentioned', node_id: '6b91dd88-d284-4ba1-b95a-b66c1ee08d91'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Grouped by (rgn_region, m_area, m_market, construction_gc): Plan Achievement % = 100 * distinct(pj_project_id with ms_1550_construction_start_actual and ms_1555_construction_complete_actual) / distinct(pj_project_id with ms_1550_construction_start_actual); Avg CX Cycle Days = AVG(ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) where both present; FTR Rate % = 100 * distinct(pj_project_id with ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl present and first_time_right normalized to \'yes\') / distinct(pj_project_id with ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl present); Active Backlog (WIP) = distinct(pj_project_id with ms_1550_construction_start_actual present and ms_1555_construction_complete_actual null); On-Air Pending = distinct(pj_project_id with ms_1555_construction_complete_actual present and pj_completion_objective_actual_date null). Denominator=0 => NULL.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region."}, {"column": "m_area", "type": "string", "description": "Area."}, {"column": "m_market", "type": "string", "description": "Market."}, {"column": "construction_gc", "type": "string", "description": "General contractor."}, {"column": "plan_achievement_pct", "type": "float", "description": "Percent of distinct projects with construction start actual that also have construction complete actual."}, {"column": "avg_cx_cycle_days", "type": "float", "description": "Average days between construction start actual date and construction complete actual date for projects with both dates present."}, {"column": "ftr_rate_pct", "type": "float", "description": "Percent of distinct audited projects that are marked first_time_right=\'Yes\'."}, {"column": "active_backlog_wip", "type": "int", "description": "Count of distinct projects started (construction start actual present) but not completed (construction complete actual null)."}, {"column": "on_air_pending", "type": "int", "description": "Count of distinct projects with construction complete actual present but missing pj_completion_objective_actual_date."}]', kpi_business_logic: '1) Query public.stg_ndpd_mbt_tmobile_macro_combined for the grouping dimensions (rgn_region, m_area, m_market, construction_gc) plus pj_project_id and milestone/date fields ms_1550_construction_start_actual, ms_1555_construction_complete_actual, ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl, pj_completion_objective_actual_date, and first_time_right, applying an explicit allowlist of filters and an optional date range on an allowlisted date_field. WHERE is always seeded with 1=1.\n2) Separately query the same table (same WHERE) to compute cx_cycle_days per pj_project_id as (ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date).\n3) Group rows by (rgn_region, m_area, m_market, construction_gc) in Python.\n4) For each group compute distinct-project sets:\n   - Plan denominator: pj_project_id where ms_1550_construction_start_actual is not null.\n   - Plan numerator: pj_project_id where both ms_1550 and ms_1555 are not null.\n   - FTR denominator: pj_project_id where ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl is not null.\n   - FTR numerator: subset of FTR denominator where first_time_right, after str().strip().lower(), equals \'yes\'.\n   - WIP: pj_project_id where ms_1550 not null and ms_1555 is null.\n   - On-air pending: pj_project_id where ms_1555 not null and pj_completion_objective_actual_date is null.\n5) Compute metrics per group:\n   - plan_achievement_pct = 100 * numerator / denominator else NULL if denominator=0.\n   - avg_cx_cycle_days = average of cx_cycle_days for projects with both ms_1550 and ms_1555 else NULL if none.\n   - ftr_rate_pct = 100 * numerator / denominator else NULL if denominator=0.\n   - active_backlog_wip = count of distinct WIP projects.\n   - on_air_pending = count of distinct on-air-pending projects.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": "Filter to a specific region (exact match)."}, {"name": "m_area", "type": "string", "description": "Filter to a specific area (exact match)."}, {"name": "m_market", "type": "string", "description": "Filter to a specific market (exact match)."}, {"name": "construction_gc", "type": "string", "description": "Filter to a specific general contractor (exact match)."}, {"name": "pj_project_id", "type": "string", "description": "Filter to a specific project id (exact match)."}, {"name": "s_site_id", "type": "string", "description": "Filter to a specific site id (exact match)."}, {"name": "pj_project_status", "type": "string", "description": "Filter to a specific project status (exact match)."}, {"name": "pj_project_type", "type": "string", "description": "Filter to a specific project type (exact match)."}, {"name": "pj_program_name", "type": "string", "description": "Filter to a specific program name (exact match)."}, {"name": "date_field", "type": "string", "description": "Which allowlisted date field to apply the start_date/end_date filter to. One of: ms_1550_construction_start_actual, ms_1555_construction_complete_actual, ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl, pj_completion_objective_actual_date."}, {"name": "start_date", "type": "string", "description": "Inclusive start date (YYYY-MM-DD) applied to date_field (cast via ::date, including for text-stored dates)."}, {"name": "end_date", "type": "string", "description": "Inclusive end date (YYYY-MM-DD) applied to date_field (cast via ::date, including for text-stored dates)."}]', kpi_contract: '{"function_name": "get_gc_performance_scorecard", "node_type": "kpi", "node_id": "78408ea3-bf9e-4caa-8516-b7f6d0bf5f68", "node_label": "GC Performance Scorecard", "description": "Composite vendor scorecard to compare General Contractors on delivery, speed, quality, and backlog health for weekly planning and vendor volume allocation.", "parameters": [{"name": "date_field", "type": "date", "description": "Filter by date field", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "plan_achievement_pct", "type": "number", "nullable": true}, {"name": "avg_cx_cycle_days", "type": "number", "nullable": true}, {"name": "ftr_rate_pct", "type": "null", "nullable": true}, {"name": "active_backlog_wip", "type": "number", "nullable": false}, {"name": "on_air_pending", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Grouped by (rgn_region, m_area, m_market, construction_gc): Plan Achievement % = 100 * distinct(pj_project_id with ms_1550_construction_start_actual and ms_1555_construction_complete_actual) / distinct(pj_project_id with ms_1550_construction_start_actual); Avg CX Cycle Days = AVG(ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) where both present; FTR Rate % = 100 * distinct(pj_project_id with ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl present and first_time_right normalized to \'yes\') / distinct(pj_project_id with ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl present); Active Backlog (WIP) = distinct(pj_project_id with ms_1550_construction_start_actual present and ms_1555_construction_complete_actual null); On-Air Pending = distinct(pj_project_id with ms_1555_construction_complete_actual present and pj_completion_objective_actual_date null). Denominator=0 => NULL.', node_type: 'CORE', definition: 'Grouped by (rgn_region, m_area, m_market, construction_gc): Plan Achievement % = 100 * distinct(pj_project_id with ms_1550_construction_start_actual and ms_1555_construction_complete_actual) / distinct(pj_project_id with ms_1550_construction_start_actual); Avg CX Cycle Days = AVG(ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date) where both present; FTR Rate % = 100 * distinct(pj_project_id with ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl present and first_time_right normalized to \'yes\') / distinct(pj_project_id with ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl present); Active Backlog (WIP) = distinct(pj_project_id with ms_1550_construction_start_actual present and ms_1555_construction_complete_actual null); On-Air Pending = distinct(pj_project_id with ms_1555_construction_complete_actual present and pj_completion_objective_actual_date null). Denominator=0 => NULL.', kpi_python_function: 'def get_gc_performance_scorecard(execute_query, filters=None) -> list[dict]:\n    """Composite GC scorecard grouped by (rgn_region, m_area, m_market, construction_gc).\n\n    Measures:\n      1) plan_achievement_pct\n      2) avg_cx_cycle_days\n      3) ftr_rate_pct\n      4) active_backlog_wip\n      5) on_air_pending\n\n    Notes:\n      - NULL-safe denominators: return None when denominator == 0.\n      - Uses raw SQL because required columns (milestone dates, first_time_right)\n        are not exposed by the current accessor return columns.\n      - FTR denominator uses punch checklist reviewed and submitted to T-Mobile milestone\n        (ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl).\n    """\n\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Explicit allowlist of filterable columns\n    allowed_filters = {\n        \'rgn_region\', \'m_area\', \'m_market\', \'construction_gc\', \'pj_project_id\', \'s_site_id\',\n        \'pj_project_status\', \'pj_project_type\', \'pj_program_name\'\n    }\n\n    # WHERE clause must be seeded with 1=1\n    where_parts = ["1=1"]\n\n    for k in [\n        \'rgn_region\', \'m_area\', \'m_market\', \'construction_gc\', \'pj_project_id\', \'s_site_id\',\n        \'pj_project_status\', \'pj_project_type\', \'pj_program_name\'\n    ]:\n        if k in allowed_filters and filters.get(k) is not None:\n            where_parts.append(f"\\"{k}\\" = \'{esc(filters.get(k))}\'")\n\n    # Date range filtering (optional). Apply to construction start actual by default.\n    # If you need alternate behavior (e.g., filter by completion date), pass filters[\'date_field\'].\n    allowed_date_fields = {\n        \'ms_1550_construction_start_actual\',\n        \'ms_1555_construction_complete_actual\',\n        \'ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl\',\n        \'pj_completion_objective_actual_date\'\n    }\n    date_field = filters.get(\'date_field\') or \'ms_1550_construction_start_actual\'\n    if date_field not in allowed_date_fields:\n        date_field = \'ms_1550_construction_start_actual\'\n\n    if filters.get(\'start_date\'):\n        where_parts.append(f"\\"{date_field}\\"::date >= \'{esc(filters.get(\'start_date\'))}\'::date")\n    if filters.get(\'end_date\'):\n        where_parts.append(f"\\"{date_field}\\"::date <= \'{esc(filters.get(\'end_date\'))}\'::date")\n\n    where_sql = "WHERE " + " AND ".join(where_parts)\n\n    sql = f"""\n        SELECT\n            "rgn_region",\n            "m_area",\n            "m_market",\n            "construction_gc",\n            "pj_project_id",\n            "ms_1550_construction_start_actual",\n            "ms_1555_construction_complete_actual",\n            "ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl",\n            "first_time_right",\n            "pj_completion_objective_actual_date"\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        {where_sql}\n    """\n\n    rows = execute_query(sql)\n\n    # Compute cycle days via SQL (still one table; no joins)\n    sql_cycle = f"""\n        SELECT\n            "pj_project_id",\n            ("ms_1555_construction_complete_actual"::date - "ms_1550_construction_start_actual"::date) AS "cx_cycle_days"\n        FROM public.stg_ndpd_mbt_tmobile_macro_combined\n        {where_sql}\n    """\n    cycle_rows = execute_query(sql_cycle)\n    cycle_by_project = {r.get(\'pj_project_id\'): r.get(\'cx_cycle_days\') for r in cycle_rows}\n\n    # Group and aggregate in Python\n    groups = {}\n\n    for r in rows:\n        key = (\n            r.get(\'rgn_region\'),\n            r.get(\'m_area\'),\n            r.get(\'m_market\'),\n            r.get(\'construction_gc\')\n        )\n        if key not in groups:\n            groups[key] = {\n                \'rgn_region\': r.get(\'rgn_region\'),\n                \'m_area\': r.get(\'m_area\'),\n                \'m_market\': r.get(\'m_market\'),\n                \'construction_gc\': r.get(\'construction_gc\'),\n                # sets for distinct counts\n                \'_plan_den\': set(),\n                \'_plan_num\': set(),\n                \'_ftr_den\': set(),\n                \'_ftr_num\': set(),\n                \'_wip\': set(),\n                \'_on_air_pending\': set(),\n                # cycle days\n                \'_cycle_sum\': 0.0,\n                \'_cycle_cnt\': 0\n            }\n\n        g = groups[key]\n        pid = r.get(\'pj_project_id\')\n        if not pid:\n            continue\n\n        start_actual = r.get(\'ms_1550_construction_start_actual\')\n        complete_actual = r.get(\'ms_1555_construction_complete_actual\')\n        punch_reviewed_submitted_tm = r.get(\'ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl\')\n        ftr = r.get(\'first_time_right\')\n        completion_objective_actual = r.get(\'pj_completion_objective_actual_date\')\n\n        # (1) Plan Achievement %\n        if start_actual is not None:\n            g[\'_plan_den\'].add(pid)\n            if complete_actual is not None:\n                g[\'_plan_num\'].add(pid)\n\n        # (2) Avg CX Cycle Days\n        if (start_actual is not None) and (complete_actual is not None):\n            cd = cycle_by_project.get(pid)\n            if cd is not None:\n                try:\n                    g[\'_cycle_sum\'] += float(cd)\n                    g[\'_cycle_cnt\'] += 1\n                except Exception:\n                    pass\n\n        # (3) FTR Rate %\n        # Denominator: punch checklist reviewed and submitted to T-Mobile present\n        if punch_reviewed_submitted_tm is not None:\n            g[\'_ftr_den\'].add(pid)\n            if str(ftr).strip().lower() == \'yes\':\n                g[\'_ftr_num\'].add(pid)\n\n        # (4) Active Backlog (WIP)\n        if (start_actual is not None) and (complete_actual is None):\n            g[\'_wip\'].add(pid)\n\n        # (5) On-Air Pending\n        if (complete_actual is not None) and (completion_objective_actual is None):\n            g[\'_on_air_pending\'].add(pid)\n\n    out = []\n    for _, g in groups.items():\n        plan_den = len(g[\'_plan_den\'])\n        plan_num = len(g[\'_plan_num\'])\n        ftr_den = len(g[\'_ftr_den\'])\n        ftr_num = len(g[\'_ftr_num\'])\n\n        plan_pct = (100.0 * plan_num / plan_den) if plan_den > 0 else None\n        ftr_pct = (100.0 * ftr_num / ftr_den) if ftr_den > 0 else None\n        avg_cycle = (g[\'_cycle_sum\'] / g[\'_cycle_cnt\']) if g[\'_cycle_cnt\'] > 0 else None\n\n        out.append({\n            \'rgn_region\': g[\'rgn_region\'],\n            \'m_area\': g[\'m_area\'],\n            \'m_market\': g[\'m_market\'],\n            \'construction_gc\': g[\'construction_gc\'],\n            \'plan_achievement_pct\': plan_pct,\n            \'avg_cx_cycle_days\': avg_cycle,\n            \'ftr_rate_pct\': ftr_pct,\n            \'active_backlog_wip\': len(g[\'_wip\']),\n            \'on_air_pending\': len(g[\'_on_air_pending\'])\n        })\n\n    return out\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_id', 's_site_id', 'pj_project_status', 'pj_project_type', 'pj_program_name', 'ms_1550_construction_start_actual', 'ms_1555_construction_complete_actual', 'ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl', 'first_time_right', 'pj_completion_objective_actual_date'], session_id: '69a3d22f26e208edc083a06e', label: 'GC Performance Scorecard', kpi_related_core_node_ids: ['project', 'site', 'general_contractor'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '78408ea3-bf9e-4caa-8516-b7f6d0bf5f68', entity_type: 'kpi', kpi_name: 'GC Performance Scorecard', name: '78408ea3-bf9e-4caa-8516-b7f6d0bf5f68', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Composite vendor scorecard to compare General Contractors on delivery, speed, quality, and backlog health for weekly planning and vendor volume allocation.', status: 'mentioned', node_id: '78408ea3-bf9e-4caa-8516-b7f6d0bf5f68'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Per project: CX Cycle Time (calendar days) is computed using a coherent source fallback. If both Magenta milestones exist, CX Cycle Time = construction complete (pj_a_5175_construction_complete_finish, Magenta MS 5175)::date − construction start (pj_a_4225_construction_start_finish, Magenta MS 4225)::date. Otherwise, if both NDPd milestones exist, CX Cycle Time = ms_1555_construction_complete_actual::date − ms_1550_construction_start_actual::date. Projects with neither full pair are excluded, and negative durations are excluded. SLA: sla_threshold_days is pj_expected_cx_cycle_time cast to numeric when parseable; otherwise default_sla_days (filter, default 21). Classify each project as \'Out of SLA\' when CX Cycle Time > sla_threshold_days else \'In SLA\'. Publish grouped aggregates by rgn_region, m_area, m_market, construction_gc, por_category, s_site_class, source_system: project_count, AVG/P50/P90/MAX of CX Cycle Time plus sla_compliant_count and sla_compliance_rate_pct.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping dimension."}, {"column": "m_area", "type": "string", "description": "Area grouping dimension."}, {"column": "m_market", "type": "string", "description": "Market grouping dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping dimension."}, {"column": "por_category", "type": "string", "description": "Optional slice dimension for POR category."}, {"column": "s_site_class", "type": "string", "description": "Optional slice dimension for site class."}, {"column": "project_count", "type": "int", "description": "Number of projects in the group."}, {"column": "avg_cx_cycle_days", "type": "float", "description": "Average construction cycle time in days for the group."}, {"column": "p50_cx_cycle_days", "type": "float", "description": "Median (P50) construction cycle time in days for the group."}, {"column": "p90_cx_cycle_days", "type": "float", "description": "90th percentile construction cycle time in days for the group."}, {"column": "max_cx_cycle_days", "type": "int", "description": "Maximum construction cycle time in days for the group."}]', kpi_business_logic: 'Seed WHERE with 1=1.\nKeep only rows where either the full Magenta milestone pair is present (pj_a_4225 and pj_a_5175 both non-null) OR the full NDPd milestone pair is present (ms_1550 and ms_1555 both non-null).\nCompute cx_cycle_days using COALESCE of two CASE expressions: use Magenta date difference when both Magenta dates exist; else use NDPd date difference when both NDPd dates exist. Do not mix systems.\nExclude rows where cx_cycle_days < 0.\nCompute effective completion date using the same coherent fallback (Magenta completion when Magenta pair used; else NDPd completion) and apply start_date/end_date filters against it.\nApply optional equality filters for pj_project_id, s_site_id, rgn_region, m_area, m_market, construction_gc, por_category, s_site_class.\nDerive source_system per row: \'Magenta\' when Magenta pair exists; else \'NDPd\' when NDPd pair exists.\nCompute sla_threshold_days: cast pj_expected_cx_cycle_time to numeric when parseable by regex; otherwise use default_sla_days (default 21).\nCompute sla_classification per row: \'Out of SLA\' if cx_cycle_days > sla_threshold_days else \'In SLA\'.\nAggregate by rgn_region, m_area, m_market, construction_gc, por_category, s_site_class, source_system to compute project_count, avg/p50/p90/max cx_cycle_days, sla_compliant_count, and sla_compliance_rate_pct.', kpi_filters: '[{"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "por_category", "type": "string", "description": ""}, {"name": "s_site_class", "type": "string", "description": ""}, {"name": "default_sla_days", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_cx_cycle_time", "node_type": "kpi", "node_id": "3c1fd435-6d07-4984-9546-45233e3bac72", "node_label": "CX Cycle Time", "description": "Measures the number of calendar days it takes to complete construction for a project/site, from construction start to construction complete. It is used as the primary construction benchmark for planning and capacity modeling.", "parameters": [{"name": "default_sla_days", "type": "string", "description": "Filter by default sla days", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "por_category", "type": "string", "nullable": false}, {"name": "s_site_class", "type": "string", "nullable": false}, {"name": "source_system", "type": "string", "nullable": false}, {"name": "project_count", "type": "number", "nullable": false}, {"name": "avg_cx_cycle_days", "type": "number", "nullable": false}, {"name": "p50_cx_cycle_days", "type": "number", "nullable": false}, {"name": "p90_cx_cycle_days", "type": "number", "nullable": false}, {"name": "max_cx_cycle_days", "type": "number", "nullable": false}, {"name": "sla_compliant_count", "type": "number", "nullable": false}, {"name": "sla_compliance_rate_pct", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Per project: CX Cycle Time (calendar days) is computed using a coherent source fallback. If both Magenta milestones exist, CX Cycle Time = construction complete (pj_a_5175_construction_complete_finish, Magenta MS 5175)::date − construction start (pj_a_4225_construction_start_finish, Magenta MS 4225)::date. Otherwise, if both NDPd milestones exist, CX Cycle Time = ms_1555_construction_complete_actual::date − ms_1550_construction_start_actual::date. Projects with neither full pair are excluded, and negative durations are excluded. SLA: sla_threshold_days is pj_expected_cx_cycle_time cast to numeric when parseable; otherwise default_sla_days (filter, default 21). Classify each project as \'Out of SLA\' when CX Cycle Time > sla_threshold_days else \'In SLA\'. Publish grouped aggregates by rgn_region, m_area, m_market, construction_gc, por_category, s_site_class, source_system: project_count, AVG/P50/P90/MAX of CX Cycle Time plus sla_compliant_count and sla_compliance_rate_pct.', node_type: 'CORE', definition: 'Per project: CX Cycle Time (calendar days) is computed using a coherent source fallback. If both Magenta milestones exist, CX Cycle Time = construction complete (pj_a_5175_construction_complete_finish, Magenta MS 5175)::date − construction start (pj_a_4225_construction_start_finish, Magenta MS 4225)::date. Otherwise, if both NDPd milestones exist, CX Cycle Time = ms_1555_construction_complete_actual::date − ms_1550_construction_start_actual::date. Projects with neither full pair are excluded, and negative durations are excluded. SLA: sla_threshold_days is pj_expected_cx_cycle_time cast to numeric when parseable; otherwise default_sla_days (filter, default 21). Classify each project as \'Out of SLA\' when CX Cycle Time > sla_threshold_days else \'In SLA\'. Publish grouped aggregates by rgn_region, m_area, m_market, construction_gc, por_category, s_site_class, source_system: project_count, AVG/P50/P90/MAX of CX Cycle Time plus sla_compliant_count and sla_compliance_rate_pct.', kpi_python_function: 'def get_cx_cycle_time(execute_query, filters=None) -> list[dict]:\n    """CX Cycle Time + SLA Compliance (Magenta preferred; NDPd fallback)\n\n    Per-project CX Cycle Time (calendar days) uses a coherent source fallback:\n      1) If BOTH Magenta milestones are present, use:\n         pj_a_5175_construction_complete_finish::date - pj_a_4225_construction_start_finish::date\n      2) Else if BOTH NDPd milestones are present, use:\n         ms_1555_construction_complete_actual::date - ms_1550_construction_start_actual::date\n      3) Else exclude the project.\n\n    Adds per-project source_system (\'Magenta\' or \'NDPd\') and publishes grouped aggregates:\n      - project_count\n      - avg, p50 (median), p90, max of cx_cycle_days\n      - sla_compliant_count and sla_compliance_rate_pct\n\n    SLA logic per project:\n      sla_threshold_days = numeric value parsed from pj_expected_cx_cycle_time when parseable;\n                          else fallback to filters[\'default_sla_days\'] (default 21)\n      sla_classification = \'Out of SLA\' if cx_cycle_days > sla_threshold_days else \'In SLA\'\n\n    Inclusion criteria (project rows):\n      - at least one full milestone pair exists (Magenta pair OR NDPd pair)\n      - cx_cycle_days >= 0 (computed from the coherent fallback)\n\n    Group-by dimensions (fixed set):\n      rgn_region, m_area, m_market, construction_gc, por_category, s_site_class, source_system\n\n    Filters (allowlist):\n      - start_date/end_date: applied to the effective completion date (Magenta completion when Magenta pair used; else NDPd completion)\n      - pj_project_id, s_site_id, rgn_region, m_area, m_market, construction_gc, por_category, s_site_class\n      - default_sla_days (integer; default 21)\n    """\n\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    try:\n        default_sla_days = int(filters.get("default_sla_days", 21))\n    except Exception:\n        default_sla_days = 21\n\n    # Coherent fallback expressions (must be used everywhere cycle days / completion date are referenced)\n    cycle_days_expr = """COALESCE(\n      CASE WHEN "pj_a_5175_construction_complete_finish" IS NOT NULL\n            AND "pj_a_4225_construction_start_finish" IS NOT NULL\n           THEN "pj_a_5175_construction_complete_finish"::date - "pj_a_4225_construction_start_finish"::date\n      END,\n      CASE WHEN "ms_1555_construction_complete_actual" IS NOT NULL\n            AND "ms_1550_construction_start_actual" IS NOT NULL\n           THEN "ms_1555_construction_complete_actual"::date - "ms_1550_construction_start_actual"::date\n      END\n    )"""\n\n    effective_complete_date_expr = """COALESCE(\n      CASE WHEN "pj_a_5175_construction_complete_finish" IS NOT NULL\n            AND "pj_a_4225_construction_start_finish" IS NOT NULL\n           THEN "pj_a_5175_construction_complete_finish"::date\n      END,\n      CASE WHEN "ms_1555_construction_complete_actual" IS NOT NULL\n            AND "ms_1550_construction_start_actual" IS NOT NULL\n           THEN "ms_1555_construction_complete_actual"::date\n      END\n    )"""\n\n    # Seed WHERE with 1=1, then metric-defining conditions\n    where_parts = [\n        "1=1",\n        "((\\"pj_a_5175_construction_complete_finish\\" IS NOT NULL AND \\"pj_a_4225_construction_start_finish\\" IS NOT NULL) OR (\\"ms_1555_construction_complete_actual\\" IS NOT NULL AND \\"ms_1550_construction_start_actual\\" IS NOT NULL))",\n        f"({cycle_days_expr}) >= 0",\n    ]\n\n    # Date range applied to effective completion date (completion from the same system used for cx_cycle_days)\n    if filters.get("start_date"):\n        where_parts.append(f"({effective_complete_date_expr}) >= \'{esc(filters[\'start_date\'])}\'")\n    if filters.get("end_date"):\n        where_parts.append(f"({effective_complete_date_expr}) <= \'{esc(filters[\'end_date\'])}\'")\n\n    # Optional dimensional filters (explicit allowlist)\n    for col in [\n        "pj_project_id",\n        "s_site_id",\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "por_category",\n        "s_site_class",\n    ]:\n        if filters.get(col) is not None:\n            where_parts.append(f\'"{col}" = \\\'{esc(filters[col])}\\\'\')\n\n    where_sql = " AND ".join(where_parts)\n\n    sql = f"""\n    SELECT\n      b."rgn_region",\n      b."m_area",\n      b."m_market",\n      b."construction_gc",\n      b."por_category",\n      b."s_site_class",\n      b."source_system",\n      COUNT(DISTINCT b."pj_project_id")::int AS project_count,\n      AVG(b."cx_cycle_days")::float AS avg_cx_cycle_days,\n      PERCENTILE_CONT(0.50) WITHIN GROUP (ORDER BY b."cx_cycle_days") AS p50_cx_cycle_days,\n      PERCENTILE_CONT(0.90) WITHIN GROUP (ORDER BY b."cx_cycle_days") AS p90_cx_cycle_days,\n      MAX(b."cx_cycle_days")::int AS max_cx_cycle_days,\n      COUNT(DISTINCT CASE WHEN b."cx_cycle_days" <= b."sla_threshold_days" THEN b."pj_project_id" END)::int AS sla_compliant_count,\n      (\n        100.0\n        * COUNT(DISTINCT CASE WHEN b."cx_cycle_days" <= b."sla_threshold_days" THEN b."pj_project_id" END)\n        / NULLIF(COUNT(DISTINCT b."pj_project_id"), 0)\n      )::float AS sla_compliance_rate_pct\n    FROM (\n      SELECT\n        "pj_project_id",\n        "s_site_id",\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "por_category",\n        "s_site_class",\n        CASE\n          WHEN "pj_a_5175_construction_complete_finish" IS NOT NULL\n           AND "pj_a_4225_construction_start_finish" IS NOT NULL THEN \'Magenta\'\n          WHEN "ms_1555_construction_complete_actual" IS NOT NULL\n           AND "ms_1550_construction_start_actual" IS NOT NULL THEN \'NDPd\'\n          ELSE NULL\n        END AS source_system,\n        ({cycle_days_expr}) AS cx_cycle_days,\n        CASE\n          WHEN "pj_expected_cx_cycle_time" IS NOT NULL\n               AND "pj_expected_cx_cycle_time" ~ \'^[0-9]+(\\\\.[0-9]+)?$\'\n            THEN "pj_expected_cx_cycle_time"::numeric\n          ELSE {default_sla_days}::numeric\n        END AS sla_threshold_days,\n        CASE\n          WHEN ({cycle_days_expr})\n               >\n               (CASE\n                  WHEN "pj_expected_cx_cycle_time" IS NOT NULL\n                       AND "pj_expected_cx_cycle_time" ~ \'^[0-9]+(\\\\.[0-9]+)?$\'\n                    THEN "pj_expected_cx_cycle_time"::numeric\n                  ELSE {default_sla_days}::numeric\n                END)\n            THEN \'Out of SLA\'\n          ELSE \'In SLA\'\n        END AS sla_classification\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\n      WHERE {where_sql}\n    ) b\n    GROUP BY 1,2,3,4,5,6,7\n    ORDER BY 1,2,3,4,5,6,7\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['pj_project_id', 's_site_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 's_site_class', 'pj_a_5175_construction_complete_finish', 'pj_a_4225_construction_start_finish', 'ms_1555_construction_complete_actual', 'ms_1550_construction_start_actual', 'pj_expected_cx_cycle_time'], session_id: '69a3d22f26e208edc083a06e', label: 'CX Cycle Time', kpi_related_core_node_ids: ['project', 'site'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: '3c1fd435-6d07-4984-9546-45233e3bac72', entity_type: 'kpi', kpi_name: 'CX Cycle Time', name: '3c1fd435-6d07-4984-9546-45233e3bac72', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 's_site_class', 'source_system'], kpi_description: 'Measures the number of calendar days it takes to complete construction for a project/site, from construction start to construction complete. It is used as the primary construction benchmark for planning and capacity modeling.', status: 'mentioned', node_id: '3c1fd435-6d07-4984-9546-45233e3bac72'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Civil Cycle Time (days) per project is computed as COALESCE( (pj_a_4750_civil_construction_complete_finish::date − pj_a_4250_civil_construction_start_finish::date) when both Magenta dates are present, otherwise (ms_1551_civil_construction_complete_actual_date::date − ms_1549_civil_construction_start_actual::date) when both NDPd dates are present ). Projects with neither complete+start pair populated are excluded, and negative durations are excluded. Output aggregates (COUNT, AVG, P50, P90, MAX) grouped by rgn_region, m_area, m_market, construction_gc, and source_system (Magenta vs NDPd), plus optional por_category and/or s_site_class when enabled.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping field."}, {"column": "m_area", "type": "string", "description": "Area grouping field."}, {"column": "m_market", "type": "string", "description": "Market grouping field."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping field."}, {"column": "por_category", "type": "string", "description": "Optional grouping field when enabled."}, {"column": "s_site_class", "type": "string", "description": "Optional grouping field when enabled."}, {"column": "project_count", "type": "int", "description": "Number of projects (rows) included in the group after filters."}, {"column": "avg_civil_cycle_days", "type": "float", "description": "Average civil cycle time in days for the group."}, {"column": "median_p50_civil_cycle_days", "type": "float", "description": "Median (P50) civil cycle time in days for the group."}, {"column": "p90_civil_cycle_days", "type": "float", "description": "90th percentile civil cycle time in days for the group."}, {"column": "max_civil_cycle_days", "type": "int", "description": "Maximum civil cycle time in days for the group."}]', kpi_business_logic: 'Seed WHERE clause with 1=1, require confirm_split_spo IS NOT NULL.\nInclude a project only if either: (Magenta complete AND Magenta start) are both non-null, OR (NDPd complete AND NDPd start) are both non-null.\nCompute civil_cycle_days using the required COALESCE(CASE Magenta..., CASE NDPd...) expression; this ensures a project uses Magenta dates together or NDPd dates together, never mixed.\nExclude records where the computed civil_cycle_days is negative.\nDerive source_system as \'Magenta\' when the Magenta pair is present, else \'NDPd\' when the NDPd pair is present.\nApply optional date filters (start_date/end_date) to the effective completion date: Magenta complete date when Magenta pair is present, else NDPd complete date.\nApply optional equality filters for rgn_region, m_area, m_market, construction_gc, por_category, s_site_class.\nAggregate by rgn_region, m_area, m_market, construction_gc, source_system (+ optional por_category / s_site_class) and return project_count, avg, p50, p90, max of civil_cycle_days.', kpi_filters: '[{"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "por_category", "type": "string", "description": ""}, {"name": "s_site_class", "type": "string", "description": ""}, {"name": "group_by_por_category", "type": "string", "description": ""}, {"name": "group_by_site_class", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_civil_cycle_time", "node_type": "kpi", "node_id": "b91a6e98-8c3f-4fae-a943-003665793220", "node_label": "Civil Cycle Time", "description": "Measures the civil construction cycle time in calendar days for split-scope/civil-confirmed sites, used to monitor performance against the civil SLA target (<= 21 days). Results are summarized by market and general contractor (and related regional rollups).", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}, {"name": "group_by_por_category", "type": "string", "description": "Filter by group by por category", "required": false, "sample_values": []}, {"name": "group_by_site_class", "type": "string", "description": "Filter by group by site class", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "source_system", "type": "string", "nullable": false}, {"name": "project_count", "type": "number", "nullable": false}, {"name": "avg_civil_cycle_days", "type": "string", "nullable": false}, {"name": "median_p50_civil_cycle_days", "type": "number", "nullable": false}, {"name": "p90_civil_cycle_days", "type": "number", "nullable": false}, {"name": "max_civil_cycle_days", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Civil Cycle Time (days) per project is computed as COALESCE( (pj_a_4750_civil_construction_complete_finish::date − pj_a_4250_civil_construction_start_finish::date) when both Magenta dates are present, otherwise (ms_1551_civil_construction_complete_actual_date::date − ms_1549_civil_construction_start_actual::date) when both NDPd dates are present ). Projects with neither complete+start pair populated are excluded, and negative durations are excluded. Output aggregates (COUNT, AVG, P50, P90, MAX) grouped by rgn_region, m_area, m_market, construction_gc, and source_system (Magenta vs NDPd), plus optional por_category and/or s_site_class when enabled.', node_type: 'CORE', definition: 'Civil Cycle Time (days) per project is computed as COALESCE( (pj_a_4750_civil_construction_complete_finish::date − pj_a_4250_civil_construction_start_finish::date) when both Magenta dates are present, otherwise (ms_1551_civil_construction_complete_actual_date::date − ms_1549_civil_construction_start_actual::date) when both NDPd dates are present ). Projects with neither complete+start pair populated are excluded, and negative durations are excluded. Output aggregates (COUNT, AVG, P50, P90, MAX) grouped by rgn_region, m_area, m_market, construction_gc, and source_system (Magenta vs NDPd), plus optional por_category and/or s_site_class when enabled.', kpi_python_function: 'def get_civil_cycle_time(execute_query, filters=None) -> list[dict]:\n    """Civil Cycle Time (calendar days) for split-scope/civil-confirmed sites.\n\n    Computes cycle days per project using Magenta milestones when both Magenta dates\n    are present; otherwise falls back to NDPd milestones when both NDPd dates are present.\n    Never mixes systems within a project.\n\n    Returns one row per grouping with avg/median/p90/max/count of civil cycle days.\n\n    Expected optional filters keys (all optional):\n      - start_date, end_date: applied to the *effective completion date* (Magenta complete when present, else NDPd complete)\n      - rgn_region, m_area, m_market, construction_gc\n      - por_category, s_site_class\n\n    Optional grouping flags:\n      - group_by_por_category (bool)\n      - group_by_site_class (bool)\n\n    Notes:\n      - Uses raw SQL because the needed milestone columns are not exposed by Tier-1 accessors.\n      - Postgres date math: (complete_date::date - start_date::date) yields integer days.\n    """\n\n    filters = filters or {}\n\n    def _esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Base WHERE (seeded with 1=1 per platform convention)\n    where_parts = [\n        "1=1",\n        "\\"confirm_split_spo\\" IS NOT NULL",\n        # Inclusion check: require either the full Magenta pair OR the full NDPd pair\n        "(\\n          (\\"pj_a_4750_civil_construction_complete_finish\\" IS NOT NULL AND \\"pj_a_4250_civil_construction_start_finish\\" IS NOT NULL)\\n          OR\\n          (\\"ms_1551_civil_construction_complete_actual_date\\" IS NOT NULL AND \\"ms_1549_civil_construction_start_actual\\" IS NOT NULL)\\n        )",\n        # Non-negative duration rule using the exact COALESCE pattern\n        "(\\n          COALESCE(\\n            CASE WHEN \\"pj_a_4750_civil_construction_complete_finish\\" IS NOT NULL\\n                   AND \\"pj_a_4250_civil_construction_start_finish\\" IS NOT NULL\\n                  THEN \\"pj_a_4750_civil_construction_complete_finish\\"::date - \\"pj_a_4250_civil_construction_start_finish\\"::date\\n            END,\\n            CASE WHEN \\"ms_1551_civil_construction_complete_actual_date\\" IS NOT NULL\\n                   AND \\"ms_1549_civil_construction_start_actual\\" IS NOT NULL\\n                  THEN \\"ms_1551_civil_construction_complete_actual_date\\"::date - \\"ms_1549_civil_construction_start_actual\\"::date\\n            END\\n          )\\n        ) >= 0"\n    ]\n\n    # Date range filter on *effective completion date* (per request)\n    effective_completion_date_expr = """(\n      COALESCE(\n        CASE WHEN \\"pj_a_4750_civil_construction_complete_finish\\" IS NOT NULL\n               AND \\"pj_a_4250_civil_construction_start_finish\\" IS NOT NULL\n             THEN \\"pj_a_4750_civil_construction_complete_finish\\"::date\n        END,\n        CASE WHEN \\"ms_1551_civil_construction_complete_actual_date\\" IS NOT NULL\n               AND \\"ms_1549_civil_construction_start_actual\\" IS NOT NULL\n             THEN \\"ms_1551_civil_construction_complete_actual_date\\"::date\n        END\n      )\n    )""".strip()\n\n    if filters.get("start_date"):\n        where_parts.append(f"{effective_completion_date_expr} >= \'{_esc(filters[\'start_date\'])}\'")\n    if filters.get("end_date"):\n        where_parts.append(f"{effective_completion_date_expr} <= \'{_esc(filters[\'end_date\'])}\'")\n\n    # Allowlisted equality filters only (no generic filter loops)\n    eq_filter_allowlist = [\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "por_category",\n        "s_site_class",\n    ]\n    for k in eq_filter_allowlist:\n        if filters.get(k) is not None and filters.get(k) != "":\n            where_parts.append(f"\\"{k}\\" = \'{_esc(filters[k])}\'")\n\n    where_sql = " AND ".join(where_parts)\n\n    # Group-by dimensions (mandatory set + optional)\n    group_dims = ["rgn_region", "m_area", "m_market", "construction_gc", "source_system"]\n    optional_dims = []\n    if filters.get("group_by_por_category"):\n        optional_dims.append("por_category")\n    if filters.get("group_by_site_class"):\n        optional_dims.append("s_site_class")\n\n    group_dims_all = group_dims + optional_dims\n\n    select_dims_sql = ", ".join([f"\\"{d}\\"" for d in group_dims_all]) if group_dims_all else ""\n    group_by_sql = f"GROUP BY {\', \'.join([f\'\\"{d}\\"\' for d in group_dims_all])}" if group_dims_all else ""\n    order_by_sql = f"ORDER BY {\', \'.join([f\'\\"{d}\\"\' for d in group_dims_all])}" if group_dims_all else ""\n\n    select_prefix = (select_dims_sql + ",\\n       ") if select_dims_sql else ""\n\n    sql = f"""\nSELECT\n       {select_prefix}COUNT(*) AS project_count,\n       AVG(\\"civil_cycle_days\\")::numeric(18,2) AS avg_civil_cycle_days,\n       percentile_cont(0.5) WITHIN GROUP (ORDER BY \\"civil_cycle_days\\") AS median_p50_civil_cycle_days,\n       percentile_cont(0.9) WITHIN GROUP (ORDER BY \\"civil_cycle_days\\") AS p90_civil_cycle_days,\n       MAX(\\"civil_cycle_days\\") AS max_civil_cycle_days\nFROM (\n  SELECT\n    \\"rgn_region\\",\n    \\"m_area\\",\n    \\"m_market\\",\n    \\"construction_gc\\",\n    \\"por_category\\",\n    \\"s_site_class\\",\n    CASE\n      WHEN \\"pj_a_4750_civil_construction_complete_finish\\" IS NOT NULL\n       AND \\"pj_a_4250_civil_construction_start_finish\\" IS NOT NULL THEN \'Magenta\'\n      WHEN \\"ms_1551_civil_construction_complete_actual_date\\" IS NOT NULL\n       AND \\"ms_1549_civil_construction_start_actual\\" IS NOT NULL THEN \'NDPd\'\n      ELSE NULL\n    END AS \\"source_system\\",\n    COALESCE(\n      CASE WHEN \\"pj_a_4750_civil_construction_complete_finish\\" IS NOT NULL\n            AND \\"pj_a_4250_civil_construction_start_finish\\" IS NOT NULL\n           THEN \\"pj_a_4750_civil_construction_complete_finish\\"::date - \\"pj_a_4250_civil_construction_start_finish\\"::date\n      END,\n      CASE WHEN \\"ms_1551_civil_construction_complete_actual_date\\" IS NOT NULL\n            AND \\"ms_1549_civil_construction_start_actual\\" IS NOT NULL\n           THEN \\"ms_1551_civil_construction_complete_actual_date\\"::date - \\"ms_1549_civil_construction_start_actual\\"::date\n      END\n    ) AS \\"civil_cycle_days\\"\n  FROM public.stg_ndpd_mbt_tmobile_macro_combined\n  WHERE {where_sql}\n) base\n{group_by_sql}\n{order_by_sql}\n""".strip()\n\n    # Guardrail: platform does not support CTEs\n    if "WITH " in sql.upper():\n        raise ValueError("CTEs (WITH ...) are not supported in execute_query; rewrite using subqueries.")\n\n    return execute_query(sql)\n', kpi_source_columns: ['confirm_split_spo', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'por_category', 's_site_class', 'pj_a_4250_civil_construction_start_finish', 'pj_a_4750_civil_construction_complete_finish', 'ms_1549_civil_construction_start_actual', 'ms_1551_civil_construction_complete_actual_date'], session_id: '69a3d22f26e208edc083a06e', label: 'Civil Cycle Time', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: 'b91a6e98-8c3f-4fae-a943-003665793220', entity_type: 'kpi', kpi_name: 'Civil Cycle Time', name: 'b91a6e98-8c3f-4fae-a943-003665793220', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'source_system', 'por_category (optional)', 's_site_class (optional)'], kpi_description: 'Measures the civil construction cycle time in calendar days for split-scope/civil-confirmed sites, used to monitor performance against the civil SLA target (<= 21 days). Results are summarized by market and general contractor (and related regional rollups).', status: 'mentioned', node_id: 'b91a6e98-8c3f-4fae-a943-003665793220'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Weekly GC Run Rate (sites/week) = COUNT(DISTINCT pj_project_id with effective completion date in the trailing (trailing_weeks * 7)-day window ending on evaluation_date) / trailing_weeks, grouped by rgn_region, m_area, m_market, construction_gc, and source_system. Effective completion date uses Magenta milestone pj_a_5175_construction_complete_finish when available; otherwise falls back to NDPd milestone ms_1555_construction_complete_actual. A project is attributed to exactly one source_system: Magenta when pj_a_5175 is populated, otherwise NDPd when ms_1555 is populated. trailing_weeks is a parameter (default 12).', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping dimension."}, {"column": "m_area", "type": "string", "description": "Area grouping dimension."}, {"column": "m_market", "type": "string", "description": "Market grouping dimension."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping dimension."}, {"column": "weekly_gc_run_rate", "type": "float", "description": "Average completed sites per week over the trailing 12-week window (distinct completed projects / 12)."}, {"column": "completed_projects_trailing_12w", "type": "int", "description": "Count of distinct projects completed within the trailing 12-week window."}, {"column": "evaluation_date", "type": "string", "description": "Evaluation date used to define the trailing window (null when default CURRENT_DATE is used)."}]', kpi_business_logic: '1) Determine evaluation_date: use filters.evaluation_date (or as_of_date/date) if provided, else CURRENT_DATE. 2) Determine trailing_weeks from filters.trailing_weeks, default 12; coerce to int; if <=0 or invalid, fall back to 12. 3) Compute trailing_days = trailing_weeks*7. 4) In an inner subquery over public.stg_ndpd_mbt_tmobile_macro_combined, apply all raw-column filters: seed 1=1; require at least one completion column populated (pj_a_5175 or ms_1555); filter by trailing window using COALESCE(pj_a_5175::date, ms_1555::date) against [evaluation_date - trailing_days, evaluation_date + 1 day); apply optional equality filters on rgn_region, m_area, m_market, construction_gc, pj_project_id. 5) In that same inner subquery, compute completion_date via COALESCE(pj_a_5175::date, ms_1555::date) and compute source_system via CASE (Magenta if pj_a_5175 not null else NDPd if ms_1555 not null). 6) In the outer query, optionally filter by source_system (since it is computed). 7) Group by rgn_region, m_area, m_market, construction_gc, source_system. 8) Compute completed_projects_trailing_window = COUNT(DISTINCT pj_project_id). 9) Compute weekly_gc_run_rate = completed_projects_trailing_window / trailing_weeks.', kpi_filters: '[{"name": "evaluation_date", "type": "string", "description": ""}, {"name": "as_of_date", "type": "string", "description": ""}, {"name": "date", "type": "string", "description": ""}, {"name": "trailing_weeks", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "source_system", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_weekly_gc_run_rate", "node_type": "kpi", "node_id": "72e61595-33fb-4639-b09b-b20643936de0", "node_label": "Weekly GC Run Rate", "description": "Observed weekly throughput (sites/week) per market and general contractor, used as a capacity proxy input to a capacity-vs-demand gap analysis when explicit crew counts are not available.", "parameters": [{"name": "evaluation_date", "type": "date", "description": "Filter by evaluation date", "required": false, "sample_values": []}, {"name": "as_of_date", "type": "date", "description": "Filter by as of date", "required": false, "sample_values": []}, {"name": "date", "type": "date", "description": "Filter by date", "required": false, "sample_values": []}, {"name": "trailing_weeks", "type": "string", "description": "Filter by trailing weeks", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "source_system", "type": "string", "nullable": false}, {"name": "weekly_gc_run_rate", "type": "number", "nullable": false}, {"name": "completed_projects_trailing_window", "type": "number", "nullable": false}, {"name": "evaluation_date", "type": "null", "nullable": true}, {"name": "trailing_weeks", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'Weekly GC Run Rate (sites/week) = COUNT(DISTINCT pj_project_id with effective completion date in the trailing (trailing_weeks * 7)-day window ending on evaluation_date) / trailing_weeks, grouped by rgn_region, m_area, m_market, construction_gc, and source_system. Effective completion date uses Magenta milestone pj_a_5175_construction_complete_finish when available; otherwise falls back to NDPd milestone ms_1555_construction_complete_actual. A project is attributed to exactly one source_system: Magenta when pj_a_5175 is populated, otherwise NDPd when ms_1555 is populated. trailing_weeks is a parameter (default 12).', node_type: 'CORE', definition: 'Weekly GC Run Rate (sites/week) = COUNT(DISTINCT pj_project_id with effective completion date in the trailing (trailing_weeks * 7)-day window ending on evaluation_date) / trailing_weeks, grouped by rgn_region, m_area, m_market, construction_gc, and source_system. Effective completion date uses Magenta milestone pj_a_5175_construction_complete_finish when available; otherwise falls back to NDPd milestone ms_1555_construction_complete_actual. A project is attributed to exactly one source_system: Magenta when pj_a_5175 is populated, otherwise NDPd when ms_1555 is populated. trailing_weeks is a parameter (default 12).', kpi_python_function: 'def get_weekly_gc_run_rate(execute_query, filters=None) -> list[dict]:\n    """Weekly GC Run Rate (sites/week) per (rgn_region, m_area, m_market, construction_gc, source_system).\n\n    Definition:\n      weekly_gc_run_rate = COUNT(DISTINCT pj_project_id completed in trailing window) / trailing_weeks\n\n    Completion date (Magenta-preferred / NDPd-fallback):\n      completion_date = COALESCE(\n        "pj_a_5175_construction_complete_finish"::date,\n        "ms_1555_construction_complete_actual"::date\n      )\n\n    Source system assignment (mutually exclusive per project):\n      - \'Magenta\' if pj_a_5175_construction_complete_finish is populated\n      - else \'NDPd\' if ms_1555_construction_complete_actual is populated\n\n    Trailing window (relative to evaluation_date):\n      completion_date >= (evaluation_date - trailing_weeks*7 days)\n      AND completion_date < (evaluation_date + 1 day)\n\n    Filters (optional):\n      - evaluation_date (YYYY-MM-DD). If not provided, uses CURRENT_DATE.\n      - trailing_weeks (int). If not provided, defaults to 12.\n      - rgn_region, m_area, m_market, construction_gc, pj_project_id, source_system\n\n    Returns list[dict] grouped by region/area/market/gc/source_system.\n    """\n\n    filters = filters or {}\n\n    # evaluation_date\n    eval_date = filters.get("evaluation_date") or filters.get("as_of_date") or filters.get("date")\n    if eval_date is None:\n        eval_date_sql = "CURRENT_DATE"\n        eval_date_out = None\n    else:\n        eval_date_escaped = str(eval_date).replace("\'", "\'\'")\n        eval_date_sql = f"DATE \'{eval_date_escaped}\'"\n        eval_date_out = str(eval_date)\n\n    # trailing_weeks parameter (default 12)\n    trailing_weeks_raw = filters.get("trailing_weeks", 12)\n    try:\n        trailing_weeks = int(trailing_weeks_raw)\n    except Exception:\n        trailing_weeks = 12\n\n    if trailing_weeks <= 0:\n        trailing_weeks = 12\n\n    trailing_days = trailing_weeks * 7\n\n    # Build INNER where clause (raw columns live here)\n    inner_where_parts = [\n        "1=1",\n        \'("pj_a_5175_construction_complete_finish" IS NOT NULL OR "ms_1555_construction_complete_actual" IS NOT NULL)\',\n        f"(COALESCE(\\"pj_a_5175_construction_complete_finish\\"::date, \\"ms_1555_construction_complete_actual\\"::date) >= ({eval_date_sql} - {trailing_days}))",\n        f"(COALESCE(\\"pj_a_5175_construction_complete_finish\\"::date, \\"ms_1555_construction_complete_actual\\"::date) < ({eval_date_sql} + 1))",\n    ]\n\n    # Allowlisted equality filters (raw columns)\n    allowed_inner_dim_filters = {\n        "rgn_region": \'"rgn_region"\',\n        "m_area": \'"m_area"\',\n        "m_market": \'"m_market"\',\n        "construction_gc": \'"construction_gc"\',\n        "pj_project_id": \'"pj_project_id"\',\n    }\n\n    for fk, col in allowed_inner_dim_filters.items():\n        if fk in filters and filters[fk] is not None and str(filters[fk]) != "":\n            v = str(filters[fk]).replace("\'", "\'\'")\n            inner_where_parts.append(f"{col} = \'{v}\'")\n\n    inner_where_sql = " AND ".join(inner_where_parts)\n\n    # Build OUTER where clause (computed columns live here)\n    outer_where_sql = ""\n    if "source_system" in filters and filters["source_system"] is not None and str(filters["source_system"]) != "":\n        v = str(filters["source_system"]).replace("\'", "\'\'")\n        outer_where_sql = f"WHERE 1=1 AND base.source_system = \'{v}\'"\n\n    sql = f"""\n        SELECT\n            base."rgn_region" AS rgn_region,\n            base."m_area" AS m_area,\n            base."m_market" AS m_market,\n            base."construction_gc" AS construction_gc,\n            base.source_system AS source_system,\n            (COUNT(DISTINCT base."pj_project_id")::numeric / NULLIF({trailing_weeks}::numeric, 0)) AS weekly_gc_run_rate,\n            COUNT(DISTINCT base."pj_project_id") AS completed_projects_trailing_window\n        FROM (\n            SELECT\n                "pj_project_id",\n                "rgn_region",\n                "m_area",\n                "m_market",\n                "construction_gc",\n                COALESCE(\n                    "pj_a_5175_construction_complete_finish"::date,\n                    "ms_1555_construction_complete_actual"::date\n                ) AS completion_date,\n                CASE\n                    WHEN "pj_a_5175_construction_complete_finish" IS NOT NULL THEN \'Magenta\'\n                    WHEN "ms_1555_construction_complete_actual" IS NOT NULL THEN \'NDPd\'\n                    ELSE NULL\n                END AS source_system\n            FROM public.stg_ndpd_mbt_tmobile_macro_combined\n            WHERE {inner_where_sql}\n        ) base\n        {outer_where_sql}\n        GROUP BY\n            base."rgn_region",\n            base."m_area",\n            base."m_market",\n            base."construction_gc",\n            base.source_system\n    """.strip()\n\n    rows = execute_query(sql)\n\n    out = []\n    for r in rows or []:\n        out.append({\n            "rgn_region": r.get("rgn_region"),\n            "m_area": r.get("m_area"),\n            "m_market": r.get("m_market"),\n            "construction_gc": r.get("construction_gc"),\n            "source_system": r.get("source_system"),\n            "weekly_gc_run_rate": float(r.get("weekly_gc_run_rate")) if r.get("weekly_gc_run_rate") is not None else None,\n            "completed_projects_trailing_window": int(r.get("completed_projects_trailing_window")) if r.get("completed_projects_trailing_window") is not None else 0,\n            "evaluation_date": eval_date_out,\n            "trailing_weeks": trailing_weeks,\n        })\n\n    return out\n', kpi_source_columns: ['pj_project_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_a_5175_construction_complete_finish', 'ms_1555_construction_complete_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Weekly GC Run Rate', kpi_related_core_node_ids: ['project', 'market', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '72e61595-33fb-4639-b09b-b20643936de0', entity_type: 'kpi', kpi_name: 'Weekly GC Run Rate', name: '72e61595-33fb-4639-b09b-b20643936de0', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'source_system'], kpi_description: 'Observed weekly throughput (sites/week) per market and general contractor, used as a capacity proxy input to a capacity-vs-demand gap analysis when explicit crew counts are not available.', status: 'mentioned', node_id: '72e61595-33fb-4639-b09b-b20643936de0'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'CX to On-Air Backlog (as-of evaluation_date, default CURRENT_DATE): per (rgn_region, m_area, m_market, construction_gc) count DISTINCT pj_project_id where construction is complete in EITHER system (ms_1555_construction_complete_actual::date IS NOT NULL OR pj_a_5175_construction_complete_finish::date IS NOT NULL) AND integration is NOT complete in EITHER system (ms_1970_integration_complete_actual::date IS NULL AND pj_a_5275_integration_complete_finish::date IS NULL). Aging is computed per project as days_in_backlog = evaluation_date - COALESCE(pj_a_5175_construction_complete_finish::date, ms_1555_construction_complete_actual::date) (Magenta preferred, NDPd fallback); rows with days_in_backlog < 0 are excluded. Output includes total_cx_complete_not_on_air plus aging aggregates avg_days_in_backlog, p50_days_in_backlog, p90_days_in_backlog, max_days_in_backlog. Legacy pending_* columns were removed because they were duplicates of the main count under the simplified definition.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region grouping attribute."}, {"column": "m_area", "type": "string", "description": "Area grouping attribute."}, {"column": "m_market", "type": "string", "description": "Market grouping attribute."}, {"column": "construction_gc", "type": "string", "description": "General contractor grouping attribute."}, {"column": "total_cx_complete_not_on_air", "type": "int", "description": "Count of distinct projects with construction complete and not yet On-Air."}, {"column": "pending_integration_start", "type": "int", "description": "Count of distinct backlog projects where integration start/finish milestone is not present."}, {"column": "pending_integration_complete", "type": "int", "description": "Count of distinct backlog projects where integration has started but integration complete milestone is not present."}, {"column": "pending_cop_approval", "type": "int", "description": "Count of distinct backlog projects where integration is complete but COP approval milestone is not present."}, {"column": "pending_other", "type": "int", "description": "Count of distinct backlog projects where COP approval is present but the project is still not On-Air."}]', kpi_business_logic: 'Determine eval_date as CURRENT_DATE unless filters.evaluation_date / filters.as_of_date / filters.date is provided; if provided use DATE \'YYYY-MM-DD\'.\nDefine construction_complete_date = COALESCE(pj_a_5175_construction_complete_finish::date, ms_1555_construction_complete_actual::date) (Magenta preferred).\nInclude a project in the backlog base set if (ms_1555_construction_complete_actual::date IS NOT NULL OR pj_a_5175_construction_complete_finish::date IS NOT NULL) AND (ms_1970_integration_complete_actual::date IS NULL AND pj_a_5275_integration_complete_finish::date IS NULL).\nIf start_date provided, require construction_complete_date >= start_date. If end_date provided, require construction_complete_date <= end_date.\nApply allowlisted equality filters (rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id) when provided.\nCompute days_in_backlog = eval_date - construction_complete_date; exclude rows where days_in_backlog < 0.\nGroup by (rgn_region, m_area, m_market, construction_gc) and compute: COUNT(DISTINCT pj_project_id) as total_cx_complete_not_on_air; AVG(days_in_backlog), PERCENTILE_CONT(0.5) of days_in_backlog, PERCENTILE_CONT(0.9) of days_in_backlog, and MAX(days_in_backlog).', kpi_filters: '[{"name": "evaluation_date", "type": "string", "description": ""}, {"name": "as_of_date", "type": "string", "description": ""}, {"name": "date", "type": "string", "description": ""}, {"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_cx_to_on_air_backlog", "node_type": "kpi", "node_id": "a9310885-be13-4778-bc99-7ead870d99ee", "node_label": "CX to On-Air Backlog", "description": "Counts projects where construction is complete but the site is not yet On-Air as of a current-state (CURRENT_DATE) snapshot. The KPI also breaks this backlog into blocker-stage buckets to show where projects are stuck in the process.", "parameters": [{"name": "evaluation_date", "type": "date", "description": "Filter by evaluation date", "required": false, "sample_values": []}, {"name": "as_of_date", "type": "date", "description": "Filter by as of date", "required": false, "sample_values": []}, {"name": "date", "type": "date", "description": "Filter by date", "required": false, "sample_values": []}, {"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "total_cx_complete_not_on_air", "type": "number", "nullable": false}, {"name": "avg_days_in_backlog", "type": "number", "nullable": false}, {"name": "p50_days_in_backlog", "type": "number", "nullable": false}, {"name": "p90_days_in_backlog", "type": "number", "nullable": false}, {"name": "max_days_in_backlog", "type": "number", "nullable": false}], "sample_output": [], "row_count": 10}', nl_description: 'CX to On-Air Backlog (as-of evaluation_date, default CURRENT_DATE): per (rgn_region, m_area, m_market, construction_gc) count DISTINCT pj_project_id where construction is complete in EITHER system (ms_1555_construction_complete_actual::date IS NOT NULL OR pj_a_5175_construction_complete_finish::date IS NOT NULL) AND integration is NOT complete in EITHER system (ms_1970_integration_complete_actual::date IS NULL AND pj_a_5275_integration_complete_finish::date IS NULL). Aging is computed per project as days_in_backlog = evaluation_date - COALESCE(pj_a_5175_construction_complete_finish::date, ms_1555_construction_complete_actual::date) (Magenta preferred, NDPd fallback); rows with days_in_backlog < 0 are excluded. Output includes total_cx_complete_not_on_air plus aging aggregates avg_days_in_backlog, p50_days_in_backlog, p90_days_in_backlog, max_days_in_backlog. Legacy pending_* columns were removed because they were duplicates of the main count under the simplified definition.', node_type: 'CORE', definition: 'CX to On-Air Backlog (as-of evaluation_date, default CURRENT_DATE): per (rgn_region, m_area, m_market, construction_gc) count DISTINCT pj_project_id where construction is complete in EITHER system (ms_1555_construction_complete_actual::date IS NOT NULL OR pj_a_5175_construction_complete_finish::date IS NOT NULL) AND integration is NOT complete in EITHER system (ms_1970_integration_complete_actual::date IS NULL AND pj_a_5275_integration_complete_finish::date IS NULL). Aging is computed per project as days_in_backlog = evaluation_date - COALESCE(pj_a_5175_construction_complete_finish::date, ms_1555_construction_complete_actual::date) (Magenta preferred, NDPd fallback); rows with days_in_backlog < 0 are excluded. Output includes total_cx_complete_not_on_air plus aging aggregates avg_days_in_backlog, p50_days_in_backlog, p90_days_in_backlog, max_days_in_backlog. Legacy pending_* columns were removed because they were duplicates of the main count under the simplified definition.', kpi_python_function: 'def get_cx_to_on_air_backlog(execute_query, filters=None) -> list[dict]:\n    """CX to On-Air Backlog (evaluation-date snapshot).\n\n    A project is in backlog when:\n      - Construction is complete in EITHER system (NDPd OR Magenta)\n      - AND Integration is NOT complete in EITHER system (both null)\n\n    Aging (days_in_backlog) is computed per project as:\n      eval_date - COALESCE(Magenta_construction_complete_date, NDPd_construction_complete_date)\n\n    Output:\n      rgn_region, m_area, m_market, construction_gc,\n      total_cx_complete_not_on_air,\n      avg_days_in_backlog, p50_days_in_backlog, p90_days_in_backlog, max_days_in_backlog\n\n    Note: Legacy pending_* columns were removed because under the simplified Nokia definition\n    they became duplicates of the main backlog count.\n    """\n\n    filters = filters or {}\n\n    def _sql_str(v):\n        return str(v).replace("\'", "\'\'")\n\n    # Allowlisted equality filters (no generic filter loops)\n    allowed_filters = {\n        "rgn_region": "rgn_region",\n        "m_area": "m_area",\n        "m_market": "m_market",\n        "construction_gc": "construction_gc",\n        "pj_project_id": "pj_project_id",\n        "s_site_id": "s_site_id",\n    }\n\n    # evaluation date parameter handling (Weekly GC Run Rate-style aliases)\n    evaluation_date = (\n        filters.get("evaluation_date")\n        or filters.get("as_of_date")\n        or filters.get("date")\n    )\n    if evaluation_date:\n        eval_date_sql = f"DATE \'{_sql_str(evaluation_date)}\'"\n    else:\n        eval_date_sql = "CURRENT_DATE"\n\n    # Optional date range filters apply to the COALESCE\'d construction complete date\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n\n    # Seed WHERE with 1=1, then add defining metric predicates first\n    where_parts = [\n        "1=1",\n        # Backlog inclusion logic (liberal complete, strict not-complete)\n        "(\\"ms_1555_construction_complete_actual\\"::date IS NOT NULL OR \\"pj_a_5175_construction_complete_finish\\"::date IS NOT NULL)",\n        "(\\"ms_1970_integration_complete_actual\\"::date IS NULL AND \\"pj_a_5275_integration_complete_finish\\"::date IS NULL)",\n    ]\n\n    # Date range filters (construction completion date window)\n    if start_date:\n        sd = _sql_str(start_date)\n        where_parts.append(\n            f"COALESCE(\\"pj_a_5175_construction_complete_finish\\"::date, \\"ms_1555_construction_complete_actual\\"::date) >= DATE \'{sd}\'"\n        )\n    if end_date:\n        ed = _sql_str(end_date)\n        where_parts.append(\n            f"COALESCE(\\"pj_a_5175_construction_complete_finish\\"::date, \\"ms_1555_construction_complete_actual\\"::date) <= DATE \'{ed}\'"\n        )\n\n    # Equality filters\n    for k, col in allowed_filters.items():\n        if k in filters and filters[k] is not None and filters[k] != "":\n            where_parts.append(f"\\"{col}\\" = \'{_sql_str(filters[k])}\'")\n\n    where_sql = "WHERE " + " AND ".join(where_parts)\n\n    sql = f"""\n    SELECT\n      base.\\"rgn_region\\" AS rgn_region,\n      base.\\"m_area\\" AS m_area,\n      base.\\"m_market\\" AS m_market,\n      base.\\"construction_gc\\" AS construction_gc,\n\n      COUNT(DISTINCT base.\\"pj_project_id\\") AS total_cx_complete_not_on_air,\n\n      AVG(base.days_in_backlog)::float AS avg_days_in_backlog,\n      PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY base.days_in_backlog) AS p50_days_in_backlog,\n      PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY base.days_in_backlog) AS p90_days_in_backlog,\n      MAX(base.days_in_backlog) AS max_days_in_backlog\n\n    FROM (\n      SELECT\n        \\"rgn_region\\",\n        \\"m_area\\",\n        \\"m_market\\",\n        \\"construction_gc\\",\n        \\"pj_project_id\\",\n        (\n          {eval_date_sql}\n          - COALESCE(\n              \\"pj_a_5175_construction_complete_finish\\"::date,\n              \\"ms_1555_construction_complete_actual\\"::date\n            )\n        ) AS days_in_backlog\n      FROM public.stg_ndpd_mbt_tmobile_macro_combined\n      {where_sql}\n    ) base\n    WHERE base.days_in_backlog >= 0\n    GROUP BY base.\\"rgn_region\\", base.\\"m_area\\", base.\\"m_market\\", base.\\"construction_gc\\"\n    ORDER BY base.\\"rgn_region\\", base.\\"m_area\\", base.\\"m_market\\", base.\\"construction_gc\\"\n    """\n\n    return execute_query(sql)\n', kpi_source_columns: ['rgn_region', 'm_area', 'm_market', 'construction_gc', 'pj_project_id', 's_site_id', 'ms_1555_construction_complete_actual', 'pj_a_5175_construction_complete_finish', 'ms_1970_integration_complete_actual', 'pj_a_5275_integration_complete_finish'], session_id: '69a3d22f26e208edc083a06e', label: 'CX to On-Air Backlog', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'AGGREGATES', kpi_kpi_id: 'a9310885-be13-4778-bc99-7ead870d99ee', entity_type: 'kpi', kpi_name: 'CX to On-Air Backlog', name: 'a9310885-be13-4778-bc99-7ead870d99ee', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Counts projects where construction is complete but the site is not yet On-Air as of a current-state (CURRENT_DATE) snapshot. The KPI also breaks this backlog into blocker-stage buckets to show where projects are stuck in the process.', status: 'mentioned', node_id: 'a9310885-be13-4778-bc99-7ead870d99ee'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined'], nl_business_rule: '', kpi_formula_description: 'Measures Nokia\'s scoping package round-trip with T-Mobile. Cycle Time = approval date (ms_1333) − submission date (ms_1331), reported as avg/p50/p90/max in calendar days. Quality dimension reports submitted_count, approved_count, pending_approval_count, and approval_rate_pct (= 100 × approved / submitted). All counts are distinct projects. The base row set is restricted to rows where at least one of ms_1331 or ms_1333 is non-null. Date range filters anchor on submission date (ms_1331::date) so packages still pending approval are not silently excluded. Replaces an earlier implementation that incorrectly used pre-NTP and pre-construction package validation milestones (ms_1310, ms_1323, ms_1327) — those phases have been removed from this KPI.', kpi_output_schema: '[{"column": "rgn_region", "type": "string", "description": "Region for the scorecard row."}, {"column": "m_area", "type": "string", "description": "Area for the scorecard row."}, {"column": "m_market", "type": "string", "description": "Market for the scorecard row."}, {"column": "construction_gc", "type": "string", "description": "General contractor (included when drilling down by contractor)."}, {"column": "avg_pre_ntp_to_scoping_ready_days", "type": "float", "description": "Average days from ms_1310 to ms_1323 for non-negative differences."}, {"column": "p50_pre_ntp_to_scoping_ready_days", "type": "float", "description": "Median (P50) days from ms_1310 to ms_1323 for non-negative differences."}, {"column": "avg_scoping_ready_to_validated_days", "type": "float", "description": "Average days from ms_1323 to ms_1327 for non-negative differences."}, {"column": "p50_scoping_ready_to_validated_days", "type": "float", "description": "Median (P50) days from ms_1323 to ms_1327 for non-negative differences."}, {"column": "avg_full_scoping_cycle_days", "type": "float", "description": "Average days from ms_1310 to ms_1327 for non-negative differences."}, {"column": "p50_full_scoping_cycle_days", "type": "float", "description": "Median (P50) days from ms_1310 to ms_1327 for non-negative differences."}, {"column": "pending_scoping_count", "type": "int", "description": "Count of distinct active projects with ms_1310 present and ms_1327 missing."}, {"column": "scoping_ftr_pct", "type": "float", "description": "FTR percentage = 100 * (completed with rcm_ftr=\'option1\') / (completed)."}, {"column": "scoping_ftr_numerator_completed_ftr", "type": "int", "description": "Numerator for FTR: count of RCM records with rcm_state=\'completed\' and rcm_ftr=\'option1\'."}, {"column": "scoping_ftr_denominator_completed", "type": "int", "description": "Denominator for FTR: count of RCM records with rcm_state=\'completed\'."}, {"column": "project_count_in_cohort", "type": "int", "description": "Count of distinct projects seen in the macro cohort for the group."}]', kpi_business_logic: 'Query public.stg_ndpd_mbt_tmobile_macro_combined.\nSeed WHERE with 1=1.\nApply allowlisted equality filters when provided: rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id.\nRestrict the base row set to rows where ms_1331_scoping_package_submitted_actual IS NOT NULL OR ms_1333_scoping_package_approved_by_customer_actual IS NOT NULL.\nIf start_date/end_date are provided, filter on ms_1331_scoping_package_submitted_actual::date within the specified bounds.\nGroup by rgn_region, m_area, m_market, construction_gc.\nCompute distinct-project counts: submitted_count (ms_1331 not null), approved_count (ms_1333 not null), pending_approval_count (ms_1331 not null and ms_1333 null).\nCompute approval_rate_pct = 100.0 * approved_count / NULLIF(submitted_count, 0).\nFor cycle metrics, compute scoping_cycle_days = ms_1333::date - ms_1331::date and include only rows where both timestamps are present and the day difference is non-negative.\nCompute cycle_project_count as COUNT(DISTINCT pj_project_id) under the cycle-eligible condition; compute avg/p50/p90/max over scoping_cycle_days using conditional expressions so only cycle-eligible values contribute.\nReturn rows ordered by rgn_region, m_area, m_market, construction_gc with the required output column order.', kpi_filters: '[{"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}, {"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_scoping_cycle_time_quality", "node_type": "kpi", "node_id": "9308cdae-49ee-4686-a0f8-c338053aedb5", "node_label": "Scoping Cycle Time & Quality", "description": "Grouped scorecard KPI measuring scoping lifecycle speed, backlog, and first-time-right (FTR) quality. It is used to assess how quickly scoping progresses, how much scoping work is pending, and the quality of completed scoping outcomes.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [{"name": "rgn_region", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "m_market", "type": "string", "nullable": false}, {"name": "construction_gc", "type": "string", "nullable": false}, {"name": "submitted_count", "type": "number", "nullable": false}, {"name": "approved_count", "type": "number", "nullable": false}, {"name": "pending_approval_count", "type": "number", "nullable": false}, {"name": "approval_rate_pct", "type": "string", "nullable": true}, {"name": "cycle_project_count", "type": "number", "nullable": false}, {"name": "avg_scoping_cycle_days", "type": "null", "nullable": true}, {"name": "p50_scoping_cycle_days", "type": "null", "nullable": true}, {"name": "p90_scoping_cycle_days", "type": "null", "nullable": true}, {"name": "max_scoping_cycle_days", "type": "null", "nullable": true}], "sample_output": [], "row_count": 10}', nl_description: 'Measures Nokia\'s scoping package round-trip with T-Mobile. Cycle Time = approval date (ms_1333) − submission date (ms_1331), reported as avg/p50/p90/max in calendar days. Quality dimension reports submitted_count, approved_count, pending_approval_count, and approval_rate_pct (= 100 × approved / submitted). All counts are distinct projects. The base row set is restricted to rows where at least one of ms_1331 or ms_1333 is non-null. Date range filters anchor on submission date (ms_1331::date) so packages still pending approval are not silently excluded. Replaces an earlier implementation that incorrectly used pre-NTP and pre-construction package validation milestones (ms_1310, ms_1323, ms_1327) — those phases have been removed from this KPI.', node_type: 'CORE', definition: 'Measures Nokia\'s scoping package round-trip with T-Mobile. Cycle Time = approval date (ms_1333) − submission date (ms_1331), reported as avg/p50/p90/max in calendar days. Quality dimension reports submitted_count, approved_count, pending_approval_count, and approval_rate_pct (= 100 × approved / submitted). All counts are distinct projects. The base row set is restricted to rows where at least one of ms_1331 or ms_1333 is non-null. Date range filters anchor on submission date (ms_1331::date) so packages still pending approval are not silently excluded. Replaces an earlier implementation that incorrectly used pre-NTP and pre-construction package validation milestones (ms_1310, ms_1323, ms_1327) — those phases have been removed from this KPI.', kpi_python_function: 'def get_scoping_cycle_time_quality(execute_query, filters=None) -> list[dict]:\n    """Scoping Cycle Time & Quality (Nokia) KPI.\n\n    Measures scoping submission -> customer approval round-trip using:\n      - ms_1331_scoping_package_submitted_actual (submission)\n      - ms_1333_scoping_package_approved_by_customer_actual (approval)\n\n    Grain: (rgn_region, m_area, m_market, construction_gc)\n\n    Allowlisted filters (optional):\n      - rgn_region, m_area, m_market, construction_gc, pj_project_id, s_site_id (equality)\n      - start_date, end_date (apply to submission date: ms_1331::date)\n\n    Output schema (in order):\n      rgn_region, m_area, m_market, construction_gc,\n      submitted_count, approved_count, pending_approval_count, approval_rate_pct,\n      cycle_project_count, avg_scoping_cycle_days, p50_scoping_cycle_days,\n      p90_scoping_cycle_days, max_scoping_cycle_days\n    """\n\n    filters = filters or {}\n\n    where_parts = ["1=1"]\n\n    def _add_eq(filter_key: str, col_sql: str):\n        v = filters.get(filter_key)\n        if v is None or str(v).strip() == "":\n            return\n        vv = str(v).replace("\'", "\'\'")\n        where_parts.append(f"{col_sql} = \'{vv}\'")\n\n    # allowlisted equality filters\n    _add_eq(\'rgn_region\', \'"rgn_region"\')\n    _add_eq(\'m_area\', \'"m_area"\')\n    _add_eq(\'m_market\', \'"m_market"\')\n    _add_eq(\'construction_gc\', \'"construction_gc"\')\n    _add_eq(\'pj_project_id\', \'"pj_project_id"\')\n    _add_eq(\'s_site_id\', \'"s_site_id"\')\n\n    # base restriction: at least one milestone present\n    where_parts.append(\n        "(\\n"\n        "  \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL\\n"\n        "  OR \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NOT NULL\\n"\n        ")"\n    )\n\n    # date filters anchored on submission date\n    start_date = filters.get(\'start_date\')\n    end_date = filters.get(\'end_date\')\n    if start_date is not None and str(start_date).strip() != "":\n        sd = str(start_date).strip().replace("\'", "\'\'")\n        where_parts.append(f"\\"ms_1331_scoping_package_submitted_actual\\"::date >= \'{sd}\'::date")\n    if end_date is not None and str(end_date).strip() != "":\n        ed = str(end_date).strip().replace("\'", "\'\'")\n        where_parts.append(f"\\"ms_1331_scoping_package_submitted_actual\\"::date <= \'{ed}\'::date")\n\n    where_sql = " WHERE " + " AND ".join(where_parts)\n\n    # No CTEs; single-table SQL with SQL-side aggregation\n    sql = (\n        "SELECT "\n        "  \\"rgn_region\\" AS \\"rgn_region\\", "\n        "  \\"m_area\\" AS \\"m_area\\", "\n        "  \\"m_market\\" AS \\"m_market\\", "\n        "  \\"construction_gc\\" AS \\"construction_gc\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL THEN \\"pj_project_id\\" END) AS \\"submitted_count\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NOT NULL THEN \\"pj_project_id\\" END) AS \\"approved_count\\", "\n        "  COUNT(DISTINCT CASE WHEN \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL AND \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NULL THEN \\"pj_project_id\\" END) AS \\"pending_approval_count\\", "\n        "  (100.0 * "\n        "     COUNT(DISTINCT CASE WHEN \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NOT NULL THEN \\"pj_project_id\\" END) "\n        "     / NULLIF(COUNT(DISTINCT CASE WHEN \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL THEN \\"pj_project_id\\" END), 0) "\n        "  ) AS \\"approval_rate_pct\\", "\n        "  COUNT(DISTINCT CASE WHEN "\n        "     \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL "\n        "     AND \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NOT NULL "\n        "     AND (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) >= 0 "\n        "    THEN \\"pj_project_id\\" END) AS \\"cycle_project_count\\", "\n        "  AVG(CASE WHEN "\n        "     \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL "\n        "     AND \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NOT NULL "\n        "     AND (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) >= 0 "\n        "    THEN (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) END) AS \\"avg_scoping_cycle_days\\", "\n        "  PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY (CASE WHEN "\n        "     \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL "\n        "     AND \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NOT NULL "\n        "     AND (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) >= 0 "\n        "    THEN (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) END)) AS \\"p50_scoping_cycle_days\\", "\n        "  PERCENTILE_CONT(0.9) WITHIN GROUP (ORDER BY (CASE WHEN "\n        "     \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL "\n        "     AND \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NOT NULL "\n        "     AND (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) >= 0 "\n        "    THEN (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) END)) AS \\"p90_scoping_cycle_days\\", "\n        "  MAX(CASE WHEN "\n        "     \\"ms_1331_scoping_package_submitted_actual\\" IS NOT NULL "\n        "     AND \\"ms_1333_scoping_package_approved_by_customer_actual\\" IS NOT NULL "\n        "     AND (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) >= 0 "\n        "    THEN (\\"ms_1333_scoping_package_approved_by_customer_actual\\"::date - \\"ms_1331_scoping_package_submitted_actual\\"::date) END) AS \\"max_scoping_cycle_days\\" "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        + where_sql +\n        " GROUP BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\" "\n        " ORDER BY \\"rgn_region\\", \\"m_area\\", \\"m_market\\", \\"construction_gc\\""\n    )\n\n    rows = execute_query(sql) or []\n\n    out = []\n    for r in rows:\n        out.append({\n            \'rgn_region\': r.get(\'rgn_region\'),\n            \'m_area\': r.get(\'m_area\'),\n            \'m_market\': r.get(\'m_market\'),\n            \'construction_gc\': r.get(\'construction_gc\'),\n            \'submitted_count\': r.get(\'submitted_count\'),\n            \'approved_count\': r.get(\'approved_count\'),\n            \'pending_approval_count\': r.get(\'pending_approval_count\'),\n            \'approval_rate_pct\': r.get(\'approval_rate_pct\'),\n            \'cycle_project_count\': r.get(\'cycle_project_count\'),\n            \'avg_scoping_cycle_days\': r.get(\'avg_scoping_cycle_days\'),\n            \'p50_scoping_cycle_days\': r.get(\'p50_scoping_cycle_days\'),\n            \'p90_scoping_cycle_days\': r.get(\'p90_scoping_cycle_days\'),\n            \'max_scoping_cycle_days\': r.get(\'max_scoping_cycle_days\')\n        })\n\n    return out\n', kpi_source_columns: ['pj_project_id', 's_site_id', 'rgn_region', 'm_area', 'm_market', 'construction_gc', 'ms_1331_scoping_package_submitted_actual', 'ms_1333_scoping_package_approved_by_customer_actual'], session_id: '69a3d22f26e208edc083a06e', label: 'Scoping Cycle Time & Quality', kpi_related_core_node_ids: ['project', 'site', 'market', 'general_contractor'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: '9308cdae-49ee-4686-a0f8-c338053aedb5', entity_type: 'kpi', kpi_name: 'Scoping Cycle Time & Quality', name: '9308cdae-49ee-4686-a0f8-c338053aedb5', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Grouped scorecard KPI measuring scoping lifecycle speed, backlog, and first-time-right (FTR) quality. It is used to assess how quickly scoping progresses, how much scoping work is pending, and the quality of completed scoping outcomes.', status: 'mentioned', node_id: '9308cdae-49ee-4686-a0f8-c338053aedb5'});
CREATE (:BKGNode {kpi_source_tables: ['public.stg_ndpd_mbt_tmobile_macro_combined', 'public.stg_services_ndpc_answers_daily_from_sdb'], nl_business_rule: '', kpi_formula_description: 'Computes site-level First-Time-Right (FTR) using NDPc answer activity. Source is public.stg_services_ndpc_answers_daily_from_sdb joined to public.stg_ndpd_mbt_tmobile_macro_combined on scop_title = sessiontitle to inherit grouping dimensions (rgn_region, m_area, m_market, construction_gc). A site (scop_title) is in-scope if it has ≥1 NDPc answer record (INNER JOIN). A site is FTR if it has zero answers with formanswerstatus = \'2\' (rejected); non-FTR if it has ≥1 rejected answer. Output includes: total_sites_with_ndpc, ftr_sites, non_ftr_sites, ftr_rate_pct = 100*ftr_sites/total_sites_with_ndpc, plus answer-level totals (total_answers, rejected_answer_count) and answer_rejection_rate_pct = 100*rejected_answer_count/total_answers.', kpi_output_schema: '[{"column": "audited_count", "type": "int", "description": "Count of distinct pj_project_id with Nokia audit completed (ms_1556_punch_checklist_audit_completed_by_nokia_actual is not null)."}, {"column": "ftr_yes_count", "type": "int", "description": "Count of distinct pj_project_id with Nokia audit completed and first_time_right explicitly equal to \'Yes\' after TRIM/blank-to-NULL normalization."}, {"column": "not_ftr_or_unknown_count", "type": "int", "description": "audited_count minus ftr_yes_count (projects not first-time-right or with unknown/blank/non-Yes first_time_right)."}, {"column": "ftr_rate_pct", "type": "float", "description": "First-time-right rate percentage: 100.0 * ftr_yes_count / audited_count (null when audited_count is 0)."}]', kpi_business_logic: 'INNER JOIN macro combined (c) to answer daily (a) on c.scop_title = a.sessiontitle to scope to sites with NDPc activity.\nApply WHERE seeded with 1=1, including c.scop_title IS NOT NULL, optional date range on a.formanswerdate::date, and optional equality filters on c dimensions/IDs.\nInner aggregation at site level: for each (rgn_region, m_area, m_market, construction_gc, scop_title), compute site_has_rejection = MAX(CASE WHEN formanswerstatus=\'2\' THEN 1 ELSE 0 END), total_answers = COUNT(*), rejected_answers = SUM(CASE WHEN formanswerstatus=\'2\' THEN 1 ELSE 0 END).\nOuter aggregation at group level: compute total_sites_with_ndpc, ftr_sites (site_has_rejection=0), non_ftr_sites (site_has_rejection=1), ftr_rate_pct, and answer-level totals and rejection rate.', kpi_filters: '[{"name": "start_date", "type": "string", "description": ""}, {"name": "end_date", "type": "string", "description": ""}, {"name": "rgn_region", "type": "string", "description": ""}, {"name": "m_area", "type": "string", "description": ""}, {"name": "m_market", "type": "string", "description": ""}, {"name": "construction_gc", "type": "string", "description": ""}, {"name": "pj_project_id", "type": "string", "description": ""}, {"name": "s_site_id", "type": "string", "description": ""}]', kpi_contract: '{"function_name": "get_ndpc_quality_ftr_rate", "node_type": "kpi", "node_id": "f44a788a-0aab-4a97-b60e-38a9d43063af", "node_label": "NDPc Quality FTR Rate", "description": "Percentage of projects/sites that pass the NDPc quality gate first-time-right after Nokia audit completion. This indicates how often audited projects meet the quality requirements on the first attempt.", "parameters": [{"name": "start_date", "type": "date", "description": "Filter by start date", "required": false, "sample_values": []}, {"name": "end_date", "type": "date", "description": "Filter by end date", "required": false, "sample_values": []}], "output_columns": [], "sample_output": [], "row_count": 0}', nl_description: 'Computes site-level First-Time-Right (FTR) using NDPc answer activity. Source is public.stg_services_ndpc_answers_daily_from_sdb joined to public.stg_ndpd_mbt_tmobile_macro_combined on scop_title = sessiontitle to inherit grouping dimensions (rgn_region, m_area, m_market, construction_gc). A site (scop_title) is in-scope if it has ≥1 NDPc answer record (INNER JOIN). A site is FTR if it has zero answers with formanswerstatus = \'2\' (rejected); non-FTR if it has ≥1 rejected answer. Output includes: total_sites_with_ndpc, ftr_sites, non_ftr_sites, ftr_rate_pct = 100*ftr_sites/total_sites_with_ndpc, plus answer-level totals (total_answers, rejected_answer_count) and answer_rejection_rate_pct = 100*rejected_answer_count/total_answers.', node_type: 'CORE', definition: 'Computes site-level First-Time-Right (FTR) using NDPc answer activity. Source is public.stg_services_ndpc_answers_daily_from_sdb joined to public.stg_ndpd_mbt_tmobile_macro_combined on scop_title = sessiontitle to inherit grouping dimensions (rgn_region, m_area, m_market, construction_gc). A site (scop_title) is in-scope if it has ≥1 NDPc answer record (INNER JOIN). A site is FTR if it has zero answers with formanswerstatus = \'2\' (rejected); non-FTR if it has ≥1 rejected answer. Output includes: total_sites_with_ndpc, ftr_sites, non_ftr_sites, ftr_rate_pct = 100*ftr_sites/total_sites_with_ndpc, plus answer-level totals (total_answers, rejected_answer_count) and answer_rejection_rate_pct = 100*rejected_answer_count/total_answers.', kpi_python_function: 'def get_ndpc_quality_ftr_rate(execute_query, filters=None) -> list[dict]:\n    """NDPc Quality — Site-level First-Time-Right (FTR) from NDPc answer activity.\n\n    Definition (per Nokia): a site is FTR if it has at least one NDPc answer AND none of its answers were rejected.\n      - Non-FTR if ANY answer has formanswerstatus = \'2\' (rejected).\n      - Status codes are strings: \'0\' submitted/no action, \'1\' approved, \'2\' rejected.\n\n    Data sources:\n      - public.stg_ndpd_mbt_tmobile_macro_combined (dims + scop_title join key)\n      - public.stg_services_ndpc_answers_daily_from_sdb (answer-level statuses + answer date)\n\n    Output (grouped by region/area/market/GC):\n      rgn_region, m_area, m_market, construction_gc,\n      total_sites_with_ndpc, ftr_sites, non_ftr_sites, ftr_rate_pct,\n      total_answers, rejected_answer_count, answer_rejection_rate_pct\n\n    Filters (allowlist):\n      - start_date, end_date  (applied to a."formanswerdate"::date)\n      - rgn_region, m_area, m_market, construction_gc (applied to c.*)\n      - pj_project_id, s_site_id (applied to c.*)\n\n    Notes:\n      - Uses INNER JOIN: KPI scope is only sites with at least one NDPc answer record.\n      - No CTEs; uses a derived-table subquery for two-level aggregation.\n    """\n\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    # ---- allowlisted filters only (no generic filter loops) ----\n    start_date = filters.get("start_date")\n    end_date = filters.get("end_date")\n\n    # Inner WHERE clause (raw columns accessible here)\n    where_parts = ["1=1"]\n\n    # Defining/defensive condition (INNER JOIN already implies it, but included explicitly)\n    where_parts.append(\'c."scop_title" IS NOT NULL\')\n\n    if start_date:\n        where_parts.append(f"a.\\"formanswerdate\\"::date >= \'{esc(start_date)}\'::date")\n    if end_date:\n        where_parts.append(f"a.\\"formanswerdate\\"::date <= \'{esc(end_date)}\'::date")\n\n    for k in [\n        "rgn_region",\n        "m_area",\n        "m_market",\n        "construction_gc",\n        "pj_project_id",\n        "s_site_id",\n    ]:\n        v = filters.get(k)\n        if v is not None and v != "":\n            where_parts.append(f\'c."{k}" = \\\'{esc(v)}\\\'\')\n\n    inner_where_sql = " AND ".join(where_parts)\n\n    sql = f"""\n        SELECT\n          site_level."rgn_region",\n          site_level."m_area",\n          site_level."m_market",\n          site_level."construction_gc",\n          COUNT(DISTINCT site_level."scop_title") AS total_sites_with_ndpc,\n          COUNT(DISTINCT CASE WHEN site_level."site_has_rejection" = 0 THEN site_level."scop_title" ELSE NULL END) AS ftr_sites,\n          COUNT(DISTINCT CASE WHEN site_level."site_has_rejection" = 1 THEN site_level."scop_title" ELSE NULL END) AS non_ftr_sites,\n          (\n            100.0 *\n            COUNT(DISTINCT CASE WHEN site_level."site_has_rejection" = 0 THEN site_level."scop_title" ELSE NULL END)\n            / NULLIF(COUNT(DISTINCT site_level."scop_title"), 0)\n          ) AS ftr_rate_pct,\n          SUM(site_level."total_answers") AS total_answers,\n          SUM(site_level."rejected_answers") AS rejected_answer_count,\n          (\n            100.0 * SUM(site_level."rejected_answers")\n            / NULLIF(SUM(site_level."total_answers"), 0)\n          ) AS answer_rejection_rate_pct\n        FROM (\n          SELECT\n            c."rgn_region",\n            c."m_area",\n            c."m_market",\n            c."construction_gc",\n            c."scop_title",\n            MAX(CASE WHEN a."formanswerstatus" = \'2\' THEN 1 ELSE 0 END) AS site_has_rejection,\n            COUNT(*) AS total_answers,\n            SUM(CASE WHEN a."formanswerstatus" = \'2\' THEN 1 ELSE 0 END) AS rejected_answers\n          FROM public.stg_ndpd_mbt_tmobile_macro_combined c\n          INNER JOIN public.stg_services_ndpc_answers_daily_from_sdb a\n            ON c."scop_title" = a."sessiontitle"\n          WHERE {inner_where_sql}\n          GROUP BY\n            c."rgn_region",\n            c."m_area",\n            c."m_market",\n            c."construction_gc",\n            c."scop_title"\n        ) site_level\n        GROUP BY\n          site_level."rgn_region",\n          site_level."m_area",\n          site_level."m_market",\n          site_level."construction_gc"\n        ORDER BY\n          site_level."rgn_region",\n          site_level."m_area",\n          site_level."m_market",\n          site_level."construction_gc"\n    """\n\n    return execute_query(sql) or []\n', kpi_source_columns: ['public.stg_ndpd_mbt_tmobile_macro_combined.pj_project_id', 'public.stg_ndpd_mbt_tmobile_macro_combined.s_site_id', 'public.stg_ndpd_mbt_tmobile_macro_combined.rgn_region', 'public.stg_ndpd_mbt_tmobile_macro_combined.m_area', 'public.stg_ndpd_mbt_tmobile_macro_combined.m_market', 'public.stg_ndpd_mbt_tmobile_macro_combined.construction_gc', 'public.stg_ndpd_mbt_tmobile_macro_combined.scop_title', 'public.stg_services_ndpc_answers_daily_from_sdb.sessiontitle', 'public.stg_services_ndpc_answers_daily_from_sdb.formanswerstatus', 'public.stg_services_ndpc_answers_daily_from_sdb.formanswerdate'], session_id: '69a3d22f26e208edc083a06e', label: 'NDPc Quality FTR Rate', kpi_related_core_node_ids: ['project'], kpi_relationship_type: 'COMPUTES_FROM', kpi_kpi_id: 'f44a788a-0aab-4a97-b60e-38a9d43063af', entity_type: 'kpi', kpi_name: 'NDPc Quality FTR Rate', name: 'f44a788a-0aab-4a97-b60e-38a9d43063af', kpi_dimensions: ['rgn_region', 'm_area', 'm_market', 'construction_gc'], kpi_description: 'Percentage of projects/sites that pass the NDPc quality gate first-time-right after Nokia audit completion. This indicates how often audited projects meet the quality requirements on the first attempt.', status: 'mentioned', node_id: 'f44a788a-0aab-4a97-b60e-38a9d43063af'});

