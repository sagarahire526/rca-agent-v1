\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = [\n        "ms_1555_construction_complete_actual IS NOT NULL"\n    ]\n\n    for k in [\n        "pj_project_id", "s_site_id", "m_market", "m_area", "rgn_region",\n        "construction_gc", "pj_project_status", "por_category",\n        "cop_approval_type", "pj_approve_close_out_binder_status"\n    ]:\n        if filters.get(k) is not None:\n            where_parts.append(f"{k} = \'{esc(filters[k])}\'")\n\n    sql = (\n        "SELECT pj_project_id, s_site_id, m_market, m_area, rgn_region, "\n        "construction_gc, pj_project_status, por_category, "\n        "first_time_right, punch_checklist_completion_percent, "\n        "punchlist_received_from_t_mobile, punchlist_cleared_by_gc_percent, "\n        "cop_approval_type, written_email_cop_approval, "\n        "pj_approve_close_out_binder_status, "\n        "ms_1556_punch_checklist_audit_completed_by_nokia_actual, "\n        "ms_1557_punch_checklist_reviewed_and_submitted_to_tmobile_atl, "\n        "ms_1558_admin_checklist_submitted_to_t_mobile_actual, "\n        "ms_1559_cop_approved_by_t_mobile_actual, "\n        "pj_a_5400_punch_list_to_gc_finish, "\n        "pj_a_5425_punch_list_complete_finish, "\n        "pj_a_5500_receive_close_out_binder_finish, "\n        "pj_a_5525_approve_close_out_binder_finish, "\n        "pj_a_5540_financial_closeout_finish, "\n        "ms_2400_contractual_customer_acceptance_actual, "\n        "ms_2450_customer_payment_release_actual, "\n        "ms_2490_project_complete_actual "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n        "WHERE " + " AND ".join(where_parts)\n    )\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'closeout_package', definition: 'A project deliverable document set assembled for a site/project closeout (including as-built documentation) and submitted for customer review; triggers COP approval and downstream acceptance/payment steps.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'closeout_package'});
CREATE (:BKGNode {map_key_column: 'person_name', map_table_name: 'MULTI_SOURCE', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Person', map_sql_template: '-- Multi-source node: person names extracted from 5 tables.\n-- Sources: macro_combined, hse, nas_rejection, riot, ndpc_sessions.\n-- See Python function for dynamic SQL per source.', map_label_column: 'person_name', nl_description: 'A named individual assigned to work on projects/sites in specific roles (e.g., Project Manager, Construction Manager, Deployment Coordinator, NAS Integration Engineer). Used for accountability, escalations, and market operations.', entity_type: 'reference', map_contract: '{"function_name": "get_person", "node_type": "core", "node_id": "person", "node_label": "person", "description": "Query person data from MULTI_SOURCE", "parameters": [{"name": "person_name", "type": "string", "description": "Filter by person_name (primary key)", "required": false, "sample_values": ["willie west", "donald rowland", "kevin booth"]}], "output_columns": [{"name": "person_name", "type": "string", "nullable": false}], "sample_output": [], "row_count": 3}', node_type: 'VIRTUAL', map_python_function: 'def get_person(execute_query, filters=None):\n    """Fetch Person records.\n\n    Node: Person | Virtual/reference — no single person registry table exists.\n\n    Person identifiers are scattered across multiple tables/columns, e.g.:\n      - macro_combined: pj_construction_pm, pj_dev_manager, pj_ec_lead, pj_rf_engineer, ...\n      - riot: nas_engineer\n      - hse: hse_engineer_name\n      - nas_rejection: nas_rej_userid\n      - ndpc_sessions: owner\n\n    This accessor intentionally DOES NOT attempt cross-source identity resolution\n    (e.g., matching an email to a free-text name). For macro_combined only, it can\n    return role-tagged assignments by emitting (person_name, role_id, pj_project_id).\n\n    Filters:\n      - source: one of [macro_combined, hse, nas_rejection, riot, ndpc_sessions] (default macro_combined)\n      - person_name: optional exact match\n      - role_id: optional exact match (macro_combined only)\n      - pj_project_id: optional exact match (macro_combined only)\n\n    Returns columns:\n      - person_name\n      - role_id (nullable)\n      - pj_project_id (nullable)\n      - source\n    """\n\n    filters = filters or {}\n    source = filters.get("source", "macro_combined")\n\n    def _escape(v):\n        return str(v).replace("\'", "\'\'")\n\n    if source == "macro_combined":\n        # Map macro_combined columns to role_id\n        # pm: pj_construction_pm, pj_dev_manager, pj_hard_cost_pm, pj_soft_cost_pm\n        # cm: pre_con_local_cm\n        # dc: pj_ec_lead\n        # nas_eng: pj_integrator, pj_rf_engineer\n        # scoping: scoping_package_created_by\n        sql = (\n            "SELECT DISTINCT person_name, role_id, pj_project_id, \'macro_combined\' AS source "\n            "FROM ("\n            "  SELECT pj_construction_pm AS person_name, \'pm\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            "  UNION ALL "\n            "  SELECT pj_dev_manager AS person_name, \'pm\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            "  UNION ALL "\n            "  SELECT pj_hard_cost_pm AS person_name, \'pm\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            "  UNION ALL "\n            "  SELECT pj_soft_cost_pm AS person_name, \'pm\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            "  UNION ALL "\n            "  SELECT pre_con_local_cm AS person_name, \'cm\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            "  UNION ALL "\n            "  SELECT pj_ec_lead AS person_name, \'dc\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            "  UNION ALL "\n            "  SELECT pj_integrator AS person_name, \'nas_eng\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            "  UNION ALL "\n            "  SELECT pj_rf_engineer AS person_name, \'nas_eng\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            "  UNION ALL "\n            "  SELECT scoping_package_created_by AS person_name, \'scoping\' AS role_id, pj_project_id "\n            "  FROM public.stg_ndpd_mbt_tmobile_macro_combined "\n            ") a "\n            "WHERE person_name IS NOT NULL"\n        )\n\n        # Apply optional filters (macro_combined only)\n        where_clauses = []\n        if filters.get("person_name") is not None:\n            where_clauses.append(f"person_name = \'{_escape(filters[\'person_name\'])}\'")\n        if filters.get("role_id") is not None:\n            where_clauses.append(f"role_id = \'{_escape(filters[\'role_id\'])}\'")\n        if filters.get("pj_project_id") is not None:\n            where_clauses.append(f"pj_project_id = \'{_escape(filters[\'pj_project_id\'])}\'")\n\n        if where_clauses:\n            sql = f"SELECT * FROM ({sql}) q WHERE " + " AND ".join(where_clauses)\n\n        return execute_query(sql) or []\n\n    elif source == "hse":\n        sql = (\n            "SELECT DISTINCT hse_engineer_name AS person_name, NULL::text AS role_id, NULL::text AS pj_project_id, \'hse\' AS source "\n            "FROM public.stg_ndpd_hse_site_checklist "\n            "WHERE hse_engineer_name IS NOT NULL"\n        )\n\n    elif source == "nas_rejection":\n        sql = (\n            "SELECT DISTINCT nas_rej_userid AS person_name, NULL::text AS role_id, NULL::text AS pj_project_id, \'nas_rejection\' AS source "\n            "FROM public.stg_nas_rejection_data_last_30_days "\n            "WHERE nas_rej_userid IS NOT NULL"\n        )\n\n    elif source == "riot":\n        sql = (\n            "SELECT DISTINCT nas_engineer AS person_name, NULL::text AS role_id, NULL::text AS pj_project_id, \'riot\' AS source "\n            "FROM public.stg_nas_e911_readiness_riot_validation "\n            "WHERE nas_engineer IS NOT NULL"\n        )\n\n    elif source == "ndpc_sessions":\n        sql = (\n            "SELECT DISTINCT owner AS person_name, NULL::text AS role_id, NULL::text AS pj_project_id, \'ndpc_sessions\' AS source "\n            "FROM public.stg_services_ndpc_sessions_daily_from_sdb "\n            "WHERE owner IS NOT NULL"\n        )\n\n    else:\n        return []\n\n    # Cross-source filters: only person_name is safely applicable.\n    if filters.get("person_name") is not None:\n        sql = f"SELECT * FROM ({sql}) q WHERE person_name = \'{_escape(filters[\'person_name\'])}\'"\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'person', definition: 'A named individual assigned to work on projects/sites in specific roles (e.g., Project Manager, Construction Manager, Deployment Coordinator, NAS Integration Engineer). Used for accountability, escalations, and market operations.', map_database_name: 'MULTI_SOURCE', skip_reason: '', status: 'mentioned', node_id: 'person'});
CREATE (:BKGNode {map_key_column: 'nas_rej_sessionid', map_table_name: 'stg_nas_rejection_data_last_30_days', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Change Request', map_sql_template: 'SELECT \n    id,\n    nas_rej_userid,\n    nas_rej_sessionid,\n    nas_rej_requesttime,\n    nas_rej_market,\n    nas_rej_region,\n    nas_rej_siteid,\n    nas_rej_checkin_reject_reason,\n    nas_rej_checkout_reject_reason,\n    nas_rej_checkout_notes,\n    nas_rej_rejection_time,\n    COALESCE(nas_rej_checkin_reject_reason, nas_rej_checkout_reject_reason) AS rejection_reason\nFROM stg_nas_rejection_data_last_30_days\nWHERE nas_rej_checkin_reject_reason IS NOT NULL\n   OR nas_rej_checkout_reject_reason IS NOT NULL', map_label_column: 'rejection_reason', nl_description: 'A project-specific change request (CR) prerequisite that must be in a valid state for downstream work (notably integration) to proceed. Can block or cause rejections when invalid; treated as an integration-related artifact with its own validity status lifecycle.', map_contract: '{"function_name": "get_change_request", "node_type": "core", "node_id": "change_request", "node_label": "change_request", "description": "Query change_request data from stg_nas_rejection_data_last_30_days", "parameters": [{"name": "nas_rej_sessionid", "type": "string", "description": "Filter by nas_rej_sessionid (primary key)", "required": false, "sample_values": ["300000", "300001", "300002"]}, {"name": "nas_rej_market", "type": "string", "description": "Filter by nas_rej_market", "required": false, "sample_values": ["Chicago", "Detroit", "Indianapolis"]}, {"name": "nas_rej_region", "type": "string", "description": "Filter by nas_rej_region", "required": false, "sample_values": ["Central"]}, {"name": "id", "type": "number", "description": "Filter by id", "required": false, "sample_values": ["116271", "116272", "116273"]}, {"name": "nas_rej_userid", "type": "string", "description": "Filter by nas_rej_userid", "required": false, "sample_values": ["brian.woodward.ext@nokia.com", "nicole.barnes.ext@nokia.com", "michael.schmidt.ext@nokia.com"]}, {"name": "nas_rej_requesttime", "type": "string", "description": "Filter by nas_rej_requesttime", "required": false, "sample_values": ["2026-01-24 19:40:53", "2026-01-07 19:29:48", "2026-01-22 13:28:23"]}, {"name": "nas_rej_siteid", "type": "string", "description": "Filter by nas_rej_siteid", "required": false, "sample_values": ["CH10000A", "DE10001A", "IN10002A"]}, {"name": "nas_rej_rejection_time", "type": "string", "description": "Filter by nas_rej_rejection_time", "required": false, "sample_values": ["2026-01-25 00:24:53", "2026-01-08 00:09:48", "2026-01-22 18:36:23"]}, {"name": "nas_rej_checkin_reject_reason", "type": "string", "description": "Filter by nas_rej_checkin_reject_reason", "required": false, "sample_values": ["Material Not Ready"]}, {"name": "nas_rej_checkout_reject_reason", "type": "string", "description": "Filter by nas_rej_checkout_reject_reason", "required": false, "sample_values": ["Signal Loss", "RTWP"]}, {"name": "nas_rej_checkout_notes", "type": "string", "description": "Filter by nas_rej_checkout_notes", "required": false, "sample_values": []}], "output_columns": [{"name": "id", "type": "number", "nullable": false}, {"name": "nas_rej_userid", "type": "string", "nullable": false}, {"name": "nas_rej_sessionid", "type": "string", "nullable": false}, {"name": "nas_rej_requesttime", "type": "string", "nullable": false}, {"name": "nas_rej_market", "type": "string", "nullable": false}, {"name": "nas_rej_region", "type": "string", "nullable": false}, {"name": "nas_rej_siteid", "type": "string", "nullable": false}, {"name": "nas_rej_checkin_reject_reason", "type": "string", "nullable": true}, {"name": "nas_rej_checkout_reject_reason", "type": "string", "nullable": true}, {"name": "nas_rej_checkout_notes", "type": "string", "nullable": true}, {"name": "nas_rej_rejection_time", "type": "string", "nullable": false}, {"name": "COALESCE(nas_rej_checkin_reject_reason", "type": "string", "nullable": false}, {"name": "nas_rej_checkout_reject_reason) AS rejection_reason", "type": "string", "nullable": false}], "row_count": 3}', node_type: 'CORE', entity_type: 'core', map_python_function: 'def get_change_request(execute_query, filters=None):\n    """Fetch Change Request (integration gating rejection) records.\n    Node: Change Request | Table: stg_nas_rejection_data_last_30_days | Key: nas_rej_sessionid | DB: public\n    """\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = [\n        "(nas_rej_checkin_reject_reason IS NOT NULL OR nas_rej_checkout_reject_reason IS NOT NULL)"\n    ]\n\n    for k in ["nas_rej_market", "nas_rej_region", "nas_rej_siteid", "nas_rej_userid", "nas_rej_sessionid"]:\n        if filters.get(k) is not None:\n            where_parts.append(f"{k} = \'{esc(filters[k])}\'")\n\n    if filters.get("start_date"):\n        where_parts.append(f"nas_rej_rejection_time >= \'{esc(filters[\'start_date\'])}\'")\n    if filters.get("end_date"):\n        where_parts.append(f"nas_rej_rejection_time < \'{esc(filters[\'end_date\'])}\'")\n\n    sql = (\n        "SELECT id, nas_rej_userid, nas_rej_sessionid, nas_rej_requesttime, "\n        "nas_rej_market, nas_rej_region, nas_rej_siteid, "\n        "nas_rej_checkin_reject_reason, nas_rej_checkout_reject_reason, "\n        "nas_rej_checkout_notes, nas_rej_rejection_time, "\n        "COALESCE(nas_rej_checkin_reject_reason, nas_rej_checkout_reject_reason) AS rejection_reason "\n        "FROM public.stg_nas_rejection_data_last_30_days "\n        "WHERE " + " AND ".join(where_parts)\n    )\n\n    return execute_query(sql) or []', is_skipped: false, name: 'change_request', definition: 'A project-specific change request (CR) prerequisite that must be in a valid state for downstream work (notably integration) to proceed. Can block or cause rejections when invalid; treated as an integration-related artifact with its own validity status lifecycle.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'change_request'});
CREATE (:BKGNode {map_key_column: 'pj_project_id', map_table_name: 'stg_ndpd_mbt_tmobile_macro_combined', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Permit', map_sql_template: 'SELECT\n    "pj_project_id",\n    "s_site_id",\n    "m_market",\n    "m_area",\n    "rgn_region",\n    "construction_gc",\n    "pj_project_status",\n    "por_category",\n    "pj_building_permit_approved_status",\n    "pj_building_permit_expiration_date",\n    "pj_building_permit_not_required_document_status",\n    "ms_1406_tower_ntp_received_actual",\n    "ms_1407_tower_ntp_validated_actual",\n    "ms_1408_tower_ntp_rejected_actual",\n    "ms_1507_tower_ntp_approved_actual",\n    "pj_a_3550_ran_zoning_applied_finish",\n    "pj_a_3575_ran_zoning_approved_finish",\n    "pj_a_3650_ran_building_permit_applied_finish",\n    "pj_a_3675_ran_building_permit_approved_finish",\n    "pj_a_3710_ran_entitlement_complete_finish",\n    "pj_a_3715_aav_entitlement_complete_finish",\n    "pj_a_3720_mw_entitlement_complete_finish",\n    "pj_a_3725_all_entitlement_complete_finish",\n    "pj_a_3500_all_regulatory_complete_finish",\n    "pj_a_4350_electrical_permit_applied_finish",\n    "pj_a_4375_electrical_permit_approved_finish"\nFROM "public"."stg_ndpd_mbt_tmobile_macro_combined"', map_label_column: 'pj_project_id', nl_description: 'A site-level access/permissions authorization required to execute work (e.g., FCC filing, landlord permission, local authority approvals). Tracked by type and status (pending/granted/expired) and commonly acts as a prerequisite/blocker for site progress.', map_contract: '{"function_name": "get_permit", "node_type": "core", "node_id": "permit", "node_label": "permit", "description": "Query permit data from stg_ndpd_mbt_tmobile_macro_combined", "parameters": [{"name": "pj_project_id", "type": "string", "description": "Filter by pj_project_id (primary key)", "required": false, "sample_values": ["CH10000A-0002000000", "DE10001A-0002000001", "IN10002A-00020000