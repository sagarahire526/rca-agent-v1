le": true}], "row_count": 3}', node_type: 'CORE', entity_type: 'core', map_python_function: 'def get_project(execute_query, filters=None):\n    """Fetch Project records with key lifecycle attributes and milestones.\n    Node: Project | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: pj_project_id | DB: public\n    """\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = []\n    for k in ["pj_project_id", "pj_project_status", "pj_project_type", "pj_program_name",\n              "construction_gc", "construction_gc", "s_site_id", "smp_id",\n              "m_market", "m_area", "rgn_region", "por_category", "s_site_class"]:\n        if filters.get(k) is not None:\n            where_parts.append(f"{k} = \'{esc(filters[k])}\'")\n\n    if filters.get("start_date"):\n        where_parts.append(\n            f"ms_1550_construction_start_actual::date >= \'{esc(filters[\'start_date\'])}\'"\n        )\n    if filters.get("end_date"):\n        where_parts.append(\n            f"ms_1550_construction_start_actual::date <= \'{esc(filters[\'end_date\'])}\'"\n        )\n\n    sql = (\n        "SELECT id, pj_project_id, pj_project_name, pj_project_status, pj_project_type, "\n        "pj_program_name, pj_por_count, construction_gc, construction_gc, "\n        "s_site_id, smp_id, m_market, m_area, rgn_region, por_category, "\n        "por_regional_dev_initiatives, s_site_class, s_structure_height_in_feet, "\n        "confirm_split_spo, is_lift_required, first_time_right, "\n        "ms_1310_pre_construction_package_received_actual, "\n        "ms_1323_ready_for_scoping_actual, "\n        "ms_1327_scoping_and_quoting_package_validated_actual, "\n        "ms_1407_tower_ntp_validated_actual, "\n        "ms_1507_tower_ntp_approved_actual, "\n        "ms_1550_construction_start_actual, "\n        "ms_1555_construction_complete_actual, "\n        "ms_1556_punch_checklist_audit_completed_by_nokia_actual, "\n        "ms_1970_integration_complete_actual, "\n        "ms_1559_cop_approved_by_t_mobile_actual, "\n        "pj_completion_objective_actual_date "\n        "FROM public.stg_ndpd_mbt_tmobile_macro_combined"\n    )\n\n    if where_parts:\n        sql += " WHERE " + " AND ".join(where_parts)\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'project', definition: 'Unit of work managed for a Site (1:1). Identified by Site Code (T-Mobile), SMP ID (internal Nokia), and Project ID. Contains hundreds of milestone fields (~792 columns) representing lifecycle gating and dates. Includes priority (P1/P2/P3), construction scope type (tower-only vs civil+tower), and an attribute for whether NTP is required (case-by-case; triggers NTP approval flow when true). Also includes a key lifecycle anchor milestone for On-Air (OA) date.', map_database_name: 'public', skip_reason: '', status: 'active', node_id: 'project'});
CREATE (:BKGNode {map_key_column: 'm_market', map_table_name: 'stg_ndpd_mbt_tmobile_macro_combined', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Market', map_sql_template: 'SELECT\n  m_market,\n  m_area,\n  rgn_region,\n  COUNT(DISTINCT pj_project_id) AS project_count,\n  COUNT(DISTINCT CASE WHEN pj_project_status = \'Active\' THEN pj_project_id END) AS active_project_count\nFROM stg_ndpd_mbt_tmobile_macro_combined\nWHERE m_market IS NOT NULL\nGROUP BY m_market, m_area, rgn_region', map_label_column: 'm_market', nl_description: 'Geographic territory used to organize execution and reporting. General Contractors are assigned at the market level; analysis rolls up by market. Market is modeled as a flat entity pending confirmation of any region/area hierarchy.', map_contract: '{"function_name": "get_market", "node_type": "core", "node_id": "market", "node_label": "market", "description": "Query market data from stg_ndpd_mbt_tmobile_macro_combined", "parameters": [{"name": "m_market", "type": "string", "description": "Filter by m_market (primary key)", "required": false, "sample_values": ["CHICAGO", "DETROIT", "INDIANAPOLIS"]}, {"name": "m_area", "type": "string", "description": "Filter by m_area", "required": false, "sample_values": ["GREAT LAKES"]}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn_region", "required": false, "sample_values": ["CENTRAL"]}, {"name": "COUNT(DISTINCT pj_project_id) AS project_count", "type": "string", "description": "Filter by COUNT(DISTINCT pj_project_id) AS project_count", "required": false, "sample_values": []}, {"name": "COUNT(DISTINCT CASE WHEN pj_project_status = \'Active\' THEN pj_project_id END) AS active_project_count", "type": "string", "description": "Filter by COUNT(DISTINCT CASE WHEN pj_project_status = \'Active\' THEN pj_project_id END) AS active_project_count", "required": false, "sample_values": []}], "output_columns": [{"name": "m_market", "type": "string", "nullable": false}, {"name": "m_area", "type": "string", "nullable": false}, {"name": "rgn_region", "type": "string", "nullable": false}, {"name": "COUNT(DISTINCT pj_project_id) AS project_count", "type": "string", "nullable": false}, {"name": "COUNT(DISTINCT CASE WHEN pj_project_status = \'Active\' THEN pj_project_id END) AS active_project_count", "type": "string", "nullable": false}], "row_count": 3}', node_type: 'CORE', entity_type: 'core', map_python_function: 'def get_market(execute_query, filters=None):\n    """Fetch distinct Market records with geographic hierarchy + basic project counts.\n    Node: Market | Table: stg_ndpd_mbt_tmobile_macro_combined | Key: m_market | DB: public\n    """\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = ["m_market IS NOT NULL"]\n\n    for k in ["m_market", "m_area", "rgn_region"]:\n        if filters.get(k) is not None:\n            where_parts.append(f"{k} = \'{esc(filters[k])}\'")\n\n    sql = (\n        "SELECT "\n        "  m_market, "\n        "  m_area, "\n        "  rgn_region, "\n        "  COUNT(DISTINCT pj_project_id) AS project_count, "\n        "  COUNT(DISTINCT CASE WHEN pj_project_status = \'Active\' THEN pj_project_id END) AS active_project_count "\n        "FROM stg_ndpd_mbt_tmobile_macro_combined "\n        "WHERE " + " AND ".join(where_parts) + " "\n        "GROUP BY m_market, m_area, rgn_region"\n    )\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'market', definition: 'Geographic territory used to organize execution and reporting. General Contractors are assigned at the market level; analysis rolls up by market. Market is modeled as a flat entity pending confirmation of any region/area hierarchy.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'market'});
CREATE (:BKGNode {map_key_column: 'construction_gc', map_table_name: 'stg_ndpd_mbt_tmobile_macro_combined', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'General Contractor', map_sql_template: 'SELECT\n    "construction_gc",\n    "rgn_region",\n    "m_area",\n    "m_market",\n    COUNT(DISTINCT "pj_project_id") AS total_projects,\n    COUNT(DISTINCT CASE WHEN "pj_project_status" = \'Active\' THEN "pj_project_id" END) AS active_projects,\n    COUNT(DISTINCT CASE WHEN "ms_1550_construction_start_actual" IS NOT NULL AND "ms_1555_construction_complete_actual" IS NULL THEN "pj_project_id" END) AS wip_projects,\n    COUNT(DISTINCT CASE WHEN "ms_1555_construction_complete_actual" IS NOT NULL THEN "pj_project_id" END) AS completed_projects\nFROM "public"."stg_ndpd_mbt_tmobile_macro_combined"\nWHERE "construction_gc" IS NOT NULL\nGROUP BY "construction_gc", "rgn_region", "m_area", "m_market"', map_label_column: 'construction_gc', nl_description: 'A vendor company performing the physical construction work on sites. Assigned early based on market forecast; can accept/reject assignment; reassignment possible but uncommon once work begins. Tracked with identity attributes and market presence; crew count/capacity tracked per market; performance (e.g., productivity, on-time, SLA breach, rework) tracked operationally.', map_contract: '{"function_name": "get_general_contractor", "node_type": "core", "node_id": "general_contractor", "node_label": "general_contractor", "description": "Query general_contractor data from stg_ndpd_mbt_tmobile_macro_combined", "parameters": [{"name": "construction_gc", "type": "string", "description": "Filter by construction_gc (primary key)", "required": false, "sample_values": ["impirium", "telcom construction", "hampton enterprises"]}, {"name": "rgn_region", "type": "string", "description": "Filter by rgn_region", "required": false, "sample_values": []}, {"name": "m_area", "type": "string", "description": "Filter by m_area", "re