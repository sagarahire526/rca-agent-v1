: "string", "nullable": false}, {"name": "ps_rpm_nas_nnr_eventtime", "type": "string", "nullable": true}, {"name": "ps_rpm_nas_nnr_eventtype", "type": "string", "nullable": false}, {"name": "ps_rpm_nas_nnr_userid", "type": "string", "nullable": false}, {"name": "ps_rpm_nas_nnr_session_id", "type": "string", "nullable": false}, {"name": "mb_status", "type": "string", "nullable": false}, {"name": "on_hold_status", "type": "string", "nullable": true}, {"name": "create_uid", "type": "number", "nullable": false}, {"name": "create_date", "type": "string", "nullable": false}, {"name": "write_uid", "type": "number", "nullable": false}, {"name": "write_date", "type": "string", "nullable": false}], "sample_output": [], "row_count": 3}', entity_type: 'transaction', node_type: 'CORE', map_python_function: 'def get_nas_task_tracker_item(execute_query: callable, filters: dict = None) -> list[dict]:\n    """Fetch NAS Task Tracker Item (RF010) records.\n\n    Curated filters only.\n\n    Allowed equality filters:\n      - project_site_id, market_id, region_id, project_category,\n        activity_tracker_state, work_package_id, on_hold_status,\n        ps_rpm_nas_nnr_session_id\n\n    Allowed date range filters (on task_received_datetime):\n      - task_received_datetime_start (>=)\n      - task_received_datetime_end (<=)\n\n    Node: NAS Task Tracker Item | Table: stg_nas_rf010_dashboard | Key: id | DB: public\n    """\n\n    base_sql = (\n        \'SELECT "id", "project_id", "project_activity_id", "project_site_id", "region_id", "market_id", \'\n        \'"project_ref_id", "project_category", "work_package_id", "activity_tracker_state", "stage_id", \'\n        \'"project_task_delivery_id", "task_received_datetime", "task_completed_datetime", \'\n        \'"ps_rpm_nas_nnr_eventtime", "ps_rpm_nas_nnr_eventtype", "ps_rpm_nas_nnr_userid", \'\n        \'"ps_rpm_nas_nnr_session_id", "mb_status", "on_hold_status", \'\n        \'"create_uid", "create_date", "write_uid", "write_date" \'\n        \'FROM "public"."stg_nas_rf010_dashboard"\'\n    )\n\n    allowed_eq = {\n        "project_site_id",\n        "market_id",\n        "region_id",\n        "project_category",\n        "activity_tracker_state",\n        "work_package_id",\n        "on_hold_status",\n        "ps_rpm_nas_nnr_session_id",\n    }\n\n    where_parts = []\n    if filters:\n        # Equality filters\n        for col in sorted(allowed_eq):\n            if col in filters:\n                v = filters.get(col)\n                if v is None:\n                    where_parts.append(f\'"{col}" IS NULL\')\n                elif isinstance(v, (int, float)):\n                    where_parts.append(f\'"{col}" = {v}\')\n                else:\n                    escaped = str(v).replace("\'", "\'\'")\n                    where_parts.append(f\'"{col}" = \\\'{escaped}\\\'\')\n\n        # Date range filters (received datetime)\n        start = filters.get("task_received_datetime_start")\n        end = filters.get("task_received_datetime_end")\n\n        if start is not None:\n            escaped = str(start).replace("\'", "\'\'")\n            where_parts.append(f\'"task_received_datetime" >= \\\'{escaped}\\\'\')\n        if end is not None:\n            escaped = str(end).replace("\'", "\'\'")\n            where_parts.append(f\'"task_received_datetime" <= \\\'{escaped}\\\'\')\n\n    if where_parts:\n        base_sql += " WHERE " + " AND ".join(where_parts)\n\n    rows = execute_query(base_sql)\n    return rows if rows else []\n', is_skipped: false, name: 'nas_task_tracker_item', definition: 'A task/work-package tracking record in the NAS Task Tracker (RF010) representing a dispatchable unit of NAS work (e.g., RTT Support) with received/completed timestamps, stage/state transitions, hold/MB status flags, and NNR event audit metadata. Multiple task tracker items may reference the same Integration Activity session via ps_rpm_nas_nnr_session_id (many-to-one).', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'nas_task_tracker_item'});
