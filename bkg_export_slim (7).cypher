lable": false}, {"name": "videos", "type": "string", "nullable": false}, {"name": "images", "type": "string", "nullable": false}, {"name": "total", "type": "string", "nullable": false}, {"name": "approved", "type": "string", "nullable": false}, {"name": "rejected", "type": "string", "nullable": false}, {"name": "pending", "type": "string", "nullable": false}, {"name": "approvedpercent", "type": "string", "nullable": false}, {"name": "rejectedpercent", "type": "string", "nullable": false}, {"name": "pendingpercent", "type": "string", "nullable": false}, {"name": "completedpercent", "type": "string", "nullable": false}, {"name": "approvedbyreviewer", "type": "string", "nullable": true}, {"name": "rejectedbyreviewer", "type": "string", "nullable": false}, {"name": "approvedbyai", "type": "string", "nullable": true}, {"name": "rejectedbyai", "type": "string", "nullable": true}, {"name": "noaction", "type": "string", "nullable": true}], "sample_output": [], "row_count": 3}', node_type: 'CORE', entity_type: 'core', map_python_function: 'def get_quality_session_ndpc(execute_query, filters=None):\n    """Fetch Quality Session (NDPc) records with review status and AI/human breakdown.\n    Node: Quality Session NDPc | Table: stg_services_ndpc_sessions_daily_from_sdb | Key: contentid | DB: public\n    """\n    filters = filters or {}\n\n    def esc(v):\n        return str(v).replace("\'", "\'\'")\n\n    where_parts = []\n\n    for k in ["contentid", "siteid", "market", "customer", "project",\n              "servicetype", "subdomain", "owner", "sessionstatus"]:\n        if filters.get(k) is not None:\n            where_parts.append(f"{k} = \'{esc(filters[k])}\'")\n\n    if filters.get("start_date"):\n        where_parts.append(f"createdon::date >= \'{esc(filters[\'start_date\'])}\'")\n    if filters.get("end_date"):\n        where_parts.append(f"createdon::date <= \'{esc(filters[\'end_date\'])}\'")\n\n    sql = (\n        "SELECT id, contentid, ndpccontentid, sessiontitle, owner, "\n        "siteid, market, customer, project, servicetype, subdomain, "\n        "sessionstatus, createdon, lastactivity, length, daysactive, "\n        "pages, videos, images, "\n        "total, approved, rejected, pending, "\n        "approvedpercent, rejectedpercent, pendingpercent, completedpercent, "\n        "approvedbyreviewer, rejectedbyreviewer, approvedbyai, rejectedbyai, "\n        "noaction "\n        "FROM public.stg_services_ndpc_sessions_daily_from_sdb"\n    )\n\n    if where_parts:\n        sql += " WHERE " + " AND ".join(where_parts)\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'quality_session_ndpc', definition: 'Quality/compliance session per site containing a structured questionnaire (500–600+ questions), punch points, compliance status, and audit trail.', map_database_name: 'public', skip_reason: '', status: 'mentioned', node_id: 'quality_session_ndpc'});
CREATE (:BKGNode {map_key_column: 'team_id', map_table_name: 'VIRTUAL', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Team', map_sql_template: '-- Virtual node: static team taxonomy. See Python function.\n-- 8 teams within Nokia org.', map_label_column: 'team_name', nl_description: 'An organizational team involved in delivering projects (e.g., Scoping Team, Project Management, Construction Management, Deployment Coordination, NAS Integration).', entity_type: 'reference', map_contract: '{"function_name": "get_team", "node_type": "virtual", "node_id": "team", "node_label": "Team", "description": "Query static team taxonomy (8 Nokia teams with focus areas)", "parameters": [{"name": "org", "type": "string", "description": "Filter by organization", "required": false, "sample_values": ["Nokia"]}, {"name": "team_id", "type": "string", "description": "Filter by team_id", "required": false, "sample_values": ["secoe", "dec", "nas"]}, {"name": "team_name", "type": "string", "description": "Filter by team_name", "required": false, "sample_values": ["SECoE", "DEC (Delivery Excellence & Compliance)", "NAS (Network Activation Services)"]}], "output_columns": [{"name": "team_id", "type": "string", "nullable": false}, {"name": "team_name", "type": "string", "nullable": false}, {"name": "org", "type": "string", "nullable": false}, {"name": "focus", "type": "string", "nullable": false}], "sample_output": [], "row_count": 8}', node_type: 'VIRTUAL', map_python_function: 'def get_team(execute_query, filters=None):\n    """Fetch Team reference taxonomy.\n    Node: Team | Virtual/static reference — no physical table.\n    Returns hardcoded team definitions with focus areas.\n    """\n    teams = [\n        {"team_id": "secoe", "team_name": "SECoE", "org": "Nokia",\n         "focus": "Scoping package review, validation, and RCM tracking."},\n        {"team_id": "dec", "team_name": "DEC (Delivery Excellence & Compliance)", "org": "Nokia",\n         "focus": "Quality trend monitoring, schedule/cost variance, risk & compliance, safety, vendor performance, portfolio governance."},\n        {"team_id": "nas", "team_name": "NAS (Network Activation Services)", "org": "Nokia",\n         "focus": "Resource staffing, session volume forecasting, maintenance window planning, shift capacity, SLA compliance."},\n        {"team_id": "tmo_rpm", "team_name": "TMO RPM (Telecom Rollout Project Management)", "org": "Nokia",\n         "focus": "Site rollout planning, prerequisite management, GC capacity planning, material readiness, integration timelines, delay recovery, quality management."},\n        {"team_id": "scoping_team", "team_name": "Scoping Team", "org": "Nokia",\n         "focus": "Scoping package creation, review, and validation."},\n        {"team_id": "construction_mgmt", "team_name": "Construction Management", "org": "Nokia",\n         "focus": "Construction execution oversight at market level. CM assignment for manual surveys."},\n        {"team_id": "deployment_coord", "team_name": "Deployment Coordination", "org": "Nokia",\n         "focus": "First line GC contact, daily coordination, L1 HSE escalation."},\n        {"team_id": "project_mgmt", "team_name": "Project Management", "org": "Nokia",\n         "focus": "Project ownership, scoping decisions, L3 HSE escalation."},\n    ]\n\n    filters = filters or {}\n    if filters.get("org"):\n        teams = [t for t in teams if t["org"] == filters["org"]]\n    if filters.get("team_id"):\n        teams = [t for t in teams if t["team_id"] == filters["team_id"]]\n    if filters.get("team_name"):\n        teams = [t for t in teams if t["team_name"] == filters["team_name"]]\n\n    return teams\n', is_skipped: false, name: 'team', definition: 'An organizational team involved in delivering projects (e.g., Scoping Team, Project Management, Construction Management, Deployment Coordination, NAS Integration).', map_database_name: 'VIRTUAL', skip_reason: '', status: 'mentioned', node_id: 'team'});
CREATE (:BKGNode {map_key_column: 'role_id', map_table_name: 'VIRTUAL', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Role', map_sql_template: '-- Virtual node: static role taxonomy. See Python function.\n-- 7 roles across Nokia, GC, and External Vendor orgs.', map_label_column: 'role_name', nl_description: 'A role type with defined responsibilities in the project lifecycle (e.g., Project Manager, Construction Manager, Deployment Coordinator, NAS Integration Engineer).', map_contract: '{"function_name": "get_role", "node_type": "virtual", "node_id": "role", "node_label": "Role", "description": "Query static role taxonomy (7 roles with org and responsibilities)", "parameters": [{"name": "org", "type": "string", "description": "Filter by organization", "required": false, "sample_values": ["Nokia", "GC", "External Vendor"]}, {"name": "role_id", "type": "string", "description": "Filter by role_id", "required": false, "sample_values": ["pm", "cm", "dc"]}, {"name": "role_name", "type": "string", "description": "Filter by role_name", "required": false, "sample_values": ["Project Manager", "Construction Manager", "Deployment Coordinator"]}], "output_columns": [{"name": "role_id", "type": "string", "nullable": false}, {"name": "role_name", "type": "string", "nullable": false}, {"name": "org", "type": "string", "nullable": false}, {"name": "responsibility", "type": "string", "nullable": false}], "sample_output": [], "row_count": 7}', node_type: 'VIRTUAL', entity_type: 'reference', map_python_function: 'def get_role(execute_query, filters=None):\n    """Fetch Role reference taxonomy.\n    Node: Role | Virtual/static reference — no physical table.\n    Returns hardcoded role definitions with organization and responsibilities.\n    """\n    roles = [\n        {"role_id": "pm", "role_name": "Project Manager", "org": "Nokia",\n         "responsibility": "Owns the project. Scoping decisions. L3 HSE escalation."},\n        {"role_id": "cm", "role_name": "Construction Manager", "org": "Nokia",\n         "responsibility": "Construction at market level. Manual survey assignment."},\n        {"role_id": "dc", "role_name": "Deployment Coordinator", "org": "Nokia",\n         "responsibility": "First line GC contact. L1 HSE escalation."},\n        {"role_id": "nas_eng", "role_name": "Integration Engineer", "org": "Nokia / NAS",\n         "responsibility": "Site activation, alarm monitoring, E911 testing. Shift-based capacity."},\n        {"role_id": "scoping", "role_name": "Scoping Engineer", "org": "Nokia",\n         "responsibility": "Scoping package review and validation via SECoE."},\n        {"role_id": "crew", "role_name": "Crew", "org": "GC",\n         "responsibility": "On-site construction team. 1 crew per site per day."},\n        {"role_id": "talon", "role_name": "Talon Survey Operator", "org": "External Vendor",\n         "responsibility": "Drone survey execution and vendor assignment."},\n    ]\n\n    filters = filters or {}\n    if filters.get("org"):\n        roles = [r for r in roles if r["org"] == filters["org"]]\n    if filters.get("role_id"):\n        roles = [r for r in roles if r["role_id"] == filters["role_id"]]\n    if filters.get("role_name"):\n        roles = [r for r in roles if r["role_name"] == filters["role_name"]]\n\n    return roles\n', is_skipped: false, name: 'role', definition: 'A role type with defined responsibilities in the project lifecycle (e.g., Project Manager, Construction Manager, Deployment Coordinator, NAS Integration Engineer).', map_database_name: 'VIRTUAL', skip_reason: '', status: 'mentioned', node_id: 'role'});
CREATE (:BKGNode {map_key_column: 'customer_id', map_table_name: 'VIRTUAL', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Customer', map_sql_template: '-- Virtual node: single customer (T-Mobile). See Python function.', map_label_column: 'customer_name', nl_description: 'The customer organization for whom the deployment program is executed (T-Mobile for this program). Used as a contextual anchor for projects, sites, approvals, and payments.', entity_type: 'reference', node_type: 'VIRTUAL', map_contract: '{"function_name": "get_customer", "node_type": "virtual", "node_id": "customer", "node_label": "Customer", "description": "Query customer reference (T-Mobile is the sole customer in the Nokia Macro program)", "parameters": [{"name": "customer_id", "type": "string", "description": "Filter by customer_id", "required": false, "sample_values": ["tmo"]}], "output_columns": [{"name": "customer_id", "type": "string", "nullable": false}, {"name": "customer_name", "type": "string", "nullable": false}, {"name": "role", "type": "string", "nullable": false}, {"name": "material_ownership", "type": "string", "nullable": false}, {"name": "approval_gates", "type": "string", "nullable": false}, {"name": "quality_review", "type": "string", "nullable": false}], "sample_output": [], "row_count": 1}', map_python_function: 'def get_customer(execute_query, filters=None):\n    """Fetch Customer reference record.\n    Node: Customer | Virtual/static reference.\n    In the Nokia Macro program, T-Mobile is the sole customer.\n    """\n    customers = [\n        {\n            "customer_id": "tmo",\n            "customer_name": "T-Mobile",\n            "role": "Network operator and site owner",\n            "material_ownership": "T-Mobile owns all materials; Nokia coordinates logistics",\n            "approval_gates": "Scoping approval (ms_1333), NTP, COP approval (ms_1559), Customer Acceptance (ms_2400), Payment Release (ms_2450)",\n            "quality_review": "Punch checklist review, NDPc session acceptance, admin checklist review",\n        }\n    ]\n\n    filters = filters or {}\n    if filters.get("customer_id"):\n        customers = [c for c in customers if c["customer_id"] == filters["customer_id"]]\n\n    return customers\n', is_skipped: false, name: 'customer', definition: 'The customer organization for whom the deployment program is executed (T-Mobile for this program). Used as a contextual anchor for projects, sites, approvals, and payments.', map_database_name: 'VIRTUAL', skip_reason: '', status: 'mentioned', node_id: 'customer'});
