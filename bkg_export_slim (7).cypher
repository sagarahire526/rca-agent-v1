n    )\n\n    if where_parts:\n        sql += " WHERE " + " AND ".join(where_parts)\n\n    return execute_query(sql) or []\n', is_skipped: false, name: 'material_equipment', definition: 'Customer-owned materials/equipment required per site (Bill of Materials). BOM status/availability is milestone-gated (BOM exists/approved → material available at T-Mobile warehouse → GC pickup confirmed → pickup validated). BOM can be survey-validated or design-based (urgent/no-survey path); discrepancies may be reconciled during construction/integration.', map_database_name: 'public', skip_reason: '', status: 'enriched', node_id: 'material_equipment'});
CREATE (:BKGNode {map_key_column: 'milestone_id', map_table_name: 'VIRTUAL', nl_business_rule: '', session_id: '69a3d22f26e208edc083a06e', label: 'Milestone', map_sql_template: '-- Virtual node: static milestone taxonomy. See Python function.\n-- 26 milestones across 7 phases, hardcoded in get_milestone().', map_label_column: 'milestone_name', nl_description: 'Reference taxonomy/definition and sequencing framework for project milestone fields (stored as ~792 named columns on Project). Each milestone definition may include phase tagging (Phase 1–7), meaning, prerequisites, and ordering rules; not modeled as normalized per-project milestone records.', entity_type: 'reference', map_contract: '{"function_name": "get_milestone", "node_type": "virtual", "node_id": "milestone", "node_label": "Milestone", "description": "Query static milestone taxonomy (26 milestones across 7 phases)", "parameters": [{"name": "phase", "type": "string", "description": "Filter by phase", "required": false, "sample_values": ["Pre-NTP & Survey", "Scoping", "NTP & Material"]}, {"name": "milestone_id", "type": "string", "description": "Filter by milestone_id", "required": false, "sample_values": ["ms_1310", "ms_1313", "ms_1314"]}], "output_columns": [{"name": "milestone_id", "type": "string", "nullable": false}, {"name": "milestone_name", "type": "string", "nullable": false}, {"name": "phase", "type": "string", "nullable": false}, {"name": "sequence", "type": "number", "nullable": false}], "sample_output": [], "row_count": 26}', node_type: 'VIRTUAL', map_python_function: 'def get_milestone(execute_query, filters=None):\n    """Fetch Milestone reference taxonomy.\n\n    Node: Milestone | Virtual/static reference — no physical table.\n    Returns hardcoded milestone definitions with phase and sequence.\n\n    Supported filters:\n      - phase: exact match\n      - milestone_id: exact match\n\n    Note: execute_query is unused (kept for interface compatibility).\n    """\n    milestones = [\n        {"milestone_id": "ms_1310", "milestone_name": "Pre-NTP Package Received", "phase": "Pre-NTP & Survey", "sequence": 1},\n        {"milestone_id": "ms_1313", "milestone_name": "Pre-NTP Package Validated", "phase": "Pre-NTP & Survey", "sequence": 2},\n        {"milestone_id": "ms_1314", "milestone_name": "NDPc Survey Request Submitted", "phase": "Pre-NTP & Survey", "sequence": 3},\n        {"milestone_id": "ms_1316", "milestone_name": "Pre-Con Site Walk Completed", "phase": "Pre-NTP & Survey", "sequence": 4},\n        {"milestone_id": "ms_1321", "milestone_name": "Talon Drone Survey Completed", "phase": "Pre-NTP & Survey", "sequence": 5},\n        {"milestone_id": "ms_1323", "milestone_name": "Ready for Scoping", "phase": "Scoping", "sequence": 6},\n        {"milestone_id": "ms_1327", "milestone_name": "Scoping Package Validated", "phase": "Scoping", "sequence": 7},\n        {"milestone_id": "ms_1333", "milestone_name": "Scoping Package Approved by Customer", "phase": "Scoping", "sequence": 8},\n        {"milestone_id": "ms_1406", "milestone_name": "Tower NTP Received", "phase": "NTP & Material", "sequence": 9},\n        {"milestone_id": "ms_1407", "milestone_name": "Tower NTP Validated", "phase": "NTP & Material", "sequence": 10},\n        {"milestone_id": "ms_1507", "milestone_name": "Tower NTP Approved", "phase": "NTP & Material", "sequence": 11},\n        {"milestone_id": "ms_1549", "milestone_name": "Civil Construction Start", "phase": "Construction", "sequence": 12},\n        {"milestone_id": "ms_1550", "milestone_name": "Construction Start", "phase": "Construction", "sequence": 13},\n        {"milestone_id": "ms_1551", "milestone_name": "Civil Construction Complete", "phase": "Construction", "sequence": 14},\n        {"milestone_id": "ms_1555", "milestone_name": "Construction Complete", "phase": "Construction", "sequence": 15},\n        {"milestone_id": "ms_1556", "milestone_name": "Punch Checklist Audit by Nokia", "phase": "Quality & Compliance", "sequence": 16},\n        {"milestone_id": "ms_1557", "milestone_name": "Punch Checklist Submitted to TMO", "phase": "Quality & Compliance", "sequence": 17},\n        {"milestone_id": "ms_1558", "milestone_name": "Admin Checklist Submitted", "phase": "Quality & Compliance", "sequence": 18},\n        {"milestone_id": "ms_1559", "milestone_name": "COP Approved by T-Mobile", "phase": "COP & Acceptance", "sequence": 19},\n        {"milestone_id": "ms_1564", "milestone_name": "SCF Files Validated", "phase": "Integration", "sequence": 20},\n        {"milestone_id": "ms_1899", "milestone_name": "All Technologies Integrated", "phase": "Integration", "sequence": 21},\n        {"milestone_id": "ms_1970", "milestone_name": "Integration Complete", "phase": "Integration", "sequence": 22},\n        {"milestone_id": "ms_2123", "milestone_name": "E911 Test Calls", "phase": "Integration", "sequence": 23},\n        {"milestone_id": "ms_2400", "milestone_name": "Customer Acceptance", "phase": "Acceptance & Payment", "sequence": 24},\n        {"milestone_id": "ms_2450", "milestone_name": "Customer Payment Release", "phase": "Acceptance & Payment", "sequence": 25},\n        {"milestone_id": "ms_2490", "milestone_name": "Project Complete", "phase": "Acceptance & Payment", "sequence": 26},\n    ]\n\n    filters = filters or {}\n    if filters.get("phase"):\n        milestones = [m for m in milestones if m.get("phase") == filters["phase"]]\n    if filters.get("milestone_id"):\n        milestones = [m for m in milestones if m.get("milestone_id") == filters["milestone_id"]]\n\n    return milestones\n', is_skipped: false, name: 'milestone', definition: 'Reference taxonomy/definition and sequencing framework for project milestone fields (stored as ~792 named columns on Project). Each milestone definition may include phase tagging (Phase 1–7), meaning, prerequisites, and ordering rules; not modeled as normalized per-project milestone records.', map_database_name: 'VIRTUAL', skip_reason: '', status: 'active', node_id: 'milestone'});
